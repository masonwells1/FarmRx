 .carry-table-scroll { border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); }.carry-table { min-width: 1280px; }.carry-table th, .carry-table td { padding: 12px 14px; font-size: 18px; font-variant-numeric: tabular-nums; white-space: nowrap; }.carry-table thead th { font-size: 18px; }.carry-table tbody tr:nth-child(even) td, .carry-table tbody tr:nth-child(even) th { background: var(--cream); }.carry-table .harvest-row td, .carry-table .harvest-row th { background: var(--green-tint); }.carry-table tbody th { text-align: left; }.carry-table tbody th span { display: block; margin-top: 4px; color: var(--deep-green); font-size: 18px; font-weight: 700; }.carry-table .positive { color: var(--crx-green); font-weight: 800; }.carry-table .negative { color: var(--warn-red); font-weight: 800; }.carry-table input { min-width: 112px; text-align: right; }
