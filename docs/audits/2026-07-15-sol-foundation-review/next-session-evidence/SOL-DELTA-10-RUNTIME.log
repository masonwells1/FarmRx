123:               and pe.operating_entity_id is not distinct from v_rule.operating_entity_id and pe.enterprise_label is not distinct from v_rule.enterprise_label;
124:             select coalesce(sum(gc.bushels),0) into v_contracts from public.grain_contracts gc
