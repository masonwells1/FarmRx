 128:         markFarmGranted(target, scope, validationStartedAt, serverEpoch)
 129:         continue
 130:       }
 131:       // A delayed or cached access response must never move a device backwards,
 132:       // and a revoked/partially deleted scope can only be reactivated by a
 133:       // strictly newer server epoch. First use on a clean device may begin at 1.
 134:       const priorServerEpoch = Math.max(state.serverEpoch ?? 0, priorEpochs[farm.id] ?? 0)
 135:       const recoveringKnownScope = state.kind === 'revoked' || state.kind === 'invalid' || state.kind === 'missing' && wasKnown
 136:       if (serverEpoch < priorServerEpoch || recoveringKnownScope && (priorServerEpoch === 0 || serverEpoch <= priorServerEpoch)) {
 137:         throw new Error('Farm access changed while it was being verified.')
 138:       }
 139:       if (state.kind !== 'active' || state.serverEpoch !== serverEpoch) {
 140:         quarantineRevokedFarmWork(target, scope)
 141:         await deleteUserWorkspaceCaches(supabaseConfig.projectRef, userId, farm.id)
 142:         verifyValidation()
 143:         resetFarmGrantFromLive(target, scope, serverEpoch, validationStartedAt)
 144:       }
 145:     }
 146:     verifyValidation()
 147:     writeFarmAccessEpochs(target, supabaseConfig.projectRef, userId, serverEpochs, validationStartedAt)
 148:     const selectedFarmId = prior?.selectedFarmId && farms.some((farm) => farm.id === prior.selectedFarmId) ? prior.selectedFarmId : farms.length === 1 ? farms[0].id : null
 149:     const value: StoredAccess = { version: 1, userId, farms, selectedFarmId, validatedAt: new Date().toISOString() }
 150:     verifyValidation()
 151:     await requireCurrentSession(userId)
 152:     verifyValidation()
 153:     persist(value)
 154:     return { ...value, source: 'live' }
 155:   })
 156: }
