   70: create or replace function public.generate_due_program_notifications(p_farm_id uuid, p_local_date date)
   71: returns jsonb language plpgsql security definer set search_path=public,pg_temp as $$
   72: declare v_owner uuid; v_count integer;
   73: begin
   74:   if p_farm_id is null or p_local_date is null then raise exception 'farm and local date are required'; end if;
   75:   if auth.uid() is not null and not public.can_edit_farm(p_farm_id) and not public.request_uses_service_role() then raise exception 'you do not have permission to edit this farm'; end if;
   76:   if auth.uid() is null and not public.request_uses_service_role() then raise exception 'authentication is required'; end if;
   77:   perform pg_advisory_xact_lock(hashtext(p_farm_id::text),hashtext('program-due-items'));
   78:   select user_id into v_owner from public.farm_memberships where farm_id=p_farm_id and role='owner' and status='active' order by user_id limit 1;
   79:   if v_owner is null then return jsonb_build_object('created_count',0); end if;
   80:   insert into public.notifications(farm_id,user_id,category,title,body,link,dedupe_key,created_by)
   81:   select p_farm_id,v_owner,'task',left(pa.program_name_snapshot||' due: '||ap.name,160),
   82:     'Program pass is due '||ap.due_on::text,'/programs?pass='||ap.id::text,
   83:     'program:'||ap.id::text||':due:'||ap.due_on::text,coalesce(auth.uid(),v_owner)
   84:   from public.assigned_program_passes ap join public.program_assignments pa on pa.id=ap.assignment_id and pa.farm_id=ap.farm_id
   85:   where ap.farm_id=p_farm_id and pa.status='active' and ap.status='planned' and ap.due_on is not null
   86:     and ap.due_on-ap.reminder_lead_days<=p_local_date
   87:   on conflict(farm_id,user_id,dedupe_key) where dedupe_key is not null do nothing;
   88:   get diagnostics v_count=row_count;
   89:   return jsonb_build_object('created_count',v_count);
   90: end $$;
