 155: /** Upgrade a previously stored access snapshot without letting a cached tab
 156:  * undo a revocation. Only an entirely absent pre-upgrade fence is initialized;
 157:  * partial, corrupt, or revoked state remains blocked until a live access check. */
 158: export function ensureStoredFarmGrant(storage: StorageLike, scope: FarmRevocationScope): number {
 159:   const snapshot = captureFarmRevocationFence(storage, scope)
 160:   return snapshot.generation
 161: }
