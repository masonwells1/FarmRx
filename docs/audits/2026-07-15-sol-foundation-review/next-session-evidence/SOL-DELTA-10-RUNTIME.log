355:           and relation.relkind in ('r', 'p')
356:       )
357:     order by table_name
358:   loop
359:     execute format(
360:       'create trigger farm_access_epoch_guard before insert or update or delete on public.%I for each row execute function public.guard_row_farm_access_epoch()',
361:       v_table.table_name
362:     );
363:   end loop;
364: end;
365: $$;
