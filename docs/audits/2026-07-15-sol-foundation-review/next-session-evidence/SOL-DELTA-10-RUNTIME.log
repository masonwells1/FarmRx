    1: import { createContext, useContext, useEffect, useMemo, useState, type ReactNode } from 'react'
    2: import type { Session, User } from '@supabase/supabase-js'
    3: import { supabase } from '../lib/supabaseClient'
    4: import { clearFarmAccess } from './farmContext'
    5:
    6: export type AuthPhase = 'restoring' | 'signed_out' | 'signed_in'
    7:
    8: interface AuthContextValue {
    9:   phase: AuthPhase
   10:   session: Session | null
   11:   user: User | null
   12:   signIn(email: string, password: string): Promise<void>
   13:   signOut(): Promise<void>
   14: }
   15:
   16: const AuthContext = createContext<AuthContextValue | null>(null)
   17:
   18: // A deliberate "Sign out" and an expired session both land on /login; this flag
   19: // lets RequireSession tell them apart so we never scold a farmer who just left.
   20: // Read-only during render (React may render twice); cleared on the next sign-in.
   21: let intentionalSignOut = false
   22: export function markIntentionalSignOut() { intentionalSignOut = true }
   23: export function clearIntentionalSignOut() { intentionalSignOut = false }
   24: export function wasIntentionalSignOut() { return intentionalSignOut }
   25:
   26: export function AuthProvider({ children }: { children: ReactNode }) {
   27:   const [phase, setPhase] = useState<AuthPhase>('restoring')
   28:   const [session, setSession] = useState<Session | null>(null)
   29:
   30:   useEffect(() => {
   31:     let active = true
   32:     let eventVersion = 0
   33:     const applySession = (next: Session | null) => {
   34:       if (!active) return
   35:       setSession(next)
   36:       setPhase(next ? 'signed_in' : 'signed_out')
   37:     }
   38:     const { data: listener } = supabase.auth.onAuthStateChange((event, nextSession) => {
   39:       if (event === 'SIGNED_IN' || event === 'SIGNED_OUT' || event === 'TOKEN_REFRESHED' || event === 'USER_UPDATED') { eventVersion += 1; applySession(nextSession) }
   40:     })
   41:     const restoreVersion = eventVersion
   42:     void supabase.auth.getSession().then(({ data, error }) => {
   43:       if (eventVersion !== restoreVersion) return
   44:       if (error) applySession(null); else applySession(data.session)
   45:     }).catch(() => { if (eventVersion === restoreVersion) applySession(null) })
   46:     return () => {
   47:       active = false
   48:       listener.subscription.unsubscribe()
   49:     }
   50:   }, [])
   51:
   52:   const value = useMemo<AuthContextValue>(() => ({
   53:     phase,
   54:     session,
   55:     user: session?.user ?? null,
   56:     async signIn(email, password) {
   57:       const { data, error } = await supabase.auth.signInWithPassword({ email: email.trim(), password })
   58:       if (error || !data.session) throw error ?? new Error('Farm Rx could not sign you in right now. Please try again.')
   59:       clearIntentionalSignOut()
   60:       setSession(data.session)
   61:       setPhase('signed_in')
   62:     },
   63:     async signOut() {
   64:       if (session?.user.id) await clearFarmAccess(session.user.id)
   65:       const { error } = await supabase.auth.signOut({ scope: 'local' })
   66:       if (error) throw error
   67:       markIntentionalSignOut()
   68:       setSession(null)
   69:       setPhase('signed_out')
   70:     },
   71:   }), [phase, session])
   72:
   73:   return <AuthContext.Provider value={value}>{children}</AuthContext.Provider>
   74: }
   75:
   76: export function useAuth(): AuthContextValue {
   77:   const context = useContext(AuthContext)
   78:   if (!context) throw new Error('useAuth must be used inside AuthProvider.')
   79:   return context
   80: }
