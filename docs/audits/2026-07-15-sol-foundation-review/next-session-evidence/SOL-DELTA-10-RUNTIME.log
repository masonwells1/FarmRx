 /* Weather & Spray: roomy field cards that stay readable in sun and from a truck cab. */
 .weather-page { display: grid; gap: 20px; min-width: 0; font-size: 18px; }
 .weather-heading { align-items: center; }.weather-heading > div > p:last-child { margin: 6px 0 0; color: var(--matte-gray); }
 .weather-card { display: grid; gap: 18px; overflow: hidden; padding: 20px; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--surface); box-shadow: 0 3px 10px rgb(23 81 58 / 5%); font-variant-numeric: tabular-nums; }
 .weather-card h2, .weather-card h3, .weather-card p { margin: 0; }.weather-card h2 { color: var(--deep-green); font-family: var(--brand-font); font-size: 24px; }.weather-card h3 { color: var(--charcoal); font-size: 20px; }.weather-card-title { display: flex; align-items: center; justify-content: space-between; gap: 16px; }.weather-card-title p, .weather-note, .weather-stamp { color: var(--matte-gray); }
 .weather-guidance { margin: 0; color: var(--matte-gray); font-size: 18px; }.weather-error { margin: 0; padding: 12px 14px; border: 2px solid var(--warn-red); border-radius: 10px; background: var(--warn-bg); color: var(--warn-red); font-weight: 700; }.location-card { align-items: start; }.location-card > .primary-action { width: min(100%, 330px); }.text-action { min-height: 48px; padding: 0; border: 0; background: transparent; color: var(--deep-green); font: inherit; font-size: 18px; font-weight: 700; text-decoration: underline; }
 .weather-location-form { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; width: 100%; padding: 16px; border-radius: 10px; background: var(--cream); }.weather-location-form label { display: grid; gap: 6px; color: var(--charcoal); font-size: 18px; font-weight: 700; }.weather-location-form input { min-height: 48px; width: 100%; padding: 8px 10px; border: 2px solid var(--hairline); border-radius: 9px; background: var(--surface); color: var(--charcoal); font: inherit; font-variant-numeric: tabular-nums; }.weather-location-form .primary-action { align-self: end; }
 .weather-now { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; }.weather-now > div { display: grid; gap: 4px; padding: 14px; border-radius: 10px; background: var(--cream); }.weather-now strong { color: var(--deep-green); font-size: 21px; }.weather-now span { color: var(--matte-gray); }
 .spray-summary { display: grid; grid-template-columns: 150px 1fr; gap: 18px; align-items: center; }.spray-light { display: grid; min-height: 126px; place-content: center; gap: 5px; border-radius: 14px; color: var(--charcoal); text-align: center; }.spray-light strong { font-family: var(--brand-font); font-size: 29px; }.spray-light.good { background: var(--light-green); color: var(--deep-green); }.spray-light.caution { background: var(--warn-bg); color: #744b00; }.spray-light.poor { background: #fbe9e7; color: var(--warn-red); }.spray-summary > div:last-child { display: grid; gap: 8px; }.spray-summary p { color: var(--matte-gray); }.best-window { color: var(--deep-green); }
 .hour-strip { display: grid; grid-template-columns: repeat(12, minmax(72px, 1fr)); gap: 6px; overflow-x: auto; padding-bottom: 4px; }.hour-strip > div { display: grid; min-height: 72px; align-content: center; gap: 4px; padding: 8px; border-radius: 8px; text-align: center; }.hour-strip .good { background: var(--light-green); color: var(--deep-green); }.hour-strip .caution { background: var(--warn-bg); color: #744b00; }.hour-strip .poor { background: #fbe9e7; color: var(--warn-red); }.hour-strip span { font-size: 18px; }.hour-strip b { font-size: 18px; }
 .daily-row { display: grid; grid-template-columns: repeat(7, minmax(100px, 1fr)); gap: 8px; overflow-x: auto; }.daily-row > div { display: grid; gap: 4px; padding: 12px; border-top: 4px solid var(--crx-green); background: var(--cream); }.daily-row strong { color: var(--deep-green); }.daily-row span { color: var(--matte-gray); }.empty-weather { text-align: center; }
 .weather-page button { min-height: 48px; font-size: 18px; }.weather-page input { font-size: 18px; }.weather-page, .weather-page * { font-variant-numeric: tabular-nums; }
 @media (max-width: 767px) { .weather-heading { align-items: start; flex-direction: column; }.weather-heading .secondary-action { width: 100%; }.weather-card { padding: 18px 16px; }.weather-card-title { align-items: start; flex-direction: column; }.weather-card-title .secondary-action { width: 100%; }.weather-location-form, .weather-now, .spray-summary { grid-template-columns: 1fr; }.weather-location-form .primary-action { width: 100%; }.spray-light { min-height: 104px; }.daily-row { grid-template-columns: repeat(7, minmax(112px, 1fr)); } }

 /* Equipment and Tasks: the same 18px/48px baseline as the live farm modules. */
 .equipment-page, .tasks-page { display: grid; gap: 20px; font-size: 18px; }
 .equipment-page button, .equipment-page input, .equipment-page select, .equipment-page textarea, .tasks-page button, .tasks-page input, .tasks-page select, .tasks-page textarea { min-height: 48px; font: inherit; }
 .equipment-heading, .detail-heading { display: flex; justify-content: space-between; align-items: center; gap: 16px; }
 .equipment-heading h1 { margin: 0; font-size: clamp(26px, 4vw, 36px); }.equipment-heading .eyebrow { margin: 0 0 4px; color: var(--deep-green); font-weight: 700; }
 .equipment-groups { display: grid; gap: 22px; }.equipment-groups h2, .task-column h2 { margin: 0 0 10px; font-size: 21px; }.machine-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 14px; }
 .machine-card, .task-card, .equipment-form, .equipment-detail, .task-column { border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--surface); box-shadow: 0 2px 10px #173d2a0a; }.machine-card { min-height: 180px; display: grid; align-content: start; gap: 10px; padding: 18px; text-align: left; color: var(--charcoal); cursor: pointer; }.machine-card:hover { border-color: var(--crx-green); background: var(--light-green); }.machine-card > strong { font-size: 23px; }.machine-card > span, .task-card p, .task-card small { color: var(--matte-gray); }
 .machine-facts { display: flex; flex-wrap: wrap; gap: 10px; font-variant-numeric: tabular-nums; }.machine-facts b { font-size: 18px; }.chip-row { display: flex; flex-wrap: wrap; gap: 7px; }.chip-row em, .priority-chip { padding: 4px 8px; border-radius: 999px; font-size: 18px; font-style: normal; font-weight: 700; }.status-chip { background: var(--cream); color: var(--matte-gray); }.due-chip { background: #fff0f0; color: var(--warn-red); }.warranty-chip { background: var(--warn-bg); color: #8a5600; }.priority-chip { background: #fff0f0; color: var(--warn-red); }
 .equipment-form { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 13px; padding: 18px; }.equipment-form h2, .equipment-form .equipment-error, .equipment-form fieldset, .equipment-form > div { grid-column: 1 / -1; margin: 0; }.equipment-form label { display: grid; gap: 5px; color: var(--matte-gray); font-weight: 700; }.equipment-form input, .equipment-form select, .equipment-form textarea { width: 100%; box-sizing: border-box; padding: 9px 11px; border: 1px solid var(--hairline); border-radius: 8px; background: white; color: var(--charcoal); }.equipment-form textarea { min-height: 96px; resize: vertical; }.equipment-form .wide { grid-column: span 2; }.equipment-form.compact { grid-template-columns: repeat(3, minmax(0, 1fr)); padding: 0; border: 0; box-shadow: none; }.equipment-form fieldset { display: flex; align-items: center; flex-wrap: wrap; gap: 8px; border: 0; padding: 0; }.equipment-form fieldset button.active, .task-kpis button.active { color: var(--on-dark); background: var(--deep-green); }
 .equipment-detail { display: grid; gap: 18px; padding: 20px; }.detail-heading h2 { margin: 0; }.detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }.detail-grid section, .service-log { padding: 16px; border-radius: 10px; background: var(--cream); }.detail-grid h3, .service-log h3 { margin: 0 0 12px; }.list-row { display: flex; justify-content: space-between; gap: 10px; align-items: center; min-height: 46px; border-bottom: 1px solid var(--hairline); font-variant-numeric: tabular-nums; }.list-row:last-child { border-bottom: 0; }
 .equipment-error { margin: 0; padding: 12px; border-left: 4px solid var(--warn-red); background: #fff2f2; color: var(--warn-red); }.task-kpis { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; }.task-kpis button { display: grid; gap: 3px; padding: 13px; border: 1px solid var(--hairline); border-radius: 10px; background: var(--surface); color: var(--charcoal); text-align: left; }.task-kpis strong { font-size: 28px; font-variant-numeric: tabular-nums; }.task-kpis span { color: var(--matte-gray); }.task-board { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); align-items: start; gap: 14px; }.task-column { display: grid; gap: 12px; padding: 14px; min-height: 180px; }.task-card { display: grid; gap: 8px; padding: 14px; }.task-card h3, .task-card p { margin: 0; }.task-card .chip-row button { min-height: 48px; padding: 4px 9px; border: 1px solid var(--hairline); border-radius: 999px; background: var(--light-green); color: var(--deep-green); }.task-actions { display: flex; flex-wrap: wrap; gap: 7px; }.task-actions button { min-height: 48px; padding: 6px 10px; }.overdue-amber { border-left: 6px solid var(--amber); }.overdue-red { border-left: 6px solid var(--warn-red); }.critical { border-left: 6px solid #7e0000; animation: task-critical 1.1s ease-in-out infinite alternate; }@keyframes task-critical { to { box-shadow: 0 0 0 4px #c6282833; } }
 @media (max-width: 767px) { .equipment-heading, .detail-heading { align-items: start; flex-direction: column; }.equipment-heading .primary-action { width: 100%; }.equipment-form, .equipment-form.compact, .detail-grid, .task-kpis, .task-board { grid-template-columns: 1fr; }.equipment-form .wide { grid-column: auto; }.task-column { min-height: 0; } }

 /* Module 3: intentionally roomy controls for a phone in the cab or shed. */
 .inventory-page { min-width: 0; }
 .inventory-heading { align-items: center; }
 .inventory-tabs { display: flex; gap: 8px; overflow-x: auto; padding: 0 0 16px; border-bottom: 1px solid var(--hairline); }
 .inventory-tabs button { flex: 0 0 auto; min-height: 48px; border: 1px solid var(--hairline); border-radius: 9px; padding: 10px 14px; background: var(--surface); color: var(--charcoal); font: inherit; font-size: 18px; font-weight: 700; cursor: pointer; }
 .inventory-tabs button.active { border-color: var(--deep-green); background: var(--deep-green); color: var(--on-dark); }
 .inventory-search { display: grid; gap: 6px; margin: 20px 0; color: var(--matte-gray); font-size: 18px; font-weight: 700; }
 .inventory-search input, .inventory-form input, .inventory-form select { width: 100%; min-height: 48px; box-sizing: border-box; border: 1px solid #adb7b2; border-radius: 8px; padding: 9px 11px; background: var(--surface); color: var(--charcoal); font: inherit; font-size: 18px; }
 .inventory-form input:focus, .inventory-form select:focus, .inventory-search input:focus { outline: 3px solid var(--amber); outline-offset: 1px; }
 .inventory-group { margin: 26px 0; }
 .inventory-group h2, .ledger-history h2, .compliance-list h2 { margin: 0 0 12px; color: var(--deep-green); font-size: 22px; }
 .shelf-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(225px, 1fr)); gap: 12px; }
 .shelf-card { display: grid; min-height: 150px; align-content: start; gap: 8px; border: 1px solid var(--hairline); border-radius: 16px; padding: 18px; background: var(--surface); color: var(--charcoal); text-align: left; font: inherit; cursor: pointer; }
 .shelf-card:hover, .shelf-card.selected { border-color: var(--crx-green); box-shadow: 0 2px 0 var(--crx-green); }
 .shelf-card > span { font-weight: 700; }
