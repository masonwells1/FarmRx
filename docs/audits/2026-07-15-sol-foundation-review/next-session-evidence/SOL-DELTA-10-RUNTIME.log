    3: export function parseExpectedGrainAlertAccess(headers: Headers, authenticatedUserId: string, farmId: string): ExpectedGrainAlertAccess | null {
    4:   const expectedUserId = headers.get('x-farm-rx-expected-user-id')
    5:   let accessEpoch: number | null = null
    6:   try {
    7:     const value = JSON.parse(headers.get('x-farm-rx-access-epochs') ?? 'null') as Record<string, unknown> | null
    8:     const candidate = value?.[farmId]
    9:     if (typeof candidate === 'number' && Number.isSafeInteger(candidate) && candidate >= 1) accessEpoch = candidate
   10:   } catch { /* fail closed below */ }
   11:   return expectedUserId === authenticatedUserId && accessEpoch !== null ? { userId: authenticatedUserId, farmId, accessEpoch } : null
   12: }
