29: create function public.bump_farm_access_epoch(target_farm_id uuid, target_user_id uuid)
30: returns void
31: language plpgsql
32: security definer
33: set search_path = public, pg_temp
34: as $$
35: begin
36:   if target_farm_id is null or target_user_id is null then
37:     raise exception 'farm access epoch requires a farm and user';
38:   end if;
39:
40:   -- Cascading deletion of a farm or auth user does not need a new epoch and
41:   -- must not recreate a row that its foreign key is already removing.
42:   if not exists (select 1 from public.farms where id = target_farm_id)
43:     or not exists (select 1 from auth.users where id = target_user_id) then
44:     return;
45:   end if;
46:
47:   insert into public.farm_access_epochs (farm_id, user_id, access_epoch, updated_at)
48:   values (target_farm_id, target_user_id, 1, now())
49:   on conflict (farm_id, user_id) do update
50:   set access_epoch = public.farm_access_epochs.access_epoch + 1,
51:       updated_at = now();
52: end;
53: $$;
