  110: export function resetFarmRevokedFromLive(storage: StorageLike, scope: FarmRevocationScope, serverEpoch: number, changedAt = new Date().toISOString()): number {
  111:   if (!Number.isSafeInteger(serverEpoch) || serverEpoch < 1 || Number.isNaN(Date.parse(changedAt))) throw new Error(blocked)
  112:   let generation = serverEpoch
  113:   try { const state = readState(storage, scope); generation = Math.max(serverEpoch, state.fence?.generation ?? 0, state.ledger?.generation ?? 0) + 1 } catch { /* see resetFarmGrantFromLive */ }
