  84: async function fetchAccessibleFarms(userId: string, accountEpoch: number): Promise<FarmAccess> {
  85:   const target = storage(); if (!target) throw new Error('Farm Rx could not verify farm access without device storage.')
  86:   const createId = () => typeof crypto.randomUUID === 'function' ? crypto.randomUUID() : `${Date.now()}-${Math.random()}`
  87:   return coordinatedDeviceTransaction(validationLockKey(userId), target, createId, async (verifyCoordination) => {
  88:     const prior = parseStored(userId)
  89:     const validationToken = createId()
  90:     target.setItem(validationKey(userId), validationToken)
  91:     const verifyValidation = () => {
  92:       verifyCoordination()
  93:       if (target.getItem(validationKey(userId)) !== validationToken || (accountEpochs.get(userId) ?? 0) !== accountEpoch) throw new Error('Farm access changed while it was being verified.')
  94:     }
  95:     verifyValidation()
  96:     const validationStartedAt = new Date().toISOString()
  97:     await requireCurrentSession(userId)
  98:     verifyValidation()
  99:     const { data, error } = await supabase.from('farms').select('*').order('name').order('id')
 100:     verifyValidation()
 101:     if (error) throw error
 102:     const farms = (data ?? []) as Farm[]
 103:     const serverEpochs = await loadServerEpochs(userId, farms)
 104:     verifyValidation()
 105:     const priorEpochs = readFarmAccessEpochs(target, supabaseConfig.projectRef, userId) ?? {}
 106:     const knownFarmIds = new Set([...(prior?.farms.map((farm) => farm.id) ?? []), ...listFarmRevocationScopes(target, supabaseConfig.projectRef, userId).map((scope) => scope.farmId)])
 107:     const removed = [...knownFarmIds].filter((farmId) => !farms.some((next) => next.id === farmId))
 108:     // Do not publish a new live access snapshot until every removed farm's unsent work
 109:     // is durably separated from active queues and its readable cache is gone.
 110:     for (const farmId of removed) {
 111:       verifyValidation()
 112:       const scope = { projectRef: supabaseConfig.projectRef, userId, farmId }
 113:       const state = inspectFarmRevocationState(target, scope)
 114:       const serverEpoch = priorEpochs[farmId] ?? state.serverEpoch ?? 1
 115:       if (state.kind === 'active' || state.kind === 'revoked') markFarmRevoked(target, scope, validationStartedAt, serverEpoch)
 116:       else resetFarmRevokedFromLive(target, scope, serverEpoch, validationStartedAt)
 117:       quarantineRevokedFarmWork(target, scope)
 118:       await deleteUserWorkspaceCaches(supabaseConfig.projectRef, userId, farmId)
 119:       verifyValidation()
 120:     }
 121:     for (const farm of farms) {
 122:       verifyValidation()
 123:       const scope = { projectRef: supabaseConfig.projectRef, userId, farmId: farm.id }
