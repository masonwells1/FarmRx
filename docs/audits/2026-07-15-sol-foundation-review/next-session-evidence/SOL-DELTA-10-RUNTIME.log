 158: export async function loadFarmAccess(userId: string, force = false): Promise<FarmAccess> {
 159:   const cached = parseStored(userId)
 160:   if (!force && !offline() && cached && Date.now() - Date.parse(cached.validatedAt) <= liveReuseMs && storedAccessIsFenced(cached)) return { ...cached, source: 'live' }
 161:   if (offline()) {
 162:     if (!cached || Date.now() - Date.parse(cached.validatedAt) > maximumAccessAgeMs || !storedAccessIsFenced(cached)) throw new Error('This device needs a connection to verify your farm access.')
 163:     return { ...cached, source: 'offline' }
 164:   }
 165:   const accountEpoch = accountEpochs.get(userId) ?? 0
 166:   let refresh = refreshes.get(userId)
 167:   if (!refresh || refresh.epoch !== accountEpoch) {
 168:     const promise = fetchAccessibleFarms(userId, accountEpoch).finally(() => { if (refreshes.get(userId)?.promise === promise) refreshes.delete(userId) })
 169:     refresh = { epoch: accountEpoch, promise }; refreshes.set(userId, refresh)
 170:   }
 171:   try { const result = await refresh.promise; if (result.userId !== userId || (accountEpochs.get(userId) ?? 0) !== accountEpoch) throw new Error('Farm access changed while it was being verified.'); return result } catch (error) {
 172:     if (cached && transport(error) && Date.now() - Date.parse(cached.validatedAt) <= maximumAccessAgeMs && storedAccessIsFenced(cached)) return { ...cached, source: 'offline' }
 173:     throw error
 174:   }
 175: }
 176:
 177: export async function currentFarmContext(): Promise<{ userId: string; farmId: string }> {
 178:   const userId = await currentUserId()
 179:   const access = await loadFarmAccess(userId)
 180:   if (!access.selectedFarmId) throw new Error(access.farms.length > 1 ? 'Choose which farm you want to open.' : 'Crop RX needs to finish your farm setup.')
 181:   return { userId, farmId: access.selectedFarmId }
 182: }
 183:
 184: export async function selectFarm(userId: string, farmId: string): Promise<void> {
 185:   const access = await loadFarmAccess(userId)
 186:   if (!access.farms.some((farm) => farm.id === farmId)) throw new Error('You no longer have access to that farm.')
 187:   persist({ version: 1, userId, farms: access.farms, selectedFarmId: farmId, validatedAt: access.validatedAt })
 188: }
 189:
 190: export function hasPendingFarmWork(userId: string, farmId: string): boolean {
 191:   const target = storage(); if (!target) return false
 192:   for (let index = 0; index < target.length; index += 1) {
 193:     const key = target.key(index); if (!key || !key.includes(supabaseConfig.projectRef) || !key.includes(userId) || !key.includes(farmId) || key.endsWith(':lease')) continue
 194:     const raw = target.getItem(key); if (!raw) continue
 195:     try { const value = JSON.parse(raw) as { entries?: unknown }; if (Array.isArray(value.entries) && value.entries.length > 0) return true } catch { /* corrupt records are handled by their owning queue */ }
 196:   }
 197:   return false
 198: }
 199:
 200: export async function clearFarmAccess(userId: string): Promise<void> {
 201:   accountEpochs.set(userId, (accountEpochs.get(userId) ?? 0) + 1)
 202:   const target = storage()
 203:   if (target) {
 204:     target.setItem(validationKey(userId), typeof crypto.randomUUID === 'function' ? crypto.randomUUID() : `${Date.now()}-${Math.random()}`)
 205:     target.removeItem(accessKey(userId)); clearFarmAccessEpochs(target, supabaseConfig.projectRef, userId)
 206:     try { const active = JSON.parse(target.getItem(activeKey) ?? '{}') as { userId?: unknown }; if (active.userId === userId) target.removeItem(activeKey) } catch { target.removeItem(activeKey) }
 207:   }
 208:   await deleteUserWorkspaceCaches(supabaseConfig.projectRef, userId)
 209: }

