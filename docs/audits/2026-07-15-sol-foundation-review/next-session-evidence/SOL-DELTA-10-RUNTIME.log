   79:   let weatherTimedOut = false
   80:   const fail = (index: number, reason: string) => {
   81:     if (settled[index]) return
   82:     settled[index] = true
   83:     const field = fields[index]!
   84:     const failure = { index, farmId: field.farm_id, fieldId: field.id, reason }
   85:     failures.push(failure)
   86:     dependencies.log?.({ event: 'scheduled_weather_field_failed', farmId: failure.farmId, fieldId: failure.fieldId, reason })
   87:   }
   88:   const worker = async () => {
   89:     while (true) {
   90:       if (controller.signal.aborted) return
   91:       const index = nextIndex
   92:       nextIndex += 1
   93:       if (index >= fields.length) return
   94:       const field = fields[index]!
   95:       try {
   96:         const observation = parseScheduledWeatherResponse(await dependencies.fetchWeather(field, controller.signal), now)
   97:         if (controller.signal.aborted) throw new DOMException('Weather deadline reached', 'TimeoutError')
   98:         const recorded = await dependencies.database.recordSprayWindow({
   99:           farmId: field.farm_id,
  100:           fieldId: field.id,
  101:           localDate: localDateFromForecast(observation),
  102:           isGood: scheduledSprayIsGood(observation),
  103:           observedAt: observation.observed_at,
  104:           observation,
  105:         }, controller.signal)
