===== supabase/migrations/0040_farm_access_epoch_fencing.sql =====
    1: -- Close stale-client writes across revoke/regrant cycles. PostgreSQL owns a
    2: -- monotonically increasing epoch for every user/farm relationship. Browser
    3: -- writes must present the exact current epoch in x-farm-rx-access-epochs;
    4: -- checking only can_access_farm() is insufficient after access is re-granted.
    5:
    6: create table public.farm_access_epochs (
    7:   farm_id uuid not null references public.farms(id) on delete cascade,
    8:   user_id uuid not null references auth.users(id) on delete cascade,
    9:   access_epoch bigint not null default 1 check (access_epoch >= 1),
   10:   updated_at timestamptz not null default now(),
   11:   primary key (farm_id, user_id)
   12: );
   13:
   14: create index farm_access_epochs_user_farm_idx
   15: on public.farm_access_epochs (user_id, farm_id);
   16:
   17: insert into public.farm_access_epochs (farm_id, user_id, access_epoch)
   18: select membership.farm_id, membership.user_id, 1
   19: from public.farm_memberships membership
   20: union
   21: select access.farm_id, access.rep_user_id, 1
   22: from public.farm_rep_access access
   23: on conflict (farm_id, user_id) do nothing;
   24:
   25: alter table public.farm_access_epochs enable row level security;
   26: revoke all on table public.farm_access_epochs
   27: from public, anon, authenticated, service_role;
   28:
   29: create function public.bump_farm_access_epoch(target_farm_id uuid, target_user_id uuid)
   30: returns void
   31: language plpgsql
   32: security definer
   33: set search_path = public, pg_temp
   34: as $$
   35: begin
   36:   if target_farm_id is null or target_user_id is null then
   37:     raise exception 'farm access epoch requires a farm and user';
   38:   end if;
   39:
   40:   -- Cascading deletion of a farm or auth user does not need a new epoch and
   41:   -- must not recreate a row that its foreign key is already removing.
   42:   if not exists (select 1 from public.farms where id = target_farm_id)
   43:     or not exists (select 1 from auth.users where id = target_user_id) then
   44:     return;
   45:   end if;
   46:
   47:   insert into public.farm_access_epochs (farm_id, user_id, access_epoch, updated_at)
   48:   values (target_farm_id, target_user_id, 1, now())
   49:   on conflict (farm_id, user_id) do update
   50:   set access_epoch = public.farm_access_epochs.access_epoch + 1,
   51:       updated_at = now();
   52: end;
   53: $$;
   54:
   55: create function public.current_request_farm_access_epoch(target_farm_id uuid)
   56: returns bigint
   57: language plpgsql
   58: stable
   59: security definer
   60: set search_path = public, pg_temp
   61: as $$
   62: declare
   63:   v_headers_text text := nullif(current_setting('request.headers', true), '');
   64:   v_epochs_text text;
   65:   v_epochs jsonb;
   66:   v_epoch_text text;
   67: begin
   68:   if target_farm_id is null or v_headers_text is null then return null; end if;
   69:
   70:   begin
   71:     v_epochs_text := v_headers_text::jsonb ->> 'x-farm-rx-access-epochs';
   72:     if v_epochs_text is null then return null; end if;
   73:     v_epochs := v_epochs_text::jsonb;
   74:   exception
   75:     when others then return null;
   76:   end;
   77:
   78:   if jsonb_typeof(v_epochs) <> 'object' then return null; end if;
   79:   v_epoch_text := v_epochs ->> target_farm_id::text;
   80:   if v_epoch_text is null or v_epoch_text !~ '^[1-9][0-9]{0,18}$' then return null; end if;
   81:
   82:   begin
   83:     return v_epoch_text::bigint;
   84:   exception
   85:     when numeric_value_out_of_range then return null;
   86:   end;
   87: end;
   88: $$;
   89:
   90: create function public.current_request_expected_user_id()
   91: returns uuid
   92: language plpgsql
   93: stable
   94: security definer
   95: set search_path = public, pg_temp
   96: as $$
   97: declare
   98:   v_headers_text text := nullif(current_setting('request.headers', true), '');
   99:   v_user_text text;
  100: begin
  101:   if v_headers_text is null then return null; end if;
  102:   begin
  103:     v_user_text := v_headers_text::jsonb ->> 'x-farm-rx-expected-user-id';
  104:     if v_user_text is null
  105:       or v_user_text !~* '^[0-9a-f]{8}-[0-9a-f]{4}-[1-8][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$' then
  106:       return null;
  107:     end if;
  108:     return v_user_text::uuid;
  109:   exception
  110:     when others then return null;
  111:   end;
  112: end;
  113: $$;
  114:
  115: create function public.assert_current_farm_access_epoch(target_farm_id uuid)
  116: returns void
  117: language plpgsql
  118: security definer
  119: set search_path = public, pg_temp
  120: as $$
  121: declare
  122:   v_user_id uuid := auth.uid();
  123:   v_expected_user_id uuid;
  124:   v_presented bigint;
  125:   v_current bigint;
  126: begin
  127:   -- Server-owned schedulers and delivery workers do not use a browser access
  128:   -- snapshot. Their service-role claim is independently checked at each RPC.
  129:   if public.request_uses_service_role() then return; end if;
  130:
  131:   v_expected_user_id := public.current_request_expected_user_id();
  132:
  133:   if v_user_id is null or v_expected_user_id is distinct from v_user_id or target_farm_id is null then
  134:     raise exception using errcode = 'P0001', message = 'FARM_ACCESS_EPOCH_CHANGED';
  135:   end if;
  136:
  137:   v_presented := public.current_request_farm_access_epoch(target_farm_id);
  138:
  139:   -- The row lock linearizes an in-flight write against a concurrent revoke or
  140:   -- re-grant. Whichever transaction obtains this row first defines the order.
  141:   select epoch.access_epoch into v_current
  142:   from public.farm_access_epochs epoch
  143:   where epoch.farm_id = target_farm_id and epoch.user_id = v_user_id
  144:   for share;
  145:
  146:   if v_current is null
  147:     or v_presented is distinct from v_current
  148:     or not public.can_access_farm(target_farm_id) then
  149:     raise exception using errcode = 'P0001', message = 'FARM_ACCESS_EPOCH_CHANGED';
  150:   end if;
  151: end;
  152: $$;
  153:
  154: create function public.get_current_farm_access_epochs()
  155: returns table(farm_id uuid, access_epoch bigint)
  156: language sql
  157: stable
  158: security definer
  159: set search_path = public, pg_temp
  160: as $$
  161:   select epoch.farm_id, epoch.access_epoch
  162:   from public.farm_access_epochs epoch
  163:   where epoch.user_id = auth.uid()
  164:     and public.can_access_farm(epoch.farm_id)
  165:   order by epoch.farm_id;
  166: $$;
  167:
  168: create function public.guard_row_farm_access_epoch()
  169: returns trigger
  170: language plpgsql
  171: security definer
  172: set search_path = public, pg_temp
  173: as $$
  174: declare
  175:   v_row jsonb := case when tg_op = 'DELETE' then to_jsonb(old) else to_jsonb(new) end;
  176:   v_farm_id uuid;
  177:   v_old_farm_id uuid;
  178: begin
  179:   v_farm_id := nullif(v_row ->> 'farm_id', '')::uuid;
  180:
  181:   -- The owner membership is created by the farm bootstrap trigger before an
  182:   -- epoch row exists. This is the sole authenticated bootstrap exception.
  183:   if tg_table_name = 'farm_memberships' and tg_op = 'INSERT' then
  184:     if nullif(v_row ->> 'user_id', '')::uuid = auth.uid()
  185:       and not exists (
  186:         select 1 from public.farm_access_epochs epoch
  187:         where epoch.farm_id = v_farm_id
  188:           and epoch.user_id = nullif(v_row ->> 'user_id', '')::uuid
  189:       )
  190:       and exists (
  191:         select 1 from public.farms farm
  192:         where farm.id = v_farm_id and farm.created_by = auth.uid()
  193:       ) then
  194:       return new;
  195:     end if;
  196:   end if;
  197:
  198:   -- bootstrap_first_farm creates exactly one initial entity in the same
  199:   -- transaction as its new owner farm. The browser cannot know that farm's
  200:   -- epoch before the RPC returns. No later transaction or second entity can
  201:   -- use this exception.
  202:   if tg_table_name = 'entities' and tg_op = 'INSERT' and exists (
  203:     select 1
  204:     from public.farms farm
  205:     join public.farm_access_epochs epoch
  206:       on epoch.farm_id = farm.id and epoch.user_id = auth.uid()
  207:     join public.farm_memberships membership
  208:       on membership.farm_id = farm.id and membership.user_id = auth.uid()
  209:     where farm.id = v_farm_id
  210:       and farm.created_by = auth.uid()
  211:       and farm.created_at = transaction_timestamp()
  212:       and epoch.access_epoch = 1
  213:       and membership.role = 'owner' and membership.status = 'active'
  214:       and not exists (select 1 from public.entities entity where entity.farm_id = farm.id)
  215:   ) then
  216:     return new;
  217:   end if;
  218:
  219:   if tg_op = 'UPDATE' then
  220:     v_old_farm_id := nullif(to_jsonb(old) ->> 'farm_id', '')::uuid;
  221:     if v_old_farm_id is distinct from v_farm_id then
  222:       perform public.assert_current_farm_access_epoch(v_old_farm_id);
  223:     end if;
  224:   end if;
  225:   perform public.assert_current_farm_access_epoch(v_farm_id);
  226:   return case when tg_op = 'DELETE' then old else new end;
  227: end;
  228: $$;
  229:
  230: create function public.guard_farm_root_access_epoch()
  231: returns trigger
  232: language plpgsql
  233: security definer
  234: set search_path = public, pg_temp
  235: as $$
  236: begin
  237:   -- Creating a farm is guarded by created_by = auth.uid() and the hardened
  238:   -- bootstrap trigger. Existing farm roots require the captured epoch.
  239:   if tg_op <> 'INSERT' then
  240:     perform public.assert_current_farm_access_epoch(old.id);
  241:   end if;
  242:   return case when tg_op = 'DELETE' then old else new end;
  243: end;
  244: $$;
