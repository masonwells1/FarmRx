 * { box-sizing: border-box; }

 html { background: var(--cream); }

 body {
   margin: 0;
   min-width: 320px;
   min-height: 100vh;
   background: var(--cream);
   color: var(--charcoal);
   font-family: var(--ui-font);
   font-size: 18px;
   line-height: 1.5;
   font-variant-numeric: tabular-nums;
   -webkit-font-smoothing: antialiased;
 }

 button, input, select, textarea { font: inherit; }
 button, input, select, textarea { min-width: 48px; min-height: 48px; }
 button { cursor: pointer; }

 button:focus-visible, a:focus-visible, input:focus-visible {
   outline: 3px solid var(--amber);
   outline-offset: 3px;
 }

 .numeric { font-variant-numeric: tabular-nums; }

-.app-shell { min-height: 100vh; display: flex; }
+.app-shell { min-height: 100vh; min-height: 100dvh; display: flex; }

 .sidebar {
   width: 262px;
   min-height: 100vh;
   flex: 0 0 262px;
   display: flex;
   flex-direction: column;
   background: var(--nav-dark);
   color: #fff;
   padding: 22px 12px 18px;
 }

 .farm-lockup { margin: 0 8px 16px; padding: 16px 12px 18px; border-bottom: 1px solid rgb(255 255 255 / 10%); }
 .farm-name, h1, .product-name, .card-heading, .table-total, .stat-label, .powered-mark { font-family: var(--brand-font); }
 .farm-name { font-weight: 700; font-size: 20px; line-height: 1.2; }
 .farm-logo-note { margin-top: 4px; color: var(--nav-muted); font-size: 18px; letter-spacing: .06em; text-transform: uppercase; }
 .sidebar-nav { flex: 1; }

 .nav-link {
   position: relative;
   min-height: 48px;
   display: flex;
   align-items: center;
   gap: 13px;
   margin-bottom: 2px;
   padding: 12px 14px;
   border-radius: 10px;
   color: var(--nav-muted);
   font-size: 18px;
   font-weight: 500;
   text-decoration: none;
   transition: background-color 150ms ease-out, color 150ms ease-out;
 }

 .nav-link:hover { color: #fff; background: rgb(255 255 255 / 5%); }
 .nav-link.active { color: #fff; background: rgb(255 255 255 / 6%); font-weight: 600; }
 .nav-link.active::before { content: ""; position: absolute; left: 0; top: 8px; bottom: 8px; width: 3px; border-radius: 0 3px 3px 0; background: var(--crx-green); }
 .nav-icon { width: 22px; display: inline-flex; align-items: center; justify-content: center; }
 .nav-icon svg { width: 22px; height: 22px; display: block; }
 .nav-link.active .nav-icon { color: var(--crx-green); }

 .powered-by { margin: 8px; padding: 18px 0 0; border-top: 1px solid rgb(255 255 255 / 10%); color: var(--nav-muted); text-align: center; font-size: 18px; letter-spacing: .08em; text-transform: uppercase; }
 .powered-mark { margin-bottom: 3px; color: #fff; font-size: 21px; font-weight: 700; letter-spacing: -.02em; text-transform: none; }
 .powered-mark span, .product-name span { color: var(--crx-green); }

 .app-main { min-width: 0; flex: 1; }
 .topbar { position: sticky; top: 0; z-index: 10; min-height: 72px; display: flex; align-items: center; justify-content: space-between; gap: 20px; padding: 15px 32px; border-bottom: 1px solid var(--hairline); background: rgb(249 247 242 / 82%); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); }
 .topbar-actions { display: flex; align-items: center; gap: 12px; }
 .farm-summary { display: flex; align-items: center; gap: 10px; }
 .farm-switcher { display: flex; align-items: center; gap: 8px; color: var(--matte-gray); font-size: 18px; font-weight: 700; }
 .farm-switcher select { max-width: 260px; min-height: 44px; padding: 7px 34px 7px 10px; border: 1px solid var(--hairline); border-radius: 9px; background: var(--surface); color: var(--charcoal); }
 .offline-context { display: inline-flex; align-items: center; min-height: 32px; padding: 4px 10px; border-radius: 99px; background: var(--warn-bg); color: #604a22; font-size: 18px; font-weight: 700; white-space: nowrap; }
 .offline-data-notice { padding: 10px 24px; border-bottom: 1px solid #e8d39d; background: var(--warn-bg); color: #604a22; font-size: 18px; font-weight: 650; text-align: center; }
 .alert-bell { position: relative; min-width: 48px; min-height: 48px; border: 1px solid var(--hairline); border-radius: 12px; background: rgb(255 255 255 / 65%); color: var(--matte-gray); font: inherit; font-size: 25px; transition: background-color 150ms ease-out, box-shadow 150ms ease-out; }
 .alert-bell:hover { background: var(--surface); box-shadow: var(--shadow-card); }
 .alert-bell svg { width: 25px; height: 25px; vertical-align: middle; }
 .alert-bell b { position: absolute; top: -8px; right: -8px; min-width: 28px; height: 28px; display: grid; place-items: center; padding: 0 4px; border-radius: 99px; background: var(--warn-red); color: var(--on-dark); font-size: 18px; font-variant-numeric: tabular-nums; }

 /* Notification center: plain-language, phone-first alerts without crowding the farm work. */
 .notifications-page { display: grid; gap: 18px; }
@@ -474,165 +474,165 @@ tbody tr:nth-child(even) td { background: var(--cream); }
 .saved-whisper { color: var(--deep-green); font-size: 18px; font-weight: 700; }
