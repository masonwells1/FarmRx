    2: -- No provider secret or test control is stored in the database or exposed by an
    3: -- HTTP handler. All server RPCs retain modern request.jwt.claims authorization.
    4:
    5: -- Release preflight: the legacy parent protocol cannot prove which device was
    6: -- reached after any claim or failure. Pause every scheduler/send-push entry
    7: -- point, wait for old invocations to drain, and explicitly adjudicate these
    8: -- rows before retrying this migration. Refusing is safer than duplicating a
    9: -- customer alert while converting a partially delivered parent into targets.
   10: do $$
   11: declare
   12:   v_ambiguous integer;
   13: begin
   14:   select count(*) into v_ambiguous
   15:   from public.push_deliveries
   16:   where status='failed'
   17:      or (status='pending' and (attempts>0 or claimed_at is not null));
   18:   if v_ambiguous>0 then
   19:     raise exception '0039 rollout blocked: % ambiguous legacy push deliveries require adjudication',v_ambiguous
   20:       using hint='Pause scheduler and send-push entry points, wait for old invocations to drain, then adjudicate every failed or previously claimed legacy parent before retrying.';
   21:   end if;
   22: end;
   23: $$;
