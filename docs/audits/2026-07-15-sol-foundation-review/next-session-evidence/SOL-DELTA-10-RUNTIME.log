 .contract-entry summary { min-height: 48px; cursor: pointer; }
 .contract-entry details > div { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10px; margin-top: 8px; }
 .contract-entry details label { display: grid; gap: 4px; color: var(--matte-gray); font-size: 18px; letter-spacing: .04em; text-transform: uppercase; }
 .contract-entry .primary-action { min-height: 48px; padding: 10px 14px; white-space: nowrap; }
