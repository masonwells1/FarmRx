 .shelf-card small { font-size: 18px; }.shelf-card em { width: fit-content; border-radius: 99px; padding: 4px 8px; background: var(--warn-bg); color: #87520b; font-size: 18px; font-style: normal; font-weight: 700; }.shelf-card p { margin: 0; color: var(--warn-red); font-size: 18px; line-height: 1.35; }.shelf-card.low p { color: #87520b; }.shelf-card.negative { border-color: var(--warn-red); }
 .inventory-panel { margin-top: 20px; overflow: hidden; border: 1px solid var(--hairline); border-radius: 16px; background: var(--surface); }.panel-note { margin: 0; padding: 16px 20px; color: var(--matte-gray); }
 .inventory-form { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; padding: 20px; border-top: 1px solid var(--hairline); }.inventory-form > label, .inventory-form fieldset > label { display: grid; gap: 6px; color: var(--charcoal); font-size: 18px; font-weight: 700; }.inventory-form .wide { grid-column: span 2; }.inventory-form .primary-action { width: fit-content; align-self: end; }
