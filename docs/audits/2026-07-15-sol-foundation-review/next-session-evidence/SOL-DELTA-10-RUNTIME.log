  118: export function captureFarmRevocationFence(storage: StorageLike, scope: FarmRevocationScope): FarmRevocationSnapshot {
  119:   const current = readFence(storage, scope)
  120:   if (current.revoked) throw new Error(blocked)
  121:   return { ...scope, generation: current.generation, token: current.token, serverEpoch: current.serverEpoch }
  122: }
  123:
  124: export function verifyFarmRevocationFence(storage: StorageLike, snapshot: FarmRevocationSnapshot): void {
  125:   const current = readFence(storage, snapshot)
  126:   if (current.revoked || current.generation !== snapshot.generation || current.token !== snapshot.token || current.serverEpoch !== snapshot.serverEpoch) throw new Error(blocked)
  127: }
  128:
  129: export function markFarmRevoked(storage: StorageLike, scope: FarmRevocationScope, changedAt = new Date().toISOString(), serverEpoch?: number): number {
  130:   const { fence, ledger } = readState(storage, scope)
  131:   if (fence?.revoked && ledger) return fence.generation
  132:   const generation = Math.max(fence?.generation ?? 0, ledger?.generation ?? 0) + 1
  133:   const authoritativeEpoch = serverEpoch ?? fence?.serverEpoch ?? ledger?.serverEpoch
  134:   if (!authoritativeEpoch) throw new Error(blocked)
  135:   writeFence(storage, scope, { version: 2, generation, token: nextToken(), serverEpoch: authoritativeEpoch, revoked: true, changedAt })
  136:   return generation
  137: }
  138:
  139: export function markFarmGranted(storage: StorageLike, scope: FarmRevocationScope, changedAt = new Date().toISOString(), serverEpoch?: number): number {
  140:   const { fence, ledger } = readState(storage, scope)
  141:   if (Number.isNaN(Date.parse(changedAt))) throw new Error(blocked)
  142:   const authoritativeEpoch = serverEpoch ?? (!browserStorage(storage) ? fence?.serverEpoch ?? ledger?.serverEpoch ?? 1 : undefined)
  143:   if (!authoritativeEpoch || !Number.isSafeInteger(authoritativeEpoch) || authoritativeEpoch < 1) throw new Error(blocked)
  144:   const lastChangedAt = fence?.changedAt ?? ledger?.changedAt
  145:   // A live farm list is authoritative only for the snapshot time at which its
  146:   // request began. A delayed older response must not undo a newer revocation.
  147:   if ((!fence || fence.revoked) && lastChangedAt && Date.parse(lastChangedAt) > Date.parse(changedAt)) throw new Error(blocked)
