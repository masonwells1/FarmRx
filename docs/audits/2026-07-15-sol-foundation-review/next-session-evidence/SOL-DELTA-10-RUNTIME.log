  300: create function public.bump_rep_access_epoch()
  301: returns trigger
  302: language plpgsql
  303: security definer
  304: set search_path = public, pg_temp
  305: as $$
  306: begin
  307:   if tg_op = 'UPDATE'
  308:     and (old.farm_id, old.rep_user_id) is distinct from (new.farm_id, new.rep_user_id) then
  309:     perform public.bump_farm_access_epoch(old.farm_id, old.rep_user_id);
  310:   end if;
  311:   perform public.bump_farm_access_epoch(
  312:     case when tg_op = 'DELETE' then old.farm_id else new.farm_id end,
  313:     case when tg_op = 'DELETE' then old.rep_user_id else new.rep_user_id end
  314:   );
  315:   return case when tg_op = 'DELETE' then old else new end;
  316: end;
