  148:   private overlay(workspace: ProfitabilityWorkspace, entries: ProfitabilityQueueEntryV1[]): ProfitabilityWorkspace {
  149:     let next = structuredClone(workspace)
  150:     for (const entry of entries) {
  151:       if (entry.kind === 'createBudget') { next.budgets = replace(next.budgets, entry.row); next.matrix_steps = [...next.matrix_steps.filter((step) => step.budget_id !== entry.row.id), ...entry.priceSteps, ...entry.yieldSteps] }
  152:       else if (entry.kind === 'saveBudget') next.budgets = replace(next.budgets, entry.row)
  153:       else if (entry.kind === 'saveCostLine') { const { sort_order: _sortOrder, ...publicLine } = entry.row; next.cost_lines = replace(next.cost_lines, publicLine) }
  154:       else if (entry.kind === 'deleteCostLine') next.cost_lines = next.cost_lines.filter((line) => line.id !== entry.id)
  155:       else if (entry.kind === 'replaceMatrixSteps') next.matrix_steps = [...next.matrix_steps.filter((step) => step.budget_id !== entry.budgetId), ...entry.steps]
  156:       else if (entry.kind === 'saveAllocation') next.allocations = replace(next.allocations, entry.row)
  157:       else if (entry.kind === 'deleteAllocation') next.allocations = next.allocations.filter((row) => row.id !== entry.id)
  158:       else if (entry.kind === 'copyBudget') { next.budgets = replace(next.budgets, entry.budget); next.cost_lines = [...next.cost_lines, ...entry.costLines.map(({ sort_order: _sortOrder, ...rest }) => rest)]; next.matrix_steps = [...next.matrix_steps, ...entry.matrixSteps] }
  159:     }
  160:     return next
  161:   }
  162:   async replayCurrent() {
  163:     let source: Awaited<ReturnType<QueuedProfitabilityRepository['contextAndQueue']>>
  164:     try { source = await this.contextAndQueue() } catch { return }
  165:     const { context, queue, memoryGuard } = source
  166:     try {
  167:       await this.locked(queue, async (verify) => {
  168:         let envelope = queue.read()
  169:         if (!envelope.entries.length) { const parked = readNeedsAttention(this.dependencies.storage, queue.key).length; setModuleSyncStatus('profitability', parked ? { kind: 'blocked', pending: parked, message: `${parked} saves need attention.` } : { kind: 'synced', pending: 0 }); return }
  170:         if (this.dependencies.isOffline()) { setModuleSyncStatus('profitability', { kind: 'pending', pending: envelope.entries.length }); return }
  171:         const versions = new Map<string, string>()
  172:         while (envelope.entries.length) {
  173:           const head = envelope.entries[0]
  174:           if (head.userId !== context.userId || head.farmId !== context.farmId) throw new Error(blocked)
  175:           await this.verifyOperation(head, memoryGuard.fence, memoryGuard)
  176:           setModuleSyncStatus('profitability', { kind: 'syncing', pending: envelope.entries.length })
  177:           try { const saved = await this.write(this.rebase(head, versions), memoryGuard.fence); const key = this.mutableKey(head); if (key && saved && typeof saved === 'object' && typeof (saved as { updated_at?: unknown }).updated_at === 'string') versions.set(key, (saved as { updated_at: string }).updated_at); verify(); await this.verifyOperation(head, memoryGuard.fence, memoryGuard); envelope = queue.removeConfirmedHead(head.operationId) }
  178:           catch (error) {
  179:             await this.verifyOperation(head, memoryGuard.fence, memoryGuard)
  180:             if (isTransportFailure(error, this.dependencies.isOffline())) { setModuleSyncStatus('profitability', { kind: 'pending', pending: envelope.entries.length }); return }
  181:             const updateRequired = error instanceof Error && error.message === SAVE_DURABILITY_UPDATE_MESSAGE
  182:             envelope = queue.parkHead(head.operationId, updateRequired ? SAVE_DURABILITY_UPDATE_MESSAGE : ('legacyUnknownSnapshot' in head ? 'This older matrix save needs attention because its original matrix snapshot is unknown. Review it after the database update.' : 'This save needs attention before it can be retried.'), updateRequired ? 'database_update_required' : undefined); continue
  183:           }
  184:         }
  185:         const parked = readNeedsAttention(this.dependencies.storage, queue.key).length; setModuleSyncStatus('profitability', parked ? { kind: 'blocked', pending: parked, message: `${parked} saves need attention.` } : { kind: 'synced', pending: 0 })
  186:       })
  187:     } catch { setModuleSyncStatus('profitability', { kind: 'blocked', pending: 0, message: blocked }) }
  188:   }
