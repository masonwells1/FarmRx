  281: create function public.bump_membership_access_epoch()
  282: returns trigger
  283: language plpgsql
  284: security definer
  285: set search_path = public, pg_temp
  286: as $$
  287: begin
  288:   if tg_op = 'UPDATE'
  289:     and (old.farm_id, old.user_id) is distinct from (new.farm_id, new.user_id) then
  290:     perform public.bump_farm_access_epoch(old.farm_id, old.user_id);
  291:   end if;
  292:   perform public.bump_farm_access_epoch(
  293:     case when tg_op = 'DELETE' then old.farm_id else new.farm_id end,
  294:     case when tg_op = 'DELETE' then old.user_id else new.user_id end
  295:   );
  296:   return case when tg_op = 'DELETE' then old else new end;
  297: end;
  298: $$;
