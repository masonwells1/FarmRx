57: export async function runScheduledAlertSweep(dependencies: ScheduledAlertDependencies): Promise<ScheduledAlertRunResult> {
58:   const now = dependencies.now()
59:   if (!Number.isFinite(now.getTime())) throw new Error('scheduler clock is invalid')
60:   const nowIso = now.toISOString()
61:   const runController = new AbortController()
62:   const schedulerDeadlineMs = Math.max(1, Math.min(Math.trunc(dependencies.schedulerDeadlineMs ?? 50_000), 55_000))
63:   const runTimer = setTimeout(() => runController.abort(new DOMException('Scheduler deadline reached', 'TimeoutError')), schedulerDeadlineMs)
64:   try {
65:   const sweep = await dependencies.database.runAlertSweep(nowIso, runController.signal)
66:   if (runController.signal.aborted) throw new DOMException('Scheduler deadline reached', 'TimeoutError')
67:   const fields = await dependencies.database.listWeatherFields(runController.signal)
68:   if (runController.signal.aborted) throw new DOMException('Scheduler deadline reached', 'TimeoutError')
69:   let weatherChecked = 0
70:   let sprayFired = 0
71:   const failures: Array<ScheduledAlertRunResult['weatherFailureFields'][number] & { index: number }> = []
72:   const settled = fields.map(() => false)
73:   const controller = new AbortController()
74:   const abortWeatherForRun = () => controller.abort(runController.signal.reason)
75:   runController.signal.addEventListener('abort', abortWeatherForRun, { once: true })
76:   const concurrency = Math.max(1, Math.min(Math.trunc(dependencies.weatherConcurrency ?? 6), 12))
77:   const deadlineMs = Math.max(1, Math.min(Math.trunc(dependencies.weatherDeadlineMs ?? 20_000), 30_000))
78:   let nextIndex = 0
79:   let weatherTimedOut = false
80:   const fail = (index: number, reason: string) => {
81:     if (settled[index]) return
82:     settled[index] = true
83:     const field = fields[index]!
84:     const failure = { index, farmId: field.farm_id, fieldId: field.id, reason }
85:     failures.push(failure)
86:     dependencies.log?.({ event: 'scheduled_weather_field_failed', farmId: failure.farmId, fieldId: failure.fieldId, reason })
87:   }
88:   const worker = async () => {
89:     while (true) {
90:       if (controller.signal.aborted) return
91:       const index = nextIndex
92:       nextIndex += 1
93:       if (index >= fields.length) return
94:       const field = fields[index]!
95:       try {
96:         const observation = parseScheduledWeatherResponse(await dependencies.fetchWeather(field, controller.signal), now)
97:         if (controller.signal.aborted) throw new DOMException('Weather deadline reached', 'TimeoutError')
98:         const recorded = await dependencies.database.recordSprayWindow({
99:           farmId: field.farm_id,
100:           fieldId: field.id,
101:           localDate: localDateFromForecast(observation),
102:           isGood: scheduledSprayIsGood(observation),
103:           observedAt: observation.observed_at,
104:           observation,
105:         }, controller.signal)
106:         if (settled[index]) continue
107:         settled[index] = true
108:         weatherChecked += 1
109:         if (recorded.fired === true) sprayFired += 1
110:       } catch (error) {
111:         fail(index, failureReason(error))
112:       }
113:     }
114:   }
115:   const workers = Array.from({ length: Math.min(concurrency, fields.length) }, () => worker())
116:   let timer: ReturnType<typeof setTimeout> | undefined
117:   const deadline = new Promise<void>((resolve) => {
118:     timer = setTimeout(() => {
119:       weatherTimedOut = true
120:       controller.abort()
121:       for (let index = 0; index < fields.length; index += 1) fail(index, 'TimeoutError')
122:       resolve()
123:     }, deadlineMs)
124:   })
125:   if (workers.length) await Promise.race([Promise.all(workers).then(() => undefined), deadline])
126:   if (timer !== undefined) clearTimeout(timer)
127:   if (weatherTimedOut) controller.abort(new DOMException('Weather deadline reached', 'TimeoutError'))
128:   await Promise.allSettled(workers)
129:   runController.signal.removeEventListener('abort', abortWeatherForRun)
130:   const weatherFailureFields = failures.sort((left, right) => left.index - right.index).map(({ index: _index, ...failure }) => failure)
131:
132:   // Deliberately last and deliberately not caught: a push sweep failure must
133:   // make the HTTP request fail so monitoring never reports false success.
134:   if (runController.signal.aborted) throw new DOMException('Scheduler deadline reached', 'TimeoutError')
135:   const push = await dependencies.runPushSweep(runController.signal)
136:   return { sweep, weatherChecked, weatherFailed: weatherFailureFields.length, weatherFailureFields, weatherTimedOut, sprayFired, push }
137:   } finally { clearTimeout(runTimer) }
138: }

