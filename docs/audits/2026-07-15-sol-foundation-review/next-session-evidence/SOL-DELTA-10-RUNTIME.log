   44:   private async raw(farmId: string) { const b: InventoryRowBundle = await this.dependencies.gateway.loadWorkspace(farmId); if (![b.products, b.receipts, b.receipt_lines, b.adjustments, b.applications, b.application_products, b.program_application_products, b.on_hand, b.rup_completeness].every(Array.isArray)) fail(); return { products: b.products.map(mapProduct), receipts: b.receipts.map(mapReceipt), receipt_lines: b.receipt_lines.map(mapLine), adjustments: b.adjustments.map(mapAdjustment), applications: b.applications.map(mapApplication), application_products: b.application_products.map(mapApplicationProduct), program_application_products: b.program_application_products.map(mapProgramApplicationProduct), on_hand: b.on_hand.map(mapOnHand), rup_completeness: b.rup_completeness.map(mapRup) } }
   45:   private validate(data: Awaited<ReturnType<SupabaseInventoryRepository['raw']>>, farmId: string, fields: FieldsData) { if (fields.farm.id !== farmId) fail('Farm Rx could not verify the selected farm.'); const unique = <T extends { id: string }>(rows: T[], label: string) => { const seen = new Set<string>(); for (const row of rows) { if (seen.has(row.id)) fail(`Farm Rx found duplicated ${label} data.`); seen.add(row.id) } }; unique(data.products, 'product'); unique(data.receipts, 'receipt'); unique(data.receipt_lines, 'receipt line'); unique(data.adjustments, 'adjustment'); unique(data.applications, 'application'); unique(data.application_products, 'application product'); for (const rows of [data.products, data.receipts, data.adjustments, data.applications]) for (const row of rows) if (row.farm_id !== farmId) fail(); for (const row of data.program_application_products) if (row.farm_id !== farmId) fail(); const products = new Map(data.products.map((row) => [row.id, row])); const receiptIds = new Set(data.receipts.map((row) => row.id)); const applicationIds = new Set(data.applications.map((row) => row.id)); for (const row of data.receipt_lines) { if (!receiptIds.has(row.receipt_id) || !products.has(row.product_id) || !conversionSafe(row.entered_unit, products.get(row.product_id)!.inventory_unit, row.inventory_units_per_entered_unit)) fail() } for (const row of data.adjustments) if (!products.has(row.product_id)) fail(); for (const row of data.applications) { const assignment = fields.crop_assignments.find((item) => item.id === row.crop_assignment_id && item.field_id === row.field_id && item.farm_id === farmId); if (!assignment || !fields.fields.some((item) => item.id === row.field_id && item.farm_id === farmId) || row.applied_acres > assignment.planted_acres || row.corrects_application_id === row.id || row.corrects_application_id !== null && !applicationIds.has(row.corrects_application_id)) fail() } const lotKeys = new Set<string>(); for (const row of data.application_products) { if (!applicationIds.has(row.application_id) || !products.has(row.product_id)) fail(); const raw = row as unknown as Record<string, unknown>; const key = `${row.application_id}|${row.product_id}|${String(raw.lot_number_snapshot ?? '')}`; if (lotKeys.has(key)) fail(); lotKeys.add(key) } const hand = new Set<string>(); for (const row of data.on_hand) { if (hand.has(row.product_id) || !products.has(row.product_id)) fail(); hand.add(row.product_id) } for (const product of data.products) if (!hand.has(product.id)) fail(); const effectiveRup = data.application_products.filter((p) => p.is_restricted_use_snapshot && data.applications.find((a) => a.id === p.application_id)?.status === 'completed'); const rup = new Set(data.rup_completeness.map((r) => `${r.application_id}|${r.application_product_id}`)); for (const p of effectiveRup) if (!rup.has(`${p.application_id}|${p.id}`)) fail(); for (const r of data.rup_completeness) if (r.farm_id !== farmId || !data.applications.some((a) => a.id === r.application_id) || !data.application_products.some((p) => p.id === r.application_product_id && p.application_id === r.application_id && p.is_restricted_use_snapshot)) fail() }
   46:   async getWorkspace() { const farmId = await this.dependencies.getFarmId(); const [data, fields] = await Promise.all([this.raw(farmId), this.dependencies.fieldsRepository.getData()]); this.validate(data, farmId, fields); for (const row of data.program_application_products) if (!data.applications.some((application) => application.id === row.application_record_id && (application.status === 'draft' || application.status === 'completed'))) fail('Farm Rx found invalid Program application details.'); return { ...data, products: [...data.products].sort((a, b) => a.name.localeCompare(b.name) || a.id.localeCompare(b.id)), receipts: [...data.receipts].sort((a, b) => a.created_at.localeCompare(b.created_at) || a.id.localeCompare(b.id)), receipt_lines: [...data.receipt_lines].sort((a, b) => a.receipt_id.localeCompare(b.receipt_id) || a.id.localeCompare(b.id)), adjustments: [...data.adjustments].sort((a, b) => a.adjusted_at.localeCompare(b.adjusted_at) || a.id.localeCompare(b.id)), applications: [...data.applications].sort((a, b) => a.application_date.localeCompare(b.application_date) || a.id.localeCompare(b.id)), application_products: [...data.application_products].sort((a, b) => a.application_id.localeCompare(b.application_id) || a.id.localeCompare(b.id)), program_application_products: [...data.program_application_products].sort((a, b) => a.application_record_id.localeCompare(b.application_record_id) || a.sequence - b.sequence), on_hand: [...data.on_hand].sort((a, b) => a.product_id.localeCompare(b.product_id)), rup_completeness: [...data.rup_completeness].sort((a, b) => a.application_id.localeCompare(b.application_id) || a.application_product_id.localeCompare(b.application_product_id)), fields } }
   48:   async saveProductOperation(value: InventoryProduct, context: FarmOperationContext) { const farmId = await this.operationFarmId(context); const fields = await this.dependencies.fieldsRepository.getData(); if (fields.farm.id !== farmId) fail(); const now = this.dependencies.clock(); const normalized = { ...value, farm_id: farmId, created_at: value.created_at || now, updated_at: value.updated_at || now }; mapProduct(normalized); const raw = await this.raw(farmId); const prior = raw.products.find((p) => p.id === normalized.id); if (prior && prior.inventory_unit !== normalized.inventory_unit && (raw.receipt_lines.some((x) => x.product_id === prior.id) || raw.adjustments.some((x) => x.product_id === prior.id) || raw.application_products.some((x) => x.product_id === prior.id))) fail('Inventory unit cannot change after a product has ledger history.'); const saved = mapProduct(await this.dependencies.gateway.upsertProduct(farmId, normalized as InventoryProductWrite, prior ? value.updated_at : null, context)); if (saved.id !== normalized.id || saved.farm_id !== farmId || saved.product_kind !== normalized.product_kind || saved.inventory_unit !== normalized.inventory_unit || saved.is_active !== normalized.is_active || saved.commodity_id !== normalized.commodity_id || saved.variety_name !== normalized.variety_name || saved.is_restricted_use !== normalized.is_restricted_use) fail('Farm Rx could not confirm this product saved.'); return saved }
   52:   async saveReceiptBundleOperation(write: ReceiptBundleWrite, context: FarmOperationContext) { const farmId = await this.operationFarmId(context); const lines = write.lines; if (!lines.length) fail(); const response = object(await this.dependencies.gateway.saveReceiptBundle({ ...write, farmId }, context)); const receipt = mapReceipt(bundle(response, 'receipt')); const v = required(response, 'lines'); if (!Array.isArray(v)) fail(); const savedLines = (v as unknown[]).map(mapLine); if (receipt.farm_id !== farmId || receipt.id !== write.receipt.id || receipt.status !== write.receipt.status) fail('Farm Rx could not confirm this receipt saved.'); const expected = lines.map((x: Record<string, unknown>) => `${x.id}|${x.product_id}|${x.entered_quantity}|${x.entered_unit}`).sort(); const actual = savedLines.map((x) => `${x.id}|${x.product_id}|${x.entered_quantity}|${x.entered_unit}`).sort(); if (expected.length !== actual.length || expected.some((value, i) => value !== actual[i]) || savedLines.some((x) => x.receipt_id !== receipt.id)) fail('Farm Rx could not confirm this receipt saved.') }
   59:   async saveApplicationBundleOperation(write: ApplicationBundleWrite, context: FarmOperationContext) { const farmId = await this.operationFarmId(context); const fields = await this.dependencies.fieldsRepository.getData(); const a = write.application; const assignment = fields.crop_assignments.find((x) => x.id === a.crop_assignment_id && x.field_id === a.field_id && x.farm_id === farmId); if (!assignment || Number(a.applied_acres) > assignment.planted_acres) fail('Choose one field and its crop, then enter valid application details.'); const response = object(await this.dependencies.gateway.saveApplicationBundle({ ...write, farmId }, context)); const application = mapApplication(bundle(response, 'application')); const value = required(response, 'products'); if (!Array.isArray(value)) fail(); const products = (value as unknown[]).map(mapApplicationProduct); if (application.id !== a.id || application.farm_id !== farmId || application.field_id !== a.field_id || application.crop_assignment_id !== a.crop_assignment_id || application.status !== a.status) fail('Farm Rx could not confirm this application saved.'); const expected = write.products.map((x: Record<string, unknown>) => `${x.id}|${x.product_id}|${x.rate}|${x.total_quantity}`).sort(); const actual = products.map((x) => `${x.id}|${x.product_id}|${x.rate}|${x.total_quantity}`).sort(); if (expected.length !== actual.length || expected.some((item, i) => item !== actual[i]) || products.some((x) => x.application_id !== application.id)) fail('Farm Rx could not confirm this application saved.') }
