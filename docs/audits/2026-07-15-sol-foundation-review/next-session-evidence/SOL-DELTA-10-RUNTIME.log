   34: export interface PushDeliveryOptions { limit?: number; concurrency?: number; budgetMs?: number }
   35:
   36: const budgetExpired = 'push delivery budget exhausted'
   37:
   38: function providerStatus(error: unknown) {
   39:   const status = (error as { statusCode?: unknown } | null)?.statusCode
   40:   return typeof status === 'number' && Number.isInteger(status) ? status : null
   41: }
   42:
   43: async function finishWithRetry(database: PushDeliveryDatabase, targetId: string, outcome: PushTargetOutcome, error: string | null, signal: AbortSignal) {
   44:   let failure: unknown
   45:   for (let attempt = 0; attempt < 3; attempt += 1) {
   46:     try { await callBeforeAbort(() => database.finishTarget(targetId, outcome, error, signal), signal); return }
   47:     catch (caught) { failure = caught }
   48:   }
   49:   throw failure
   50: }
   51:
   52: function beforeAbort<T>(promise: Promise<T>, signal: AbortSignal): Promise<T> {
   53:   if (signal.aborted) return Promise.reject(new DOMException(budgetExpired, 'AbortError'))
   54:   return new Promise<T>((resolve, reject) => {
   55:     const aborted = () => reject(new DOMException(budgetExpired, 'AbortError'))
   56:     signal.addEventListener('abort', aborted, { once: true })
   57:     promise.then(
   58:       (value) => { signal.removeEventListener('abort', aborted); resolve(value) },
   59:       (error) => { signal.removeEventListener('abort', aborted); reject(error) },
   60:     )
   61:   })
   62: }
   63:
   64: function callBeforeAbort<T>(operation: () => Promise<T>, signal: AbortSignal): Promise<T> {
   65:   if (signal.aborted) return Promise.reject(new DOMException(budgetExpired, 'AbortError'))
   66:   try { return beforeAbort(operation(), signal) }
   67:   catch (error) { return Promise.reject(error) }
   68: }
   69:
   70: export async function deliverClaimedPushTargets(
   71:   database: PushDeliveryDatabase,
   72:   provider: PushProvider,
   73:   notificationId: string | null,
   74:   options: PushDeliveryOptions | number = {},
   75: ): Promise<PushDeliveryResult> {
   76:   const normalized = typeof options === 'number' ? { limit: options } : options
   77:   const limit = Math.max(1, Math.min(normalized.limit ?? 12, 100))
   78:   const concurrency = Math.max(1, Math.min(normalized.concurrency ?? 6, 12))
   79:   const budgetMs = Math.max(100, Math.min(normalized.budgetMs ?? 20_000, 25_000))
   80:   const deadlineAt = Date.now() + budgetMs
   81:   const providerMaxMs = Math.min(8_000, Math.max(50, Math.floor(budgetMs / 2)))
   82:   const completionReserveMs = Math.min(1_500, Math.max(25, Math.floor(budgetMs / 4)))
   83:   const controller = new AbortController()
   84:   const timer = setTimeout(() => controller.abort(), budgetMs)
   85:   let targets: ClaimedPushTarget[]
   86:   try { targets = await callBeforeAbort(() => database.claimTargets(notificationId, limit, controller.signal), controller.signal) }
   87:   catch (error) { clearTimeout(timer); throw error }
   88:   let sent = 0
   89:   let failed = 0
   90:   let gone = 0
   91:   let cursor = 0
   92:
   93:   const deliverOne = async (target: ClaimedPushTarget) => {
   94:     const payload = JSON.stringify({
   95:       notification_id: target.notification_id,
   96:       title: target.title,
   97:       body: target.body ?? '',
   98:       link: target.link ?? '/notifications',
   99:       category: target.category,
  100:     })
  101:     try {
  102:       if (controller.signal.aborted) throw new DOMException(budgetExpired, 'AbortError')
  103:       const providerTimeoutMs = Math.min(providerMaxMs, deadlineAt - Date.now() - completionReserveMs)
  104:       if (providerTimeoutMs < 1) { controller.abort(); throw new DOMException(budgetExpired, 'AbortError') }
  105:       await callBeforeAbort(() => provider.send(target, payload, controller.signal, providerTimeoutMs), controller.signal)
  106:     } catch (error) {
  107:       const status = providerStatus(error)
  108:       if (status === 404 || status === 410) {
  109:         try { await finishWithRetry(database, target.target_id, 'gone', `push provider status ${status}`, controller.signal); gone += 1 }
  110:         catch { failed += 1 }
  111:       } else {
  112:         // Do not persist or log provider messages: they can include endpoints or
  113:         // request details. A stable status is enough for retry diagnostics.
  114:         const reason = controller.signal.aborted ? budgetExpired : status === null ? 'push provider failure' : `push provider status ${status}`
  115:         try { await finishWithRetry(database, target.target_id, 'retry', reason, controller.signal) }
  116:         catch { /* The invocation remains unhealthy; the sending lease expires for retry. */ }
  117:         finally { failed += 1 }
  118:       }
  119:       return
  120:     }
  121:     // A provider success must never be reclassified as a provider failure when
  122:     // only the database completion write fails. Retry that write in place; if
  123:     // it stays unavailable, leave the target sending and fail the invocation.
  124:     try { await finishWithRetry(database, target.target_id, 'sent', null, controller.signal); sent += 1 }
  125:     catch { failed += 1 }
  126:   }
  127:
  128:   const worker = async () => {
  129:     while (true) {
  130:       if (controller.signal.aborted) return
  131:       const index = cursor
  132:       cursor += 1
  133:       if (index >= targets.length) return
  134:       await deliverOne(targets[index]!)
  135:     }
  136:   }
  137:
  138:   try {
  139:     await Promise.all(Array.from({ length: Math.min(concurrency, targets.length) }, () => worker()))
  140:     if (controller.signal.aborted) failed = Math.max(failed, targets.length - sent - gone)
  141:     try {
  142:       const health = await callBeforeAbort(() => database.getHealth(notificationId, controller.signal), controller.signal)
  143:       return { claimed: targets.length, sent, failed, gone, terminalFailed: health.terminalFailed, retryable: health.retryable }
  144:     } catch {
  145:       // A timed-out health read must not extend the invocation. Every target
  146:       // that was not durably completed remains leased/retryable in PostgreSQL.
  147:       const retryable = Math.max(0, targets.length - sent - gone)
  148:       return { claimed: targets.length, sent, failed: Math.max(1, failed, retryable), gone, terminalFailed: 0, retryable }
  149:     }
  150:   } finally { clearTimeout(timer) }
  151: }
