   33: /** Compare-and-swap save for mutable farm rows, with identical lost-response
   34:  * retries treated as idempotent success. */
   35: export async function optimisticSave(table: string, farmId: string, id: string, columns: Row, expectedUpdatedAt: string | null | undefined, context: FarmOperationContext, idColumn = 'id'): Promise<Row> {
   36:   const existing = await current(table, farmId, idColumn, id)
   37:   if (existing) {
   38:     if (sameOptimisticWrite(existing, columns)) return existing
   39:     if (!expectedUpdatedAt || existing.updated_at !== expectedUpdatedAt) throw new StaleWriteConflictError()
   40:     const updated = await bindFarmOperationRequest(supabase.from(table).update(columns).eq('farm_id', farmId).eq(idColumn, id).eq('updated_at', expectedUpdatedAt).select('*').maybeSingle(), context)
   41:     if (updated.error) throw updated.error
   42:     if (updated.data) return updated.data as Row
   43:     const after = await current(table, farmId, idColumn, id)
   44:     if (after && sameOptimisticWrite(after, columns)) return after
   45:     throw new StaleWriteConflictError()
   46:   }
   47:
   48:   const inserted = await bindFarmOperationRequest(supabase.from(table).insert(columns).select('*').maybeSingle(), context)
   49:   if (!inserted.error && inserted.data) return inserted.data as Row
   50:   if (inserted.error?.code !== '23505') throw inserted.error ?? new Error('Farm Rx could not confirm that save.')
   51:   const after = await current(table, farmId, idColumn, id)
   52:   if (after && sameOptimisticWrite(after, columns)) return after
   53:   throw new StaleWriteConflictError()
   54: }
