   89:     rp_premium_per_acre: nullableBoundedDecimal(value.rp_premium_per_acre, { precision: 14, scale: 4, label: 'the premium per acre' }),
   90:   }
   91: }
   92: export function normalizeInsurancePatchDecimals(patch: InsuranceBudgetPatch): InsuranceBudgetPatch {
   93:   return {
   94:     rp_coverage_pct: nullableBoundedDecimal(patch.rp_coverage_pct, { precision: 5, scale: 2, label: 'the coverage percent' }),
   95:     rp_aph_yield: nullableBoundedDecimal(patch.rp_aph_yield, { precision: 12, scale: 4, label: 'the APH yield' }),
   96:     rp_projected_price: nullableBoundedDecimal(patch.rp_projected_price, { precision: 12, scale: 6, label: 'the projected price' }),
   97:     rp_premium_per_acre: nullableBoundedDecimal(patch.rp_premium_per_acre, { precision: 14, scale: 4, label: 'the premium per acre' }),
   98:   }
   99: }
  100: export function normalizeMatrixStepDecimals(step: ProfitabilityMatrixStep): ProfitabilityMatrixStep {
  101:   return { ...step, value: boundedDecimal(step.value, { precision: 14, scale: 6, label: 'a matrix step' }) }
  102: }
  103: export function normalizeCostLineDecimals(line: BudgetCostLineWrite): BudgetCostLineWrite {
  104:   return { ...line, amount_per_acre: boundedDecimal(line.amount_per_acre, { precision: 14, scale: 4, label: 'the cost per acre' }) }
  105: }
  106: export function normalizeAllocationDecimals(value: BudgetFieldAllocation): BudgetFieldAllocation {
  107:   return {
  108:     ...value,
  109:     allocated_acres: boundedDecimal(value.allocated_acres, { precision: 12, scale: 2, label: 'the allocated acres' }),
  110:     expected_yield_override: nullableBoundedDecimal(value.expected_yield_override, { precision: 12, scale: 4, label: 'the yield override' }),
  111:     expected_price_override: nullableBoundedDecimal(value.expected_price_override, { precision: 12, scale: 6, label: 'the price override' }),
  112:   }
  113: }
  114:
  115: /** Trusted, pre-resolved write operations used directly by the live repository and replayed by the offline queue. */
  116: export interface ProfitabilityOperationWriter {
  117:   createBudgetOperation(value: CropBudget, priceSteps: ProfitabilityMatrixStep[], yieldSteps: ProfitabilityMatrixStep[], context: FarmOperationContext): Promise<{ budget: CropBudget; steps: ProfitabilityMatrixStep[] }>
  118:   saveBudgetOperation(value: CropBudget, context: FarmOperationContext): Promise<CropBudget>
  119:   saveBudgetInsuranceOperation(budgetId: string, patch: InsuranceBudgetPatch, expectedUpdatedAt: string | null | undefined, context: FarmOperationContext): Promise<CropBudget>
  120:   saveCostLineOperation(value: BudgetCostLineWrite, context: FarmOperationContext): Promise<BudgetCostLine>
  121:   deleteCostLineOperation(id: string, context: FarmOperationContext): Promise<string>
  122:   replaceMatrixStepsOperation(budgetId: string, steps: ProfitabilityMatrixStep[], expectedSteps: ProfitabilityMatrixStep[] | null | undefined, context: FarmOperationContext): Promise<ProfitabilityMatrixStep[]>
  123:   saveAllocationOperation(value: BudgetFieldAllocation, context: FarmOperationContext): Promise<BudgetFieldAllocation>
  124:   deleteAllocationOperation(id: string, context: FarmOperationContext): Promise<string>
  125:   copyBudgetOperation(sourceBudgetId: string, budget: CropBudget, costLines: BudgetCostLineWrite[], matrixSteps: ProfitabilityMatrixStep[], context: FarmOperationContext): Promise<CropBudget>
  126:   /** Raw cost lines (with sort_order) for the offline queue's client-side sort_order minting. */
  127:   rawCostLines(): Promise<BudgetCostLineWrite[]>
  128: }
  129:
  130: export class SupabaseProfitabilityRepository implements ProfitabilityRepository, ProfitabilityOperationWriter {
  131:   constructor(private readonly dependencies: { gateway: ProfitabilityDataGateway; fieldsRepository: FieldsRepository; getFarmId: () => Promise<string>; getOperationContext: () => Promise<FarmOperationContext>; verifyOperationContext: (expected: FarmOperationContext) => Promise<void>; createId: () => string; clock: () => string }) {}
  132:   private async operationFarmId(expected: FarmOperationContext) { await this.dependencies.verifyOperationContext(expected); return expected.farmId }
  133:   private async fields() { return this.dependencies.fieldsRepository.getData() }
  134:   async getSaveDurabilityCapability() { return this.dependencies.gateway.getSaveDurabilityCapability ? this.dependencies.gateway.getSaveDurabilityCapability() : false }
  135:   private async loadRaw(farmId: string) {
  136:     let bundle: ProfitabilityRowBundle
  137:     try { bundle = await this.dependencies.gateway.loadWorkspace(farmId) }
  138:     catch (error) { if (error instanceof Error && error.message === 'PROFITABILITY_PRIVATE_ACCESS_DENIED') fail(PRIVACY_DENIED); throw error }
  139:     return { budgets: bundle.budgets.map(mapBudget), cost_lines: bundle.cost_lines.map(mapCostLine), matrix_steps: bundle.matrix_steps.map(mapMatrixStep), allocations: bundle.allocations.map(mapAllocation) }
  140:   }
  141:   private validateBudget(value: CropBudget, farmId: string, fields: FieldsData) {
  142:     if (value.farm_id !== farmId) fail('Farm Rx could not verify the farm for this budget.')
  143:     if (!value.name.trim() || value.expected_yield_per_acre <= 0 || value.expected_price_per_bushel <= 0) fail('Farm Rx found an invalid budget.')
  144:     const rpErrors = validateRevenueProtectionInputs(value); if (rpErrors.length) fail(rpErrors[0])
  145:     if (!fields.commodities.some((item) => item.id === value.commodity_id)) fail('Farm Rx could not verify this budget’s commodity.')
  146:     if (value.operating_entity_id !== null && !fields.entities.some((item) => item.id === value.operating_entity_id && item.farm_id === farmId)) fail('Farm Rx could not verify this budget’s entity.')
  147:   }
  148:   private validateMatrix(steps: ProfitabilityMatrixStep[]) {
  149:     for (const axis of ['price', 'yield'] as const) {
  150:       const axisSteps = steps.filter((step) => step.axis === axis)
  151:       if (axisSteps.length < 2) fail('Enter at least two price steps and two yield steps.')
  152:       const values = new Set<number>(); const orders = new Set<number>()
  153:       for (const step of axisSteps) {
  154:         if (!uuid.test(step.id) || !Number.isFinite(step.value) || step.value <= 0 || !Number.isInteger(step.sort_order) || step.sort_order < 0) fail('Farm Rx found an invalid matrix step.')
  155:         if (values.has(step.value)) fail('Matrix values must be distinct.')
  156:         values.add(step.value)
  157:         if (orders.has(step.sort_order)) fail('Matrix step order must be distinct.')
  158:         orders.add(step.sort_order)
  159:       }
  160:     }
  161:   }
  162:
  163:   async getWorkspace(): Promise<ProfitabilityWorkspace> {
  164:     const farmId = await this.dependencies.getFarmId()
  165:     const [raw, fields] = await Promise.all([this.loadRaw(farmId), this.fields()])
  166:     if (fields.farm.id !== farmId) fail('Farm Rx could not verify the selected farm.')
  167:     const budgetIds = new Set<string>()
  168:     for (const item of raw.budgets) { if (budgetIds.has(item.id)) fail('Farm Rx found a duplicated budget.'); budgetIds.add(item.id); this.validateBudget(item, farmId, fields) }
  169:     const lineIds = new Set<string>()
  170:     for (const item of raw.cost_lines) { if (lineIds.has(item.id)) fail('Farm Rx found a duplicated cost line.'); lineIds.add(item.id); if (!budgetIds.has(item.budget_id)) fail('Farm Rx found a cost line for an unknown budget.') }
  171:     const stepIds = new Set<string>(); const stepOrders = new Set<string>(); const stepValues = new Set<string>()
  172:     for (const item of raw.matrix_steps) {
  173:       if (stepIds.has(item.id)) fail('Farm Rx found a duplicated matrix step.')
  174:       stepIds.add(item.id)
  175:       if (!budgetIds.has(item.budget_id)) fail('Farm Rx found a matrix step for an unknown budget.')
  176:       const orderKey = `${item.budget_id}|${item.axis}|${item.sort_order}`; const valueKey = `${item.budget_id}|${item.axis}|${item.value}`
  177:       if (stepOrders.has(orderKey)) fail('Farm Rx found a duplicated matrix step order.')
  178:       stepOrders.add(orderKey)
  179:       if (stepValues.has(valueKey)) fail('Farm Rx found a duplicated matrix value.')
  180:       stepValues.add(valueKey)
  181:     }
  182:     const allocationIds = new Set<string>(); const allocationKeys = new Set<string>()
  183:     for (const item of raw.allocations) {
  184:       if (allocationIds.has(item.id)) fail('Farm Rx found a duplicated field allocation.')
  185:       allocationIds.add(item.id)
  186:       if (!budgetIds.has(item.budget_id)) fail('Farm Rx found a field allocation for an unknown budget.')
  187:       if (!fields.crop_assignments.some((item2) => item2.id === item.crop_assignment_id && item2.farm_id === farmId)) fail('Farm Rx found a field allocation for an unknown field.')
  188:       const key = `${item.budget_id}|${item.crop_assignment_id}`
  189:       if (allocationKeys.has(key)) fail('Farm Rx found a duplicated field allocation.')
  190:       allocationKeys.add(key)
  191:     }
  192:     const budgets = [...raw.budgets].sort((left, right) => left.crop_year - right.crop_year || left.commodity_id.localeCompare(right.commodity_id) || (left.operating_entity_id ?? '').localeCompare(right.operating_entity_id ?? '') || (left.enterprise_label ?? '').localeCompare(right.enterprise_label ?? '') || left.name.localeCompare(right.name) || left.id.localeCompare(right.id))
  193:     const cost_lines = [...raw.cost_lines].sort((left, right) => left.budget_id.localeCompare(right.budget_id) || left.sort_order - right.sort_order || left.id.localeCompare(right.id)).map(({ sort_order: _sortOrder, ...rest }) => rest)
  194:     const matrix_steps = [...raw.matrix_steps].sort((left, right) => left.budget_id.localeCompare(right.budget_id) || left.axis.localeCompare(right.axis) || left.sort_order - right.sort_order)
  195:     const allocations = [...raw.allocations].sort((left, right) => left.budget_id.localeCompare(right.budget_id) || left.crop_assignment_id.localeCompare(right.crop_assignment_id))
  196:     return { budgets, cost_lines, matrix_steps, allocations, fields }
  197:   }
  198:
  199:   async createBudget(value: CropBudget) {
  200:     const context = await this.dependencies.getOperationContext(); const farmId = await this.operationFarmId(context); const fields = await this.fields()
  201:     const normalized: CropBudget = { ...value, farm_id: farmId, copied_from_budget_id: null }
  202:     this.validateBudget(normalized, farmId, fields)
  203:     const { priceValues, yieldValues } = defaultMatrixValues(normalized)
  204:     const priceSteps: ProfitabilityMatrixStep[] = priceValues.map((amount, index) => ({ id: this.dependencies.createId(), budget_id: normalized.id, axis: 'price', value: amount, sort_order: index }))
  205:     const yieldSteps: ProfitabilityMatrixStep[] = yieldValues.map((amount, index) => ({ id: this.dependencies.createId(), budget_id: normalized.id, axis: 'yield', value: amount, sort_order: index }))
  206:     await this.createBudgetOperation(normalized, priceSteps, yieldSteps, context)
  207:   }
  208:   async createBudgetOperation(value: CropBudget, priceSteps: ProfitabilityMatrixStep[], yieldSteps: ProfitabilityMatrixStep[], context: FarmOperationContext) {
  209:     const farmId = await this.operationFarmId(context); const fields = await this.fields()
  210:     const normalized: CropBudget = normalizeBudgetDecimals({ ...value, farm_id: farmId, copied_from_budget_id: null })
  211:     this.validateBudget(normalized, farmId, fields)
  212:     const steps = [...priceSteps, ...yieldSteps].map((step) => normalizeMatrixStepDecimals({ ...step, budget_id: normalized.id }))
  213:     this.validateMatrix(steps)
  214:     const savedBudget = mapBudget(await this.dependencies.gateway.createBudgetWithMatrix({ farmId, budget: normalized, matrixSteps: steps, context }))
  215:     const savedSteps = steps
  216:     if (savedBudget.id !== normalized.id || savedBudget.farm_id !== farmId) fail('Farm Rx could not confirm this budget saved.')
  217:     return { budget: savedBudget, steps: savedSteps }
  218:   }
  219:
  220:   async saveBudget(value: CropBudget) { await this.saveBudgetOperation(value, await this.dependencies.getOperationContext()) }
  221:   async saveBudgetInsurance(budgetId: string, patch: InsuranceBudgetPatch, expectedUpdatedAt?: string | null) { await this.saveBudgetInsuranceOperation(budgetId, patch, expectedUpdatedAt, await this.dependencies.getOperationContext()) }
  222:   async saveBudgetInsuranceOperation(budgetId: string, patch: InsuranceBudgetPatch, expectedUpdatedAt: string | null | undefined, context: FarmOperationContext): Promise<CropBudget> {
  223:     insuranceColumns(patch)
  224:     const normalizedPatch = normalizeInsurancePatchDecimals(patch)
  225:     const farmId = await this.operationFarmId(context); const fields = await this.fields()
  226:     if (!uuid.test(budgetId)) fail('Farm Rx could not save this insurance detail.')
  227:     const current = (await this.loadRaw(farmId)).budgets.find((item) => item.id === budgetId)
  228:     await this.dependencies.verifyOperationContext(context)
  229:     if (!current) fail('That budget changed before its insurance details could be saved.')
  230:     const next = { ...(current as CropBudget), ...normalizedPatch }; this.validateBudget(next, farmId, fields)
  231:     const raw = await this.dependencies.gateway.patchBudgetInsurance(farmId, budgetId, normalizedPatch, expectedUpdatedAt ?? current!.updated_at, context)
  232:     await this.dependencies.verifyOperationContext(context)
  233:     const saved = mapBudget(raw)
  234:     if (saved.id !== budgetId || saved.farm_id !== farmId || Object.keys(normalizedPatch).some((key) => saved[key as keyof CropBudget] !== normalizedPatch[key as keyof InsuranceBudgetPatch])) fail('Farm Rx could not confirm the insurance save.')
  235:     return saved
  236:   }
  237:   async saveBudgetOperation(value: CropBudget, context: FarmOperationContext): Promise<CropBudget> {
  238:     const farmId = await this.operationFarmId(context); const fields = await this.fields()
  239:     const normalized: CropBudget = normalizeBudgetDecimals({ ...value, farm_id: farmId })
  240:     this.validateBudget(normalized, farmId, fields)
  241:     const raw = await this.loadRaw(farmId)
  242:     const existing = raw.budgets.find((item) => item.id === normalized.id)
  243:     if (existing && (existing.crop_year !== normalized.crop_year || existing.commodity_id !== normalized.commodity_id || existing.operating_entity_id !== normalized.operating_entity_id) && raw.allocations.some((item) => item.budget_id === normalized.id)) fail('Remove field allocations before changing this budget’s crop, year, or entity.')
  244:     const saved = mapBudget(await this.dependencies.gateway.upsertBudget(farmId, normalized, context))
  245:     this.validateBudget(saved, farmId, fields)
  246:     if (saved.id !== normalized.id || saved.farm_id !== farmId || saved.crop_year !== normalized.crop_year || saved.commodity_id !== normalized.commodity_id || saved.operating_entity_id !== normalized.operating_entity_id || saved.enterprise_label !== normalized.enterprise_label) fail('Farm Rx could not confirm this budget saved.')
  247:     return saved
  248:   }
  249:
  250:   async saveCostLine(value: BudgetCostLine) {
  251:     const context = await this.dependencies.getOperationContext(); const farmId = await this.operationFarmId(context)
  252:     const raw = await this.loadRaw(farmId)
  253:     if (!raw.budgets.some((item) => item.id === value.budget_id)) fail('That budget changed before this cost line could be saved. Refresh and try again.')
  254:     const existing = raw.cost_lines.find((line) => line.id === value.id)
  255:     if (existing && existing.source_kind !== undefined && existing.source_kind !== 'manual') fail(SOURCED_COST_LINE_EDIT_MESSAGE)
  256:     await this.saveCostLineOperation(manualCostLineWrite(mintCostLine(value, raw.cost_lines)), context)
  257:   }
  258:   async saveCostLineOperation(value: BudgetCostLineWrite, context: FarmOperationContext): Promise<BudgetCostLine> {
  259:     const farmId = await this.operationFarmId(context)
  260:     const raw = await this.loadRaw(farmId)
  261:     const existing = raw.cost_lines.find((line) => line.id === value.id)
  262:     if (existing && existing.source_kind !== undefined && existing.source_kind !== 'manual') fail(SOURCED_COST_LINE_EDIT_MESSAGE)
  263:     const normalized = normalizeCostLineDecimals(manualCostLineWrite(value))
  264:     if (!uuid.test(normalized.id) || !uuid.test(normalized.budget_id) || !normalized.name.trim() || normalized.amount_per_acre < 0 || !Number.isInteger(normalized.sort_order) || normalized.sort_order < 0) fail('Farm Rx could not save this cost line.')
  265:     const saved = mapCostLine(await this.dependencies.gateway.upsertCostLine(farmId, normalized, context))
  266:     if (saved.id !== normalized.id || saved.budget_id !== normalized.budget_id || saved.name !== normalized.name || saved.amount_per_acre !== normalized.amount_per_acre) fail('Farm Rx could not confirm this cost line saved.')
  267:     const { sort_order: _sortOrder, ...publicLine } = saved
  268:     return publicLine
  269:   }
  270:   async rawCostLines(): Promise<BudgetCostLineWrite[]> { const farmId = await this.dependencies.getFarmId(); return (await this.loadRaw(farmId)).cost_lines }
  271:
  272:   async deleteCostLine(costLineId: string) { await this.deleteCostLineOperation(costLineId, await this.dependencies.getOperationContext()) }
  273:   async deleteCostLineOperation(costLineId: string, context: FarmOperationContext): Promise<string> {
  274:     const farmId = await this.operationFarmId(context)
  275:     if (!uuid.test(costLineId)) fail('Farm Rx could not remove this cost line.')
  276:     const deletedId = await this.dependencies.gateway.deleteCostLine(farmId, costLineId, context)
  277:     if (typeof deletedId !== 'string' || deletedId !== costLineId) fail('Farm Rx could not confirm this cost line was removed.')
  278:     return deletedId as string
  279:   }
  280:
  281:   async replaceMatrixSteps(budgetId: string, steps: ProfitabilityMatrixStep[]) { const context = await this.dependencies.getOperationContext(); const raw = await this.loadRaw(await this.operationFarmId(context)); await this.replaceMatrixStepsOperation(budgetId, steps, raw.matrix_steps.filter((step) => step.budget_id === budgetId), context) }
  282:   async replaceMatrixStepsOperation(budgetId: string, steps: ProfitabilityMatrixStep[], expectedSteps: ProfitabilityMatrixStep[] | null | undefined, context: FarmOperationContext): Promise<ProfitabilityMatrixStep[]> {
  283:     const farmId = await this.operationFarmId(context)
  284:     if (!uuid.test(budgetId)) fail('Farm Rx could not save this matrix.')
  285:     const normalized = steps.map((step) => normalizeMatrixStepDecimals({ ...step, budget_id: budgetId }))
  286:     this.validateMatrix(normalized)
  287:     const savedAll = (await this.dependencies.gateway.replaceMatrixSteps({ farmId, budgetId, steps: normalized, expectedSteps, context })).map(mapMatrixStep)
  288:     const saved = savedAll.filter((step) => step.budget_id === budgetId)
  289:     this.validateMatrix(saved)
  290:     const key = (step: ProfitabilityMatrixStep) => `${step.id}|${step.axis}|${step.sort_order}|${step.value}`
  291:     const expected = normalized.map(key).sort(); const actual = saved.map(key).sort()
  292:     if (expected.length !== actual.length || expected.some((value, index) => value !== actual[index])) fail('Farm Rx could not confirm the matrix saved.')
  293:     return saved
  294:   }
  295:
  296:   async saveAllocation(value: BudgetFieldAllocation) { await this.saveAllocationOperation(value, await this.dependencies.getOperationContext()) }
  297:   async saveAllocationOperation(value: BudgetFieldAllocation, context: FarmOperationContext): Promise<BudgetFieldAllocation> {
  298:     const farmId = await this.operationFarmId(context); const fields = await this.fields(); const raw = await this.loadRaw(farmId)
  299:     const budgetRow = raw.budgets.find((item) => item.id === value.budget_id)
  300:     const assignmentRow = fields.crop_assignments.find((item) => item.id === value.crop_assignment_id && item.farm_id === farmId)
  301:     if (!budgetRow || !assignmentRow) fail('That field crop does not match this budget.')
  302:     const confirmedBudget = budgetRow as NonNullable<typeof budgetRow>
  303:     const assignment = assignmentRow as NonNullable<typeof assignmentRow>
  304:     if (assignment.crop_year !== confirmedBudget.crop_year || assignment.commodity_id !== confirmedBudget.commodity_id) fail('That field crop does not match this budget.')
  305:     const normalized = normalizeAllocationDecimals(value)
  306:     if (!uuid.test(normalized.id) || normalized.allocated_acres <= 0) fail('Farm Rx could not save this field allocation.')
  307:     if (normalized.allocated_acres > assignment.planted_acres) fail('Allocated acres cannot be more than planted acres.')
  308:     if (raw.allocations.some((item) => item.id !== normalized.id && item.budget_id === normalized.budget_id && item.crop_assignment_id === normalized.crop_assignment_id)) fail('That field is already allocated to this budget.')
  309:     const saved = mapAllocation(await this.dependencies.gateway.upsertAllocation(farmId, normalized, context))
  310:     if (saved.id !== normalized.id || saved.budget_id !== normalized.budget_id || saved.crop_assignment_id !== normalized.crop_assignment_id || saved.allocated_acres !== normalized.allocated_acres) fail('Farm Rx could not confirm this field allocation saved.')
  311:     return saved
  312:   }
  313:
  314:   async deleteAllocation(allocationId: string) { await this.deleteAllocationOperation(allocationId, await this.dependencies.getOperationContext()) }
  315:   async deleteAllocationOperation(allocationId: string, context: FarmOperationContext): Promise<string> {
  316:     const farmId = await this.operationFarmId(context)
  317:     if (!uuid.test(allocationId)) fail('Farm Rx could not remove this field allocation.')
  318:     const deletedId = await this.dependencies.gateway.deleteAllocation(farmId, allocationId, context)
  319:     if (typeof deletedId !== 'string' || deletedId !== allocationId) fail('Farm Rx could not confirm this field allocation was removed.')
  320:     return deletedId as string
  321:   }
  322:
  323:   async copyBudget(sourceBudgetId: string, copy: CropBudget) {
  324:     const context = await this.dependencies.getOperationContext(); const farmId = await this.operationFarmId(context)
  325:     const raw = await this.loadRaw(farmId)
  326:     const source = raw.budgets.find((item) => item.id === sourceBudgetId)
  327:     if (!source || copy.farm_id !== farmId) fail('Choose a budget from this farm to copy.')
  328:     const costLines: BudgetCostLineWrite[] = raw.cost_lines.filter((line) => line.budget_id === sourceBudgetId).map((line) => manualCostLineWrite({ ...structuredClone(line), id: this.dependencies.createId(), budget_id: copy.id }))
  329:     const matrixSteps: ProfitabilityMatrixStep[] = raw.matrix_steps.filter((step) => step.budget_id === sourceBudgetId).map((step) => ({ ...structuredClone(step), id: this.dependencies.createId(), budget_id: copy.id }))
  330:     await this.copyBudgetOperation(sourceBudgetId, { ...copy, copied_from_budget_id: sourceBudgetId }, costLines, matrixSteps, context)
  331:   }
  332:   async copyBudgetOperation(sourceBudgetId: string, value: CropBudget, costLines: BudgetCostLineWrite[], matrixSteps: ProfitabilityMatrixStep[], context: FarmOperationContext): Promise<CropBudget> {
  333:     const farmId = await this.operationFarmId(context); const fields = await this.fields()
  334:     const normalized: CropBudget = normalizeBudgetDecimals({ ...value, farm_id: farmId, copied_from_budget_id: sourceBudgetId })
  335:     this.validateBudget(normalized, farmId, fields)
  336:     if (!uuid.test(sourceBudgetId) || normalized.id === sourceBudgetId) fail('Farm Rx could not copy this budget.')
  337:     const normalizedLines = costLines.map((line) => normalizeCostLineDecimals(manualCostLineWrite(line)))
  338:     const normalizedSteps = matrixSteps.map(normalizeMatrixStepDecimals)
  339:     for (const line of normalizedLines) if (line.budget_id !== normalized.id) fail('Farm Rx could not copy this budget.')
  340:     for (const step of normalizedSteps) if (step.budget_id !== normalized.id) fail('Farm Rx could not copy this budget.')
  341:     this.validateMatrix(normalizedSteps)
  342:     const saved = mapBudget(await this.dependencies.gateway.copyBudget({ farmId, sourceId: sourceBudgetId, budget: normalized, costLines: normalizedLines, matrixSteps: normalizedSteps, context }))
  343:     if (saved.id !== normalized.id || saved.copied_from_budget_id !== sourceBudgetId || saved.farm_id !== farmId || saved.crop_year !== normalized.crop_year || saved.commodity_id !== normalized.commodity_id || saved.operating_entity_id !== normalized.operating_entity_id || saved.enterprise_label !== normalized.enterprise_label) fail('Farm Rx could not confirm this budget was copied.')
  344:     return saved
  345:   }
  346:
  347:   async getBreakeven(scope: PositionScope, _fields: FieldsData): Promise<number | null> {
  348:     const workspace = await this.getWorkspace()
  349:     const match = workspace.budgets.find((item) => item.farm_id === scope.farm_id && item.crop_year === scope.crop_year && item.commodity_id === scope.commodity_id && item.operating_entity_id === scope.operating_entity_id && item.enterprise_label === scope.enterprise_label)
  350:     if (!match) return null
