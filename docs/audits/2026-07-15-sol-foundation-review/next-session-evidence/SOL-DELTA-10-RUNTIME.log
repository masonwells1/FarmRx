   15: export interface PushDeliveryDatabase {
   16:   claimTargets(notificationId: string | null, limit: number, signal: AbortSignal): Promise<ClaimedPushTarget[]>
   17:   finishTarget(targetId: string, outcome: PushTargetOutcome, error: string | null, signal: AbortSignal): Promise<void>
