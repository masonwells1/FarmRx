 .alert-template:nth-child(2) { border-top-color: var(--amber); }.alert-template:nth-child(3) { border-top-color: var(--deep-green); }.alert-template:hover { background: var(--light-green); border-color: var(--deep-green); }.alert-template strong { font-family: var(--brand-font); font-size: 25px; }.alert-template span, .alert-rule span, .alert-rule small, .alert-empty { color: var(--matte-gray); font-size: 18px; }.alert-rule-form { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; padding: 20px; border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); background: var(--light-green); font-variant-numeric: tabular-nums; }.alert-rule-form > div:first-child, .alert-rule-form .alert-note, .alert-rule-form .form-error, .alert-rule-form .alert-form-actions { grid-column: 1 / -1; }.alert-rule-form h3, .alert-rule-form p { margin: 0; }.alert-rule-form h3 { font-size: 23px; }.alert-rule-form > div:first-child p { color: var(--matte-gray); }.alert-rule-form label, .alert-email-card label { display: grid; gap: 6px; color: var(--matte-gray); font-size: 18px; font-weight: 700; }.alert-rule-form input, .alert-rule-form select, .alert-email-card input { width: 100%; min-height: 48px; box-sizing: border-box; padding: 8px 10px; border: 2px solid var(--hairline); border-radius: 9px; background: var(--surface); color: var(--charcoal); font: inherit; font-size: 18px; font-variant-numeric: tabular-nums; }.alert-rule-form label small, .alert-email-card label small { color: var(--matte-gray); font-size: 18px; font-weight: 500; }.alert-fact { align-self: end; margin: 0; padding: 12px; border-left: 5px solid var(--crx-green); background: var(--surface); color: var(--charcoal); font-size: 18px; font-weight: 700; }.alert-form-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 14px; }.alert-rule-list { display: grid; padding: 0 20px; }.alert-rule { display: flex; align-items: center; justify-content: space-between; gap: 18px; padding: 18px 0; border-top: 1px solid var(--hairline); font-variant-numeric: tabular-nums; }.alert-rule > div:first-child { display: grid; gap: 5px; min-width: 0; }.alert-rule > div:first-child strong { font-size: 19px; }.alert-rule.paused { opacity: .62; }.alert-rule-actions { display: flex; flex-wrap: wrap; justify-content: end; gap: 8px; }.alert-rule-actions .text-action { min-height: 48px; }.alert-empty { margin: 0; padding: 20px 0; }.alert-email-card form { display: grid; gap: 14px; padding: 0 20px 20px; }.alert-email-card form > div { display: flex; align-items: center; flex-wrap: wrap; gap: 12px; }
 @media (max-width: 767px) { .alert-template-row, .alert-rule-form { grid-template-columns: 1fr; padding-right: 16px; padding-left: 16px; }.alert-template { min-height: 104px; }.alert-rule-form > div:first-child, .alert-rule-form .alert-note, .alert-rule-form .form-error, .alert-rule-form .alert-form-actions { grid-column: auto; }.alert-rule { align-items: start; flex-direction: column; }.alert-rule-actions { width: 100%; justify-content: start; }.alert-rule-actions .secondary-action { flex: 1 1 100%; }.alert-email-card form { padding-right: 16px; padding-left: 16px; }.alert-email-card form .primary-action { width: 100%; } }

 /* Chunk 7 profitability overview: crop cards + grouped expense categories. */
 .whole-farm-kpis { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; }
 .whole-farm-kpi { display: grid; gap: 10px; min-width: 0; min-height: 124px; align-content: center; padding: 18px; border: 1px solid var(--hairline); border-top: 6px solid var(--crx-green); border-radius: var(--radius); background: var(--surface); box-shadow: var(--shadow-card); font-variant-numeric: tabular-nums; }
 .whole-farm-kpi:nth-child(2) { border-top-color: var(--amber); }.whole-farm-kpi:nth-child(3) { border-top-color: var(--deep-green); }.whole-farm-kpi:nth-child(4) { border-top-color: var(--crx-green); }
 .whole-farm-kpi span { color: var(--matte-gray); font-size: 18px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; }.whole-farm-kpi strong { overflow-wrap: anywhere; color: var(--charcoal); font-family: var(--brand-font); font-size: 31px; line-height: 1; }.whole-farm-kpi.alert strong { color: var(--warn-red); }
 .overview-budgets { display: grid; gap: 16px; min-width: 0; }.overview-budgets-heading { display: flex; align-items: end; justify-content: space-between; gap: 16px; }.overview-budgets-heading h2 { margin: 2px 0 4px; }.overview-budgets-heading p { margin: 0; color: var(--matte-gray); }.overview-budgets-heading label { display: grid; flex: 0 0 180px; gap: 6px; color: var(--matte-gray); font-size: 18px; font-weight: 700; }.overview-budgets-heading select { min-height: 48px; padding: 8px 10px; border: 2px solid var(--hairline); border-radius: 9px; background: var(--surface); color: var(--charcoal); font: inherit; font-size: 18px; font-variant-numeric: tabular-nums; }
 .overview-budget-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; min-width: 0; }.overview-budget-card { display: grid; min-width: 0; overflow: hidden; border: 1px solid var(--hairline); border-top: 6px solid var(--crx-green); border-radius: var(--radius); background: var(--surface); box-shadow: var(--shadow-card); font-variant-numeric: tabular-nums; }.overview-budget-card:nth-child(3n+2) { border-top-color: var(--amber); }.overview-budget-card:nth-child(3n) { border-top-color: var(--deep-green); }
 .overview-budget-main { display: grid; gap: 16px; min-width: 0; padding: 20px; cursor: pointer; }.overview-budget-main:focus-visible { outline: 3px solid var(--amber); outline-offset: -3px; }.overview-budget-main header { display: grid; gap: 2px; }.overview-budget-main header span, .overview-cost-bars-title { color: var(--matte-gray); font-size: 18px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; }.overview-budget-main h3 { margin: 0; color: var(--charcoal); font-family: var(--brand-font); font-size: 25px; line-height: 1.05; }.overview-profit { display: grid; gap: 4px; }.overview-profit span { color: var(--matte-gray); font-size: 18px; font-weight: 700; }.overview-profit strong { color: var(--deep-green); font-family: var(--brand-font); font-size: 42px; line-height: 1; }.overview-profit.negative strong { color: var(--warn-red); }
 .overview-budget-metrics { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 8px; margin: 0; }.overview-budget-metrics div { min-width: 0; padding: 10px 0; border-top: 1px solid var(--hairline); }.overview-budget-metrics dt { color: var(--matte-gray); font-size: 18px; font-weight: 700; }.overview-budget-metrics dd { margin: 3px 0 0; color: var(--charcoal); font-size: 18px; font-weight: 800; overflow-wrap: anywhere; }.overview-cost-bars { display: grid; gap: 8px; }.overview-cost-bars p { margin: 0; color: var(--matte-gray); }.overview-cost-bar { display: grid; grid-template-columns: minmax(74px, .8fr) minmax(70px, 1fr) auto; gap: 8px; align-items: center; min-width: 0; }.overview-cost-bar > span, .overview-cost-bar strong { min-width: 0; font-size: 18px; overflow-wrap: anywhere; }.overview-cost-bar strong { text-align: right; white-space: nowrap; }.overview-cost-bar > div { height: 10px; overflow: hidden; border-radius: 999px; background: var(--cream-dark); }.overview-cost-bar i { display: block; height: 100%; border-radius: inherit; background: var(--deep-green); }.overview-budget-card footer { display: grid; gap: 10px; padding: 14px 20px 18px; border-top: 1px solid var(--hairline); background: var(--green-tint); }.overview-budget-card footer > span { color: var(--matte-gray); font-size: 18px; font-weight: 700; }.overview-view-budget { justify-self: start; min-height: 48px; padding: 0; border: 0; background: transparent; color: var(--deep-green); font: inherit; font-size: 18px; font-weight: 800; text-decoration: underline; cursor: pointer; }
 .overview-budget-card.selected { border-color: var(--deep-green); box-shadow: 0 0 0 2px var(--deep-green), var(--shadow-card); }
 .overview-budget-metrics dd em { display: block; margin-top: 2px; color: var(--matte-gray); font-size: 18px; font-style: normal; font-weight: 700; font-variant-numeric: tabular-nums; }
 .cost-category-group .cost-category-subtotal th, .cost-category-group .cost-category-subtotal td { padding: 8px 12px; border-top: 2px solid var(--hairline); background: var(--green-tint); color: var(--charcoal); font-size: 18px; font-variant-numeric: tabular-nums; }.cost-category-group .cost-category-subtotal th { text-align: left; text-transform: none; }.cost-category-subtotal th span { font-weight: 800; }.cost-category-subtotal th small { display: block; margin-top: 2px; color: var(--matte-gray); font-size: 18px; font-weight: 700; text-transform: none; }.cost-category-subtotal td { font-weight: 800; }.cost-category-subtotal td:last-child { padding: 4px 8px; text-align: right; }.cost-category-toggle { display: inline-grid; width: 48px; min-height: 48px; place-items: center; border: 0; border-radius: 9px; background: transparent; color: var(--deep-green); font: inherit; font-size: 26px; font-weight: 800; cursor: pointer; }.cost-category-toggle:hover, .cost-category-toggle:focus-visible { background: var(--light-green); }.cost-category-group tr:nth-child(even) td { background: var(--cream); }
 @media (max-width: 767px) { .whole-farm-kpis { grid-template-columns: 1fr; }.whole-farm-kpi { min-height: 104px; }.overview-budgets-heading { align-items: stretch; flex-direction: column; }.overview-budgets-heading label { flex-basis: auto; width: 100%; }.overview-budget-grid { grid-template-columns: minmax(0, 1fr); }.overview-budget-metrics { grid-template-columns: 1fr; }.overview-budget-main, .overview-budget-card footer { padding-right: 16px; padding-left: 16px; }.overview-cost-bar { grid-template-columns: minmax(82px, 1fr) minmax(70px, 1fr) auto; } }
  .save-receipt { display: inline-block; min-height: 18px; margin: 4px 0; font-size: 18px; line-height: 1.25; color: var(--ink-muted); }
