   5: create or replace function public.record_marketing_alert_transition(
   6:   p_farm_id uuid,
   7:   p_rule_id uuid,
   8:   p_condition_true boolean
   9: )
  10: returns jsonb
  11: language plpgsql
  12: security definer
  13: set search_path = public, pg_temp
  14: as $$
  15: declare
  16:   v_previous boolean;
  17:   v_fired boolean := false;
  18: begin
  19:   perform public.assert_current_farm_access_epoch(p_farm_id);
  20:   if not public.can_edit_farm(p_farm_id) then
  21:     raise exception 'you do not have permission to edit this farm';
  22:   end if;
  23:   if not exists (
  24:     select 1 from public.marketing_alert_rules rule
  25:     where rule.id = p_rule_id and rule.farm_id = p_farm_id
  26:   ) then
  27:     raise exception 'alert rule not found for this farm';
  28:   end if;
  29:
  30:   perform pg_advisory_xact_lock(hashtextextended(p_rule_id::text, 0));
  31:   select state.is_condition_true into v_previous
  32:   from public.alert_rule_states state
  33:   where state.rule_id = p_rule_id
  34:   for update;
  35:
  36:   if not found then
  37:     v_previous := false;
  38:     insert into public.alert_rule_states (rule_id, is_condition_true, fired_at)
  39:     values (p_rule_id, p_condition_true, case when p_condition_true then now() else null end);
  40:     v_fired := p_condition_true;
  41:   else
  42:     v_fired := not v_previous and p_condition_true;
  43:     update public.alert_rule_states
  44:     set is_condition_true = p_condition_true,
  45:         fired_at = case when v_fired then now() else fired_at end,
  46:         updated_at = now()
  47:     where rule_id = p_rule_id;
  48:   end if;
  49:
  50:   return jsonb_build_object('fired', v_fired);
  51: end;
  52: $$;
