379: create function public.get_push_delivery_health(p_notification_id uuid default null)
380: returns jsonb
381: language plpgsql
382: stable
383: security definer
384: set search_path = pg_catalog
385: as $$
386: declare
387:   v_terminal integer;
388:   v_retryable integer;
389: begin
390:   if not public.request_uses_service_role() then raise exception 'server delivery only'; end if;
391:   select
392:     count(*) filter(where t.status in ('sending','failed') and t.attempts>=10),
393:     count(*) filter(where t.status in ('pending','sending','failed') and t.attempts<10)
394:   into v_terminal,v_retryable
395:   from public.push_delivery_targets t
396:   join public.push_deliveries d on d.id=t.delivery_id
397:   where p_notification_id is null or d.notification_id=p_notification_id;
398:   return pg_catalog.jsonb_build_object('terminal_failed_targets',v_terminal,'retryable_targets',v_retryable);
399: end;
400: $$;
401:
402: -- The target protocol is authoritative after this migration. Safe release order:
403: -- pause scheduler/send-push entry points; wait for old invocations to drain;
404: -- run the preflight above and adjudicate any rejected legacy parents; deploy the
405: -- new Edge Function (its missing RPC fails before provider I/O); apply this
406: -- migration atomically; then resume the scheduler only after health proof.
407: create or replace function public.claim_push_deliveries(p_limit integer default 25)
408: returns table(id uuid,notification_id uuid,attempts integer)
409: language plpgsql security definer set search_path=pg_catalog as $$
410: begin
411:   if not public.request_uses_service_role() then raise exception 'server delivery only'; end if;
412:   raise exception 'legacy push protocol retired';
413: end;
414: $$;
