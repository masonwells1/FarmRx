177: -- Observations are monotonic per field/local day. The first complete good
178: -- observation is eligible to fire; an older or duplicate observation is never
179: -- allowed to overwrite newer state.
180: create or replace function public.record_scheduled_spray_window(
181:   p_farm_id uuid,p_field_id uuid,p_local_date date,p_is_good boolean,p_observed_at timestamptz,p_observation jsonb
182: )
183: returns jsonb
184: language plpgsql
185: security definer
186: set search_path = pg_catalog
187: as $$
188: declare
189:   v_owner uuid;
190:   v_field_name text;
191:   v_previous boolean := false;
192:   v_previous_observed_at timestamptz;
193:   v_exists boolean := false;
194:   v_notification uuid;
195: begin
196:   if not public.request_uses_service_role() then raise exception 'server scheduler only'; end if;
197:   if p_observed_at is null or p_observation is null or pg_catalog.jsonb_typeof(p_observation)<>'object' then raise exception 'complete spray observation required'; end if;
198:   perform pg_catalog.pg_advisory_xact_lock(pg_catalog.hashtext(p_farm_id::text),pg_catalog.hashtext('spray:'||p_field_id::text||':'||p_local_date::text));
199:   select name into v_field_name from public.fields where id=p_field_id and farm_id=p_farm_id and is_active;
200:   if not found then raise exception 'active field not found for this farm'; end if;
201:
202:   select is_good,observed_at into v_previous,v_previous_observed_at
203:   from public.spray_window_states where field_id=p_field_id and local_date=p_local_date for update;
204:   v_exists := found;
205:   if v_exists and p_observed_at<=v_previous_observed_at then
206:     return pg_catalog.jsonb_build_object('fired',false,'ignored','stale_observation','observed_at',v_previous_observed_at);
207:   end if;
208:
209:   if v_exists then
210:     update public.spray_window_states set is_good=p_is_good,observed_at=p_observed_at,observation=p_observation,updated_at=now()
211:     where field_id=p_field_id and local_date=p_local_date;
212:   else
213:     insert into public.spray_window_states(farm_id,field_id,local_date,is_good,observed_at,observation)
214:     values(p_farm_id,p_field_id,p_local_date,p_is_good,p_observed_at,p_observation);
215:   end if;
216:
217:   if (not v_exists or not v_previous) and p_is_good then
218:     select user_id into v_owner from public.farm_memberships
219:     where farm_id=p_farm_id and role='owner' and status='active' order by user_id limit 1;
220:     if v_owner is not null then
221:       insert into public.notifications(farm_id,user_id,category,title,body,link,dedupe_key,created_by)
222:       values(p_farm_id,v_owner,'spray',left('Spray window is good on '||v_field_name,160),'Current field conditions are good for spraying today. Always follow the product label and applicator judgment.','/weather','spray:'||p_field_id||':'||p_local_date,v_owner)
223:       on conflict(farm_id,user_id,dedupe_key) where dedupe_key is not null do nothing returning id into v_notification;
224:     end if;
225:   end if;
226:   return pg_catalog.jsonb_build_object('fired',v_notification is not null,'notification_id',v_notification,'initialized',not v_exists);
227: end;
228: $$;
