   14: /** The email provider is an irreversible boundary. Callers must put every
   15:  * recipient/config read before this helper so revocation gets one final check
   16:  * immediately before the provider request. */
   17: export async function runWithRetainedExpectedOwnerAccess<T>(retainsAccess: () => Promise<boolean>, providerRequest: () => Promise<T>): Promise<{ allowed: false } | { allowed: true; value: T }> {
   18:   if (!await retainsAccess()) return { allowed: false }
   19:   return { allowed: true, value: await providerRequest() }
