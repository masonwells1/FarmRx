===== supabase/migrations/0038_modern_postgrest_service_role_claims.sql =====
--- 1-140 ---
    1: -- Forward repair for server-owned RPC authorization under modern PostgREST.
    2: -- Modern JSON claims are authoritative when present. The legacy per-claim GUC
    3: -- is consulted only when request.jwt.claims is absent, so a conflicting legacy
    4: -- value cannot override an authenticated or anonymous modern request.
    5:
    6: create function public.request_uses_service_role()
    7: returns boolean
    8: language plpgsql
    9: stable
   10: security invoker
   11: set search_path = pg_catalog, pg_temp
   12: as $$
   13: declare
   14:   v_claims_text text := nullif(current_setting('request.jwt.claims', true), '');
   15:   v_claims jsonb;
   16: begin
   17:   if v_claims_text is not null then
   18:     begin
   19:       v_claims := v_claims_text::jsonb;
   20:     exception
   21:       when invalid_text_representation then return false;
   22:     end;
   23:     return coalesce(v_claims ->> 'role' = 'service_role', false);
   24:   end if;
   25:
   26:   return coalesce(
   27:     nullif(current_setting('request.jwt.claim.role', true), '') = 'service_role',
   28:     false
   29:   );
   30: end;
   31: $$;
