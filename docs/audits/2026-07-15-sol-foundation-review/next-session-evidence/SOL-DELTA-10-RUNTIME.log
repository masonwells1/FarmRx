  151:   writeFence(storage, scope, { version: 2, generation, token: nextToken(), serverEpoch: authoritativeEpoch, revoked: false, changedAt })
  152:   return generation
  153: }
  154:
  155: /** Upgrade a previously stored access snapshot without letting a cached tab
  156:  * undo a revocation. Only an entirely absent pre-upgrade fence is initialized;
  157:  * partial, corrupt, or revoked state remains blocked until a live access check. */
  158: export function ensureStoredFarmGrant(storage: StorageLike, scope: FarmRevocationScope): number {
  159:   const snapshot = captureFarmRevocationFence(storage, scope)
  160:   return snapshot.generation
  161: }
  162:
  163: /** Repository compatibility for isolated tests and pre-access bootstrap only.
  164:  * In the browser, an existing access snapshot with missing fence metadata is a
  165:  * known farm and therefore fails closed instead of being silently re-created. */
  166: export function ensureQueueFarmGrant(storage: StorageLike, scope: FarmRevocationScope): number {
  167:   const { fence, ledger } = readState(storage, scope)
  168:   if (!fence && !ledger) {
  169:     if (browserStorage(storage)) throw new Error(blocked)
  170:     return resetFarmGrantFromLive(storage, scope, 1)
  171:   }
  172:   return captureFarmRevocationFence(storage, scope).generation
  173: }
