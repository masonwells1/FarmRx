 .bins-card { border-right: 1px solid var(--hairline); }
 .bin-list { padding: 0 20px 6px; }
 .bin-row { align-items: center; padding: 14px 0; border-top: 1px solid var(--hairline); }
 .bin-row > div:first-child { display: grid; gap: 2px; }
 .bin-row > div:first-child span { color: var(--matte-gray); font-size: 18px; }
 .commodity-badge { display: inline-flex; padding: 4px 8px; border-radius: 99px; background: #eef0ef; color: var(--matte-gray); font-size: 18px; font-weight: 700; }
 .commodity-badge.ip { background: #fff2d9; color: #8a5b05; }
 .bin-balance { display: grid; gap: 2px; text-align: right; }
 .bin-balance span { color: var(--matte-gray); font-size: 18px; }
 .bin-balance strong { color: var(--charcoal); }
 .bin-card { display: grid; gap: 12px; padding: 16px 0; border-top: 1px solid var(--hairline); }
 .bin-card-meta { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
 .moisture-reading, .moisture-flag { min-height: 32px; display: inline-flex; align-items: center; padding: 4px 8px; border-radius: 8px; font-weight: 700; }
 .moisture-reading { background: #eef0ef; color: var(--matte-gray); }
 .moisture-flag, .bin-warning { color: var(--warn-red); background: var(--warn-bg); }
 .bin-warning { margin: 0; padding: 9px 10px; border-left: 4px solid var(--warn-red); border-radius: 6px; font-weight: 600; }
 .bin-fill { display: grid; gap: 7px; }
 .bin-fill > div { display: flex; justify-content: space-between; gap: 8px; color: var(--matte-gray); }
 .bin-fill > div strong { color: var(--charcoal); font-size: 20px; }
 .bin-fill > span { display: block; min-height: 12px; max-width: 100%; border-radius: 99px; background: var(--crx-green); }
 .bin-fill::after { content: ''; display: block; height: 12px; margin-top: -19px; border-radius: 99px; background: #e3e6e4; z-index: 0; }
 .bin-fill > span { z-index: 1; }
 .bin-ledger { padding-top: 12px; border-top: 1px solid var(--hairline); }
 .bin-ledger summary { min-height: 48px; display: flex; align-items: center; color: var(--deep-green); font-weight: 700; cursor: pointer; }
 .bin-ledger > p { margin: 0 0 12px; color: var(--matte-gray); }
 .bin-form, .movement-form { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; padding: 16px 20px; border-top: 1px solid var(--hairline); background: var(--light-green); }
 .bin-form h3, .bin-form-fact, .bin-form > div, .movement-form .movement-note, .movement-form .form-error { grid-column: 1 / -1; }
 .bin-form label, .movement-form label { display: grid; gap: 4px; color: var(--matte-gray); font-weight: 700; }
 .bin-form input, .bin-form select, .movement-form input, .movement-form select { width: 100%; min-height: 48px; padding: 9px 10px; border: 2px solid var(--hairline); border-radius: 9px; background: var(--surface); color: var(--charcoal); }
 .bin-form-fact { margin: 0; color: var(--matte-gray); }
 .movement-form { grid-template-columns: repeat(4, minmax(0, 1fr)); padding: 12px 0; background: transparent; }
 .movement-list { display: grid; gap: 0; }
 .movement-list > div { display: grid; gap: 2px; padding: 11px 0; border-top: 1px solid var(--hairline); }
 .movement-list span, .movement-list small { color: var(--matte-gray); }
 .movement-in { color: var(--deep-green); }
 .movement-out { color: var(--warn-red); }
 .basis-entry { display: grid; grid-template-columns: 1.2fr 1fr .7fr auto; gap: 8px; padding: 0 20px 16px; }
 .basis-entry .secondary-action { white-space: nowrap; }
 .basis-list { padding: 0 20px 12px; }
 .basis-list > div { display: grid; grid-template-columns: 1fr auto auto; gap: 10px; align-items: center; padding: 11px 0; border-top: 1px solid var(--hairline); }
 .basis-list span, .basis-list small { color: var(--matte-gray); font-size: 18px; }
 .basis-list strong { color: var(--deep-green); }
 .compliance-note { padding: 18px 20px; border-left: 5px solid var(--amber); border-radius: 8px; background: #fffaf0; color: #604a22; }
 .compliance-note strong { display: block; margin-bottom: 2px; }
 .target-modal-backdrop { position: fixed; z-index: 20; inset: 0; display: grid; place-items: center; padding: 20px; background: rgb(23 81 58 / 42%); }
 .target-modal { width: min(100%, 480px); display: grid; gap: 17px; padding: 24px; border-radius: var(--radius); background: var(--surface); box-shadow: 0 16px 50px rgb(0 0 0 / 25%); }
 .target-modal label { display: grid; gap: 6px; color: var(--matte-gray); font-weight: 700; }
 .target-modal label small { color: var(--matte-gray); font-size: 18px; font-weight: 500; }

