  60: async function loadServerEpochs(userId: string, farms: Farm[]): Promise<Record<string, number>> {
  61:   await requireCurrentSession(userId)
  62:   const { data, error } = await supabase.rpc('get_current_farm_access_epochs')
  63:   if (error || !Array.isArray(data)) throw error ?? new Error('Farm access versions were unavailable.')
  64:   const epochs: Record<string, number> = {}
  65:   for (const value of data as unknown[]) {
  66:     if (!value || typeof value !== 'object' || Array.isArray(value)) throw new Error('Farm access versions were malformed.')
  67:     const row = value as { farm_id?: unknown; access_epoch?: unknown }
  68:     const epoch = typeof row.access_epoch === 'string' ? Number(row.access_epoch) : row.access_epoch
