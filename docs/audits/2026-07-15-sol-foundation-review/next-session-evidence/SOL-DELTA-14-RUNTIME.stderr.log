 114: create function public.delete_push_subscription(
 115:   p_farm_id uuid,
 116:   p_endpoint text
 117: )
 118: returns jsonb
 119: language plpgsql
 120: security definer
 121: set search_path = public, pg_temp
 122: as $$
 123: declare
 124:   v_caller uuid := auth.uid();
 125:   v_deleted_count integer := 0;
 126: begin
 127:   perform public.assert_current_farm_access_epoch(p_farm_id);
 128:   if p_endpoint is null or btrim(p_endpoint) = '' then
 129:     raise exception 'endpoint is required';
 130:   end if;
 131:
 132:   delete from public.push_subscriptions subscription
 133:   where subscription.endpoint = p_endpoint
 134:     and subscription.user_id = v_caller;
 135:
 136:   get diagnostics v_deleted_count = row_count;
 137:   return jsonb_build_object('deleted_count', v_deleted_count);
 138: end;
 139: $$;
 140:
 141: -- Browser writes must use the farm- and access-epoch-bound RPCs above. The
 142: -- original reminders migration exposed direct table DML with user-only RLS;
 143: -- because this device table has no farm_id, that path cannot enforce the
 144: -- captured farm generation and would bypass the 0041 fence.
 145: revoke insert, update, delete on table public.push_subscriptions from public, anon, authenticated;
 146: drop policy if exists push_subscriptions_insert on public.push_subscriptions;
 147: drop policy if exists push_subscriptions_update on public.push_subscriptions;
 148: drop policy if exists push_subscriptions_delete on public.push_subscriptions;
 149:
 150: -- Retire the unfenced browser signatures while preserving the migration
 151: -- history that may already exist in deployed databases.
 152: revoke all on function public.save_push_subscription(text, text, text, text)
 153: from public, anon, authenticated, service_role;
 154: revoke all on function public.delete_push_subscription(text)
 155: from public, anon, authenticated, service_role;
 156:
 157: revoke all on function public.record_marketing_alert_transition(uuid, uuid, boolean),
 158:   public.save_push_subscription(uuid, text, text, text, text),
 159:   public.delete_push_subscription(uuid, text)
 160: from public, anon, authenticated, service_role;
 161:
 162: grant execute on function public.record_marketing_alert_transition(uuid, uuid, boolean),
 163:   public.save_push_subscription(uuid, text, text, text, text),
 164:   public.delete_push_subscription(uuid, text)
 165: to authenticated;
