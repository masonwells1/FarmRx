  13:     // caller-provided spelling.
  14:     if (!canonical.startsWith('/') || canonical.startsWith('//') || unsafeCharacters.test(canonical)) return fallback
  15:     if (new URL(canonical, origin).origin !== origin) return fallback
  16:     return canonical
  17:   } catch { return fallback }
  18: }
