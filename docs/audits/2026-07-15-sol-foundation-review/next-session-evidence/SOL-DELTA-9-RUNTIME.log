   48: function finiteNumber(value: unknown, label: string) {
   49:   if (typeof value !== 'number' || !Number.isFinite(value)) throw new Error(`${label} is missing or non-finite`)
   50:   return value
   51: }
   52:
   53: function localTimeMilliseconds(value: string) {
