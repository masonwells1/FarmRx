  408: returns table(id uuid,notification_id uuid,attempts integer)
  409: language plpgsql security definer set search_path=pg_catalog as $$
  410: begin
  411:   if not public.request_uses_service_role() then raise exception 'server delivery only'; end if;
  412:   raise exception 'legacy push protocol retired';
  413: end;
  414: $$;
  415:
  416: create or replace function public.finish_push_delivery(p_delivery_id uuid,p_sent boolean,p_error text default null)
  417: returns jsonb language plpgsql security definer set search_path=pg_catalog as $$
  418: begin
  419:   if not public.request_uses_service_role() then raise exception 'server delivery only'; end if;
  420:   raise exception 'legacy push protocol retired';
  421: end;
  422: $$;
