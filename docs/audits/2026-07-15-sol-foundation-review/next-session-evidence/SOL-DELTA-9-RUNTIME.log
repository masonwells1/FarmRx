    5: -- One notification has one durable delivery record. This includes notifications
    6: -- created by older features after this migration is applied.
    7: create table public.push_deliveries (
    8:   id uuid primary key default gen_random_uuid(),
    9:   notification_id uuid not null references public.notifications(id) on delete cascade,
   10:   status text not null default 'pending' check (status in ('pending','sent','failed')),
   11:   attempts integer not null default 0 check (attempts >= 0),
   12:   claimed_at timestamptz,
   13:   sent_at timestamptz,
   14:   last_error text,
   15:   created_at timestamptz not null default now(),
   16:   updated_at timestamptz not null default now(),
   17:   unique (notification_id)
   18: );
   19: create index push_deliveries_claim_idx on public.push_deliveries(status, claimed_at, created_at);
   20: alter table public.push_deliveries enable row level security;
   21: revoke all on public.push_deliveries from public, anon, authenticated;
   22:
   23: create function public.enqueue_push_delivery()
   24: returns trigger language plpgsql security definer set search_path=public,pg_temp as $$
   25: begin
   26:   insert into public.push_deliveries(notification_id) values (new.id)
   27:   on conflict (notification_id) do nothing;
   28:   return new;
   29: end $$;
   30: create trigger notifications_enqueue_push_delivery
   31: after insert on public.notifications for each row execute function public.enqueue_push_delivery();
