   59:   if (!Number.isFinite(now.getTime())) throw new Error('scheduler clock is invalid')
   60:   const nowIso = now.toISOString()
   61:   const runController = new AbortController()
   62:   const schedulerDeadlineMs = Math.max(1, Math.min(Math.trunc(dependencies.schedulerDeadlineMs ?? 50_000), 55_000))
   63:   const runTimer = setTimeout(() => runController.abort(new DOMException('Scheduler deadline reached', 'TimeoutError')), schedulerDeadlineMs)
   64:   try {
   65:   const sweep = await dependencies.database.runAlertSweep(nowIso, runController.signal)
   66:   if (runController.signal.aborted) throw new DOMException('Scheduler deadline reached', 'TimeoutError')
   67:   const fields = await dependencies.database.listWeatherFields(runController.signal)
   68:   if (runController.signal.aborted) throw new DOMException('Scheduler deadline reached', 'TimeoutError')
   69:   let weatherChecked = 0
   70:   let sprayFired = 0
   71:   const failures: Array<ScheduledAlertRunResult['weatherFailureFields'][number] & { index: number }> = []
   72:   const settled = fields.map(() => false)
   73:   const controller = new AbortController()
