   92: create or replace function public.run_scheduled_alert_sweep(p_now timestamptz default now())
   93: returns jsonb language plpgsql security definer set search_path=public,pg_temp as $$
   94: declare
   95:   v_farm public.farms%rowtype;
   96:   v_rule public.marketing_alert_rules%rowtype;
   97:   v_owner uuid;
   98:   v_local_date date;
   99:   v_condition boolean;
  100:   v_previous boolean;
  101:   v_price numeric;
  102:   v_bid_date date;
  103:   v_production numeric;
  104:   v_contracts numeric;
  105:   v_pct numeric;
  106:   v_notification_id uuid;
  107:   v_created integer:=0;
  108:   v_program_created integer:=0;
  109:   v_program_result jsonb;
  110:   v_ids jsonb:='[]'::jsonb;
  111:   v_title text;
  112:   v_body text;
  113: begin
  114:   if not public.request_uses_service_role() then raise exception 'server scheduler only'; end if;
  115:   if not pg_try_advisory_xact_lock(hashtext('farm-rx-scheduled-alert-sweep')) then return jsonb_build_object('skipped','already_running'); end if;
  116:   for v_farm in select * from public.farms order by id loop
  117:     v_local_date := (p_now at time zone v_farm.time_zone)::date;
  118:     v_program_result := public.generate_due_program_notifications(v_farm.id,v_local_date);
  119:     v_program_created := v_program_created + coalesce((v_program_result->>'created_count')::integer,0);
  120:     select user_id into v_owner from public.farm_memberships where farm_id=v_farm.id and role='owner' and status='active' order by user_id limit 1;
  121:     if v_owner is null then continue; end if;
  122:     for v_rule in select * from public.marketing_alert_rules where farm_id=v_farm.id and active order by id loop
  123:       v_condition:=false; v_price:=null; v_bid_date:=null; v_pct:=null; v_title:='Farm Rx marketing reminder'; v_body:=coalesce(v_rule.message,'A saved grain item needs your review.');
  124:       if v_rule.rule_type='price_target' then
  125:         select b.cash_price,b.bid_date into v_price,v_bid_date from public.cash_bids b
  126:         where b.farm_id=v_farm.id and b.commodity_id=v_rule.commodity_id and b.cash_price is not null
  127:           and b.bid_date between v_local_date-2 and v_local_date
  128:         order by b.bid_date desc,b.updated_at desc,b.id desc limit 1;
  129:         v_condition:=v_price is not null and ((v_rule.direction='at_or_above' and v_price>=v_rule.threshold) or (v_rule.direction='at_or_below' and v_price<=v_rule.threshold));
  130:         v_title:='Farm Rx price target reached';
  131:         if v_condition then v_body:=v_rule.crop_year||' '||v_rule.commodity_id||' cash price is $'||trim(to_char(v_price,'FM999999990.00'))||' from the '||v_bid_date||' bid.'; end if;
  132:       elsif v_rule.rule_type='pct_marketed_goal' then
  133:         select coalesce(sum(case when pe.drives_math='actual' and pe.actual_bushels is not null then pe.actual_bushels else pe.expected_bushels end),0) into v_production
  134:         from public.production_estimates pe where pe.farm_id=v_farm.id and pe.crop_year=v_rule.crop_year and pe.commodity_id=v_rule.commodity_id
  135:           and pe.operating_entity_id is not distinct from v_rule.operating_entity_id and pe.enterprise_label is not distinct from v_rule.enterprise_label;
  136:         select coalesce(sum(gc.bushels),0) into v_contracts from public.grain_contracts gc
  137:         where gc.farm_id=v_farm.id and gc.crop_year=v_rule.crop_year and gc.commodity_id=v_rule.commodity_id
  138:           and gc.operating_entity_id is not distinct from v_rule.operating_entity_id and gc.enterprise_label is not distinct from v_rule.enterprise_label;
  139:         v_pct:=case when v_production>0 then v_contracts/v_production*100 else null end;
  140:         v_condition:=v_pct is not null and v_pct<v_rule.threshold;
  141:         v_title:='Farm Rx marketed goal reminder';
  142:         if v_condition then v_body:=v_rule.crop_year||' '||v_rule.commodity_id||' is '||trim(to_char(v_pct,'FM990.0'))||'% marketed; your goal is '||trim(to_char(v_rule.threshold,'FM990.0'))||'%.'; end if;
  143:       elsif v_rule.rule_type='deadline' then
  144:         v_condition:=v_rule.remind_on between v_local_date and v_local_date+7;
  145:         v_title:='Farm Rx marketing deadline';
  146:         if v_condition then v_body:=v_rule.crop_year||' '||v_rule.commodity_id||' reminder is due '||v_rule.remind_on||'.'; end if;
  147:       end if;
  148:
  149:       perform pg_advisory_xact_lock(hashtextextended(v_rule.id::text,0));
  150:       insert into public.alert_rule_states(rule_id,is_condition_true) values(v_rule.id,false) on conflict(rule_id) do nothing;
  151:       select is_condition_true into v_previous from public.alert_rule_states where rule_id=v_rule.id for update;
  152:       v_notification_id:=null;
  153:       if not v_previous and v_condition then
  154:         insert into public.notifications(farm_id,user_id,category,title,body,link,dedupe_key,created_by)
  155:         values(v_farm.id,v_owner,'general',left(v_title,160),left(v_body,500),'/grain','marketing-rule:'||v_rule.id||':'||v_local_date,v_owner)
  156:         on conflict(farm_id,user_id,dedupe_key) where dedupe_key is not null do nothing returning id into v_notification_id;
  157:         if v_notification_id is not null then v_created:=v_created+1; v_ids:=v_ids||to_jsonb(v_notification_id); update public.marketing_alert_rules set last_triggered_at=p_now where id=v_rule.id and farm_id=v_farm.id; end if;
  158:       end if;
  159:       update public.alert_rule_states set is_condition_true=v_condition,fired_at=case when not v_previous and v_condition then p_now else fired_at end,updated_at=p_now where rule_id=v_rule.id;
  160:     end loop;
  161:   end loop;
  162:   return jsonb_build_object('marketing_created',v_created,'program_created',v_program_created,'notification_ids',v_ids);
  163: end $$;
