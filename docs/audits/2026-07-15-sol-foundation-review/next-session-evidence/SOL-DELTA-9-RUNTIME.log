   43: create function public.claim_push_deliveries(p_limit integer default 25)
   44: returns table(id uuid, notification_id uuid, attempts integer)
   45: language plpgsql security definer set search_path=public,pg_temp as $$
   46: begin
   47:   if coalesce(current_setting('request.jwt.claim.role',true),'') <> 'service_role' then raise exception 'server delivery only'; end if;
   48:   return query
   49:   with claimed as (
   50:     select d.id from public.push_deliveries d
   51:     where ((d.status='pending' and (d.claimed_at is null or d.claimed_at < now()-interval '5 minutes'))
   52:         or (d.status='failed' and d.claimed_at < now()-interval '5 minutes'))
   53:       and d.attempts < 10
   54:     order by d.created_at, d.id for update skip locked limit greatest(1, least(coalesce(p_limit,25),100))
   55:   )
   56:   update public.push_deliveries d set status='pending', attempts=d.attempts+1, claimed_at=now(), updated_at=now()
   57:   from claimed where d.id=claimed.id returning d.id,d.notification_id,d.attempts;
   58: end $$;
