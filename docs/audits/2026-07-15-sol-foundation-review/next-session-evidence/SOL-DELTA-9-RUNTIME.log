   57:   return parsed
   58: }
   59:
   60: function inRange(value: number, minimum: number, maximum: number, label: string) {
   61:   if (value < minimum || value > maximum) throw new Error(`${label} is outside the provider domain`)
   62:   return value
   63: }
   64:
   65: function readPoint(source: Record<string, unknown>, time: string, probability: unknown, label: string): ScheduledWeatherPoint {
   66:   const point = { time } as ScheduledWeatherPoint
   67:   for (const key of pointKeys) point[key] = finiteNumber(source[key], `${label}.${key}`)
   68:   point.precipitation_probability = finiteNumber(probability, `${label}.precipitation_probability`)
   69:   inRange(point.temperature_2m, -150, 150, `${label}.temperature_2m`)
   70:   inRange(point.relative_humidity_2m, 0, 100, `${label}.relative_humidity_2m`)
   71:   inRange(point.precipitation, 0, 100, `${label}.precipitation`)
   72:   inRange(point.rain, 0, 100, `${label}.rain`)
   73:   if (!Number.isInteger(point.weather_code) || point.weather_code < 0 || point.weather_code > 99) throw new Error(`${label}.weather_code is outside the provider domain`)
   74:   inRange(point.wind_speed_10m, 0, 300, `${label}.wind_speed_10m`)
   75:   inRange(point.wind_gusts_10m, 0, 300, `${label}.wind_gusts_10m`)
   76:   inRange(point.precipitation_probability, 0, 100, `${label}.precipitation_probability`)
   77:   return point
   78: }
