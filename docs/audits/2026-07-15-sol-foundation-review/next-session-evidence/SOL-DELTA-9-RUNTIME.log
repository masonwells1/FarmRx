  219:     where farm_id=p_farm_id and role='owner' and status='active' order by user_id limit 1;
  220:     if v_owner is not null then
  221:       insert into public.notifications(farm_id,user_id,category,title,body,link,dedupe_key,created_by)
  222:       values(p_farm_id,v_owner,'spray',left('Spray window is good on '||v_field_name,160),'Current field conditions are good for spraying today. Always follow the product label and applicator judgment.','/weather','spray:'||p_field_id||':'||p_local_date,v_owner)
  223:       on conflict(farm_id,user_id,dedupe_key) where dedupe_key is not null do nothing returning id into v_notification;
  224:     end if;
  225:   end if;
  226:   return pg_catalog.jsonb_build_object('fired',v_notification is not null,'notification_id',v_notification,'initialized',not v_exists);
  227: end;
  228: $$;
  229:
  230: create function public.claim_push_delivery_targets(
  231:   p_notification_id uuid default null,
  232:   p_limit integer default 100
  233: )
  234: returns table(
  235:   target_id uuid,
  236:   delivery_id uuid,
  237:   notification_id uuid,
  238:   endpoint text,
  239:   p256dh text,
  240:   auth text,
  241:   title text,
  242:   body text,
  243:   link text,
  244:   category text,
  245:   attempts integer
  246: )
  247: language plpgsql
  248: security definer
  249: set search_path = pg_catalog
  250: as $$
  251: declare
  252:   v_delivery_id uuid;
  253:   v_limit integer := greatest(1, least(coalesce(p_limit,100),250));
  254: begin
  255:   if not public.request_uses_service_role() then raise exception 'server delivery only'; end if;
  256:
  257:   -- Lock each not-yet-initialized delivery before snapshotting its current
  258:   -- subscription set. Concurrent caller and scheduled sweeps skip the lock.
  259:   for v_delivery_id in
  260:     select d.id from public.push_deliveries d
  261:     where d.targets_initialized_at is null
  262:       and d.status <> 'sent'
  263:       and (p_notification_id is null or d.notification_id=p_notification_id)
  264:     order by d.created_at,d.id
  265:     for update skip locked
  266:     limit v_limit
  267:   loop
  268:     insert into public.push_delivery_targets(delivery_id,subscription_id)
  269:     select v_delivery_id,s.id
  270:     from public.push_deliveries d
  271:     join public.notifications n on n.id=d.notification_id
  272:     join public.push_subscriptions s on s.user_id=n.user_id
  273:     where d.id=v_delivery_id
  274:     on conflict on constraint push_delivery_targets_delivery_subscription_key do nothing;
  275:     update public.push_deliveries set targets_initialized_at=now(),updated_at=now() where id=v_delivery_id;
  276:   end loop;
  277:
  278:   update public.push_delivery_targets
  279:   set status='gone',updated_at=now(),last_error='subscription removed'
  280:   where subscription_id is null and status in ('pending','sending','failed');
  281:
  282:   update public.push_deliveries d
  283:   set status='sent',sent_at=coalesce(d.sent_at,now()),last_error=null,updated_at=now()
  284:   where d.targets_initialized_at is not null and d.status<>'sent'
  285:     and (p_notification_id is null or d.notification_id=p_notification_id)
  286:     and not exists (
  287:       select 1 from public.push_delivery_targets t
  288:       where t.delivery_id=d.id and t.status not in ('sent','gone')
  289:     );
  290:
  291:   return query
  292:   with claimed as (
  293:     select t.id
  294:     from public.push_delivery_targets t
  295:     join public.push_deliveries d on d.id=t.delivery_id
  296:     where d.status<>'sent'
  297:       and (p_notification_id is null or d.notification_id=p_notification_id)
  298:       and t.subscription_id is not null
  299:       and t.attempts<10
  300:       and (
  301:         (t.status='pending' and t.claimed_at is null)
  302:         or (t.status in ('sending','failed') and t.claimed_at<now()-interval '5 minutes')
  303:       )
  304:     order by t.created_at,t.id
  305:     for update of t skip locked
  306:     limit v_limit
  307:   ), updated as (
  308:     update public.push_delivery_targets t
  309:     set status='sending',attempts=t.attempts+1,claimed_at=now(),updated_at=now()
  310:     from claimed where t.id=claimed.id
  311:     returning t.*
  312:   )
  313:   select u.id,u.delivery_id,d.notification_id,s.endpoint,s.p256dh,s.auth,
  314:     n.title,n.body,n.link,n.category,u.attempts
  315:   from updated u
  316:   join public.push_deliveries d on d.id=u.delivery_id
  317:   join public.notifications n on n.id=d.notification_id
  318:   join public.push_subscriptions s on s.id=u.subscription_id
  319:   order by u.created_at,u.id;
  320:
  321:   update public.push_deliveries d
  322:   set status='pending',claimed_at=now(),updated_at=now(),
  323:     attempts=greatest(d.attempts,coalesce((select max(t.attempts) from public.push_delivery_targets t where t.delivery_id=d.id),d.attempts))
  324:   where d.status<>'sent'
  325:     and (p_notification_id is null or d.notification_id=p_notification_id)
  326:     and exists(select 1 from public.push_delivery_targets t where t.delivery_id=d.id and t.status='sending');
  327: end;
  328: $$;
  329:
  330: create function public.finish_push_delivery_target(
  331:   p_target_id uuid,
  332:   p_outcome text,
  333:   p_error text default null
  334: )
  335: returns jsonb
  336: language plpgsql
  337: security definer
  338: set search_path = pg_catalog
  339: as $$
  340: declare
  341:   v_target public.push_delivery_targets%rowtype;
  342:   v_delivery public.push_deliveries%rowtype;
  343: begin
  344:   if not public.request_uses_service_role() then raise exception 'server delivery only'; end if;
  345:   if p_outcome is null or p_outcome not in ('sent','retry','gone') then raise exception 'invalid push target outcome'; end if;
  346:   select * into v_target from public.push_delivery_targets where id=p_target_id for update;
  347:   if not found then raise exception 'push delivery target not found'; end if;
  348:
  349:   if v_target.status not in ('sent','gone') then
  350:     update public.push_delivery_targets set
  351:       status=case p_outcome when 'sent' then 'sent' when 'gone' then 'gone' else 'failed' end,
  352:       sent_at=case when p_outcome='sent' then now() else null end,
  353:       claimed_at=case when p_outcome='retry' then coalesce(claimed_at,now()) else claimed_at end,
  354:       last_error=case when p_outcome='sent' then null else left(coalesce(p_error,'push provider failure'),1000) end,
  355:       updated_at=now()
  356:     where id=p_target_id returning * into v_target;
  357:
  358:     if p_outcome='gone' and v_target.subscription_id is not null then
  359:       delete from public.push_subscriptions where id=v_target.subscription_id;
  360:     end if;
  361:   end if;
  362:
  363:   update public.push_deliveries d set
  364:     status=case
  365:       when exists(select 1 from public.push_delivery_targets t where t.delivery_id=d.id and t.status='failed' and t.attempts>=10) then 'failed'
  366:       when exists(select 1 from public.push_delivery_targets t where t.delivery_id=d.id and t.status not in ('sent','gone'))
  367:         then case when exists(select 1 from public.push_delivery_targets t where t.delivery_id=d.id and t.status='failed') then 'failed' else 'pending' end
  368:       else 'sent'
  369:     end,
  370:     sent_at=case when not exists(select 1 from public.push_delivery_targets t where t.delivery_id=d.id and t.status not in ('sent','gone')) then coalesce(d.sent_at,now()) else null end,
  371:     last_error=case when exists(select 1 from public.push_delivery_targets t where t.delivery_id=d.id and t.status='failed') then left(coalesce(p_error,'push provider failure'),1000) else null end,
  372:     updated_at=now()
  373:   where d.id=v_target.delivery_id returning * into v_delivery;
  374:
  375:   return pg_catalog.jsonb_build_object('target_id',v_target.id,'target_status',v_target.status,'delivery_id',v_delivery.id,'delivery_status',v_delivery.status);
  376: end;
  377: $$;
  378:
  379: create function public.get_push_delivery_health(p_notification_id uuid default null)
  380: returns jsonb
  381: language plpgsql
  382: stable
  383: security definer
  384: set search_path = pg_catalog
  385: as $$
  386: declare
  387:   v_terminal integer;
  388:   v_retryable integer;
  389: begin
  390:   if not public.request_uses_service_role() then raise exception 'server delivery only'; end if;

