   33: -- A harmless unauthenticated representative probe. The client treats only this
   34: -- exact sentinel (or a successful RPC) as the all-of-0035 capability signal.
   35: create function public.operational_integrity_capability_probe(p_farm_id uuid)
   36: returns boolean language plpgsql security definer set search_path=public,pg_temp as $$
   37: begin
   38:   if auth.uid() is null then raise exception 'authentication is required'; end if;
   39:   if not public.can_edit_farm(p_farm_id) then raise exception 'you do not have permission to edit this farm'; end if;
   40:   return true;
   41: end $$;
