   60: create function public.finish_push_delivery(p_delivery_id uuid, p_sent boolean, p_error text default null)
   61: returns jsonb language plpgsql security definer set search_path=public,pg_temp as $$
   62: declare v public.push_deliveries%rowtype;
   63: begin
   64:   if coalesce(current_setting('request.jwt.claim.role',true),'') <> 'service_role' then raise exception 'server delivery only'; end if;
   65:   select * into v from public.push_deliveries where id=p_delivery_id for update;
   66:   if not found then raise exception 'push delivery not found'; end if;
   67:   if v.status='sent' then return jsonb_build_object('id',v.id,'status','sent'); end if;
   68:   -- A failure recorded on a never-claimed row must stay retryable: the failed
   69:   -- branch's backoff predicate compares claimed_at, so stamp it here.
   70:   update public.push_deliveries set status=case when p_sent then 'sent' else 'failed' end,
   71:     sent_at=case when p_sent then now() else null end, claimed_at=case when p_sent then claimed_at else coalesce(claimed_at, now()) end,
   72:     last_error=left(coalesce(p_error,''),1000), updated_at=now()
   73:   where id=p_delivery_id returning * into v;
   74:   return jsonb_build_object('id',v.id,'status',v.status);
   75: end $$;
