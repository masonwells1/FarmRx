105:export async function deleteUserWorkspaceCaches(projectRef: string, userId: string, farmId?: string): Promise<void> {
106:  if (!available()) return
107:  const database = await open(projectRef)
108:  try {
109:    const transaction = database.transaction(storeName, 'readwrite')
110:    const store = transaction.objectStore(storeName)
111:    await new Promise<void>((resolve, reject) => {
112:      const cursor = store.openCursor()
113:      cursor.onsuccess = () => {
114:        const current = cursor.result
115:        if (!current) { resolve(); return }
116:        const value = current.value as Partial<WorkspaceEnvelope<unknown>>
117:        if (value.projectRef === projectRef && value.userId === userId && (farmId === undefined || value.farmId === farmId)) current.delete()
118:        current.continue()
119:      }
120:      cursor.onerror = () => reject(cursor.error ?? new Error('Farm Rx could not clear offline data.'))
121:    })
122:    await complete(transaction)
123:    const verification = database.transaction(storeName, 'readonly').objectStore(storeName).openCursor()
124:    await new Promise<void>((resolve, reject) => {
125:      verification.onsuccess = () => {
126:        const current = verification.result
127:        if (!current) { resolve(); return }
128:        const value = current.value as Partial<WorkspaceEnvelope<unknown>>
129:        if (value.projectRef === projectRef && value.userId === userId && (farmId === undefined || value.farmId === farmId)) { reject(new Error('Farm Rx could not remove the offline copy for a farm you no longer can open.')); return }
130:        current.continue()
131:      }
132:      verification.onerror = () => reject(verification.error ?? new Error('Farm Rx could not verify offline cleanup.'))
133:    })
134:    notices.clear(); noticeSnapshot = []; for (const listener of listeners) listener()
135:  } finally { database.close() }
136:}
