81:export async function recordMarketingAlertTransitionsGuarded(farmId: string, conditions: Array<{ ruleId: string; met: boolean }>, operationContext: FarmOperationContext, dependencies: AlertTransitionDependencies): Promise<Set<string> | null> {
82:  await dependencies.verify(operationContext)
83:  if (!await dependencies.hasCapability()) { await dependencies.verify(operationContext); return null }
84:  if (operationContext.farmId !== farmId) return null
85:  const fired = new Set<string>()
