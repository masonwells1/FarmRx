91:  try { fence = captureFarmRevocationFence(localStorage, scope) } catch { return null }
92:  const database = await open(scope.projectRef)
93:  try {
94:    const transaction = database.transaction(storeName, 'readonly')
95:    const value = await requestResult(transaction.objectStore(storeName).get(cacheKey(scope)))
96:    if (value === undefined) return null
97:    if (!validEnvelope<T>(value, scope, fence)) return null
98:    if (Date.now() - Date.parse(value.cachedAt) > maximumAgeMs) throw new WorkspaceCacheExpiredError()
99:    try { verifyFarmRevocationFence(localStorage, fence) } catch { return null }
100:    publish({ module: scope.module.split(':')[0], cachedAt: value.cachedAt })
101:    return { data: structuredClone(value.data), cachedAt: value.cachedAt }
102:  } finally { database.close() }
