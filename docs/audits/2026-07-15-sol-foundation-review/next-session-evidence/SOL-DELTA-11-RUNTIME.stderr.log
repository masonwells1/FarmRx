241:    or p_auth is null or btrim(p_auth) = ''
242:  then
243:    raise exception 'endpoint and push keys are required';
244:  end if;
245:
246:  -- An endpoint may move between accounts on a shared device. The caller can
247:  -- claim it by replacing ownership and keys, but receives only the new row;
248:  -- this path never reads or returns the prior user's stored key material.
249:  insert into public.push_subscriptions (
250:    user_id,
251:    endpoint,
252:    p256dh,
253:    auth,
254:    user_agent
255:  )
