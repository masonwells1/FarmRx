73:export async function writeWorkspaceCache<T>(scope: WorkspaceCacheScope, data: T, fence: FarmRevocationSnapshot | null, cachedAt = new Date().toISOString()): Promise<boolean> {
74:  if (!available() || !fence) return false
75:  let database: IDBDatabase | null = null
76:  try {
77:    database = await open(scope.projectRef)
78:    verifyFarmRevocationFence(localStorage, fence)
79:    const transaction = database.transaction(storeName, 'readwrite')
80:    transaction.objectStore(storeName).put({ version: 2, key: cacheKey(scope), ...scope, generation: fence.generation, fenceToken: fence.token, serverEpoch: fence.serverEpoch, cachedAt, data: structuredClone(data) } satisfies WorkspaceEnvelope<T>)
81:    await complete(transaction)
82:    verifyFarmRevocationFence(localStorage, fence)
83:    return true
84:  } catch { return false }
85:  finally { database?.close() }
86:}
