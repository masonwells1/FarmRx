228:language plpgsql
229:security definer
230:set search_path = public, pg_temp
231:as $$
232:declare
233:  v_caller uuid := auth.uid();
234:  v_subscription public.push_subscriptions%rowtype;
235:begin
236:  if v_caller is null then
237:    raise exception 'authentication is required';
238:  end if;
239:  if p_endpoint is null or btrim(p_endpoint) = ''
