  234: returns table(
  235:   target_id uuid,
  236:   delivery_id uuid,
  237:   notification_id uuid,
  238:   endpoint text,
  239:   p256dh text,
  240:   auth text,
  241:   title text,
  242:   body text,
  243:   link text,
  244:   category text,
