87:    await dependencies.verify(operationContext)
88:    const { data, error } = await dependencies.record(condition, farmOperationRequestHeaders(operationContext))
89:    await dependencies.verify(operationContext)
90:    if (error) { if (error.code === '42883' || error.code === 'PGRST202') return null; continue }
91:    if (data && typeof data === 'object' && (data as { fired?: unknown }).fired === true) fired.add(condition.ruleId)
92:  }
93:  return fired
94:}
