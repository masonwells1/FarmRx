39:/** Testable core for the browser alert path. Every awaited boundary reuses the
40: * one context captured before Grain loaded; this function never recaptures and
41: * therefore cannot rebound an A operation onto B or a newer access epoch. */
42:export async function requestOwnerAlertDeliveryGuarded(alerts: GrainAlert[], farmId: string, operationContext: FarmOperationContext, dependencies: AlertDeliveryDependencies) {
43:  if (!alerts.length) return [] as string[]
44:  await dependencies.verify(operationContext)
45:  if (farmId !== operationContext.farmId) throw new Error('The selected farm changed before alert delivery could finish.')
46:  const auth = await dependencies.getUser(); await dependencies.verify(operationContext)
47:  if (auth.error || auth.userId !== operationContext.userId) throw new Error('The signed-in account changed before alert delivery could finish.')
48:  const key = sentKey(operationContext.userId, farmId); const sent = dependencies.readSent(key)
49:  const failures: string[] = []
50:  for (const alert of alerts.filter((item) => !sent.has(item.key))) {
51:    const flightKey = `${operationContext.userId}:${farmId}:${alert.key}`
52:    if (inFlight.has(flightKey)) continue
53:    inFlight.add(flightKey)
54:    try {
55:      await dependencies.verify(operationContext)
56:      const deliveryError = await dependencies.invoke(alert, farmId, farmOperationRequestHeaders(operationContext))
57:      await dependencies.verify(operationContext)
58:      if (deliveryError) failures.push(alert.key); else sent.add(alert.key)
59:    } finally { inFlight.delete(flightKey) }
60:  }
61:  await dependencies.verify(operationContext)
62:  try { dependencies.writeSent(key, [...sent]) } catch { /* delivery remains best effort and will be retried */ }
63:  return failures
64:}
