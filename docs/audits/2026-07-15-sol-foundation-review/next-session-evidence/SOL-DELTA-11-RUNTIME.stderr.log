   36: create or replace function public.claim_push_deliveries(p_limit integer default 25)
   37: returns table(id uuid, notification_id uuid, attempts integer)
   38: language plpgsql security definer set search_path=public,pg_temp as $$
   39: begin
   40:   if not public.request_uses_service_role() then raise exception 'server delivery only'; end if;
   41:   return query
   42:   with claimed as (
   43:     select d.id from public.push_deliveries d
   44:     where ((d.status='pending' and (d.claimed_at is null or d.claimed_at < now()-interval '5 minutes'))
   45:         or (d.status='failed' and d.claimed_at < now()-interval '5 minutes'))
   46:       and d.attempts < 10
   47:     order by d.created_at, d.id for update skip locked limit greatest(1, least(coalesce(p_limit,25),100))
   48:   )
   49:   update public.push_deliveries d set status='pending', attempts=d.attempts+1, claimed_at=now(), updated_at=now()
