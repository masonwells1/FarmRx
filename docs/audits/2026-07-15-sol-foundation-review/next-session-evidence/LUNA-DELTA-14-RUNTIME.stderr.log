--- verify-foundation.ps1 ---
    1: $ErrorActionPreference = 'Stop'
    2: $root = Split-Path -Parent $PSScriptRoot
    3:
    4: function Invoke-FoundationLane([scriptblock]$Command, [string]$Failure) {
    5:   $global:LASTEXITCODE = 0
    6:   & $Command
    7:   if ($LASTEXITCODE -ne 0) { throw $Failure }
    8: }
    9:
   10: function Assert-IntermediateLaneFailureIsFatal {
   11:   $expected = 'Controlled intermediate foundation lane failed.'
   12:   $detected = $false
   13:   try {
   14:     Invoke-FoundationLane { & powershell -NoProfile -Command 'exit 23' } $expected
   15:   } catch {
   16:     if ($_.Exception.Message -ne $expected) { throw }
   17:     $detected = $true
   18:   }
   19:   if (-not $detected) { throw 'Foundation orchestrator ignored a controlled intermediate failure.' }
   20:   Write-Output 'Foundation orchestrator intermediate-failure probe: PASS'
   21: }
   22:
   23: Push-Location $root
   24: try {
   25:   Assert-IntermediateLaneFailureIsFatal
   26:   Invoke-FoundationLane { & npx tsc -b --force } 'Forced TypeScript failed.'
   27:   Invoke-FoundationLane { & npm run regression } 'Fast regression suite failed.'
   28:   Invoke-FoundationLane { & npm run build } 'Production build failed.'
   29:   Invoke-FoundationLane { & npm audit --audit-level=high } 'Dependency audit failed.'
   30:   Invoke-FoundationLane { & node scripts/foundation-static-guards.mjs } 'Foundation static guard failed.'
   31:   Invoke-FoundationLane { & node scripts/verify-foundation-mutations.mjs } 'Foundation mutation drill failed.'
   32:   Invoke-FoundationLane { & (Join-Path $PSScriptRoot 'verify-0033-disposable.ps1') } 'Disposable 0033 proof failed.'
   33:   Invoke-FoundationLane { & (Join-Path $PSScriptRoot 'verify-0034-disposable.ps1') } 'Disposable 0034 proof failed.'
   34:   Invoke-FoundationLane { & (Join-Path $PSScriptRoot 'verify-0035-disposable.ps1') } 'Disposable 0035 proof failed.'
   35:   Invoke-FoundationLane { & (Join-Path $PSScriptRoot 'verify-0036-disposable.ps1') } 'Disposable 0036 proof failed.'
   36:   Invoke-FoundationLane { & (Join-Path $PSScriptRoot 'verify-0037-disposable.ps1') } 'Disposable 0037 proof failed.'
   37:   Invoke-FoundationLane { & (Join-Path $PSScriptRoot 'verify-0039-disposable.ps1') } 'Disposable 0039 proof failed.'
   38:   Invoke-FoundationLane { & (Join-Path $PSScriptRoot 'verify-0040-disposable.ps1') } 'Disposable 0040 proof failed.'
   39:   Invoke-FoundationLane { & (Join-Path $PSScriptRoot 'verify-0041-disposable.ps1') } 'Disposable 0041 proof failed.'
