--- verify-0036-disposable.ps1 ---
    1: $ErrorActionPreference = 'Stop'
    2: $name = "farmrx-0036-$PID"
    3: $root = Split-Path -Parent $PSScriptRoot
    4: $passed = $false
    5: function Invoke-Probe([string]$sql, [string]$failure) {
    6:   $sql | docker exec -i $name psql -q -v ON_ERROR_STOP=1 -U postgres -d farmrx_disposable
    7:   if ($LASTEXITCODE -ne 0) { throw $failure }
    8: }
    9: try {
   10:   docker run --rm -d --name $name -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=farmrx_disposable postgres:16 | Out-Null
   11:   $ready = $false
   12:   for ($i = 0; $i -lt 30; $i++) { if ((docker exec $name sh -c 'grep -qx postgres /proc/1/comm && pg_isready -U postgres -d farmrx_disposable' 2>$null) -match 'accepting connections') { $ready = $true; break }; Start-Sleep -Milliseconds 500 }
   13:   if (!$ready) { throw 'Disposable postgres:16 did not become ready.' }
