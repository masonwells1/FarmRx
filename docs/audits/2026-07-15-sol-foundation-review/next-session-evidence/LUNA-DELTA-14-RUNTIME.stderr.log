    6:
    7: function Invoke-Probe([string]$sql, [string]$failure) {
    8:   $sql | docker exec -i $name psql -q -v ON_ERROR_STOP=1 -U postgres -d farmrx_disposable
    9:   if ($LASTEXITCODE -ne 0) { throw $failure }
   10: }
   11:
   12: function Invoke-ExpectedFailure([string]$sql, [string]$expected, [string]$failure) {
   13:   $priorPreference = $ErrorActionPreference
   14:   $ErrorActionPreference = 'Continue'
   15:   try {
   16:     $output = $sql | docker exec -i $name psql -q -v ON_ERROR_STOP=1 -U postgres -d farmrx_disposable 2>&1
   17:     $exitCode = $LASTEXITCODE
   18:   } finally { $ErrorActionPreference = $priorPreference }
   19:   if ($exitCode -eq 0 -or ($output -join "`n") -notmatch [regex]::Escape($expected)) { throw $failure }
   20: }
   21:
   22: try {
   23:   docker run --rm -d --name $name -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=farmrx_disposable postgres:17 | Out-Null
   24:   $ready = $false
   25:   for ($i = 0; $i -lt 30; $i++) {
   26:     if ((docker exec $name sh -c 'grep -qx postgres /proc/1/comm && pg_isready -U postgres -d farmrx_disposable' 2>$null) -match 'accepting connections') { $ready = $true; break }
   27:     Start-Sleep -Milliseconds 500
   28:   }
   29:   if (!$ready) { throw 'Disposable postgres:17 did not become ready.' }
