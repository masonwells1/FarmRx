330:create function public.finish_push_delivery_target(
331:  p_target_id uuid,
332:  p_outcome text,
333:  p_error text default null
334:)
335:returns jsonb
336:language plpgsql
337:security definer
338:set search_path = pg_catalog
339:as $$
340:declare
341:  v_target public.push_delivery_targets%rowtype;
342:  v_delivery public.push_deliveries%rowtype;
343:begin
344:  if not public.request_uses_service_role() then raise exception 'server delivery only'; end if;
345:  if p_outcome is null or p_outcome not in ('sent','retry','gone') then raise exception 'invalid push target outcome'; end if;
346:  select * into v_target from public.push_delivery_targets where id=p_target_id for update;
347:  if not found then raise exception 'push delivery target not found'; end if;
348:
349:  if v_target.status not in ('sent','gone') then
350:    update public.push_delivery_targets set
351:      status=case p_outcome when 'sent' then 'sent' when 'gone' then 'gone' else 'failed' end,
352:      sent_at=case when p_outcome='sent' then now() else null end,
353:      claimed_at=case when p_outcome='retry' then coalesce(claimed_at,now()) else claimed_at end,
354:      last_error=case when p_outcome='sent' then null else left(coalesce(p_error,'push provider failure'),1000) end,
355:      updated_at=now()
356:    where id=p_target_id returning * into v_target;
357:
358:    if p_outcome='gone' and v_target.subscription_id is not null then
359:      delete from public.push_subscriptions where id=v_target.subscription_id;
360:    end if;
361:  end if;
362:
363:  update public.push_deliveries d set
364:    status=case
365:      when exists(select 1 from public.push_delivery_targets t where t.delivery_id=d.id and t.status='failed' and t.attempts>=10) then 'failed'
366:      when exists(select 1 from public.push_delivery_targets t where t.delivery_id=d.id and t.status not in ('sent','gone'))
367:        then case when exists(select 1 from public.push_delivery_targets t where t.delivery_id=d.id and t.status='failed') then 'failed' else 'pending' end
368:      else 'sent'
369:    end,
370:    sent_at=case when not exists(select 1 from public.push_delivery_targets t where t.delivery_id=d.id and t.status not in ('sent','gone')) then coalesce(d.sent_at,now()) else null end,
371:    last_error=case when exists(select 1 from public.push_delivery_targets t where t.delivery_id=d.id and t.status='failed') then left(coalesce(p_error,'push provider failure'),1000) else null end,
372:    updated_at=now()
373:  where d.id=v_target.delivery_id returning * into v_delivery;
374:
375:  return pg_catalog.jsonb_build_object('target_id',v_target.id,'target_status',v_target.status,'delivery_id',v_delivery.id,'delivery_status',v_delivery.status);
376:end;
377:$$;
