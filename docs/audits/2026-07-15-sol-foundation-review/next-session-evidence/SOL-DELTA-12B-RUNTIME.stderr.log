168:create function public.guard_row_farm_access_epoch()
169:returns trigger
170:language plpgsql
171:security definer
172:set search_path = public, pg_temp
173:as $$
174:declare
175:  v_row jsonb := case when tg_op = 'DELETE' then to_jsonb(old) else to_jsonb(new) end;
176:  v_farm_id uuid;
177:  v_old_farm_id uuid;
178:begin
179:  v_farm_id := nullif(v_row ->> 'farm_id', '')::uuid;
180:
181:  -- The owner membership is created by the farm bootstrap trigger before an
182:  -- epoch row exists. This is the sole authenticated bootstrap exception.
183:  if tg_table_name = 'farm_memberships' and tg_op = 'INSERT' then
184:    if nullif(v_row ->> 'user_id', '')::uuid = auth.uid()
185:      and not exists (
186:        select 1 from public.farm_access_epochs epoch
187:        where epoch.farm_id = v_farm_id
188:          and epoch.user_id = nullif(v_row ->> 'user_id', '')::uuid
189:      )
190:      and exists (
191:        select 1 from public.farms farm
192:        where farm.id = v_farm_id and farm.created_by = auth.uid()
193:      ) then
194:      return new;
195:    end if;
196:  end if;
197:
198:  -- bootstrap_first_farm creates exactly one initial entity in the same
199:  -- transaction as its new owner farm. The browser cannot know that farm's
200:  -- epoch before the RPC returns. No later transaction or second entity can
201:  -- use this exception.
202:  if tg_table_name = 'entities' and tg_op = 'INSERT' and exists (
203:    select 1
204:    from public.farms farm
205:    join public.farm_access_epochs epoch
206:      on epoch.farm_id = farm.id and epoch.user_id = auth.uid()
207:    join public.farm_memberships membership
208:      on membership.farm_id = farm.id and membership.user_id = auth.uid()
209:    where farm.id = v_farm_id
210:      and farm.created_by = auth.uid()
211:      and farm.created_at = transaction_timestamp()
212:      and epoch.access_epoch = 1
213:      and membership.role = 'owner' and membership.status = 'active'
214:      and not exists (select 1 from public.entities entity where entity.farm_id = farm.id)
215:  ) then
216:    return new;
217:  end if;
218:
219:  if tg_op = 'UPDATE' then
220:    v_old_farm_id := nullif(to_jsonb(old) ->> 'farm_id', '')::uuid;
221:    if v_old_farm_id is distinct from v_farm_id then
222:      perform public.assert_current_farm_access_epoch(v_old_farm_id);
223:    end if;
224:  end if;
225:  perform public.assert_current_farm_access_epoch(v_farm_id);
226:  return case when tg_op = 'DELETE' then old else new end;
227:end;
228:$$;
229:
230:create function public.guard_farm_root_access_epoch()
231:returns trigger
232:language plpgsql
233:security definer
234:set search_path = public, pg_temp
235:as $$
236:begin
237:  -- Creating a farm is guarded by created_by = auth.uid() and the hardened
238:  -- bootstrap trigger. Existing farm roots require the captured epoch.
239:  if tg_op <> 'INSERT' then
240:    perform public.assert_current_farm_access_epoch(old.id);
241:  end if;
242:  return case when tg_op = 'DELETE' then old else new end;
243:end;
244:$$;
