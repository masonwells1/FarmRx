33:export class QueuedScoutingRepository implements ScoutingRepository {
34:  constructor(private readonly live: SupabaseScoutingRepository, private readonly d: Dependencies) {
35:    setModuleSyncRetryAction('scouting', () => this.inspectAndReplay())
36:    if (typeof window !== 'undefined') window.addEventListener('online', () => { void this.inspectAndReplay() })
37:    subscribeQueueTransactions((key) => { void this.source().then(({ queue }) => { if (queue.key === key) void this.inspectAndReplay() }).catch(() => undefined) })
38:  }
