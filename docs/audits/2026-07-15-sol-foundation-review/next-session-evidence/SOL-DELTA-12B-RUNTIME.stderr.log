131:  v_expected_user_id := public.current_request_expected_user_id();
132:
133:  if v_user_id is null or v_expected_user_id is distinct from v_user_id or target_farm_id is null then
134:    raise exception using errcode = 'P0001', message = 'FARM_ACCESS_EPOCH_CHANGED';
135:  end if;
136:
137:  v_presented := public.current_request_farm_access_epoch(target_farm_id);
138:
139:  -- The row lock linearizes an in-flight write against a concurrent revoke or
140:  -- re-grant. Whichever transaction obtains this row first defines the order.
141:  select epoch.access_epoch into v_current
142:  from public.farm_access_epochs epoch
143:  where epoch.farm_id = target_farm_id and epoch.user_id = v_user_id
144:  for share;
145:
146:  if v_current is null
147:    or v_presented is distinct from v_current
148:    or not public.can_access_farm(target_farm_id) then
149:    raise exception using errcode = 'P0001', message = 'FARM_ACCESS_EPOCH_CHANGED';
150:  end if;
151:end;
152:$$;
