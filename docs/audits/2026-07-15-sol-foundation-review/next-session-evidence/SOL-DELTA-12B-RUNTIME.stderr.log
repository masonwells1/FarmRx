319:create function public.bump_rep_epochs_for_farm_sharing()
320:returns trigger
321:language plpgsql
322:security definer
323:set search_path = public, pg_temp
324:as $$
325:declare
326:  v_user_id uuid;
327:begin
328:  if old.share_with_rep is distinct from new.share_with_rep then
329:    for v_user_id in
330:      select access.rep_user_id from public.farm_rep_access access
331:      where access.farm_id = new.id
332:    loop
333:      perform public.bump_farm_access_epoch(new.id, v_user_id);
334:    end loop;
335:  end if;
336:  return new;
337:end;
338:$$;
339:
340:-- Every current public base table with a farm_id receives the same transaction-
341:-- local guard, including writes performed from SECURITY DEFINER RPCs.
342:do $$
343:declare
344:  v_table record;
345:begin
346:  for v_table in
347:    select table_name
348:    from information_schema.columns
349:    where table_schema = 'public' and column_name = 'farm_id'
350:      and table_name <> 'farm_access_epochs'
351:      and exists (
352:        select 1 from pg_catalog.pg_class relation
353:        join pg_catalog.pg_namespace namespace on namespace.oid = relation.relnamespace
354:        where namespace.nspname = 'public' and relation.relname = table_name
355:          and relation.relkind in ('r', 'p')
356:      )
357:    order by table_name
358:  loop
359:    execute format(
360:      'create trigger farm_access_epoch_guard before insert or update or delete on public.%I for each row execute function public.guard_row_farm_access_epoch()',
361:      v_table.table_name
362:    );
363:  end loop;
364:end;
365:$$;
