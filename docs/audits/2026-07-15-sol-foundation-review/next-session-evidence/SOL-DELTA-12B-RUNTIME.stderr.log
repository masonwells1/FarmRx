63:  async getData(fieldId?: string) {
64:    const source = await this.source(); const { context, operationContext, queue } = source
65:    const verifyRead = () => verifyQueuedReadContext(this.d, operationContext)
66:    const cacheScope = { projectRef: this.d.projectRef, ...context, module: `scouting:${fieldId ?? 'all'}` }
67:    try {
68:      await this.inspectAndReplay(); await verifyRead()
69:      const cacheFence = captureWorkspaceCacheFence(cacheScope)
70:      const data = await this.live.getData(fieldId); await verifyRead()
71:      await writeWorkspaceCache(cacheScope, data, cacheFence); await verifyRead()
72:      return data
73:    } catch (error) {
74:      await verifyRead()
75:      if (!isTransportFailure(error, this.d.isOffline())) throw error
76:      const cached = await readWorkspaceCache<ScoutingData>(cacheScope, operationalCacheMaxAgeMs); await verifyRead()
77:      if (!cached) throw error
78:      const data = structuredClone(cached.data)
79:      for (const entry of queue.read().entries) {
80:        if (entry.kind === 'deleteNote') data.notes = data.notes.filter((note) => note.id !== entry.noteId)
81:        else if (!fieldId || entry.draft.field_id === fieldId) {
82:          const note = pending(entry, context)
83:          data.notes = data.notes.some((item) => item.id === note.id) ? data.notes.map((item) => item.id === note.id ? note : item) : [...data.notes, note]
84:        }
85:      }
86:      await verifyRead(); return data
87:    }
