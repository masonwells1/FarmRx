85:  v_failed_farm_ids jsonb := '[]'::jsonb;
86:  v_farm_created integer;
87:  v_farm_program_created integer;
88:  v_farm_ids jsonb;
89:begin
90:  if not public.request_uses_service_role() then raise exception 'server scheduler only'; end if;
91:  if not pg_catalog.pg_try_advisory_xact_lock(pg_catalog.hashtext('farm-rx-scheduled-alert-sweep')) then
92:    return pg_catalog.jsonb_build_object('skipped','already_running');
93:  end if;
94:
95:  for v_farm in select * from public.farms order by id loop
96:    begin
97:      v_farm_created := 0;
98:      v_farm_program_created := 0;
99:      v_farm_ids := '[]'::jsonb;
100:      v_local_date := (p_now at time zone v_farm.time_zone)::date;
101:      v_program_result := public.generate_due_program_notifications(v_farm.id, v_local_date);
102:      v_farm_program_created := coalesce((v_program_result->>'created_count')::integer, 0);
103:      select user_id into v_owner from public.farm_memberships
104:      where farm_id=v_farm.id and role='owner' and status='active'
105:      order by user_id limit 1;
106:
107:      if v_owner is not null then
108:        for v_rule in select * from public.marketing_alert_rules where farm_id=v_farm.id and active order by id loop
109:          v_condition:=false; v_price:=null; v_bid_date:=null; v_pct:=null;
110:          v_title:='Farm Rx marketing reminder';
111:          v_body:=coalesce(v_rule.message,'A saved grain item needs your review.');
112:          if v_rule.rule_type='price_target' then
113:            select b.cash_price,b.bid_date into v_price,v_bid_date from public.cash_bids b
114:            where b.farm_id=v_farm.id and b.commodity_id=v_rule.commodity_id and b.cash_price is not null
115:              and b.bid_date between v_local_date-2 and v_local_date
116:            order by b.bid_date desc,b.updated_at desc,b.id desc limit 1;
117:            v_condition:=v_price is not null and ((v_rule.direction='at_or_above' and v_price>=v_rule.threshold) or (v_rule.direction='at_or_below' and v_price<=v_rule.threshold));
118:            v_title:='Farm Rx price target reached';
119:            if v_condition then v_body:=v_rule.crop_year||' '||v_rule.commodity_id||' cash price is $'||trim(to_char(v_price,'FM999999990.00'))||' from the '||v_bid_date||' bid.'; end if;
120:          elsif v_rule.rule_type='pct_marketed_goal' then
121:            select coalesce(sum(case when pe.drives_math='actual' and pe.actual_bushels is not null then pe.actual_bushels else pe.expected_bushels end),0) into v_production
122:            from public.production_estimates pe where pe.farm_id=v_farm.id and pe.crop_year=v_rule.crop_year and pe.commodity_id=v_rule.commodity_id
123:              and pe.operating_entity_id is not distinct from v_rule.operating_entity_id and pe.enterprise_label is not distinct from v_rule.enterprise_label;
124:            select coalesce(sum(gc.bushels),0) into v_contracts from public.grain_contracts gc
125:            where gc.farm_id=v_farm.id and gc.crop_year=v_rule.crop_year and gc.commodity_id=v_rule.commodity_id
126:              and gc.operating_entity_id is not distinct from v_rule.operating_entity_id and gc.enterprise_label is not distinct from v_rule.enterprise_label;
127:            v_pct:=case when v_production>0 then v_contracts/v_production*100 else null end;
128:            v_condition:=v_pct is not null and v_pct<v_rule.threshold;
129:            v_title:='Farm Rx marketed goal reminder';
130:            if v_condition then v_body:=v_rule.crop_year||' '||v_rule.commodity_id||' is '||trim(to_char(v_pct,'FM990.0'))||'% marketed; your goal is '||trim(to_char(v_rule.threshold,'FM990.0'))||'%.'; end if;
131:          elsif v_rule.rule_type='deadline' then
132:            v_condition:=v_rule.remind_on between v_local_date and v_local_date+7;
133:            v_title:='Farm Rx marketing deadline';
134:            if v_condition then v_body:=v_rule.crop_year||' '||v_rule.commodity_id||' reminder is due '||v_rule.remind_on||'.'; end if;
135:          end if;
136:
137:          perform pg_catalog.pg_advisory_xact_lock(pg_catalog.hashtextextended(v_rule.id::text,0));
138:          insert into public.alert_rule_states(rule_id,is_condition_true) values(v_rule.id,false) on conflict(rule_id) do nothing;
139:          select is_condition_true into v_previous from public.alert_rule_states where rule_id=v_rule.id for update;
140:          v_notification_id:=null;
141:          if not v_previous and v_condition then
142:            insert into public.notifications(farm_id,user_id,category,title,body,link,dedupe_key,created_by)
143:            values(v_farm.id,v_owner,'general',left(v_title,160),left(v_body,500),'/grain','marketing-rule:'||v_rule.id||':'||v_local_date,v_owner)
144:            on conflict(farm_id,user_id,dedupe_key) where dedupe_key is not null do nothing returning id into v_notification_id;
145:            if v_notification_id is not null then
146:              v_farm_created:=v_farm_created+1;
147:              v_farm_ids:=v_farm_ids||pg_catalog.to_jsonb(v_notification_id);
148:              update public.marketing_alert_rules set last_triggered_at=p_now where id=v_rule.id and farm_id=v_farm.id;
149:            end if;
150:          end if;
151:          update public.alert_rule_states set is_condition_true=v_condition,
152:            fired_at=case when not v_previous and v_condition then p_now else fired_at end,
153:            updated_at=p_now where rule_id=v_rule.id;
154:        end loop;
155:      end if;
156:      v_created := v_created + v_farm_created;
157:      v_program_created := v_program_created + v_farm_program_created;
158:      v_ids := v_ids || v_farm_ids;
159:      v_processed := v_processed + 1;
160:    exception when others then
161:      v_failed := v_failed + 1;
162:      v_failed_farm_ids := v_failed_farm_ids || pg_catalog.to_jsonb(v_farm.id);
163:    end;
164:  end loop;
165:
166:  return pg_catalog.jsonb_build_object(
167:    'marketing_created',v_created,
168:    'program_created',v_program_created,
169:    'notification_ids',v_ids,
170:    'processed_farm_count',v_processed,
171:    'farm_failure_count',v_failed,
172:    'failed_farm_ids',v_failed_farm_ids
173:  );
174:end;
175:$$;
