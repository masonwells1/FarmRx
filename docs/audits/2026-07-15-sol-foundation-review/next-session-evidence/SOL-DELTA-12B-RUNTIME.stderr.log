51:
52:  private async drainPhotoCleanup(source: Source) {
53:    if (this.d.isOffline() || !this.d.removeStoragePaths) return
54:    const { context, operationContext } = source
55:    await drainScoutingCleanupOutbox(this.d.storage, this.outboxKey(context.userId), context.userId, context.farmId, async (paths) => {
56:      await verifyQueuedOperationContext(this.d, operationContext, context)
57:      const confirmed = await this.d.removeStoragePaths!(paths, operationContext)
58:      await verifyQueuedOperationContext(this.d, operationContext, context)
59:      return confirmed
60:    })
61:  }
