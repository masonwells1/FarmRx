--- scripts/foundation-static-guards.mjs ---
   1: import { readFileSync } from 'node:fs'
   2: import { resolve } from 'node:path'
   3: import { fileURLToPath } from 'node:url'
   4: import { createHash } from 'node:crypto'
   5:
   6: const read = (root, path) => readFileSync(resolve(root, path), 'utf8')
   7: const requireText = (errors, source, text, label) => { if (!source.includes(text)) errors.push(label) }
   8:
   9: export function foundationStaticGuard(root = process.cwd()) {
  10:   const errors = []
  11:   const app = read(root, 'src/App.tsx')
  12:   const routes = ['/fields', '/grain/*', '/inventory', '/profitability/*', '/equipment', '/tasks', '/weather', '/field-log', '/scouting', '/harvest', '/programs', '/notifications']
  13:   for (const route of routes) requireText(errors, app, `path="${route}"`, `route:${route}`)
  14:   requireText(errors, app, 'mobilePrimaryPaths = new Set(["/fields", "/grain", "/tasks", "/weather"])', 'mobile:primary-destinations')
  15:   requireText(errors, app, 'mobileMoreNavigation', 'mobile:more-destinations')
  16:   requireText(errors, app, '<FarmAccessGateForUser key={user.id} user={user}>', 'identity:keyed-farm-access-gate')
  17:   requireText(errors, app, 'access?.userId !== user.id', 'identity:farm-access-render-fence')
  18:
  19:   const unscopedWriteFencing = read(root, 'supabase/migrations/0041_unscoped_authenticated_write_fencing.sql')
  20:   if ((unscopedWriteFencing.match(/perform public\.assert_current_farm_access_epoch\(p_farm_id\);/g) ?? []).length !== 3) errors.push('rpc:unscoped-write-fences')
  21:   requireText(errors, unscopedWriteFencing, 'revoke all on function public.save_push_subscription(text, text, text, text)', 'rpc:legacy-push-save-retired')
  22:   requireText(errors, unscopedWriteFencing, 'revoke all on function public.delete_push_subscription(text)', 'rpc:legacy-push-delete-retired')
  23:   requireText(errors, unscopedWriteFencing, 'where push_subscriptions.user_id = v_caller', 'rpc:push-endpoint-owner-fence')
  24:   requireText(errors, unscopedWriteFencing, "message = 'PUSH_SUBSCRIPTION_OWNED_BY_ANOTHER_USER'", 'rpc:push-endpoint-owner-conflict')
  25:   requireText(errors, unscopedWriteFencing, 'revoke insert, update, delete on table public.push_subscriptions from public, anon, authenticated;', 'table:push-direct-write-revoked')
  26:   for (const operation of ['insert', 'update', 'delete']) requireText(errors, unscopedWriteFencing, `drop policy if exists push_subscriptions_${operation} on public.push_subscriptions;`, `table:push-${operation}-policy-removed`)
  27:   if (/set\s+user_id\s*=\s*excluded\.user_id/i.test(unscopedWriteFencing)) errors.push('rpc:push-endpoint-owner-transfer')
  28:   const notificationsGateway = read(root, 'src/data/SupabaseNotificationsDataGateway.ts')
  29:   if ((notificationsGateway.match(/p_farm_id: context\.farmId/g) ?? []).length !== 2) errors.push('rpc:push-farm-context-forwarding')
  30:
  31:   const queues = [
  32:     'src/data/fieldLocation.ts',
  33:     'src/data/QueuedEquipmentTasksRepository.ts',
  34:     'src/data/QueuedFieldLogRepository.ts',
  35:     'src/data/QueuedFieldsRepository.ts',
  36:     'src/data/QueuedGrainRepository.ts',
  37:     'src/data/QueuedHarvestRepository.ts',
  38:     'src/data/QueuedInventoryRepository.ts',
  39:     'src/data/QueuedNotificationsRepository.ts',
  40:     'src/data/QueuedProfitabilityRepository.ts',
  41:     'src/data/QueuedProgramsRepository.ts',
  42:     'src/data/QueuedScoutingRepository.ts',
  43:   ]
  44:   for (const path of queues) {
  45:     const source = read(root, path)
  46:     if (!source.includes("from './queueTransaction'")) errors.push(`queue-import:${path}`)
  47:     if (!source.includes('queueTransaction(')) errors.push(`queue-lock:${path}`)
  48:   }
  49:
  50:   const readRepositories = queues.filter((path) => path !== 'src/data/fieldLocation.ts')
  51:   const readGuard = read(root, 'src/data/queuedOperationGuard.ts')
  52:   requireText(errors, readGuard, 'export async function verifyQueuedReadContext(', 'read-context:shared-guard')
  53:   requireText(errors, readGuard, 'await verifyQueuedOperationContext(dependencies, expected, expected)', 'read-context:shared-operation-verification')
  54:   for (const path of readRepositories) {
  55:     const source = read(root, path)
  56:     if (!source.includes('const verifyRead = () => verifyQueuedReadContext')) errors.push(`read-context:${path}`)
  57:     if ((source.match(/await verifyRead\(\)/g) ?? []).length < 4) errors.push(`read-boundaries:${path}`)
  58:   }
  59:
  60:   const rls = read(root, 'supabase/migrations/0002_module1_rls.sql')
  61:   const fieldsSelect = rls.slice(rls.indexOf('create policy fields_select'), rls.indexOf('create policy fields_insert'))
  62:   requireText(errors, fieldsSelect, 'public.can_access_farm(farm_id)', 'rls:fields-select-farm-scope')
  63:   requireText(errors, rls, 'alter table public.fields enable row level security;', 'rls:fields-enabled')
  64:
  65:   const cache = read(root, 'src/data/workspaceCache.ts')
  66:   requireText(errors, cache, '`${scope.projectRef}:${scope.userId}:${scope.farmId}:${scope.module}`', 'cache:user-farm-module-key')
  67:   requireText(errors, cache, 'row.userId === scope.userId && row.farmId === scope.farmId', 'cache:envelope-scope-validation')
  68:   requireText(errors, cache, 'financialCacheMaxAgeMs = 24 * 60 * 60 * 1_000', 'cache:financial-expiry')
  69:   const serviceWorker = read(root, 'src/sw.ts')
  70:   requireText(errors, serviceWorker, "registerRoute(new NavigationRoute(createHandlerBoundToURL('/index.html')))", 'service-worker:navigation-shell-only')
  71:   if (/supabase\.co|api\/v1|rest\/v1/.test(serviceWorker)) errors.push('service-worker:private-api-runtime-cache')
  72:
  73:   const widget = read(root, 'src/components/MarketQuote.tsx')
  74:   requireText(errors, widget, 'sandbox="allow-scripts"', 'widget:opaque-sandbox')
  75:   requireText(errors, widget, 'src={`/market-quote-frame.html?symbol=', 'widget:isolated-frame-document')
  76:   if (widget.includes('allow-same-origin')) errors.push('widget:same-origin-enabled')
  77:   const vercel = JSON.parse(read(root, 'vercel.json'))
  78:   const appRule = vercel.headers.find((rule) => rule.source.includes('?!market-quote-frame'))
  79:   const frameRule = vercel.headers.find((rule) => rule.source === '/market-quote-frame.html')
  80:   const headers = Object.fromEntries(appRule.headers.map(({ key, value }) => [key, value]))
  81:   for (const directive of ["default-src 'self'", "object-src 'none'", "frame-ancestors 'none'"]) if (!headers['Content-Security-Policy']?.includes(directive)) errors.push(`csp:${directive}`)
  82:   if (headers['Content-Security-Policy']?.match(/script-src[^;]*tradingview/)) errors.push('csp:third-party-parent-script')
  83:   const frameCsp = Object.fromEntries(frameRule.headers.map(({ key, value }) => [key, value]))['Content-Security-Policy']
  84:   if (!frameCsp?.includes('https://s3.tradingview.com')) errors.push('csp:frame-script-source')
  85:   const frameDocument = read(root, 'public/market-quote-frame.html')
  86:   const inline = frameDocument.match(/<script>([\s\S]*?)<\/script>/)?.[1] ?? ''
  87:   const frameHash = createHash('sha256').update(inline).digest('base64')
  88:   if (!frameCsp?.includes(`'sha256-${frameHash}'`)) errors.push('csp:frame-inline-hash')
  89:
  90:   const scheduler = read(root, 'supabase/migrations/0037_scheduled_alert_foundation.sql')
  91:   requireText(errors, scheduler, "current_setting('request.jwt.claim.role',true),'') <> 'service_role'", 'scheduler:service-role-check')
  92:   requireText(errors, scheduler, 'b.bid_date between v_local_date-2 and v_local_date', 'scheduler:bid-freshness')
  93:   requireText(errors, scheduler, 'is not distinct from v_rule.operating_entity_id', 'scheduler:entity-scope')
  94:   return errors
  95: }
  96:
  97: if (process.argv[1] && resolve(process.argv[1]) === resolve(fileURLToPath(import.meta.url))) {
  98:   const errors = foundationStaticGuard(process.argv[2] ? resolve(process.argv[2]) : process.cwd())
  99:   if (errors.length) { console.error(`Foundation static guard failed: ${errors.join(', ')}`); process.exit(1) }
 100:   console.log('Foundation static guards: PASS')
 101: }
