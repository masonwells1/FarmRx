   1: -- Fence authenticated writes whose target tables cannot carry farm_id.
   2: -- Browser callers must present the exact user/farm/access epoch captured when
   3: -- the operation began; a later session must never adopt the remote write.
   4:
   5: create or replace function public.record_marketing_alert_transition(
   6:   p_farm_id uuid,
   7:   p_rule_id uuid,
   8:   p_condition_true boolean
   9: )
  10: returns jsonb
  11: language plpgsql
  12: security definer
  13: set search_path = public, pg_temp
  14: as $$
  15: declare
  16:   v_previous boolean;
  17:   v_fired boolean := false;
  18: begin
  19:   perform public.assert_current_farm_access_epoch(p_farm_id);
  20:   if not public.can_edit_farm(p_farm_id) then
  21:     raise exception 'you do not have permission to edit this farm';
  22:   end if;
  23:   if not exists (
  24:     select 1 from public.marketing_alert_rules rule
  25:     where rule.id = p_rule_id and rule.farm_id = p_farm_id
  26:   ) then
  27:     raise exception 'alert rule not found for this farm';
  28:   end if;
  29:
  30:   perform pg_advisory_xact_lock(hashtextextended(p_rule_id::text, 0));
  31:   select state.is_condition_true into v_previous
  32:   from public.alert_rule_states state
  33:   where state.rule_id = p_rule_id
  34:   for update;
  35:
  36:   if not found then
  37:     v_previous := false;
  38:     insert into public.alert_rule_states (rule_id, is_condition_true, fired_at)
  39:     values (p_rule_id, p_condition_true, case when p_condition_true then now() else null end);
  40:     v_fired := p_condition_true;
  41:   else
  42:     v_fired := not v_previous and p_condition_true;
  43:     update public.alert_rule_states
  44:     set is_condition_true = p_condition_true,
  45:         fired_at = case when v_fired then now() else fired_at end,
  46:         updated_at = now()
  47:     where rule_id = p_rule_id;
  48:   end if;
  49:
  50:   return jsonb_build_object('fired', v_fired);
  51: end;
  52: $$;
  53:
  54: create function public.save_push_subscription(
  55:   p_farm_id uuid,
  56:   p_endpoint text,
  57:   p_p256dh text,
  58:   p_auth text,
  59:   p_user_agent text
  60: )
  61: returns jsonb
  62: language plpgsql
  63: security definer
  64: set search_path = public, pg_temp
  65: as $$
  66: declare
  67:   v_caller uuid := auth.uid();
  68:   v_subscription public.push_subscriptions%rowtype;
  69: begin
  70:   perform public.assert_current_farm_access_epoch(p_farm_id);
  71:   if p_endpoint is null or btrim(p_endpoint) = ''
  72:     or p_p256dh is null or btrim(p_p256dh) = ''
  73:     or p_auth is null or btrim(p_auth) = ''
  74:   then
  75:     raise exception 'endpoint and push keys are required';
  76:   end if;
  77:
  78:   insert into public.push_subscriptions (
  79:     user_id,
  80:     endpoint,
  81:     p256dh,
  82:     auth,
  83:     user_agent
  84:   )
  85:   values (
  86:     v_caller,
  87:     p_endpoint,
  88:     p_p256dh,
  89:     p_auth,
  90:     p_user_agent
  91:   )
  92:   on conflict (endpoint) do update
  93:   set p256dh = excluded.p256dh,
  94:       auth = excluded.auth,
  95:       user_agent = excluded.user_agent,
  96:       last_seen_at = now()
  97:   where push_subscriptions.user_id = v_caller
  98:   returning * into v_subscription;
  99:
 100:   -- A browser endpoint can still be referenced by pending delivery targets.
 101:   -- Never let a later account adopt that endpoint (and those pending sends).
 102:   -- The conditional upsert is atomic under the endpoint unique constraint, so
 103:   -- it also closes the two-call race when different users register it at once.
 104:   if not found then
 105:     raise exception using
 106:       errcode = 'P0001',
 107:       message = 'PUSH_SUBSCRIPTION_OWNED_BY_ANOTHER_USER';
 108:   end if;
 109:
 110:   return to_jsonb(v_subscription);
 111: end;
 112: $$;
