 106: create function public.create_notification(
 107:   p_farm_id uuid,
 108:   p_recipient uuid,
 109:   p_category text,
 110:   p_title text,
 111:   p_body text,
 112:   p_link text,
 113:   p_dedupe_key text
 114: )
 115: returns jsonb
 116: language plpgsql
 117: security definer
 118: set search_path = public, pg_temp
 119: as $$
 120: declare
 121:   v_caller uuid := auth.uid();
 122:   v_notification public.notifications%rowtype;
 123: begin
 124:   if v_caller is null then
 125:     raise exception 'authentication is required';
 126:   end if;
 127:   if p_farm_id is null or p_recipient is null then
 128:     raise exception 'farm and recipient are required';
 129:   end if;
 130:
 131:   if not exists (
 132:     select 1
 133:     from public.farm_memberships fm
 134:     where fm.farm_id = p_farm_id
 135:       and fm.user_id = p_recipient
 136:       and fm.status = 'active'
 137:   ) then
 138:     raise exception 'notification recipient must be an active member of this farm';
 139:   end if;
 140:
 141:   if not public.can_edit_farm(p_farm_id) and v_caller <> p_recipient then
 142:     raise exception 'you do not have permission to create this notification';
 143:   end if;
 144:
 145:   if p_category is null or p_category not in (
 146:     'spray', 'rain', 'scouting', 'harvest', 'service', 'task', 'general'
 147:   ) then
 148:     raise exception 'notification category is invalid';
 149:   end if;
 150:   if p_title is null or char_length(btrim(p_title)) not between 1 and 160 then
 151:     raise exception 'notification title must be between 1 and 160 characters';
 152:   end if;
 153:
 154:   insert into public.notifications (
 155:     farm_id,
 156:     user_id,
 157:     category,
 158:     title,
 159:     body,
 160:     link,
 161:     dedupe_key,
 162:     created_by
 163:   )
 164:   values (
 165:     p_farm_id,
 166:     p_recipient,
 167:     p_category,
 168:     p_title,
 169:     p_body,
 170:     p_link,
 171:     p_dedupe_key,
 172:     v_caller
 173:   )
 174:   on conflict (farm_id, user_id, dedupe_key)
 175:     where dedupe_key is not null
 176:     do nothing
 177:   returning * into v_notification;
 178:
 179:   if not found then
 180:     select n.*
 181:       into strict v_notification
 182:     from public.notifications n
 183:     where n.farm_id = p_farm_id
 184:       and n.user_id = p_recipient
 185:       and n.dedupe_key = p_dedupe_key;
 186:   end if;
 187:
 188:   return to_jsonb(v_notification);
 189: end;
 190: $$;
 191:
 192: create function public.mark_notifications_read(p_ids uuid[])
 193: returns jsonb
 194: language plpgsql
 195: security definer
 196: set search_path = public, pg_temp
 197: as $$
 198: declare
 199:   v_caller uuid := auth.uid();
 200:   v_updated_count integer := 0;
 201: begin
 202:   if v_caller is null then
 203:     raise exception 'authentication is required';
 204:   end if;
 205:   if p_ids is null then
 206:     raise exception 'notification IDs are required';
 207:   end if;
 208:
 209:   update public.notifications n
 210:   set read_at = now()
 211:   where n.id = any(p_ids)
 212:     and n.user_id = v_caller
 213:     and n.read_at is null;
 214:
 215:   get diagnostics v_updated_count = row_count;
 216:
 217:   return jsonb_build_object('updated_count', v_updated_count);
 218: end;
 219: $$;
 220:
 221: create function public.save_push_subscription(
 222:   p_endpoint text,
 223:   p_p256dh text,
 224:   p_auth text,
 225:   p_user_agent text
 226: )
 227: returns jsonb
 228: language plpgsql
 229: security definer
 230: set search_path = public, pg_temp
 231: as $$
 232: declare
 233:   v_caller uuid := auth.uid();
 234:   v_subscription public.push_subscriptions%rowtype;
 235: begin
 236:   if v_caller is null then
 237:     raise exception 'authentication is required';
 238:   end if;
 239:   if p_endpoint is null or btrim(p_endpoint) = ''
 240:     or p_p256dh is null or btrim(p_p256dh) = ''
 241:     or p_auth is null or btrim(p_auth) = ''
 242:   then
 243:     raise exception 'endpoint and push keys are required';
 244:   end if;
 245:
 246:   -- An endpoint may move between accounts on a shared device. The caller can
 247:   -- claim it by replacing ownership and keys, but receives only the new row;
 248:   -- this path never reads or returns the prior user's stored key material.
 249:   insert into public.push_subscriptions (
 250:     user_id,
 251:     endpoint,
 252:     p256dh,
 253:     auth,
 254:     user_agent
 255:   )
 256:   values (
 257:     v_caller,
 258:     p_endpoint,
 259:     p_p256dh,
 260:     p_auth,
 261:     p_user_agent
 262:   )
 263:   on conflict (endpoint) do update
 264:   set user_id = excluded.user_id,
 265:       p256dh = excluded.p256dh,
 266:       auth = excluded.auth,
 267:       user_agent = excluded.user_agent,
 268:       last_seen_at = now()
 269:   returning * into v_subscription;
 270:
 271:   return to_jsonb(v_subscription);
 272: end;
 273: $$;
 274:
 275: create function public.delete_push_subscription(p_endpoint text)
 276: returns jsonb
 277: language plpgsql
 278: security definer
 279: set search_path = public, pg_temp
 280: as $$
 281: declare
 282:   v_caller uuid := auth.uid();
 283:   v_deleted_count integer := 0;
 284: begin
 285:   if v_caller is null then
 286:     raise exception 'authentication is required';
 287:   end if;
 288:   if p_endpoint is null or btrim(p_endpoint) = '' then
 289:     raise exception 'endpoint is required';
 290:   end if;
 291:
 292:   delete from public.push_subscriptions s
 293:   where s.endpoint = p_endpoint
 294:     and s.user_id = v_caller;
 295:
 296:   get diagnostics v_deleted_count = row_count;
 297:
 298:   return jsonb_build_object('deleted_count', v_deleted_count);
 299: end;
 300: $$;
 301:
 302: revoke all on function public.create_notification(
 303:   uuid, uuid, text, text, text, text, text
 304: ) from public, anon, authenticated;
 305: revoke all on function public.mark_notifications_read(uuid[])
 306:   from public, anon, authenticated;
 307: revoke all on function public.save_push_subscription(text, text, text, text)
 308:   from public, anon, authenticated;
 309: revoke all on function public.delete_push_subscription(text)
 310:   from public, anon, authenticated;
 311:
 312: grant execute on function public.create_notification(
 313:   uuid, uuid, text, text, text, text, text
 314: ) to authenticated;
 315: grant execute on function public.mark_notifications_read(uuid[])
 316:   to authenticated;
 317: grant execute on function public.save_push_subscription(text, text, text, text)
 318:   to authenticated;
 319: grant execute on function public.delete_push_subscription(text)
 320:   to authenticated;
 321:
 322: -- 0016 task logic below is intentionally unchanged through row_count/return.
 323: -- The only task-generator edits are SECURITY DEFINER plus the notification
 324: -- insert between task row_count capture and the original JSON return.
 325: create or replace function public.generate_due_service_tasks(p_farm_id uuid)
 326: returns jsonb
 327: language plpgsql
 328: security definer
 329: set search_path = public, pg_temp
 330: as $$
 331: declare
 332:   v_caller uuid := auth.uid();
 333:   v_created_count integer := 0;
 334: begin
 335:   if v_caller is null then
 336:     raise exception 'you must be signed in to generate service tasks';
 337:   end if;
 338:   if p_farm_id is null then
 339:     raise exception 'farm is required to generate service tasks';
 340:   end if;
 341:   if not public.is_active_farm_member(p_farm_id) then
 342:     raise exception 'you must be an active member of this farm to generate service tasks';
 343:   end if;
 344:
 345:   perform pg_advisory_xact_lock(hashtextextended(p_farm_id::text, 0));
 346:
 347:   insert into public.farm_tasks (
 348:     farm_id,
 349:     title,
 350:     priority,
 351:     equipment_id,
 352:     source,
 353:     interval_id,
 354:     interval_cycle_key,
 355:     created_by
 356:   )
 357:   select
 358:     p_farm_id,
 359:     i.name || ' — ' || e.name,
 360:     'high',
 361:     e.id,
 362:     'service_interval',
 363:     i.id,
 364:     case d.reason
 365:       when 'meter' then
 366:         'meter:' || coalesce(i.last_done_reading::text, 'never') || ':'
 367:         || floor(
 368:              (latest.reading - coalesce(i.last_done_reading, 0)) / i.every_meter
 369:            )::text
 370:       when 'calendar' then
 371:         'cal:' || to_char(
 372:           (
 373:             coalesce(i.last_done_on, e.created_at::date)
 374:             + make_interval(months => i.every_months)
 375:           )::date,
 376:           'YYYY-MM'
 377:         )
 378:     end,
 379:     v_caller
 380:   from (
 381:     select distinct on (due.interval_id)
 382:       due.equipment_id,
 383:       due.interval_id,
 384:       due.reason,
 385:       due.overdue_amount
 386:     from public.equipment_service_due due
 387:     order by
 388:       due.interval_id,
 389:       case due.reason when 'meter' then 0 else 1 end
 390:   ) d
 391:   join public.equipment_service_intervals i
 392:     on i.id = d.interval_id
 393:    and i.farm_id = p_farm_id
 394:   join public.equipment e
 395:     on e.id = d.equipment_id
 396:    and e.farm_id = p_farm_id
 397:   left join lateral (
 398:     select r.reading
 399:     from public.equipment_meter_readings r
 400:     where r.equipment_id = e.id
 401:       and r.farm_id = p_farm_id
 402:     order by r.read_on desc, r.created_at desc, r.id desc
 403:     limit 1
 404:   ) latest on true
 405:   -- One OPEN auto-task per interval, ever: without this guard the meter cycle
 406:   -- key's floor() term grows as the un-serviced meter climbs, minting a second
 407:   -- identical card while the first is still on the board.
 408:   where not exists (
 409:     select 1
 410:     from public.farm_tasks t
 411:     where t.farm_id = p_farm_id
 412:       and t.interval_id = i.id
 413:       and t.source = 'service_interval'
 414:       and t.status in ('todo', 'doing')
 415:   )
 416:   on conflict (farm_id, interval_id, interval_cycle_key)
 417:     where interval_cycle_key is not null
 418:     do nothing;
 419:
 420:   get diagnostics v_created_count = row_count;
 421:
 422:   -- v1 notifies one active owner. The same due-row selection and exact cycle
 423:   -- expression as 0016 make the notification key track the task cycle, while
 424:   -- its own partial unique index makes retries harmless even after task edits.
 425:   insert into public.notifications (
 426:     farm_id,
 427:     user_id,
 428:     category,
 429:     title,
 430:     body,
 431:     link,
 432:     dedupe_key,
 433:     created_by
 434:   )
 435:   select
 436:     p_farm_id,
 437:     owner.user_id,
 438:     'service',
 439:     left('Service due: ' || i.name || ' — ' || e.name, 160),
 440:     null,
 441:     '/equipment',
 442:     'service:' || i.id::text || ':' ||
 443:       case d.reason
 444:         when 'meter' then
 445:           'meter:' || coalesce(i.last_done_reading::text, 'never') || ':'
 446:           || floor(
 447:                (latest.reading - coalesce(i.last_done_reading, 0)) / i.every_meter
 448:              )::text
 449:         when 'calendar' then
 450:           'cal:' || to_char(
 451:             (
 452:               coalesce(i.last_done_on, e.created_at::date)
 453:               + make_interval(months => i.every_months)
 454:             )::date,
 455:             'YYYY-MM'
 456:           )
 457:       end,
 458:     v_caller
 459:   from (
 460:     select distinct on (due.interval_id)
 461:       due.equipment_id,
 462:       due.interval_id,
 463:       due.reason,
 464:       due.overdue_amount
 465:     from public.equipment_service_due due
 466:     order by
 467:       due.interval_id,
 468:       case due.reason when 'meter' then 0 else 1 end
 469:   ) d
 470:   join public.equipment_service_intervals i
 471:     on i.id = d.interval_id
 472:    and i.farm_id = p_farm_id
 473:   join public.equipment e
 474:     on e.id = d.equipment_id
 475:    and e.farm_id = p_farm_id
 476:   join lateral (
 477:     select fm.user_id
 478:     from public.farm_memberships fm
 479:     where fm.farm_id = p_farm_id
 480:       and fm.role = 'owner'
 481:       and fm.status = 'active'
 482:     order by fm.user_id
 483:     limit 1
 484:   ) owner on true
 485:   left join lateral (
 486:     select r.reading
 487:     from public.equipment_meter_readings r
 488:     where r.equipment_id = e.id
 489:       and r.farm_id = p_farm_id
 490:     order by r.read_on desc, r.created_at desc, r.id desc
 491:     limit 1
 492:   ) latest on true
 493:   on conflict (farm_id, user_id, dedupe_key)
 494:     where dedupe_key is not null
 495:     do nothing;
 496:
 497:   return jsonb_build_object('created_count', v_created_count);
 498: end;
 499: $$;
 500:
 501: revoke all on function public.generate_due_service_tasks(uuid)
 502:   from public, anon, authenticated;
 503: grant execute on function public.generate_due_service_tasks(uuid)
 504:   to authenticated;
--- src/data/SupabaseNotificationsDataGateway.ts ---
   1: import { supabase } from '../lib/supabaseClient'
   2: import type { NotificationsDataGateway } from './NotificationsDataGateway'
   3: import type { NotificationCategory } from './notifications'
   4: import { bindFarmOperationRequest, type FarmOperationContext } from './farmOperationContext'
   5:
   6: const rows = (data: unknown, error: { message: string } | null) => { if (error) throw error; if (!Array.isArray(data)) throw new Error('Farm Rx could not load alerts.'); return data }
   7: const row = (data: unknown, error: { message: string } | null) => { if (error) throw error; if (!data || typeof data !== 'object') throw new Error('Farm Rx could not confirm the alert change.'); return data }
   8:
   9: export class SupabaseNotificationsDataGateway implements NotificationsDataGateway {
  10:   async loadNotifications() { const result = await supabase.from('notifications').select('*').order('created_at', { ascending: false }).order('id', { ascending: false }); return rows(result.data, result.error) }
  11:   async markRead(ids: string[], context: FarmOperationContext) { const result = await bindFarmOperationRequest(supabase.rpc('mark_notifications_read', { p_ids: ids }), context); return row(result.data, result.error) }
  12:   async createNotification(input: { farmId: string; recipientId: string; category: NotificationCategory; title: string; body: string; link: string; dedupeKey: string | null }, context: FarmOperationContext) { const result = await bindFarmOperationRequest(supabase.rpc('create_notification', { p_farm_id: input.farmId, p_recipient: input.recipientId, p_category: input.category, p_title: input.title, p_body: input.body, p_link: input.link, p_dedupe_key: input.dedupeKey }), context); return row(result.data, result.error) }
  13:   async savePushSubscription(input: { endpoint: string; p256dh: string; auth: string; userAgent: string }, context: FarmOperationContext) { const result = await bindFarmOperationRequest(supabase.rpc('save_push_subscription', { p_farm_id: context.farmId, p_endpoint: input.endpoint, p_p256dh: input.p256dh, p_auth: input.auth, p_user_agent: input.userAgent }), context); return row(result.data, result.error) }
  14:   async deletePushSubscription(endpoint: string, context: FarmOperationContext) { const result = await bindFarmOperationRequest(supabase.rpc('delete_push_subscription', { p_farm_id: context.farmId, p_endpoint: endpoint }), context); return row(result.data, result.error) }
  15: }
--- src/data/NotificationsDataGateway.ts ---
   1: import type { NotificationCategory } from './notifications'
   2: import type { FarmOperationContext } from './farmOperationContext'
   3:
   4: export interface NotificationsDataGateway {
   5:   loadNotifications(): Promise<unknown[]>
   6:   markRead(ids: string[], context: FarmOperationContext): Promise<unknown>
   7:   createNotification(input: { farmId: string; recipientId: string; category: NotificationCategory; title: string; body: string; link: string; dedupeKey: string | null }, context: FarmOperationContext): Promise<unknown>
   8:   savePushSubscription(input: { endpoint: string; p256dh: string; auth: string; userAgent: string }, context: FarmOperationContext): Promise<unknown>
   9:   deletePushSubscription(endpoint: string, context: FarmOperationContext): Promise<unknown>
  10: }
--- src/data/createSupabaseNotificationsServices.ts ---
   1: import { QueuedNotificationsRepository } from './QueuedNotificationsRepository'
   2: import { SupabaseNotificationsDataGateway } from './SupabaseNotificationsDataGateway'
   3: import { SupabaseNotificationsRepository } from './SupabaseNotificationsRepository'
   4: import type { StorageLike } from './writeQueue'
   5: import { captureFarmOperationContext, verifyFarmOperationContext } from './farmOperationContext'
   6: export function createSupabaseNotificationsServices(d: { getUserId: () => Promise<string>; getContext: () => Promise<{ userId: string; farmId: string }>; projectRef: string; storage: StorageLike; createId: () => string; isOffline: () => boolean }) { const getOperationContext = async () => captureFarmOperationContext(d.storage, d.projectRef, await d.getContext()); const verifyOperationContext = async (expected: Awaited<ReturnType<typeof getOperationContext>>) => verifyFarmOperationContext(d.storage, expected, await getOperationContext()); const live = new SupabaseNotificationsRepository({ gateway: new SupabaseNotificationsDataGateway(), getUserId: d.getUserId, getOperationContext, verifyOperationContext }); const queued = new QueuedNotificationsRepository(live, { getContext: d.getContext, projectRef: d.projectRef, storage: d.storage, createId: d.createId, clock: () => new Date().toISOString(), isOffline: d.isOffline }); return { notificationsRepository: queued, replayNotificationsQueue: () => queued.inspectAndReplay() } }
--- scripts/verify-0041-disposable.ps1 ---
   1: $ErrorActionPreference = 'Stop'
   2: $name = "farmrx-0041-$PID"
   3: $root = Split-Path -Parent $PSScriptRoot
   4: $passed = $false
   5: if (-not (Get-Command docker -ErrorAction SilentlyContinue)) { throw 'Docker CLI is required for the disposable 0041 proof but is not available on PATH.' }
   6:
   7: function Invoke-Probe([string]$sql, [string]$failure) {
   8:   $sql | docker exec -i $name psql -q -v ON_ERROR_STOP=1 -U postgres -d farmrx_disposable
   9:   if ($LASTEXITCODE -ne 0) { throw $failure }
  10: }
  11:
  12: function Invoke-ExpectedFailure([string]$sql, [string]$expected, [string]$failure) {
  13:   $priorPreference = $ErrorActionPreference
  14:   $ErrorActionPreference = 'Continue'
  15:   try {
  16:     $output = $sql | docker exec -i $name psql -q -v ON_ERROR_STOP=1 -U postgres -d farmrx_disposable 2>&1
  17:     $exitCode = $LASTEXITCODE
  18:   } finally { $ErrorActionPreference = $priorPreference }
  19:   if ($exitCode -eq 0 -or ($output -join "`n") -notmatch [regex]::Escape($expected)) { throw $failure }
  20: }
  21:
  22: try {
  23:   docker run --rm -d --name $name -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=farmrx_disposable postgres:17 | Out-Null
  24:   $ready = $false
  25:   for ($i = 0; $i -lt 30; $i++) {
  26:     if ((docker exec $name sh -c 'grep -qx postgres /proc/1/comm && pg_isready -U postgres -d farmrx_disposable' 2>$null) -match 'accepting connections') { $ready = $true; break }
  27:     Start-Sleep -Milliseconds 500
