 129: export function markFarmRevoked(storage: StorageLike, scope: FarmRevocationScope, changedAt = new Date().toISOString(), serverEpoch?: number): number {
 130:   const { fence, ledger } = readState(storage, scope)
 131:   if (fence?.revoked && ledger) return fence.generation
 132:   const generation = Math.max(fence?.generation ?? 0, ledger?.generation ?? 0) + 1
 133:   const authoritativeEpoch = serverEpoch ?? fence?.serverEpoch ?? ledger?.serverEpoch
 134:   if (!authoritativeEpoch) throw new Error(blocked)
 135:   writeFence(storage, scope, { version: 2, generation, token: nextToken(), serverEpoch: authoritativeEpoch, revoked: true, changedAt })
