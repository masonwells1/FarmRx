   1: // Farm Rx — durable per-device push deliverer. Provider calls occur only here;
   2: // retry decisions and target state are isolated in injected, pure logic.
   3: import webpush from 'npm:web-push@3.6.7'
   4: import { createClient } from 'jsr:@supabase/supabase-js@2'
   5: import { deliverClaimedPushTargets, type ClaimedPushTarget, type PushTargetOutcome } from '../_shared/pushDeliveryLogic.ts'
   6:
   7: const cors = { 'Access-Control-Allow-Origin': '*', 'Access-Control-Allow-Headers': 'authorization, x-client-info, apikey, content-type, x-server-delivery-key', 'Access-Control-Allow-Methods': 'POST, OPTIONS' }
   8: const json = (status: number, body: Record<string, unknown>) => new Response(JSON.stringify(body), { status, headers: { ...cors, 'Content-Type': 'application/json', 'Cache-Control': 'no-store' } })
   9: const rate = new Map<string, { count: number; reset: number }>()
  10: const allow = (key: string) => { const now = Date.now(); const current = rate.get(key); if (!current || current.reset <= now) { rate.set(key, { count: 1, reset: now + 60_000 }); return true } if (current.count >= 20) return false; current.count += 1; return true }
  11: function sameSecret(left: string, right: string) { if (left.length !== right.length) return false; let result = 0; for (let i=0;i<left.length;i++) result |= left.charCodeAt(i)^right.charCodeAt(i); return result===0 }
  12:
  13: Deno.serve(async (req) => {
  14:   if (req.method === 'OPTIONS') return new Response('ok', { headers: cors })
  15:   if (req.method !== 'POST') return json(405, { error: 'method not allowed' })
  16:   const url = Deno.env.get('SUPABASE_URL') ?? ''
  17:   const serviceKey = Deno.env.get('SUPABASE_SERVICE_ROLE_KEY') ?? ''
  18:   const anonKey = Deno.env.get('SUPABASE_ANON_KEY') ?? ''
  19:   const publicKey = Deno.env.get('VAPID_PUBLIC_KEY')
  20:   const privateKey = Deno.env.get('VAPID_PRIVATE_KEY')
  21:   const subject = Deno.env.get('VAPID_SUBJECT')
  22:   if (!url || !serviceKey || !anonKey || !publicKey || !privateKey || !subject) return json(503, { error: 'Push is not configured yet (required server secrets missing).' })
  23:
  24:   let body: Record<string, unknown>
  25:   try { body = await req.json() as Record<string, unknown> } catch { return json(400, { error: 'invalid request body' }) }
  26:   const suppliedServerKey = req.headers.get('x-server-delivery-key') ?? ''
  27:   const serverDelivery = sameSecret(serviceKey, suppliedServerKey)
  28:   const requestedId = typeof body.notification_id === 'string' ? body.notification_id : null
  29:   const admin = createClient(url, serviceKey, { auth: { persistSession: false, autoRefreshToken: false } })
  30:
  31:   if (!serverDelivery) {
  32:     const authorization = req.headers.get('Authorization')
  33:     if (!authorization || !requestedId) return json(401, { error: 'sign in required' })
  34:     const caller = createClient(url, anonKey, { global: { headers: { Authorization: authorization } }, auth: { persistSession: false, autoRefreshToken: false } })
  35:     const { data: userData, error: userError } = await caller.auth.getUser()
  36:     if (userError || !userData.user) return json(401, { error: 'sign in required' })
  37:     if (!allow(userData.user.id)) return json(429, { error: 'too many push requests' })
  38:     // Ownership is checked through the caller's RLS-bound client. The privileged
  39:     // client is used only after that check and only through server-owned RPCs.
  40:     const { data: visible, error: visibleError } = await caller.from('notifications').select('id').eq('id', requestedId).maybeSingle()
  41:     if (visibleError || !visible) return json(403, { error: 'notification is not yours' })
  42:   }
  43:
  44:   webpush.setVapidDetails(subject, publicKey, privateKey)
  45:   try {
  46:     const result = await deliverClaimedPushTargets({
  47:       async claimTargets(notificationId, limit, signal) {
  48:         const { data, error } = await admin.rpc('claim_push_delivery_targets', { p_notification_id: notificationId, p_limit: limit }).abortSignal(signal)
  49:         if (error || !Array.isArray(data)) throw new Error('could not claim push delivery targets')
  50:         return data as ClaimedPushTarget[]
  51:       },
  52:       async finishTarget(targetId, outcome: PushTargetOutcome, errorText, signal) {
  53:         const { error } = await admin.rpc('finish_push_delivery_target', { p_target_id: targetId, p_outcome: outcome, p_error: errorText }).abortSignal(signal)
  54:         if (error) throw new Error('could not finish push delivery target')
  55:       },
  56:       async getHealth(notificationId, signal) {
  57:         const { data, error } = await admin.rpc('get_push_delivery_health', { p_notification_id: notificationId }).abortSignal(signal)
  58:         if (error || !data || typeof data !== 'object' || Array.isArray(data)) throw new Error('could not read push delivery health')
  59:         const terminalFailed = Number((data as { terminal_failed_targets?: unknown }).terminal_failed_targets)
  60:         const retryable = Number((data as { retryable_targets?: unknown }).retryable_targets)
  61:         if (!Number.isSafeInteger(terminalFailed) || terminalFailed < 0 || !Number.isSafeInteger(retryable) || retryable < 0) throw new Error('push delivery health was malformed')
  62:         return { terminalFailed, retryable }
  63:       },
  64:     }, {
  65:       async send(target, payload, _signal, timeoutMs) {
  66:         const topic = target.notification_id.replaceAll('-', '').slice(0, 32)
  67:         await webpush.sendNotification({ endpoint: target.endpoint, keys: { p256dh: target.p256dh, auth: target.auth } }, payload, { TTL: 3_600, urgency: 'normal', topic, timeout: Math.max(1, Math.floor(timeoutMs)) })
  68:       },
  69:     }, serverDelivery ? null : requestedId, { limit: 12, concurrency: 6, budgetMs: 20_000 })
  70:     const unhealthy = result.failed > 0 || result.terminalFailed > 0 || result.retryable > 0
  71:     return json(unhealthy ? 503 : 200, unhealthy ? { ...result, error: result.terminalFailed > 0 ? 'one or more push targets exhausted automatic retries' : 'one or more push targets remain retryable' } : result)
  72:   } catch {
  73:     return json(500, { error: 'push delivery failed before completion' })
  74:   }
  75: })
