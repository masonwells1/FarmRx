 114: create function public.delete_push_subscription(
 115:   p_farm_id uuid,
 116:   p_endpoint text
 117: )
 118: returns jsonb
 119: language plpgsql
 120: security definer
 121: set search_path = public, pg_temp
 122: as $$
 123: declare
 124:   v_caller uuid := auth.uid();
 125:   v_deleted_count integer := 0;
 126: begin
 127:   perform public.assert_current_farm_access_epoch(p_farm_id);
 128:   if p_endpoint is null or btrim(p_endpoint) = '' then
 129:     raise exception 'endpoint is required';
 130:   end if;
 131:
 132:   delete from public.push_subscriptions subscription
 133:   where subscription.endpoint = p_endpoint
 134:     and subscription.user_id = v_caller;
 135:
 136:   get diagnostics v_deleted_count = row_count;
 137:   return jsonb_build_object('deleted_count', v_deleted_count);
 138: end;
 139: $$;
