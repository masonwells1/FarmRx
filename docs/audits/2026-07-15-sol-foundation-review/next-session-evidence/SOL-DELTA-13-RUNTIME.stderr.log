   6: import { currentFarmContext } from '../auth/farmContext'
   7: import { supabaseConfig } from '../lib/supabaseConfig'
   8: import { bindFarmOperationRequest, captureFarmOperationContext, farmOperationRequestHeaders, verifyFarmOperationContext, type FarmOperationContext } from './farmOperationContext'
   9:
  10: export interface GrainAlert { key: string; kind: 'price_target' | 'target_deadline' | 'usda_report' | 'marketing_price_target' | 'marketing_pct_marketed_goal' | 'marketing_deadline'; message: string; targetId?: string; reportId?: string; observationId?: string; ruleId?: string }
  11: const day = (value: Date) => value.toISOString().slice(0, 10)
  12: const addDays = (value: string, count: number) => { const date = new Date(`${value}T00:00:00Z`); date.setUTCDate(date.getUTCDate() + count); return day(date) }
  13: const businessDay = (value: string) => { const weekday = new Date(`${value}T00:00:00Z`).getUTCDay(); return weekday !== 0 && weekday !== 6 }
  14: const observationFresh = (bidDate: string, now: Date) => businessDay(bidDate) && now.getTime() - new Date(`${bidDate}T23:59:59Z`).getTime() <= 36 * 60 * 60 * 1000
  15:
  16: /** Client v1 is intentionally check-on-open, not background monitoring. */
  17: export function evaluateGrainAlerts(workspace: GrainWorkspace, now = new Date()): GrainAlert[] {
  18:   const today = farmLocalCalendarDate(now); const alerts: GrainAlert[] = []
  19:   for (const target of workspace.marketing_plan_targets) {
  20:     if (target.target_price !== null) { const candidates = workspace.cash_bids.filter((bid) => bid.commodity_id === target.commodity_id && bid.cash_price !== null && observationFresh(bid.bid_date, now)); const highest = candidates.sort((left, right) => (right.cash_price! - left.cash_price!) || right.bid_date.localeCompare(left.bid_date))[0]; if (highest && highest.cash_price! >= target.target_price) alerts.push({ key: `price:${target.id}:${target.target_price}:${highest.id}`, kind: 'price_target', targetId: target.id, observationId: highest.id, message: `Cash price target reached for ${target.commodity_id}: ${highest.cash_price!.toFixed(2)}.` }) }
  21:     if (target.deadline && (target.deadline === today || target.deadline === addDays(today, 7))) { const window = target.deadline === today ? 'due' : 'seven-days'; alerts.push({ key: `deadline:${target.id}:${target.deadline}:${window}`, kind: 'target_deadline', targetId: target.id, message: target.deadline === today ? `Marketing target deadline is today (${target.deadline}).` : `Marketing target deadline is in seven days (${target.deadline}).` }) }
  22:   }
  23:   for (const report of workspace.usda_report_dates) if (report.report_date === today || report.report_date === addDays(today, 7)) { const window = report.report_date === today ? 'due' : 'seven-days'; alerts.push({ key: `report:${report.id}:${report.report_date}:${window}`, kind: 'usda_report', reportId: report.id, message: report.report_date === today ? `${report.report_name} is scheduled today.` : `${report.report_name} is scheduled in seven days.` }) }
  24:   for (const item of evaluateMarketingAlertRules(workspace, now).alerts) alerts.push({ ...item, ruleId: item.ruleId })
  25:   return alerts
  26: }
  27: function sentKey(userId: string, farmId: string) { return `farm-rx-grain-alert-sent:v1:${userId}:${farmId}` }
  28: function readSent(key: string) { try { const value: unknown = JSON.parse(localStorage.getItem(key) ?? '[]'); return Array.isArray(value) && value.every((item) => typeof item === 'string') ? new Set(value) : new Set<string>() } catch { return new Set<string>() } }
  29: export async function captureGrainAlertOperationContext() { return captureFarmOperationContext(localStorage, supabaseConfig.projectRef, await currentFarmContext()) }
  30: export async function verifyGrainAlertOperationContext(expected: FarmOperationContext) { verifyFarmOperationContext(localStorage, expected, await captureGrainAlertOperationContext()) }
  31: type AlertDeliveryDependencies = {
  32:   verify: (expected: FarmOperationContext) => Promise<void>
  33:   getUser: () => Promise<{ userId: string | null; error: unknown }>
  34:   invoke: (alert: GrainAlert, farmId: string, headers: Record<string, string>) => Promise<unknown>
  35:   readSent: (key: string) => Set<string>
  36:   writeSent: (key: string, values: string[]) => void
  37: }
  38:
  39: /** Testable core for the browser alert path. Every awaited boundary reuses the
  40:  * one context captured before Grain loaded; this function never recaptures and
  41:  * therefore cannot rebound an A operation onto B or a newer access epoch. */
  42: export async function requestOwnerAlertDeliveryGuarded(alerts: GrainAlert[], farmId: string, operationContext: FarmOperationContext, dependencies: AlertDeliveryDependencies) {
  43:   if (!alerts.length) return [] as string[]
  44:   await dependencies.verify(operationContext)
  45:   if (farmId !== operationContext.farmId) throw new Error('The selected farm changed before alert delivery could finish.')
  46:   const auth = await dependencies.getUser(); await dependencies.verify(operationContext)
  47:   if (auth.error || auth.userId !== operationContext.userId) throw new Error('The signed-in account changed before alert delivery could finish.')
  48:   const key = sentKey(operationContext.userId, farmId); const sent = dependencies.readSent(key)
  49:   const failures: string[] = []
  50:   for (const alert of alerts.filter((item) => !sent.has(item.key))) {
  51:     const flightKey = `${operationContext.userId}:${farmId}:${alert.key}`
  52:     if (inFlight.has(flightKey)) continue
  53:     inFlight.add(flightKey)
  54:     try {
  55:       await dependencies.verify(operationContext)
  56:       const deliveryError = await dependencies.invoke(alert, farmId, farmOperationRequestHeaders(operationContext))
  57:       await dependencies.verify(operationContext)
  58:       if (deliveryError) failures.push(alert.key); else sent.add(alert.key)
  59:     } finally { inFlight.delete(flightKey) }
  60:   }
  61:   await dependencies.verify(operationContext)
  62:   try { dependencies.writeSent(key, [...sent]) } catch { /* delivery remains best effort and will be retried */ }
  63:   return failures
  64: }
  65: /** The Edge Function is the authority for owner verification, recipient email, rate limiting, and durable delivery. */
  66: export async function requestOwnerAlertDelivery(alerts: GrainAlert[], farmId: string, operationContext: FarmOperationContext) {
  67:   return requestOwnerAlertDeliveryGuarded(alerts, farmId, operationContext, {
  68:     verify: verifyGrainAlertOperationContext,
  69:     getUser: async () => { const { data, error } = await supabase.auth.getUser(); return { userId: data.user?.id ?? null, error } },
  70:     invoke: async (alert, targetFarmId, headers) => { const { error } = await supabase.functions.invoke('deliver-grain-alert', { headers, body: { alertKey: alert.key, kind: alert.kind, farmId: targetFarmId, targetId: alert.targetId, reportId: alert.reportId, observationId: alert.observationId, ruleId: alert.ruleId } }); return error },
  71:     readSent,
  72:     writeSent: (key, values) => localStorage.setItem(key, JSON.stringify(values)),
  73:   })
  74: }
  75: type AlertTransitionDependencies = {
  76:   verify: (expected: FarmOperationContext) => Promise<void>
  77:   hasCapability: () => Promise<boolean>
  78:   record: (condition: { ruleId: string; met: boolean }, headers: Record<string, string>) => Promise<{ data: unknown; error: { code?: string } | null }>
  79: }
  80:
  81: export async function recordMarketingAlertTransitionsGuarded(farmId: string, conditions: Array<{ ruleId: string; met: boolean }>, operationContext: FarmOperationContext, dependencies: AlertTransitionDependencies): Promise<Set<string> | null> {
  82:   await dependencies.verify(operationContext)
  83:   if (!await dependencies.hasCapability()) { await dependencies.verify(operationContext); return null }
  84:   if (operationContext.farmId !== farmId) return null
  85:   const fired = new Set<string>()
  86:   for (const condition of conditions) {
  87:     await dependencies.verify(operationContext)
  88:     const { data, error } = await dependencies.record(condition, farmOperationRequestHeaders(operationContext))
  89:     await dependencies.verify(operationContext)
  90:     if (error) { if (error.code === '42883' || error.code === 'PGRST202') return null; continue }
  91:     if (data && typeof data === 'object' && (data as { fired?: unknown }).fired === true) fired.add(condition.ruleId)
  92:   }
  93:   return fired
  94: }
  95: /** 0035 records false/true state atomically. A missing draft RPC intentionally
  96:  * returns null so the caller can retain the pre-update guarded behavior. */
  97: export async function recordMarketingAlertTransitions(farmId: string, conditions: Array<{ ruleId: string; met: boolean }>, operationContext: FarmOperationContext): Promise<Set<string> | null> {
  98:   return recordMarketingAlertTransitionsGuarded(farmId, conditions, operationContext, {
  99:     verify: verifyGrainAlertOperationContext,
 100:     hasCapability: getOperationalIntegrityCapability,
 101:     record: async (condition) => bindFarmOperationRequest(supabase.rpc('record_marketing_alert_transition', { p_farm_id: farmId, p_rule_id: condition.ruleId, p_condition_true: condition.met }), operationContext),
 102:   })
 103: }
 104: const inFlight = new Set<string>()
