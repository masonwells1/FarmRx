 148: /** Product-agnostic guidance only. The notification and UI must continue to
 149:  * tell the applicator to follow the product label and their own judgment. */
 150: export function scheduledSprayIsGood(value: ScheduledWeatherObservation) {
 151:   return pointIsClearlyGood(value.current)
 152:     && value.next_four_hours.length === SCHEDULED_WEATHER_LIMITS.requiredFutureHours
 153:     && value.next_four_hours.every(pointIsClearlyGood)
 154: }
