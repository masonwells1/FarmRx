  80: /** Parse the production provider envelope and fail closed on every incomplete,
  81:  * stale, future-dated, or misaligned shape. The current point is aligned to its
  82:  * containing hourly bucket; four complete consecutive future hours are required. */
  83: export function parseScheduledWeatherResponse(value: unknown, now: Date): ScheduledWeatherObservation {
  84:   if (!plainObject(value) || !plainObject(value.current) || !plainObject(value.hourly)) throw new Error('weather response is malformed')
  85:   if (!Number.isFinite(now.getTime())) throw new Error('scheduler clock is invalid')
  86:
  87:   const offset = finiteNumber(value.utc_offset_seconds, 'utc_offset_seconds')
  88:   if (!Number.isInteger(offset) || Math.abs(offset) > 64_800) throw new Error('utc_offset_seconds is invalid')
  89:   const currentTime = value.current.time
  90:   if (typeof currentTime !== 'string' || !localTimePattern.test(currentTime)) throw new Error('current weather time is malformed')
  91:
  92:   const observedAtMs = localTimeMilliseconds(currentTime) - offset * 1_000
  93:   const ageMinutes = (now.getTime() - observedAtMs) / 60_000
  94:   if (ageMinutes > SCHEDULED_WEATHER_LIMITS.maximumObservationAgeMinutes) throw new Error('current weather observation is stale')
  95:   if (ageMinutes < -SCHEDULED_WEATHER_LIMITS.maximumObservationFutureMinutes) throw new Error('current weather observation is materially future-dated')
  96:
  97:   const times = value.hourly.time
  98:   if (!Array.isArray(times) || !times.every((item): item is string => typeof item === 'string' && localTimePattern.test(item))) {
  99:     throw new Error('hourly weather times are missing or malformed')
 100:   }
 101:   const hourlyKeys = [...pointKeys, 'precipitation_probability'] as const
 102:   for (const key of hourlyKeys) {
 103:     const series = value.hourly[key]
 104:     if (!Array.isArray(series) || series.length !== times.length) throw new Error(`hourly ${key} is missing or misaligned`)
 105:   }
 106:
 107:   const alignedHour = `${currentTime.slice(0, 13)}:00`
 108:   const start = times.indexOf(alignedHour)
 109:   if (start < 0 || start + SCHEDULED_WEATHER_LIMITS.requiredFutureHours >= times.length) throw new Error('current and next-four-hour weather are not aligned')
 110:   for (let index = start; index <= start + SCHEDULED_WEATHER_LIMITS.requiredFutureHours; index += 1) {
 111:     if (localTimeMilliseconds(times[index]) !== localTimeMilliseconds(alignedHour) + (index - start) * 3_600_000) {
 112:       throw new Error('hourly weather times are not consecutive')
 113:     }
 114:   }
 115:
 116:   const probabilitySeries = value.hourly.precipitation_probability as unknown[]
 117:   const current = readPoint(value.current, currentTime, probabilitySeries[start], 'current')
 118:   const nextFourHours: ScheduledWeatherPoint[] = []
 119:   for (let index = start + 1; index <= start + SCHEDULED_WEATHER_LIMITS.requiredFutureHours; index += 1) {
 120:     const source: Record<string, unknown> = {}
 121:     for (const key of pointKeys) source[key] = (value.hourly[key] as unknown[])[index]
 122:     nextFourHours.push(readPoint(source, times[index], probabilitySeries[index], `hourly[${index}]`))
 123:   }
 124:
 125:   return {
 126:     observed_at: new Date(observedAtMs).toISOString(),
 127:     local_date: currentTime.slice(0, 10),
 128:     utc_offset_seconds: offset,
 129:     current,
 130:     next_four_hours: nextFourHours,
 131:   }
 132: }
