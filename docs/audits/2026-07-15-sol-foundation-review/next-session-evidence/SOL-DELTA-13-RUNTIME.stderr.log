   1: import { supabase } from '../lib/supabaseClient'
   2: import type { GrainWorkspace } from './grain'
   3: import { evaluateMarketingAlertRules } from './marketingAlerts'
   4: import { getOperationalIntegrityCapability } from './operationalIntegrityCapability'
