  94: on public.push_subscriptions for insert to authenticated
  95: with check (user_id = auth.uid());
  96:
  97: create policy push_subscriptions_update
  98: on public.push_subscriptions for update to authenticated
  99: using (user_id = auth.uid())
 100: with check (user_id = auth.uid());
 101:
