 134: function pointIsClearlyGood(value: ScheduledWeatherPoint) {
 135:   const limits = SCHEDULED_WEATHER_LIMITS
 136:   return value.temperature_2m >= limits.minimumTemperatureF
 137:     && value.temperature_2m <= limits.maximumTemperatureF
 138:     && value.wind_speed_10m >= limits.minimumWindMph
 139:     && value.wind_speed_10m <= limits.maximumWindMph
 140:     && value.wind_gusts_10m <= limits.maximumGustMph
 141:     && value.precipitation === 0
 142:     && value.rain === 0
 143:     && value.precipitation_probability < limits.maximumPrecipitationProbability
 144:     && value.weather_code >= 0
 145:     && value.weather_code <= 3
 146: }
