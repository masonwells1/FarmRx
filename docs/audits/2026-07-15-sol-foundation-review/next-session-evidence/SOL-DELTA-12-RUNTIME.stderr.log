0101:     try {
0102:       if (controller.signal.aborted) throw new DOMException(budgetExpired, 'AbortError')
0103:       const providerTimeoutMs = Math.min(providerMaxMs, deadlineAt - Date.now() - completionReserveMs)
0104:       if (providerTimeoutMs < 1) { controller.abort(); throw new DOMException(budgetExpired, 'AbortError') }
