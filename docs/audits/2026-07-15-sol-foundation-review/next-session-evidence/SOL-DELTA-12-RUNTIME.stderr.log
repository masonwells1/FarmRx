0001: const fallback = '/notifications'
0002: const unsafeCharacters = /[\\\u0000-\u001f\u007f]/
0003:
0004: export function safeNotificationLink(value: unknown, origin: string): string {
0005:   if (typeof value !== 'string' || value.length > 2_048 || !value.startsWith('/') || value.startsWith('//') || unsafeCharacters.test(value)) return fallback
0006:   try {
0007:     const resolved = new URL(value, origin)
0008:     if (resolved.origin !== origin) return fallback
0009:     const canonical = `${resolved.pathname}${resolved.search}${resolved.hash}`
0010:     // URL dot-segment normalization can turn an apparently relative path such
0011:     // as `/..//example.test` into a protocol-relative `//example.test` URL.
0012:     // Validate the canonical value that will actually be opened, not only the
0013:     // caller-provided spelling.
0014:     if (!canonical.startsWith('/') || canonical.startsWith('//') || unsafeCharacters.test(canonical)) return fallback
0015:     if (new URL(canonical, origin).origin !== origin) return fallback
0016:     return canonical
0017:   } catch { return fallback }
0018: }
