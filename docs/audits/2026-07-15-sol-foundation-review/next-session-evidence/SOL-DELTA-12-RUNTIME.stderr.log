0107:       const status = providerStatus(error)
0108:       if (status === 404 || status === 410) {
0109:         try { await finishWithRetry(database, target.target_id, 'gone', `push provider status ${status}`, controller.signal); gone += 1 }
0110:         catch { failed += 1 }
