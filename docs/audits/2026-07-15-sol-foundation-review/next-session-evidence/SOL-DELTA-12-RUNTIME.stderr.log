0112:         // Do not persist or log provider messages: they can include endpoints or
0113:         // request details. A stable status is enough for retry diagnostics.
0114:         const reason = controller.signal.aborted ? budgetExpired : status === null ? 'push provider failure' : `push provider status ${status}`
