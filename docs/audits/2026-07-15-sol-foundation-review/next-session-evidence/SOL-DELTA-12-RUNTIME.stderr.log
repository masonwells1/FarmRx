0116:         catch { /* The invocation remains unhealthy; the sending lease expires for retry. */ }
0117:         finally { failed += 1 }
0118:       }
0119:       return
0120:     }
0121:     // A provider success must never be reclassified as a provider failure when
0122:     // only the database completion write fails. Retry that write in place; if
0123:     // it stays unavailable, leave the target sending and fail the invocation.
0124:     try { await finishWithRetry(database, target.target_id, 'sent', null, controller.signal); sent += 1 }
0125:     catch { failed += 1 }
0126:   }
0127:
0128:   const worker = async () => {
0129:     while (true) {
0130:       if (controller.signal.aborted) return
0131:       const index = cursor
0132:       cursor += 1
0133:       if (index >= targets.length) return
0134:       await deliverOne(targets[index]!)
0135:     }
0136:   }
0137:
0138:   try {
0139:     await Promise.all(Array.from({ length: Math.min(concurrency, targets.length) }, () => worker()))
0140:     if (controller.signal.aborted) failed = Math.max(failed, targets.length - sent - gone)
