===== supabase\functions\_shared\pushDeliveryLogic.ts =====
0001: export type PushTargetOutcome = 'sent' | 'retry' | 'gone'
0002:
0003: export interface ClaimedPushTarget {
0004:   target_id: string
0005:   notification_id: string
0006:   endpoint: string
0007:   p256dh: string
0008:   auth: string
0009:   title: string
0010:   body: string | null
0011:   link: string | null
0012:   category: string
0013: }
0014:
0015: export interface PushDeliveryDatabase {
0016:   claimTargets(notificationId: string | null, limit: number, signal: AbortSignal): Promise<ClaimedPushTarget[]>
0017:   finishTarget(targetId: string, outcome: PushTargetOutcome, error: string | null, signal: AbortSignal): Promise<void>
0018:   getHealth(notificationId: string | null, signal: AbortSignal): Promise<{ terminalFailed: number; retryable: number }>
0019: }
0020:
0021: export interface PushProvider {
0022:   send(target: ClaimedPushTarget, payload: string, signal: AbortSignal, timeoutMs: number): Promise<void>
0023: }
0024:
0025: export interface PushDeliveryResult {
0026:   claimed: number
0027:   sent: number
0028:   failed: number
0029:   gone: number
0030:   terminalFailed: number
0031:   retryable: number
0032: }
0033:
0034: export interface PushDeliveryOptions { limit?: number; concurrency?: number; budgetMs?: number }
0035:
0036: const budgetExpired = 'push delivery budget exhausted'
0037:
0038: function providerStatus(error: unknown) {
0039:   const status = (error as { statusCode?: unknown } | null)?.statusCode
0040:   return typeof status === 'number' && Number.isInteger(status) ? status : null
0041: }
0042:
0043: async function finishWithRetry(database: PushDeliveryDatabase, targetId: string, outcome: PushTargetOutcome, error: string | null, signal: AbortSignal) {
0044:   let failure: unknown
0045:   for (let attempt = 0; attempt < 3; attempt += 1) {
0046:     try { await callBeforeAbort(() => database.finishTarget(targetId, outcome, error, signal), signal); return }
0047:     catch (caught) { failure = caught }
0048:   }
0049:   throw failure
0050: }
0051:
0052: function beforeAbort<T>(promise: Promise<T>, signal: AbortSignal): Promise<T> {
0053:   if (signal.aborted) return Promise.reject(new DOMException(budgetExpired, 'AbortError'))
0054:   return new Promise<T>((resolve, reject) => {
0055:     const aborted = () => reject(new DOMException(budgetExpired, 'AbortError'))
0056:     signal.addEventListener('abort', aborted, { once: true })
0057:     promise.then(
0058:       (value) => { signal.removeEventListener('abort', aborted); resolve(value) },
0059:       (error) => { signal.removeEventListener('abort', aborted); reject(error) },
0060:     )
0061:   })
0062: }
0063:
0064: function callBeforeAbort<T>(operation: () => Promise<T>, signal: AbortSignal): Promise<T> {
0065:   if (signal.aborted) return Promise.reject(new DOMException(budgetExpired, 'AbortError'))
0066:   try { return beforeAbort(operation(), signal) }
0067:   catch (error) { return Promise.reject(error) }
0068: }
0069:
0070: export async function deliverClaimedPushTargets(
0071:   database: PushDeliveryDatabase,
0072:   provider: PushProvider,
