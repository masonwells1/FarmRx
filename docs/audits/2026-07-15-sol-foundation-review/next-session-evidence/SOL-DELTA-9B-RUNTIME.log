   53: create or replace function public.finish_push_delivery(p_delivery_id uuid, p_sent boolean, p_error text default null)
   54: returns jsonb language plpgsql security definer set search_path=public,pg_temp as $$
   55: declare v public.push_deliveries%rowtype;
   56: begin
   57:   if not public.request_uses_service_role() then raise exception 'server delivery only'; end if;
   58:   select * into v from public.push_deliveries where id=p_delivery_id for update;
   59:   if not found then raise exception 'push delivery not found'; end if;
   60:   if v.status='sent' then return jsonb_build_object('id',v.id,'status','sent'); end if;
   61:   -- A failure recorded on a never-claimed row must stay retryable: the failed
   62:   -- branch's backoff predicate compares claimed_at, so stamp it here.
   63:   update public.push_deliveries set status=case when p_sent then 'sent' else 'failed' end,
   64:     sent_at=case when p_sent then now() else null end, claimed_at=case when p_sent then claimed_at else coalesce(claimed_at, now()) end,
   65:     last_error=left(coalesce(p_error,''),1000), updated_at=now()
   66:   where id=p_delivery_id returning * into v;
   67:   return jsonb_build_object('id',v.id,'status',v.status);
