  165: create or replace function public.record_scheduled_spray_window(
  166:   p_farm_id uuid,p_field_id uuid,p_local_date date,p_is_good boolean,p_observed_at timestamptz,p_observation jsonb
  167: )
  168: returns jsonb language plpgsql security definer set search_path=public,pg_temp as $$
  169: declare v_owner uuid; v_field_name text; v_previous boolean; v_notification uuid;
  170: begin
  171:   if not public.request_uses_service_role() then raise exception 'server scheduler only'; end if;
  172:   if p_observed_at is null or p_observation is null or jsonb_typeof(p_observation)<>'object' then raise exception 'complete spray observation required'; end if;
  173:   perform pg_advisory_xact_lock(hashtext(p_farm_id::text),hashtext('spray:'||p_field_id::text||':'||p_local_date::text));
  174:   select name into v_field_name from public.fields where id=p_field_id and farm_id=p_farm_id and is_active;
  175:   if not found then raise exception 'active field not found for this farm'; end if;
  176:   select is_good into v_previous from public.spray_window_states where field_id=p_field_id and local_date=p_local_date for update;
  177:   if not found then
  178:     insert into public.spray_window_states(farm_id,field_id,local_date,is_good,observed_at,observation) values(p_farm_id,p_field_id,p_local_date,p_is_good,p_observed_at,p_observation);
  179:     return jsonb_build_object('fired',false,'initialized',true);
  180:   end if;
  181:   update public.spray_window_states set is_good=p_is_good,observed_at=p_observed_at,observation=p_observation,updated_at=now() where field_id=p_field_id and local_date=p_local_date;
  182:   if not v_previous and p_is_good then
  183:     select user_id into v_owner from public.farm_memberships where farm_id=p_farm_id and role='owner' and status='active' order by user_id limit 1;
  184:     if v_owner is not null then insert into public.notifications(farm_id,user_id,category,title,body,link,dedupe_key,created_by) values(p_farm_id,v_owner,'spray',left('Spray window is good on '||v_field_name,160),'Current field conditions have turned good for spraying today. Always follow the product label and applicator judgment.','/weather','spray:'||p_field_id||':'||p_local_date,v_owner) on conflict(farm_id,user_id,dedupe_key) where dedupe_key is not null do nothing returning id into v_notification; end if;
  185:   end if;
  186:   return jsonb_build_object('fired',v_notification is not null,'notification_id',v_notification);
  187: end $$;
