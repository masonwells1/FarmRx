 138:       }
 139:       if (state.kind !== 'active' || state.serverEpoch !== serverEpoch) {
 140:         quarantineRevokedFarmWork(target, scope)
 141:         await deleteUserWorkspaceCaches(supabaseConfig.projectRef, userId, farm.id)
