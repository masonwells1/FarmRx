 134:       const priorServerEpoch = Math.max(state.serverEpoch ?? 0, priorEpochs[farm.id] ?? 0)
 135:       const recoveringKnownScope = state.kind === 'revoked' || state.kind === 'invalid' || state.kind === 'missing' && wasKnown
 136:       if (serverEpoch < priorServerEpoch || recoveringKnownScope && (priorServerEpoch === 0 || serverEpoch <= priorServerEpoch)) {
