 115: /** Moves revoked farm work to a separate recovery vault. It deliberately never writes to a live queue. */
 116: export function quarantineRevokedFarmWork(storage: EnumeratedStorage, scope: Scope, capturedAt = new Date().toISOString()): number {
 117:   quarantineLegacyScoutingCleanup(storage, scope.projectRef)
 118:   const candidate: Array<{ key: string; kind: RevokedWorkKind; payload: unknown }> = []
 119:   const emptyKeys: string[] = []
 120:   for (let index = 0; index < storage.length; index += 1) {
 121:     const key = storage.key(index); if (!key || key.endsWith(':lease')) continue
 122:     const expected = expectedQueueKey(key, scope); if (!expected) continue
 123:     const raw = storage.getItem(key); if (raw === null) continue
 124:     try {
 125:       const payload = expected.kind === 'queue' ? JSON.parse(raw) as unknown : parseNeedsAttentionPayload(expected.definition, raw, scope)
 126:       const entries = expected.kind === 'queue' ? scopedEntries(expected.definition, raw, scope) : (payload as { records: unknown[] }).records
 127:       if (entries.length === 0) { emptyKeys.push(key); continue }
 128:       candidate.push({ key, kind: expected.kind, payload })
 129:     } catch { throw new Error('Farm Rx found unreadable or mismatched saved work for a farm you no longer can open. Nothing was cleared.') }
 130:   }
 131:   const cleanupKey = scoutingCleanupOutboxKey(scope.projectRef, scope.userId)
 132:   const cleanupRaw = storage.getItem(cleanupKey)
 133:   let cleanupAll: ScoutingCleanupEntry[] = []
 134:   if (cleanupRaw !== null) {
 135:     try { const parsed: unknown = JSON.parse(cleanupRaw); if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed) || Object.keys(parsed).length !== 2 || (parsed as { version?: unknown }).version !== 2 || !Array.isArray((parsed as { entries?: unknown }).entries) || !(parsed as { entries: unknown[] }).entries.every((entry) => !!entry && typeof entry === 'object' && !Array.isArray(entry) && typeof (entry as { farmId?: unknown }).farmId === 'string' && validScoutingCleanup(entry, (entry as { farmId: string }).farmId, scope.userId))) throw new Error(); cleanupAll = (parsed as { entries: ScoutingCleanupEntry[] }).entries } catch { throw new Error('Farm Rx could not safely read saved scouting cleanup work. Nothing was cleared.') }
 136:     const partition = cleanupAll.filter((entry) => entry.farmId === scope.farmId)
 137:     if (partition.length) candidate.push({ key: cleanupKey, kind: 'scouting_cleanup', payload: partition })
 138:   }
 139:   const recoveryKey = revokedFarmRecoveryKey(scope.projectRef, scope.userId)
 140:   const prior = candidate.length ? parse(storage.getItem(recoveryKey)) : { version: 1 as const, records: [] }
 141:   const additions: RevokedWorkItem[] = []
 142:   for (const { key, kind, payload } of candidate) {
 143:     const existing = [...prior.records, ...additions]
 144:     if (existing.some((record) => sameRecord(record, scope, kind, key, payload))) continue
 145:     const base = baseId(scope, kind, key, payload)
 146:     let nextId = base; let suffix = 2
 147:     while (existing.some((record) => record.id === nextId)) { nextId = `${base}-${suffix}`; suffix += 1 }
 148:     additions.push({ version: 1, id: nextId, projectRef: scope.projectRef, userId: scope.userId, farmId: scope.farmId, originalKey: key, kind, capturedAt, reason: 'farm_access_removed', payload })
 149:   }
 150:   if (candidate.length) durableWrite(storage, recoveryKey, { version: 1, records: [...prior.records, ...additions] })
 151:   for (const item of candidate) {
 152:     if (item.kind === 'scouting_cleanup') {
 153:       const bytes = JSON.stringify({ version: 2, entries: cleanupAll.filter((entry) => entry.farmId !== scope.farmId || entry.userId !== scope.userId) })
 154:       storage.setItem(item.key, bytes); if (storage.getItem(item.key) !== bytes) throw new Error('Farm Rx could not remove active scouting cleanup work after recovery was saved.')
 155:     } else { storage.removeItem(item.key); if (storage.getItem(item.key) !== null) throw new Error('Farm Rx could not remove active saved work after recovery was saved.') }
 156:   }
 157:   for (const key of emptyKeys) { storage.removeItem(key); if (storage.getItem(key) !== null) throw new Error('Farm Rx could not remove an empty saved-work queue for a farm you no longer can open.') }
 158:   return candidate.length
 159: }
   1: import type { StorageLike } from './writeQueue'
