  63:
  64: .nav-link:hover { color: #fff; background: rgb(255 255 255 / 5%); }
  65: .nav-link.active { color: #fff; background: rgb(255 255 255 / 6%); font-weight: 600; }
  66: .nav-link.active::before { content: ""; position: absolute; left: 0; top: 8px; bottom: 8px; width: 3px; border-radius: 0 3px 3px 0; background: var(--crx-green); }
  67: .nav-icon { width: 22px; display: inline-flex; align-items: center; justify-content: center; }
