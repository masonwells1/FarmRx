 567: function MobileNavigation() {
 568:   const location = useLocation();
 569:   const [moreOpen, setMoreOpen] = useState(false);
 570:   const moreActive = mobileMoreNavigation.some((item) => location.pathname === item.path || location.pathname.startsWith(`${item.path}/`));
 571:   useEffect(() => setMoreOpen(false), [location.pathname]);
 572:   return (
 573:     <>
 574:       {moreOpen && (
 575:         <section className="mobile-more-menu" id="mobile-more-menu" aria-label="More Farm Rx destinations">
 576:           <header><strong>More</strong><button type="button" onClick={() => setMoreOpen(false)} aria-label="Close more navigation">Close</button></header>
 577:           <Navigation className="mobile-more-grid" items={mobileMoreNavigation} onNavigate={() => setMoreOpen(false)} />
 578:         </section>
 579:       )}
 580:       <nav className="mobile-nav" aria-label="Farm Rx navigation">
 581:         <div className="mobile-nav-list">
 582:           {mobilePrimaryNavigation.map((item) => (
 583:             <NavLink key={item.path} className="nav-link" to={item.path}>
 584:               <span className="nav-icon" aria-hidden="true">{item.icon}</span>
 585:               <span>{item.label}</span>
 586:             </NavLink>
 587:           ))}
 588:           <button className={`nav-link mobile-more-toggle${moreActive ? " active" : ""}`} type="button" aria-expanded={moreOpen} aria-controls="mobile-more-menu" onClick={() => setMoreOpen((open) => !open)}>
 589:             <span className="nav-icon" aria-hidden="true"><NavGlyph d="M5 12h.01M12 12h.01M19 12h.01" /></span>
 590:             <span>More</span>
 591:           </button>
 592:         </div>
 593:       </nav>
 594:     </>
 595:   );
 596: }
