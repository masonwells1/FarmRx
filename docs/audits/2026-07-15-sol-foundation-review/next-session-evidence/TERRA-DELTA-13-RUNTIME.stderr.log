 401: .login-card input { width: 100%; min-height: 52px; margin-bottom: 12px; padding: 12px 14px; border: 2px solid var(--hairline); border-radius: 9px; color: var(--charcoal); background: var(--surface); }
 402: .login-card select { width: 100%; min-height: 52px; margin-bottom: 12px; padding: 12px 14px; border: 2px solid var(--hairline); border-radius: 9px; color: var(--charcoal); background: var(--surface); font-size: 18px; }
 403: .login-card input::placeholder { color: #717171; }
