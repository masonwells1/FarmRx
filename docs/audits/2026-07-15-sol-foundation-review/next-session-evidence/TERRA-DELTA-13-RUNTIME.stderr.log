  69: export function queueFarmRevocationScope(key: string): FarmRevocationScope | null {
  70:   const match = queueKeyPattern.exec(key)
  71:   return match ? { projectRef: match[1]!, userId: match[2]!, farmId: match[3]! } : null
  72: }
  73:
  74: export function listFarmRevocationScopes(storage: EnumeratedStorage, projectRef: string, userId: string): FarmRevocationScope[] {
  75:   const farmIds = new Set<string>()
  76:   for (let index = 0; index < storage.length; index += 1) {
  77:     const key = storage.key(index); if (!key) continue
  78:     const match = queueKeyPattern.exec(key) ?? fenceKeyPattern.exec(key)
  79:     if (match?.[1] === projectRef && match[2] === userId) farmIds.add(match[3]!)
  80:   }
  81:   return [...farmIds].sort().map((farmId) => ({ projectRef, userId, farmId }))
  82: }
  83:
  84: export function inspectFarmRevocationState(storage: StorageLike, scope: FarmRevocationScope): { kind: 'missing' | 'invalid' | 'active' | 'revoked'; generation?: number; serverEpoch?: number } {
  85:   const fenceRaw = storage.getItem(farmRevocationFenceKey(scope)); const ledgerRaw = storage.getItem(farmRevocationGenerationKey(scope))
  86:   if (fenceRaw === null && ledgerRaw === null) return { kind: 'missing' }
  87:   try {
  88:     const { fence, ledger } = readState(storage, scope)
  89:     if (!fence || !ledger) return { kind: 'invalid', generation: fence?.generation ?? ledger?.generation, serverEpoch: fence?.serverEpoch ?? ledger?.serverEpoch }
  90:     return { kind: fence.revoked ? 'revoked' : 'active', generation: fence.generation, serverEpoch: fence.serverEpoch }
  91:   } catch {
  92:     let fence: Fence | null = null; let ledger: GenerationLedger | null = null
  93:     try { if (fenceRaw !== null) fence = parseFence(fenceRaw) } catch { /* retain any independently valid ledger */ }
  94:     try { if (ledgerRaw !== null) ledger = parseLedger(ledgerRaw) } catch { /* retain any independently valid fence */ }
  95:     const generation = Math.max(fence?.generation ?? 0, ledger?.generation ?? 0) || undefined
  96:     const serverEpoch = Math.max(fence?.serverEpoch ?? 0, ledger?.serverEpoch ?? 0) || undefined
  97:     return { kind: 'invalid', generation, serverEpoch }
  98:   }
  99: }
