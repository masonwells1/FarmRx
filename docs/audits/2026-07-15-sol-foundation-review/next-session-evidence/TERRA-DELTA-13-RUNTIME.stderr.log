' : ' unread'}`} key={notification.id}><button className="notification-open" onClick={() => { void mark(notification.read_at ? [] : [notification.id]); navigate(notification.link ?? '/notifications') }}><span className={`notification-category ${notification.category}`}>{labels[notification.category]}</span><strong>{notification.title}</strong>{notification.body && <p>{notification.body}</p>}<time dateTime={notification.created_at}>{relativeTime(notification.created_at)}</time></button><button className="secondary-action notification-read" onClick={() => void mark([notification.id])} disabled={notification.read_at !== null || busy === notification.id}>{notification.read_at ? 'Read' : busy === notification.id ? 'Saving…' : 'Mark read'}</button></article>)}</div>}</section>
