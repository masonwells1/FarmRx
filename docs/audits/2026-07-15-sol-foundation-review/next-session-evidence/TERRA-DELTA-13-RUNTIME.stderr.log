  87:
  88: /* Notification center: plain-language, phone-first alerts without crowding the farm work. */
  89: .notifications-page { display: grid; gap: 18px; }
  90: .notifications-heading { margin-bottom: 0; }
  91: .phone-alerts { display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: center; padding: 20px; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--light-green); }
  92: .phone-alerts h2 { margin: 0; color: var(--deep-green); font-size: 22px; }
  93: .phone-alerts p { margin: 6px 0 0; color: var(--matte-gray); }
  94: .phone-alerts .phone-alert-message { grid-column: 1 / -1; margin: 0; color: var(--deep-green); font-weight: 700; }
  95: .mark-all { justify-self: start; min-height: 48px; color: var(--deep-green); font: inherit; font-weight: 700; text-decoration: underline; }
  96: .notifications-list { display: grid; gap: 12px; }
  97: .notification-row { display: grid; grid-template-columns: 1fr auto; gap: 12px; align-items: center; padding: 12px; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--surface); }
  98: .notification-row.unread { border-left: 6px solid var(--crx-green); background: var(--light-green); }
  99: .notification-open { min-width: 0; display: grid; gap: 7px; padding: 4px; border: 0; background: transparent; color: var(--charcoal); font: inherit; text-align: left; cursor: pointer; }
 100: .notification-open strong { font-size: 19px; }
