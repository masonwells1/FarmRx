/* Notification center: plain-language, phone-first alerts without crowding the farm work. */
.notifications-page { display: grid; gap: 18px; }
.notifications-heading { margin-bottom: 0; }
.phone-alerts { display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: center; padding: 20px; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--light-green); }
.phone-alerts h2 { margin: 0; color: var(--deep-green); font-size: 22px; }
.phone-alerts p { margin: 6px 0 0; color: var(--matte-gray); }
.phone-alerts .phone-alert-message { grid-column: 1 / -1; margin: 0; color: var(--deep-green); font-weight: 700; }
.mark-all { justify-self: start; min-height: 48px; color: var(--deep-green); font: inherit; font-weight: 700; text-decoration: underline; }
.notifications-list { display: grid; gap: 12px; }
.notification-row { display: grid; grid-template-columns: 1fr auto; gap: 12px; align-items: center; padding: 12px; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--surface); }
.notification-row.unread { border-left: 6px solid var(--crx-green); background: var(--light-green); }
.notification-open { min-width: 0; display: grid; gap: 7px; padding: 4px; border: 0; background: transparent; color: var(--charcoal); font: inherit; text-align: left; cursor: pointer; }
.notification-open strong { font-size: 19px; }
.notification-open p { margin: 0; color: var(--matte-gray); }
.notification-open time { color: var(--matte-gray); font-size: 18px; }
.notification-category { width: fit-content; min-height: 30px; display: inline-flex; align-items: center; padding: 3px 10px; border-radius: 99px; background: var(--light-green); color: var(--deep-green); font-size: 18px; font-weight: 700; }
.notification-category.spray, .notification-category.service { background: #e7f3e9; }
.notification-category.scouting, .notification-category.task { background: var(--warn-bg); color: #604a22; }
.notification-category.harvest { background: #f3eee1; color: #69531f; }
.notification-read { min-width: 118px; }
@media (max-width: 767px) { .topbar-actions { gap: 8px; }.phone-alerts, .notification-row { grid-template-columns: 1fr; }.phone-alerts > button, .notification-read { width: 100%; }.notification-row { gap: 8px; }.notification-open { min-height: 48px; }.notifications-page { gap: 16px; } }
.product-name { color: var(--charcoal); font-size: 24px; font-weight: 700; }
.farm-summary { color: var(--matte-gray); font-size: 18px; }
.content-area { max-width: 1320px; margin: 0 auto; padding: 32px; }

.page-heading { display: flex; justify-content: space-between; align-items: end; gap: 24px; margin-bottom: 26px; }
h1 { margin: 0; color: var(--charcoal); font-size: 34px; font-weight: 700; letter-spacing: -.01em; line-height: 1.12; }
h1 .accent-word { font-weight: 500; color: var(--crx-green); }
.page-heading p { margin: 6px 0 0; color: var(--matte-gray); }
.primary-action { min-width: 48px; min-height: 52px; display: inline-flex; align-items: center; justify-content: center; border: 0; border-radius: 12px; padding: 12px 20px; background: var(--crx-green); color: var(--on-dark); font-weight: 700; text-decoration: none; transition: background-color 180ms ease-out, transform 180ms ease-out; }
.primary-action:hover { background: var(--deep-green); }
.primary-action:active { transform: translateY(1px); }

.stats-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px; margin-bottom: 26px; }
.stat-card { overflow: hidden; border: 1px solid var(--hairline); border-top: 6px solid var(--crx-green); border-radius: var(--radius); background: var(--surface); text-align: left; box-shadow: var(--shadow-card); }
.stats-grid > :nth-child(3n+2) .stat-card, .stats-grid > .stat-card:nth-child(3n+2) { border-top-color: var(--amber); }
.stats-grid > :nth-child(3n) .stat-card, .stats-grid > .stat-card:nth-child(3n) { border-top-color: var(--deep-green); }
.stat-label { display: block; padding: 17px 20px 0; background: transparent; color: var(--matte-gray); font-size: 18px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; }
.stat-value { display: block; padding: 11px 20px 20px; color: var(--charcoal); font-family: var(--brand-font); font-size: 42px; font-weight: 700; line-height: 1.05; }
.stat-unit { display: block; margin-top: 7px; color: var(--matte-gray); font-family: var(--ui-font); font-size: 18px; font-weight: 500; }

.data-card { overflow: hidden; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--surface); box-shadow: var(--shadow-card); }
.card-heading { padding: 16px 22px 13px; background: var(--surface); border-bottom: 1px solid var(--hairline); color: var(--charcoal); font-size: 21px; font-weight: 600; letter-spacing: 0; text-transform: none; }
.table-scroll { overflow-x: auto; }
table { width: 100%; min-width: 680px; border-collapse: collapse; }
th { padding: 10px 22px 8px; color: var(--matte-gray); font-size: 18px; font-weight: 700; letter-spacing: .05em; text-align: left; text-transform: uppercase; }
td { padding: 16px 22px; border-top: 1px solid var(--hairline); font-size: 18px; }
tbody tr:nth-child(even) td { background: var(--cream); }
.field-name { font-weight: 700; }
.align-right { text-align: right; }
.table-total { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 16px 22px; background: var(--crx-green); color: var(--on-dark); font-size: 18px; font-weight: 700; }
.interactive-row { cursor: pointer; transition: background-color 180ms ease-out; }
.interactive-row:hover td, .interactive-row:focus td { background: var(--light-green); }
.interactive-row:focus { outline: 3px solid var(--amber); outline-offset: -3px; }
.sort-button { min-width: 48px; min-height: 48px; padding: 8px 0; border: 0; color: inherit; background: transparent; font: inherit; font-weight: 700; letter-spacing: inherit; text-transform: inherit; }
.sort-button.active { color: var(--deep-green); }

.filter-bar { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; padding: 16px 22px; border-bottom: 1px solid var(--hairline); background: var(--green-tint); }
.filter-control { display: grid; gap: 4px; color: var(--matte-gray); font-size: 18px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; }
.filter-control select, .form-control input, .form-control select, .form-control textarea { width: 100%; min-height: 48px; padding: 10px 12px; border: 2px solid var(--hairline); border-radius: 9px; color: var(--charcoal); background: var(--surface); font-size: 18px; letter-spacing: 0; text-transform: none; }
.filter-control select:focus, .form-control input:focus, .form-control select:focus, .form-control textarea:focus { border-color: var(--crx-green); outline: none; }
.filter-empty { padding: 40px 22px; color: var(--matte-gray); text-align: center; }
.fields-empty { margin: 48px auto; }
.empty-mark { width: 58px; height: 58px; display: grid; place-items: center; margin: 0 auto 16px; border-radius: 50%; background: var(--light-green); color: var(--deep-green); font-size: 30px; font-weight: 700; }

.detail-page { max-width: 900px; }
.detail-topline { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 16px; }
.back-link, .text-action { min-width: 48px; min-height: 48px; display: inline-flex; align-items: center; color: var(--deep-green); font-weight: 700; text-decoration: none; }
.secondary-action { min-width: 48px; min-height: 48px; display: inline-flex; align-items: center; justify-content: center; border: 2px solid var(--deep-green); border-radius: 9px; padding: 8px 16px; color: var(--deep-green); background: var(--surface); font-weight: 700; text-decoration: none; }
.secondary-action:hover { background: var(--light-green); }
.compact-heading { margin-bottom: 22px; }
.detail-card { overflow: hidden; margin-bottom: 20px; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--surface); }
.info-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); margin: 0; }
.info-grid > div { min-height: 96px; padding: 17px 20px; border-right: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); }
.info-grid > div:nth-child(even) { border-right: 0; }
.info-grid > div:nth-last-child(-n+2) { border-bottom: 0; }
.info-grid dt { margin-bottom: 5px; color: var(--matte-gray); font-family: var(--brand-font); font-size: 18px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; }
.info-grid dd { margin: 0; font-weight: 600; }
.crop-history { padding: 2px 20px; }
.history-row { display: grid; grid-template-columns: 84px 1fr; gap: 16px; padding: 17px 0; border-bottom: 1px solid var(--hairline); }
.history-row:last-child { border-bottom: 0; }
.history-row strong { color: var(--deep-green); font-family: var(--brand-font); }
.history-assignment { display: grid; gap: 4px; margin-bottom: 12px; }
.history-assignment:last-child { margin-bottom: 0; }

.field-form { display: grid; gap: 20px; }
.field-form fieldset { margin: 0; padding: 0; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--surface); }
.field-form legend { margin-left: 16px; padding: 0 7px; color: var(--deep-green); font-family: var(--brand-font); font-size: 20px; font-weight: 700; }
.form-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18px; padding: 22px; }
.form-control { display: grid; gap: 6px; color: var(--matte-gray); font-family: var(--brand-font); font-size: 18px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; }
.form-control em { color: var(--matte-gray); font-family: var(--ui-font); font-size: 18px; font-style: normal; font-weight: 500; }
.form-control small { color: var(--matte-gray); font-family: var(--ui-font); font-size: 18px; font-weight: 500; letter-spacing: 0; text-transform: none; }
.form-control input[aria-invalid="true"] { border-color: var(--warn-red); }
.form-note { margin: 0; padding: 0 22px 18px; color: var(--matte-gray); font-size: 18px; }
.crop-editor { display: grid; gap: 12px; padding: 0 22px 16px; }
.crop-row { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)) auto; align-items: end; gap: 12px; }
.remove-crop { min-width: 80px; border: 0; background: transparent; text-align: left; }
.field-form fieldset > .secondary-action { margin: 0 22px 22px; }
.form-error { padding: 14px 16px; border: 1px solid var(--warn-red); border-radius: 9px; color: var(--warn-red); background: var(--warn-bg); font-weight: 700; }
.form-submit { justify-self: start; min-width: 160px; }
.loading-state { min-height: 280px; display: grid; place-items: center; color: var(--matte-gray); }

/* Module 1 polish: readable inline capture and four card editor. */
.crop-nudge { width: 100%; border: 0; cursor: pointer; font: inherit; }
.crop-nudge.needs-attention { outline: 3px solid var(--crx-green); outline-offset: -3px; }
.stat-note { display: block; min-height: 48px; padding: 0 20px 16px; color: var(--deep-green); font-size: 18px; font-weight: 700; }
.crop-nudge:not(.needs-attention) .stat-note { color: var(--matte-gray); }
.inline-add-row td { padding: 12px 10px; background: var(--light-green) !important; }
.inline-add-row input, .card-form input, .card-form select, .card-form textarea { width: 100%; min-height: 48px; padding: 10px 12px; border: 2px solid var(--hairline); border-radius: 9px; background: var(--surface); color: var(--charcoal); font: inherit; font-size: 18px; }
.inline-add-row input:focus, .card-form input:focus, .card-form select:focus, .card-form textarea:focus { border-color: var(--crx-green); outline: none; }
.inline-add-note { color: var(--deep-green); font-weight: 700; }
.inline-add-error, .inline-add-saved { display: table-cell; padding-top: 0 !important; font-weight: 700; }
.inline-add-error { color: var(--warn-red); }
.inline-add-saved { color: var(--deep-green); }
.edit-card .card-heading { min-height: 58px; display: flex; align-items: center; justify-content: space-between; gap: 12px; }
.card-edit { min-width: 72px; min-height: 48px; border: 0; border-radius: 8px; background: var(--surface); color: var(--deep-green); font: inherit; font-size: 18px; font-weight: 700; }
.card-edit:hover { background: var(--light-green); }
.card-form { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; padding: 20px; }
.card-save { grid-column: 1 / -1; display: grid; justify-items: start; gap: 12px; }
.card-save .form-error { margin: 0; }
.equivalent-rent { display: grid; gap: 7px; padding: 18px 20px; border-top: 1px solid var(--hairline); background: var(--light-green); }
.equivalent-rent strong { color: var(--deep-green); font-family: var(--brand-font); font-size: 20px; }
.equivalent-rent span { color: var(--charcoal); font-size: 18px; }
.equivalent-rent small { color: var(--matte-gray); font-size: 18px; }
.flex-preview { grid-column: 1 / -1; margin: 0; padding: 14px 16px; border-radius: 9px; background: var(--light-green); color: var(--deep-green); font-size: 18px; font-weight: 700; }
.flex-legacy-note { grid-column: 1 / -1; display: grid; gap: 12px; justify-items: start; padding: 16px; border-radius: 9px; background: var(--warn-bg); }
.flex-legacy-note p { margin: 0; color: var(--charcoal); font-size: 18px; }
.input-shares { grid-column: 1 / -1; display: grid; gap: 16px; padding: 18px; border-radius: 12px; background: var(--cream); }
.input-shares-heading { display: flex; align-items: end; justify-content: space-between; gap: 16px; }
.input-shares-heading h3, .input-shares-heading p, .input-shares-heading small { margin: 0; }
.input-shares-heading h3 { color: var(--deep-green); font-family: var(--brand-font); font-size: 20px; }
.input-shares-heading p { color: var(--charcoal); font-size: 18px; font-weight: 700; }
.input-shares-heading small { display: block; margin-top: 4px; color: var(--matte-gray); font-size: 18px; }
.input-share-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; }
.yield-list, .record-list { display: grid; padding: 0 20px; }
.yield-list > div, .record-list > div { display: grid; grid-template-columns: minmax(180px, 1fr) auto auto; gap: 16px; align-items: center; min-height: 68px; padding: 10px 0; border-top: 1px solid var(--hairline); }
.yield-list > div:first-child, .record-list > div:first-child { border-top: 0; }
.yield-list span, .record-list span { text-align: right; }
.assignment-editor { grid-template-columns: 1fr; }
.assignment-edit-row { display: grid; grid-template-columns: minmax(180px, 1fr) minmax(180px, 1fr) minmax(180px, 1fr); gap: 12px; align-items: end; padding-bottom: 16px; border-bottom: 1px solid var(--hairline); }
.assignment-edit-row strong { min-height: 48px; display: flex; align-items: center; }
.card-empty { margin: 0; padding: 22px 20px; color: var(--matte-gray); }

.empty-page { min-height: calc(100vh - 136px); display: grid; place-items: center; }
.field-log-page { display: grid; gap: 20px; }

/* Programs template builder: phone-first cards with free-typed product lines. */
.programs-page { display: grid; gap: 20px; min-width: 0; max-width: 100%; overflow-x: clip; }
.programs-page, .programs-page * { font-variant-numeric: tabular-nums; }
.program-tabs { display: flex; gap: 12px; overflow-x: auto; padding-bottom: 2px; }
.program-tabs strong, .program-tabs span { min-width: max-content; min-height: 48px; display: inline-flex; align-items: center; padding: 8px 14px; border-radius: 9px; font-size: 18px; font-weight: 700; }
.program-tabs strong { background: var(--deep-green); color: var(--on-dark); }.program-tabs span { background: var(--cream); color: var(--matte-gray); }
.program-archived { display: flex; align-items: center; gap: 10px; min-height: 48px; font-size: 18px; font-weight: 700; }.program-archived input { width: 48px; height: 48px; }
.program-list { display: grid; gap: 12px; }.program-card, .pass-card { min-width: 0; max-width: 100%; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--surface); }
.program-card { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 18px 20px; }.program-card h2, .pass-card h3 { margin: 0; overflow-wrap: anywhere; color: var(--deep-green); font-family: var(--brand-font); font-size: 23px; }.program-card p, .pass-card header p { margin: 5px 0 0; color: var(--matte-gray); overflow-wrap: anywhere; }
.program-card-title { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; }.program-kind, .pass-number { display: inline-flex; align-items: center; min-height: 30px; padding: 3px 9px; border-radius: 99px; background: var(--cream); color: var(--matte-gray); font-size: 18px; font-weight: 700; text-transform: capitalize; }.program-kind.chemical { background: #e7f3e9; color: var(--deep-green); }.program-kind.fertility { background: #edf2de; color: #52621c; }.program-kind.fungicide { background: #f3eee1; color: #69531f; }
.program-card.archived, .assignment-track.archived-history { border-style: dashed; border-color: #7b756b; background: #f7f4ed; }.archived-badge { background: #efe8d8; color: #5e5139; border: 1px solid currentColor; }.pending-note { margin: 8px 0 0; color: #69531f; font-weight: 700; overflow-wrap: anywhere; }
.program-form, .pass-editor { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; padding: 20px; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--surface); }.program-form label, .pass-editor > label, .product-line label { display: grid; gap: 6px; color: var(--matte-gray); font-size: 18px; font-weight: 700; }.program-form input, .program-form select, .program-form textarea, .pass-editor input, .pass-editor select, .pass-editor textarea { width: 100%; min-height: 48px; padding: 9px 11px; border: 2px solid var(--hairline); border-radius: 9px; background: var(--surface); color: var(--charcoal); font: inherit; font-size: 18px; }.program-form textarea, .pass-editor textarea { min-height: 96px; resize: vertical; }.wide { grid-column: 1 / -1; }.program-actions { display: flex; flex-wrap: wrap; gap: 12px; }
.passes-panel { display: grid; gap: 14px; }.passes-panel > header { display: flex; justify-content: space-between; align-items: center; gap: 16px; }.passes-panel h2, .pass-editor h3, .product-editor h4 { margin: 0; color: var(--deep-green); font-family: var(--brand-font); font-size: 24px; }.pass-card { overflow: hidden; }.pass-card > header { display: flex; align-items: start; justify-content: space-between; gap: 16px; padding: 18px 20px; background: var(--light-green); }.pass-actions { display: flex; flex-wrap: wrap; gap: 8px; justify-content: end; }.pass-actions button, .product-line > button { min-height: 48px; border: 0; background: transparent; color: var(--deep-green); font: inherit; font-size: 18px; font-weight: 700; text-decoration: underline; }.pass-actions .danger-action, .product-line .danger-action { color: var(--warn-red); }.pass-products { display: grid; gap: 8px; padding: 16px 20px; }.pass-products > div { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) auto; gap: 12px; padding: 10px 0; border-top: 1px solid var(--hairline); overflow-wrap: anywhere; }.pass-products > div:first-child { border-top: 0; }.pass-products p { margin: 0; color: var(--matte-gray); }
.pass-editor { margin: 14px; background: var(--cream); }.product-editor { display: grid; gap: 12px; }.product-line { display: grid; grid-template-columns: 1.4fr 1fr 1fr 1fr auto; gap: 10px; align-items: end; padding: 14px; border-radius: 9px; background: var(--surface); }
@media (max-width: 767px) { .programs-heading { align-items: start; flex-direction: column; }.programs-heading .primary-action { width: 100%; }.program-card { align-items: stretch; flex-direction: column; }.program-card .secondary-action { width: 100%; }.program-form, .pass-editor { grid-template-columns: 1fr; padding: 16px; }.pass-card > header { align-items: stretch; flex-direction: column; padding: 16px; }.pass-actions { justify-content: start; }.pass-actions button { flex: 1 1 120px; }.pass-products { padding: 14px 16px; }.pass-products > div { grid-template-columns: 1fr; gap: 4px; }.product-line { grid-template-columns: 1fr; }.product-line > button { width: fit-content; }.pass-editor { margin: 10px; } }

/* Programs Chunk 3: exact crop-year assignments and field-level season snapshots. */
.program-tabs button { min-width: max-content; min-height: 48px; padding: 8px 14px; border: 0; border-radius: 9px; background: var(--cream); color: var(--matte-gray); font: inherit; font-size: 18px; font-weight: 700; }
.program-tabs button.selected { background: var(--deep-green); color: var(--on-dark); }
.assignment-picker, .crop-tracker, .assignment-track, .tracker-pass, .tracker-form { min-width: 0; max-width: 100%; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--surface); }
.assignment-picker { display: grid; gap: 16px; padding: 20px; }.assignment-picker > label, .assignment-picker fieldset { display: grid; gap: 10px; color: var(--matte-gray); font-size: 18px; font-weight: 700; }.assignment-picker select, .tracker-form input, .tracker-form textarea, .reassign-form select { width: 100%; min-height: 48px; padding: 9px 11px; border: 2px solid var(--hairline); border-radius: 9px; background: var(--surface); color: var(--charcoal); font: inherit; font-size: 18px; }.assignment-picker fieldset { margin: 0; padding: 16px; }.crop-choice { display: flex; align-items: start; gap: 12px; min-height: 48px; padding: 10px 0; border-top: 1px solid var(--hairline); color: var(--charcoal); overflow-wrap: anywhere; }.crop-choice:first-of-type { border-top: 0; }.crop-choice input { width: 24px; height: 24px; flex: 0 0 auto; }
.season-tracker { display: grid; gap: 18px; }.crop-tracker { display: grid; gap: 14px; padding: 20px; }.crop-tracker > h2 { margin: 0; color: var(--deep-green); font-family: var(--brand-font); font-size: 24px; overflow-wrap: anywhere; }.assignment-track { overflow: hidden; }.assignment-track > header, .tracker-pass > header { display: flex; align-items: start; justify-content: space-between; gap: 16px; padding: 16px; background: var(--light-green); }.assignment-track h3, .tracker-pass h4 { margin: 0; color: var(--deep-green); font-family: var(--brand-font); font-size: 22px; }.template-update, .tracker-pass p, .pass-detail { margin: 6px 0 0; color: var(--matte-gray); overflow-wrap: anywhere; }.template-update { color: #69531f; font-weight: 700; }.tracker-actions, .reassign-form { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }.tracker-actions button { min-height: 48px; }.tracker-pass { margin: 12px; overflow: hidden; }.tracker-pass > header { background: var(--surface); border-bottom: 1px solid var(--hairline); }.status-word { display: inline-flex; min-height: 28px; align-items: center; padding: 2px 8px; border: 1px solid currentColor; border-radius: 99px; font-weight: 700; text-transform: capitalize; }.status-word.applied { color: var(--deep-green); }.status-word.skipped, .status-word.cancelled { color: var(--matte-gray); }.pass-detail { padding: 0 16px 16px; }.tracker-form { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; margin: 12px; padding: 16px; background: var(--cream); }.tracker-form h5 { grid-column: 1 / -1; margin: 0; color: var(--deep-green); font-family: var(--brand-font); font-size: 21px; }.tracker-form > label, .actual-product label { display: grid; gap: 6px; color: var(--matte-gray); font-size: 18px; font-weight: 700; }.actual-product { display: grid; grid-column: 1 / -1; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10px; padding: 14px; border-radius: 9px; background: var(--surface); }.reassign-form select { min-width: 190px; }
.spray-pass-light, .program-cost, .crop-cost-rollup { margin: 12px 16px; padding: 12px; border-radius: 10px; overflow-wrap: anywhere; }.spray-pass-light.good { background: #e7f6ed; color: #17633d; }.spray-pass-light.caution { background: #fff5d8; color: #725516; }.spray-pass-light.poor { background: #fdeaea; color: #962f2f; }.spray-pass-light.unavailable { background: var(--cream); color: var(--matte-gray); }.program-cost p, .crop-cost-rollup p { margin: 6px 0; }.crop-cost-rollup { margin: 0; background: var(--cream); }.program-draft-record { display: grid; gap: 12px; padding: 14px 0; border-top: 1px solid var(--hairline); }.program-draft-record p { margin: 6px 0 0; }
@media (max-width: 767px) { .program-tabs { overflow-x: auto; }.assignment-picker, .crop-tracker { padding: 16px; }.assignment-track > header, .tracker-pass > header { align-items: stretch; flex-direction: column; }.tracker-actions > button { flex: 1 1 130px; }.tracker-form, .actual-product { grid-template-columns: 1fr; }.tracker-form .wide { grid-column: auto; }.tracker-pass { margin: 10px; }.reassign-form { width: 100%; }.reassign-form select { min-width: 0; }.reassign-form .secondary-action { width: auto; } }

/* Feature D: harvest records stay readable on a phone, including long crop names. */
.harvest-page { display: grid; gap: 20px; min-width: 0; }
.harvest-heading { align-items: end; }
.harvest-year { display: grid; gap: 6px; min-width: 132px; color: var(--matte-gray); font-weight: 700; }
.harvest-year select, .harvest-form input { min-height: 48px; border: 2px solid var(--hairline); border-radius: 9px; background: var(--surface); color: var(--charcoal); font: inherit; font-variant-numeric: tabular-nums; }
.harvest-year select { padding: 8px 10px; }
.harvest-list { display: grid; gap: 20px; }
.harvest-card { overflow: hidden; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--surface); }
.harvest-card-head { display: flex; align-items: start; justify-content: space-between; gap: 16px; padding: 20px; background: var(--light-green); }
.harvest-card-head h2 { margin: 0; color: var(--charcoal); font-family: var(--brand-font); font-size: 25px; }
.harvest-card-head p, .harvest-card-head span { margin: 4px 0 0; color: var(--matte-gray); font-variant-numeric: tabular-nums; }
.harvest-card-head span { font-weight: 700; }
.harvest-crops { display: grid; }
.harvest-crop { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 16px; padding: 18px 20px; border-top: 1px solid var(--hairline); }
.harvest-crop:nth-child(even) { background: var(--cream); }
.harvest-crop-main { min-width: 0; }
.harvest-crop h3 { margin: 0; color: var(--deep-green); font-family: var(--brand-font); font-size: 22px; }
.harvest-crop-main > p { margin: 5px 0 0; color: var(--matte-gray); font-variant-numeric: tabular-nums; }
.harvest-enter { align-self: start; min-height: 48px; white-space: nowrap; }
.harvest-results { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; margin-top: 14px; }
.harvest-results > span { display: grid; gap: 3px; padding: 10px; border-radius: 9px; background: var(--light-green); }
.harvest-results small { color: var(--matte-gray); font-size: 18px; font-weight: 700; }
.harvest-results strong { color: var(--deep-green); font-size: 18px; font-variant-numeric: tabular-nums; }
.harvest-results .over-plan strong { color: var(--deep-green); }
.harvest-results .under-plan { background: var(--warn-bg); }
.harvest-results .under-plan strong { color: var(--warn-red); }
.harvest-form { display: grid; grid-column: 1 / -1; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; padding: 16px; border: 1px solid var(--hairline); border-radius: 12px; background: var(--surface); }
.harvest-form h3, .harvest-form .form-error, .harvest-form > div { grid-column: 1 / -1; margin: 0; }
.harvest-form h3 { color: var(--deep-green); font-family: var(--brand-font); font-size: 21px; }
.harvest-form label { display: grid; gap: 6px; color: var(--matte-gray); font-weight: 700; }
.harvest-form label span { font-weight: 400; }
.harvest-form input { width: 100%; padding: 8px 10px; }
.harvest-form > div { display: flex; flex-wrap: wrap; gap: 12px; }
.yield-history { border-top: 1px solid var(--hairline); }
.yield-history h3 { margin: 0; padding: 14px 20px 11px; background: var(--cream); border-bottom: 1px solid var(--hairline); color: var(--charcoal); font-family: var(--brand-font); font-size: 19px; font-weight: 600; }
.yield-history-strip { display: flex; flex-wrap: wrap; gap: 10px; padding: 16px 20px; }
.yield-history-strip span { display: grid; gap: 3px; min-width: 142px; padding: 10px; border-radius: 9px; background: var(--cream); }
.yield-history-strip strong { color: var(--charcoal); font-size: 18px; }
.yield-history-strip em { color: var(--deep-green); font-style: normal; font-weight: 700; font-variant-numeric: tabular-nums; }
.yield-history .card-empty { margin: 0; padding: 16px 20px; }
.field-log-list { display: grid; gap: 20px; }
.field-log-card { overflow: hidden; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--surface); }
.field-log-card-head { display: flex; align-items: start; justify-content: space-between; gap: 20px; padding: 20px; background: var(--light-green); }
.field-log-card-head h2 { margin: 0; font-family: var(--brand-font); font-size: 25px; }
.field-log-card-head p { margin: 4px 0 0; color: var(--matte-gray); }
.rain-total { min-width: 145px; text-align: right; }
.rain-total span, .rain-total strong { display: block; }
.rain-total span { color: var(--matte-gray); font-size: 18px; font-weight: 700; }
.rain-total strong { color: var(--deep-green); font-family: var(--brand-font); font-size: 28px; }
.field-log-actions { display: flex; flex-wrap: wrap; gap: 12px; padding: 18px 20px 0; }
.gdd-line, .gdd-prompt { display: grid; gap: 3px; margin: 0; padding: 16px 20px 0; color: var(--deep-green); }
.gdd-line small, .gdd-prompt { color: var(--matte-gray); font-size: 18px; }
.field-log-timeline { margin-top: 20px; border-top: 1px solid var(--hairline); }
.field-log-timeline h3 { margin: 0; padding: 14px 20px 11px; background: var(--cream); border-bottom: 1px solid var(--hairline); color: var(--charcoal); font-family: var(--brand-font); font-size: 19px; font-weight: 600; }
.field-log-row { display: flex; align-items: center; justify-content: space-between; gap: 16px; min-height: 68px; padding: 10px 20px; border-top: 1px solid var(--hairline); }
.field-log-row:nth-child(even) { background: var(--cream); }
.field-log-row > div:first-child { display: grid; min-width: 0; gap: 2px; }
.field-log-row span { min-width: 0; overflow-wrap: anywhere; color: var(--matte-gray); }
.field-log-pending { color: var(--matte-gray); font-style: italic; }
.field-log-row-actions { display: flex; flex-wrap: wrap; gap: 8px; }
.field-log-row-actions button, .danger-action { min-width: 48px; min-height: 48px; border: 1px solid var(--hairline); border-radius: 8px; padding: 8px 12px; background: var(--surface); color: var(--deep-green); font-weight: 700; }
.danger-action { color: var(--warn-red); }
.field-log-form { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; margin: 18px 20px 0; padding: 18px; border: 1px solid var(--hairline); border-radius: 12px; background: var(--cream); }
.field-log-form h3, .field-log-form .wide, .field-log-form > div, .field-log-form .form-error { grid-column: 1 / -1; }
.field-log-form h3 { margin: 0; font-family: var(--brand-font); }
.field-log-form label { display: grid; gap: 6px; color: var(--matte-gray); font-weight: 700; }
.field-log-form input, .field-log-form textarea { width: 100%; padding: 10px 12px; border: 2px solid var(--hairline); border-radius: 9px; color: var(--charcoal); background: var(--surface); }
.field-log-form textarea { min-height: 96px; resize: vertical; }
.field-log-form > div:last-child { display: flex; flex-wrap: wrap; gap: 12px; }
.field-log-page, .field-log-page p, .field-log-page span, .field-log-page strong, .field-log-page label, .field-log-page em, .field-log-page small { font-size: 18px; }
.field-log-page button, .field-log-page input, .field-log-page textarea { min-height: 48px; font-size: 18px; }
.empty-state { width: min(100%, 560px); padding: 40px 28px; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--surface); text-align: center; }
.empty-state p { margin: 12px auto 26px; color: var(--matte-gray); }

/* Scouting keeps field observations readable in bright light and usable with a phone camera. */
.scouting-page, .scouting-list { display: grid; gap: 20px; }
.scouting-card { overflow: hidden; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--surface); }
.scouting-card-head { display: flex; align-items: start; justify-content: space-between; gap: 18px; padding: 20px; background: var(--light-green); }
.scouting-card-head h2 { margin: 0; font-family: var(--brand-font); font-size: 25px; }
.scouting-card-head p { margin: 4px 0 0; color: var(--matte-gray); }
.scouting-timeline { margin-top: 20px; border-top: 1px solid var(--hairline); }
.scouting-timeline h3 { margin: 0; padding: 14px 20px 11px; background: var(--cream); border-bottom: 1px solid var(--hairline); color: var(--charcoal); font-family: var(--brand-font); font-size: 19px; font-weight: 600; }
.scouting-form { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; margin: 18px 20px 0; padding: 18px; border: 1px solid var(--hairline); border-radius: 12px; background: var(--cream); }
.scouting-form h3, .scouting-wide, .scouting-form > div:last-child { grid-column: 1 / -1; }
.scouting-form h3 { margin: 0; font-family: var(--brand-font); }
.scouting-form label { display: grid; gap: 6px; color: var(--matte-gray); font-weight: 700; }
.scouting-form textarea, .scouting-form input[type="date"], .scouting-form input[type="file"] { width: 100%; padding: 10px 12px; border: 2px solid var(--hairline); border-radius: 9px; color: var(--charcoal); background: var(--surface); }
.scouting-form textarea { min-height: 112px; resize: vertical; }
.scouting-form fieldset { margin: 0; padding: 0; border: 0; }
.scouting-form legend { margin-bottom: 6px; color: var(--matte-gray); font-weight: 700; }
.category-chips { display: flex; flex-wrap: wrap; gap: 8px; }
.category-chips button { min-width: 92px; min-height: 48px; border: 2px solid var(--deep-green); border-radius: 99px; background: var(--surface); color: var(--deep-green); font-weight: 700; }
.category-chips button.active { background: var(--deep-green); color: var(--on-dark); }
.location-line, .scouting-form > div:last-child { display: flex; align-items: center; flex-wrap: wrap; gap: 12px; }
.location-line span { color: var(--matte-gray); }
.scouting-form small { color: var(--matte-gray); font-weight: 500; }
.task-check { display: flex !important; grid-template-columns: 28px 1fr; align-items: center; color: var(--charcoal) !important; }
.task-check input { min-width: 48px; min-height: 48px; accent-color: var(--crx-green); }
.photo-preview, .scouting-photos { display: flex; flex-wrap: wrap; gap: 10px; }
.photo-preview img, .scouting-photos img { width: 92px; height: 92px; display: block; border-radius: 9px; object-fit: cover; }
.scouting-photos button { min-width: 92px; min-height: 92px; padding: 0; overflow: hidden; border: 2px solid var(--hairline); border-radius: 10px; background: var(--surface); }
.scouting-photos button:focus-visible { outline-offset: 2px; }
.photo-loading { min-height: 48px; display: flex; align-items: center; color: var(--matte-gray); }
.scouting-error { margin: 18px 20px 0; }
.scouting-row { display: flex; align-items: start; justify-content: space-between; gap: 16px; padding: 16px 20px; border-top: 1px solid var(--hairline); }
.scouting-row:nth-child(even) { background: var(--cream); }
.scouting-row-main { min-width: 0; display: grid; gap: 10px; }
.scouting-row-main p { margin: 0; overflow-wrap: anywhere; }
.scouting-row-meta { display: flex; align-items: center; flex-wrap: wrap; gap: 10px; color: var(--matte-gray); }
.scouting-row-meta strong { color: var(--charcoal); }
.category-chip { display: inline-flex; align-items: center; min-height: 32px; padding: 3px 10px; border-radius: 99px; background: var(--light-green); color: var(--deep-green); font-size: 18px; font-weight: 700; }
.category-chip.disease, .category-chip.insect { background: var(--warn-bg); color: #604a22; }
.photo-lightbox { position: fixed; z-index: 20; inset: 0; display: grid; place-items: center; padding: 24px; background: rgb(46 46 46 / 92%); }
.photo-lightbox img { max-width: min(100%, 920px); max-height: calc(100vh - 120px); border-radius: 12px; object-fit: contain; }
.photo-lightbox button { position: fixed; top: 18px; right: 18px; border: 2px solid var(--on-dark); border-radius: 9px; background: var(--surface); color: var(--deep-green); font-weight: 700; }

@media (max-width: 767px) {
  .scouting-card-head, .scouting-row { align-items: stretch; flex-direction: column; }
  .scouting-card-head .primary-action { width: 100%; }
  .scouting-form { grid-template-columns: 1fr; }
  .field-log-row-actions { width: 100%; }
  .field-log-row-actions button { flex: 1 1 0; }
  .field-log-form { grid-template-columns: 1fr; }
  .field-log-row { align-items: start; flex-direction: column; }
  .field-log-row-actions { width: 100%; }
  .field-log-row-actions button { flex: 1 1 0; }
}

.mobile-nav { display: none; }

.login-page { min-height: 100vh; display: grid; place-items: center; padding: 24px; background: var(--cream); }
.login-panel { width: min(100%, 620px); padding: 52px 34px 40px; border-radius: var(--radius); background: var(--chrome-green); box-shadow: 0 8px 28px rgb(23 81 58 / 22%); text-align: center; }
.farm-choice p { margin: 14px auto 24px; color: var(--matte-gray); }
.farm-choice-list { display: grid; gap: 12px; }
.farm-choice-list .primary-action { width: 100%; }
.login-brand { color: var(--on-dark); }
.rx-mark { color: var(--crx-green); font-family: var(--brand-font); font-size: 82px; font-weight: 700; line-height: .9; }
.login-brand h1 { margin-top: 8px; color: var(--on-dark); font-size: 38px; }
.login-brand h1 span { color: var(--crx-green); }
.login-brand p { margin: 8px 0 0; color: #b8dcc9; }
.login-card { display: grid; gap: 7px; margin: 34px auto 0; padding: 28px; border-radius: 12px; background: var(--surface); text-align: left; }
.login-card label { color: var(--matte-gray); font-size: 18px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; }
.login-card input { width: 100%; min-height: 52px; margin-bottom: 12px; padding: 12px 14px; border: 2px solid var(--hairline); border-radius: 9px; color: var(--charcoal); background: var(--surface); }
.login-card select { width: 100%; min-height: 52px; margin-bottom: 12px; padding: 12px 14px; border: 2px solid var(--hairline); border-radius: 9px; color: var(--charcoal); background: var(--surface); font-size: 18px; }
.login-card input::placeholder { color: #717171; }
.login-card input:focus { border-color: var(--crx-green); outline: none; }
.login-card .primary-action { width: 100%; margin-top: 2px; }
.opening-farm { color: var(--on-dark); font-size: 22px; font-weight: 700; }
.sign-out, .sync-notice button { min-width: 48px; min-height: 48px; padding: 10px 14px; border: 1px solid var(--hairline); border-radius: 8px; background: var(--surface); color: var(--deep-green); font-size: 18px; font-weight: 700; }
.sync-notice { display: flex; align-items: center; justify-content: space-between; gap: 14px; min-height: 48px; padding: 10px 24px; font-size: 18px; font-weight: 700; font-variant-numeric: tabular-nums; }
.sync-notice.synced { color: var(--deep-green); background: var(--light-green); }
.sync-notice.pending, .sync-notice.syncing { color: #604a22; background: #fffaf0; }
.sync-notice.blocked { color: #7a261f; background: #fff1ef; }
.auth-error { margin: 8px 0; color: #9b2c20; font-size: 18px; font-weight: 600; }
.slogan { margin: 30px 0 0; color: var(--crx-green); font-family: var(--brand-font); font-size: 18px; font-weight: 700; letter-spacing: .08em; }
.byline { margin: 8px 0 0; color: #b8dcc9; font-size: 18px; }

/* Module 2: Grain */
.grain-page { min-width: 0; max-width: 100%; display: grid; grid-template-columns: minmax(0, 1fr); gap: 24px; }
.grain-heading { margin-bottom: 0; }
.market-stamp, .delayed-label { color: var(--matte-gray); font-size: 18px; }
.delayed-label { white-space: nowrap; }
.position-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
.position-card, .grain-section { border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--surface); }
.position-card { padding: 20px; box-shadow: 0 3px 10px rgb(23 81 58 / 5%); }
.position-top, .section-heading, .position-foot, .plan-status, .bin-row, .modal-heading { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; }
.eyebrow { display: block; color: var(--deep-green); font-size: 18px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; }
.position-card h2, .grain-section h2 { margin: 2px 0 0; font-family: var(--brand-font); font-size: 24px; line-height: 1.2; }
.math-toggle { display: flex; min-height: 48px; overflow: hidden; padding: 0; border: 1px solid var(--hairline); border-radius: 8px; background: var(--surface); font-size: 18px; font-weight: 700; }
.math-toggle:disabled { cursor: not-allowed; opacity: .55; }
.math-toggle span { display: grid; place-items: center; min-width: 76px; padding: 8px; }
.math-toggle .active { color: var(--on-dark); background: var(--deep-green); }
.position-sentence { min-height: 79px; margin: 18px 0; font-size: 19px; font-weight: 600; line-height: 1.45; }
.position-sentence small { color: var(--matte-gray); font-weight: 500; }
.position-stats { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); border-top: 1px solid var(--hairline); border-left: 1px solid var(--hairline); }
.position-stats > div { display: grid; gap: 2px; min-height: 88px; padding: 11px 12px; border-right: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); }
.position-stats span, .position-stats small { color: var(--matte-gray); font-size: 18px; font-weight: 600; }
.position-stats strong { color: var(--charcoal); font-size: 18px; line-height: 1.2; }
.position-foot { margin-top: 14px; color: var(--matte-gray); font-size: 18px; }
.position-foot strong { color: var(--charcoal); }
.position-foot em { color: var(--deep-green); font-style: normal; font-weight: 700; }
.grain-section { overflow: hidden; }
.grain-section > .section-heading, .bins-card > .section-heading, .basis-card > .section-heading { padding: 20px 20px 16px; }
.market-data-section { min-width: 0; max-width: 100%; width: 100%; overflow: visible; }
.market-data-note { margin: 0; padding: 0 20px 18px; color: var(--matte-gray); }
.market-quote-grid { min-width: 0; max-width: 100%; width: 100%; display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; padding: 0 20px 20px; }
.market-quote { min-width: 0; max-width: 100%; padding: 14px; border: 1px solid var(--hairline); border-radius: 10px; background: var(--cream); }
.market-quote__heading { display: flex; align-items: baseline; justify-content: space-between; gap: 8px; margin-bottom: 8px; color: var(--charcoal); }
.market-quote__heading span { color: var(--matte-gray); font-size: 18px; }
.market-quote__widget, .market-quote__widget > .tradingview-widget-container__widget { display: block; min-width: 0; max-width: 100%; width: 100%; min-height: 220px; border: 0; }
.market-quote__widget iframe { display: block; min-width: 0; max-width: 100%; width: 100% !important; }
.market-quote__fallback { min-height: 220px; display: grid; place-items: center; margin: 0; color: var(--matte-gray); text-align: center; }
.market-quote--unavailable .market-quote__widget { display: none; }
.section-heading p { margin: 4px 0 0; color: var(--matte-gray); font-size: 18px; }
.commodity-picker { min-width: 220px; display: grid; gap: 4px; color: var(--matte-gray); font-size: 18px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; }
.commodity-picker select, .contract-entry select, .contract-entry input, .basis-entry select, .basis-entry input, .target-modal input { width: 100%; min-height: 48px; padding: 9px 10px; border: 2px solid var(--hairline); border-radius: 9px; background: var(--surface); color: var(--charcoal); }
.template-bar { display: flex; gap: 10px; overflow-x: auto; padding: 0 20px 17px; border-bottom: 1px solid var(--hairline); }
.template-button { min-width: 186px; min-height: 76px; display: grid; align-content: center; gap: 3px; padding: 10px 12px; border: 1px solid var(--hairline); border-radius: 10px; background: var(--light-green); color: var(--deep-green); text-align: left; }
.template-button:hover { border-color: var(--crx-green); background: #dff2e7; }
.template-button strong { font-size: 18px; }
.template-button span { color: var(--matte-gray); font-size: 18px; line-height: 1.25; }
.month-grid { display: grid; grid-template-columns: repeat(12, minmax(88px, 1fr)); overflow-x: auto; padding: 18px 20px; gap: 8px; }
.month-cell { min-width: 88px; min-height: 116px; display: grid; align-content: start; gap: 4px; padding: 10px; border: 1px solid var(--hairline); border-radius: 10px; background: var(--surface); color: var(--charcoal); text-align: left; }
.month-cell:hover, .month-cell.planned { border-color: var(--crx-green); background: var(--light-green); }
.month-cell span, .month-cell small { color: var(--matte-gray); font-size: 18px; font-weight: 700; }
.month-cell strong { color: var(--deep-green); font-size: 21px; }
.month-cell em { color: var(--charcoal); font-size: 18px; font-style: normal; font-weight: 600; }
.plan-status { align-items: center; padding: 16px 20px; border-top: 1px solid var(--hairline); background: #fafcfb; }
.plan-status div { display: grid; gap: 2px; }
.plan-status span:not(.status-chip) { color: var(--matte-gray); font-size: 18px; }
.plan-status strong { font-size: 18px; }
.status-chip { display: inline-flex; align-items: center; min-height: 34px; padding: 5px 11px; border-radius: 99px; font-size: 18px; font-weight: 700; white-space: nowrap; }
.fields-page .status-chip { font-size: 18px; }
.status-chip.on-track { background: var(--light-green); color: var(--deep-green); }
.status-chip.behind { background: var(--warn-bg); color: #a96500; }
.saved-whisper { color: var(--deep-green); font-size: 18px; font-weight: 700; }
.contract-entry { display: grid; grid-template-columns: 1.4fr 1.2fr 1fr .75fr .75fr auto; gap: 10px; align-items: end; padding: 16px 20px 20px; border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); background: var(--light-green); }
.contract-entry > label { display: grid; gap: 4px; color: var(--matte-gray); font-size: 18px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; }
.contract-entry details { grid-column: 1 / -1; color: var(--deep-green); font-size: 18px; font-weight: 700; }
.contract-entry summary { min-height: 48px; cursor: pointer; }
.contract-entry details > div { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10px; margin-top: 8px; }
.contract-entry details label { display: grid; gap: 4px; color: var(--matte-gray); font-size: 18px; letter-spacing: .04em; text-transform: uppercase; }
.contract-entry .primary-action { min-height: 48px; padding: 10px 14px; white-space: nowrap; }
.contracts-card td small { display: block; color: var(--matte-gray); font-size: 18px; font-weight: 500; }
.storage-layout { display: grid; grid-template-columns: 1.05fr .95fr; }
.bins-card { border-right: 1px solid var(--hairline); }
.bin-list { padding: 0 20px 6px; }
.bin-row { align-items: center; padding: 14px 0; border-top: 1px solid var(--hairline); }
.bin-row > div:first-child { display: grid; gap: 2px; }
.bin-row > div:first-child span { color: var(--matte-gray); font-size: 18px; }
.commodity-badge { display: inline-flex; padding: 4px 8px; border-radius: 99px; background: #eef0ef; color: var(--matte-gray); font-size: 18px; font-weight: 700; }
.commodity-badge.ip { background: #fff2d9; color: #8a5b05; }
.bin-balance { display: grid; gap: 2px; text-align: right; }
.bin-balance span { color: var(--matte-gray); font-size: 18px; }
.bin-balance strong { color: var(--charcoal); }
.bin-card { display: grid; gap: 12px; padding: 16px 0; border-top: 1px solid var(--hairline); }
.bin-card-meta { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
.moisture-reading, .moisture-flag { min-height: 32px; display: inline-flex; align-items: center; padding: 4px 8px; border-radius: 8px; font-weight: 700; }
.moisture-reading { background: #eef0ef; color: var(--matte-gray); }
.moisture-flag, .bin-warning { color: var(--warn-red); background: var(--warn-bg); }
.bin-warning { margin: 0; padding: 9px 10px; border-left: 4px solid var(--warn-red); border-radius: 6px; font-weight: 600; }
.bin-fill { display: grid; gap: 7px; }
.bin-fill > div { display: flex; justify-content: space-between; gap: 8px; color: var(--matte-gray); }
.bin-fill > div strong { color: var(--charcoal); font-size: 20px; }
.bin-fill > span { display: block; min-height: 12px; max-width: 100%; border-radius: 99px; background: var(--crx-green); }
.bin-fill::after { content: ''; display: block; height: 12px; margin-top: -19px; border-radius: 99px; background: #e3e6e4; z-index: 0; }
.bin-fill > span { z-index: 1; }
.bin-ledger { padding-top: 12px; border-top: 1px solid var(--hairline); }
.bin-ledger summary { min-height: 48px; display: flex; align-items: center; color: var(--deep-green); font-weight: 700; cursor: pointer; }
.bin-ledger > p { margin: 0 0 12px; color: var(--matte-gray); }
.bin-form, .movement-form { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; padding: 16px 20px; border-top: 1px solid var(--hairline); background: var(--light-green); }
.bin-form h3, .bin-form-fact, .bin-form > div, .movement-form .movement-note, .movement-form .form-error { grid-column: 1 / -1; }
.bin-form label, .movement-form label { display: grid; gap: 4px; color: var(--matte-gray); font-weight: 700; }
.bin-form input, .bin-form select, .movement-form input, .movement-form select { width: 100%; min-height: 48px; padding: 9px 10px; border: 2px solid var(--hairline); border-radius: 9px; background: var(--surface); color: var(--charcoal); }
.bin-form-fact { margin: 0; color: var(--matte-gray); }
.movement-form { grid-template-columns: repeat(4, minmax(0, 1fr)); padding: 12px 0; background: transparent; }
.movement-list { display: grid; gap: 0; }
.movement-list > div { display: grid; gap: 2px; padding: 11px 0; border-top: 1px solid var(--hairline); }
.movement-list span, .movement-list small { color: var(--matte-gray); }
.movement-in { color: var(--deep-green); }
.movement-out { color: var(--warn-red); }
.basis-entry { display: grid; grid-template-columns: 1.2fr 1fr .7fr auto; gap: 8px; padding: 0 20px 16px; }
.basis-entry .secondary-action { white-space: nowrap; }
.basis-list { padding: 0 20px 12px; }
.basis-list > div { display: grid; grid-template-columns: 1fr auto auto; gap: 10px; align-items: center; padding: 11px 0; border-top: 1px solid var(--hairline); }
.basis-list span, .basis-list small { color: var(--matte-gray); font-size: 18px; }
.basis-list strong { color: var(--deep-green); }
.compliance-note { padding: 18px 20px; border-left: 5px solid var(--amber); border-radius: 8px; background: #fffaf0; color: #604a22; }
.compliance-note strong { display: block; margin-bottom: 2px; }
.target-modal-backdrop { position: fixed; z-index: 20; inset: 0; display: grid; place-items: center; padding: 20px; background: rgb(23 81 58 / 42%); }
.target-modal { width: min(100%, 480px); display: grid; gap: 17px; padding: 24px; border-radius: var(--radius); background: var(--surface); box-shadow: 0 16px 50px rgb(0 0 0 / 25%); }
.target-modal label { display: grid; gap: 6px; color: var(--matte-gray); font-weight: 700; }
.target-modal label small { color: var(--matte-gray); font-size: 18px; font-weight: 500; }

@media (max-width: 767px) {
  body { padding-bottom: calc(60px + env(safe-area-inset-bottom)); }
  .sidebar { display: none; }
  .topbar { min-height: 64px; padding: 12px 16px; }
  .product-name { font-size: 22px; }
  .farm-summary { font-size: 18px; text-align: right; }
  .content-area { padding: 24px 16px; }
  .page-heading { align-items: start; flex-direction: column; margin-bottom: 24px; }
  h1 { font-size: 30px; }
  .page-heading .primary-action { width: 100%; }
  .stats-grid { grid-template-columns: 1fr; }
  .stat-value { padding: 19px 16px 22px; }
  .filter-bar { grid-template-columns: 1fr; padding: 16px; }
  .filter-control select { min-height: 52px; font-size: 18px; }
  .table-scroll { margin-bottom: 0; }
  .detail-topline { margin-bottom: 10px; }
  .info-grid { grid-template-columns: 1fr; }
  .info-grid > div, .info-grid > div:nth-child(even) { min-height: 0; border-right: 0; border-bottom: 1px solid var(--hairline); }
  .info-grid > div:last-child { border-bottom: 0; }
  .info-grid > div:nth-last-child(2) { border-bottom: 1px solid var(--hairline); }
  .crop-history { padding: 2px 16px; }
  .history-row { grid-template-columns: 70px 1fr; }
  .form-grid { grid-template-columns: 1fr; padding: 20px 16px; }
  .field-form fieldset > .secondary-action, .form-note { margin-left: 16px; margin-right: 16px; }
  .form-note { padding-left: 0; padding-right: 0; }
  .crop-editor { padding-right: 16px; padding-left: 16px; }
  .crop-row { grid-template-columns: 1fr; gap: 10px; padding-bottom: 12px; border-bottom: 1px solid var(--hairline); }
  .crop-row:last-child { padding-bottom: 0; border-bottom: 0; }
  .remove-crop { min-height: 48px; }
  .form-submit { width: 100%; }
  .card-form { grid-template-columns: 1fr; padding: 16px; }
  .input-shares { padding: 16px; }
  .input-shares-heading { align-items: stretch; flex-direction: column; }
  .input-shares-heading .secondary-action { width: 100%; }
  .input-share-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
  .yield-list, .record-list { padding: 0 16px; }
  .yield-list > div, .record-list > div, .assignment-edit-row { grid-template-columns: 1fr; gap: 6px; align-items: start; }
  .yield-list span, .record-list span { text-align: left; }
  .inline-add-note { display: none; }
  .mobile-nav { position: fixed; z-index: 10; right: 0; bottom: 0; left: 0; display: block; padding-bottom: env(safe-area-inset-bottom); border-top: 1px solid var(--hairline); background: var(--surface); box-shadow: 0 -4px 12px rgb(46 46 46 / 8%); }
  .mobile-nav-list { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); }
  .mobile-nav .nav-link { min-width: 0; min-height: 60px; width: 100%; flex-direction: column; justify-content: center; gap: 1px; margin: 0; padding: 6px 2px; border: 0; border-radius: 0; color: var(--matte-gray); background: var(--surface); font-size: 18px; line-height: 1.2; text-align: center; }
  .mobile-nav .nav-link.active { color: var(--deep-green); background: var(--light-green); }
  .mobile-nav .nav-link.active::before { display: none; }
  .mobile-nav .nav-icon { height: 19px; font-size: 18px; }
  .mobile-more-menu { position: fixed; z-index: 11; right: 0; bottom: calc(60px + env(safe-area-inset-bottom)); left: 0; max-height: calc(100dvh - 60px - env(safe-area-inset-bottom)); overflow-y: auto; padding: 14px 16px 18px; border-top: 1px solid var(--hairline); background: var(--surface); box-shadow: 0 -10px 28px rgb(46 46 46 / 16%); }
  .mobile-more-menu header { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 10px; }
  .mobile-more-menu header strong { color: var(--deep-green); font-family: var(--brand-font); font-size: 22px; }
  .mobile-more-menu header button { padding: 8px 12px; border: 1px solid var(--hairline); border-radius: 8px; background: var(--surface); color: var(--deep-green); font-weight: 700; }
  .mobile-more-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; }
  .mobile-more-grid .nav-link { min-width: 0; min-height: 56px; margin: 0; padding: 10px 12px; border: 1px solid var(--hairline); color: var(--charcoal); background: var(--cream); }
  .mobile-more-grid .nav-link:hover, .mobile-more-grid .nav-link.active { color: var(--deep-green); background: var(--light-green); }
  .mobile-more-grid .nav-link.active::before { display: none; }
  .empty-page { min-height: calc(100vh - 158px); }
  .empty-state { padding: 36px 20px; }
  .login-page { padding: 0; background: var(--chrome-green); }
  .login-panel { min-height: 100vh; width: 100%; padding: 52px 20px 36px; border-radius: 0; box-shadow: none; }
  .login-card { padding: 24px 20px; }
}

/* Weather & Spray: roomy field cards that stay readable in sun and from a truck cab. */
.weather-page { display: grid; gap: 20px; min-width: 0; font-size: 18px; }
.weather-heading { align-items: center; }.weather-heading > div > p:last-child { margin: 6px 0 0; color: var(--matte-gray); }
.weather-card { display: grid; gap: 18px; overflow: hidden; padding: 20px; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--surface); box-shadow: 0 3px 10px rgb(23 81 58 / 5%); font-variant-numeric: tabular-nums; }
.weather-card h2, .weather-card h3, .weather-card p { margin: 0; }.weather-card h2 { color: var(--deep-green); font-family: var(--brand-font); font-size: 24px; }.weather-card h3 { color: var(--charcoal); font-size: 20px; }.weather-card-title { display: flex; align-items: center; justify-content: space-between; gap: 16px; }.weather-card-title p, .weather-note, .weather-stamp { color: var(--matte-gray); }
.weather-guidance { margin: 0; color: var(--matte-gray); font-size: 18px; }.weather-error { margin: 0; padding: 12px 14px; border: 2px solid var(--warn-red); border-radius: 10px; background: var(--warn-bg); color: var(--warn-red); font-weight: 700; }.location-card { align-items: start; }.location-card > .primary-action { width: min(100%, 330px); }.text-action { min-height: 48px; padding: 0; border: 0; background: transparent; color: var(--deep-green); font: inherit; font-size: 18px; font-weight: 700; text-decoration: underline; }
.weather-location-form { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; width: 100%; padding: 16px; border-radius: 10px; background: var(--cream); }.weather-location-form label { display: grid; gap: 6px; color: var(--charcoal); font-size: 18px; font-weight: 700; }.weather-location-form input { min-height: 48px; width: 100%; padding: 8px 10px; border: 2px solid var(--hairline); border-radius: 9px; background: var(--surface); color: var(--charcoal); font: inherit; font-variant-numeric: tabular-nums; }.weather-location-form .primary-action { align-self: end; }
.weather-now { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; }.weather-now > div { display: grid; gap: 4px; padding: 14px; border-radius: 10px; background: var(--cream); }.weather-now strong { color: var(--deep-green); font-size: 21px; }.weather-now span { color: var(--matte-gray); }
.spray-summary { display: grid; grid-template-columns: 150px 1fr; gap: 18px; align-items: center; }.spray-light { display: grid; min-height: 126px; place-content: center; gap: 5px; border-radius: 14px; color: var(--charcoal); text-align: center; }.spray-light strong { font-family: var(--brand-font); font-size: 29px; }.spray-light.good { background: var(--light-green); color: var(--deep-green); }.spray-light.caution { background: var(--warn-bg); color: #744b00; }.spray-light.poor { background: #fbe9e7; color: var(--warn-red); }.spray-summary > div:last-child { display: grid; gap: 8px; }.spray-summary p { color: var(--matte-gray); }.best-window { color: var(--deep-green); }
.hour-strip { display: grid; grid-template-columns: repeat(12, minmax(72px, 1fr)); gap: 6px; overflow-x: auto; padding-bottom: 4px; }.hour-strip > div { display: grid; min-height: 72px; align-content: center; gap: 4px; padding: 8px; border-radius: 8px; text-align: center; }.hour-strip .good { background: var(--light-green); color: var(--deep-green); }.hour-strip .caution { background: var(--warn-bg); color: #744b00; }.hour-strip .poor { background: #fbe9e7; color: var(--warn-red); }.hour-strip span { font-size: 18px; }.hour-strip b { font-size: 18px; }
.daily-row { display: grid; grid-template-columns: repeat(7, minmax(100px, 1fr)); gap: 8px; overflow-x: auto; }.daily-row > div { display: grid; gap: 4px; padding: 12px; border-top: 4px solid var(--crx-green); background: var(--cream); }.daily-row strong { color: var(--deep-green); }.daily-row span { color: var(--matte-gray); }.empty-weather { text-align: center; }
.weather-page button { min-height: 48px; font-size: 18px; }.weather-page input { font-size: 18px; }.weather-page, .weather-page * { font-variant-numeric: tabular-nums; }
@media (max-width: 767px) { .weather-heading { align-items: start; flex-direction: column; }.weather-heading .secondary-action { width: 100%; }.weather-card { padding: 18px 16px; }.weather-card-title { align-items: start; flex-direction: column; }.weather-card-title .secondary-action { width: 100%; }.weather-location-form, .weather-now, .spray-summary { grid-template-columns: 1fr; }.weather-location-form .primary-action { width: 100%; }.spray-light { min-height: 104px; }.daily-row { grid-template-columns: repeat(7, minmax(112px, 1fr)); } }

/* Equipment and Tasks: the same 18px/48px baseline as the live farm modules. */
.equipment-page, .tasks-page { display: grid; gap: 20px; font-size: 18px; }
.equipment-page button, .equipment-page input, .equipment-page select, .equipment-page textarea, .tasks-page button, .tasks-page input, .tasks-page select, .tasks-page textarea { min-height: 48px; font: inherit; }
.equipment-heading, .detail-heading { display: flex; justify-content: space-between; align-items: center; gap: 16px; }
.equipment-heading h1 { margin: 0; font-size: clamp(26px, 4vw, 36px); }.equipment-heading .eyebrow { margin: 0 0 4px; color: var(--deep-green); font-weight: 700; }
.equipment-groups { display: grid; gap: 22px; }.equipment-groups h2, .task-column h2 { margin: 0 0 10px; font-size: 21px; }.machine-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 14px; }
.machine-card, .task-card, .equipment-form, .equipment-detail, .task-column { border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--surface); box-shadow: 0 2px 10px #173d2a0a; }.machine-card { min-height: 180px; display: grid; align-content: start; gap: 10px; padding: 18px; text-align: left; color: var(--charcoal); cursor: pointer; }.machine-card:hover { border-color: var(--crx-green); background: var(--light-green); }.machine-card > strong { font-size: 23px; }.machine-card > span, .task-card p, .task-card small { color: var(--matte-gray); }
.machine-facts { display: flex; flex-wrap: wrap; gap: 10px; font-variant-numeric: tabular-nums; }.machine-facts b { font-size: 18px; }.chip-row { display: flex; flex-wrap: wrap; gap: 7px; }.chip-row em, .priority-chip { padding: 4px 8px; border-radius: 999px; font-size: 18px; font-style: normal; font-weight: 700; }.status-chip { background: var(--cream); color: var(--matte-gray); }.due-chip { background: #fff0f0; color: var(--warn-red); }.warranty-chip { background: var(--warn-bg); color: #8a5600; }.priority-chip { background: #fff0f0; color: var(--warn-red); }
.equipment-form { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 13px; padding: 18px; }.equipment-form h2, .equipment-form .equipment-error, .equipment-form fieldset, .equipment-form > div { grid-column: 1 / -1; margin: 0; }.equipment-form label { display: grid; gap: 5px; color: var(--matte-gray); font-weight: 700; }.equipment-form input, .equipment-form select, .equipment-form textarea { width: 100%; box-sizing: border-box; padding: 9px 11px; border: 1px solid var(--hairline); border-radius: 8px; background: white; color: var(--charcoal); }.equipment-form textarea { min-height: 96px; resize: vertical; }.equipment-form .wide { grid-column: span 2; }.equipment-form.compact { grid-template-columns: repeat(3, minmax(0, 1fr)); padding: 0; border: 0; box-shadow: none; }.equipment-form fieldset { display: flex; align-items: center; flex-wrap: wrap; gap: 8px; border: 0; padding: 0; }.equipment-form fieldset button.active, .task-kpis button.active { color: var(--on-dark); background: var(--deep-green); }
.equipment-detail { display: grid; gap: 18px; padding: 20px; }.detail-heading h2 { margin: 0; }.detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }.detail-grid section, .service-log { padding: 16px; border-radius: 10px; background: var(--cream); }.detail-grid h3, .service-log h3 { margin: 0 0 12px; }.list-row { display: flex; justify-content: space-between; gap: 10px; align-items: center; min-height: 46px; border-bottom: 1px solid var(--hairline); font-variant-numeric: tabular-nums; }.list-row:last-child { border-bottom: 0; }
.equipment-error { margin: 0; padding: 12px; border-left: 4px solid var(--warn-red); background: #fff2f2; color: var(--warn-red); }.task-kpis { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; }.task-kpis button { display: grid; gap: 3px; padding: 13px; border: 1px solid var(--hairline); border-radius: 10px; background: var(--surface); color: var(--charcoal); text-align: left; }.task-kpis strong { font-size: 28px; font-variant-numeric: tabular-nums; }.task-kpis span { color: var(--matte-gray); }.task-board { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); align-items: start; gap: 14px; }.task-column { display: grid; gap: 12px; padding: 14px; min-height: 180px; }.task-card { display: grid; gap: 8px; padding: 14px; }.task-card h3, .task-card p { margin: 0; }.task-card .chip-row button { min-height: 48px; padding: 4px 9px; border: 1px solid var(--hairline); border-radius: 999px; background: var(--light-green); color: var(--deep-green); }.task-actions { display: flex; flex-wrap: wrap; gap: 7px; }.task-actions button { min-height: 48px; padding: 6px 10px; }.overdue-amber { border-left: 6px solid var(--amber); }.overdue-red { border-left: 6px solid var(--warn-red); }.critical { border-left: 6px solid #7e0000; animation: task-critical 1.1s ease-in-out infinite alternate; }@keyframes task-critical { to { box-shadow: 0 0 0 4px #c6282833; } }
@media (max-width: 767px) { .equipment-heading, .detail-heading { align-items: start; flex-direction: column; }.equipment-heading .primary-action { width: 100%; }.equipment-form, .equipment-form.compact, .detail-grid, .task-kpis, .task-board { grid-template-columns: 1fr; }.equipment-form .wide { grid-column: auto; }.task-column { min-height: 0; } }

/* Module 3: intentionally roomy controls for a phone in the cab or shed. */
.inventory-page { min-width: 0; }
.inventory-heading { align-items: center; }
.inventory-tabs { display: flex; gap: 8px; overflow-x: auto; padding: 0 0 16px; border-bottom: 1px solid var(--hairline); }
.inventory-tabs button { flex: 0 0 auto; min-height: 48px; border: 1px solid var(--hairline); border-radius: 9px; padding: 10px 14px; background: var(--surface); color: var(--charcoal); font: inherit; font-size: 18px; font-weight: 700; cursor: pointer; }
.inventory-tabs button.active { border-color: var(--deep-green); background: var(--deep-green); color: var(--on-dark); }
.inventory-search { display: grid; gap: 6px; margin: 20px 0; color: var(--matte-gray); font-size: 18px; font-weight: 700; }
.inventory-search input, .inventory-form input, .inventory-form select { width: 100%; min-height: 48px; box-sizing: border-box; border: 1px solid #adb7b2; border-radius: 8px; padding: 9px 11px; background: var(--surface); color: var(--charcoal); font: inherit; font-size: 18px; }
.inventory-form input:focus, .inventory-form select:focus, .inventory-search input:focus { outline: 3px solid var(--amber); outline-offset: 1px; }
.inventory-group { margin: 26px 0; }
.inventory-group h2, .ledger-history h2, .compliance-list h2 { margin: 0 0 12px; color: var(--deep-green); font-size: 22px; }
.shelf-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(225px, 1fr)); gap: 12px; }
.shelf-card { display: grid; min-height: 150px; align-content: start; gap: 8px; border: 1px solid var(--hairline); border-radius: 16px; padding: 18px; background: var(--surface); color: var(--charcoal); text-align: left; font: inherit; cursor: pointer; }
.shelf-card:hover, .shelf-card.selected { border-color: var(--crx-green); box-shadow: 0 2px 0 var(--crx-green); }
.shelf-card > span { font-weight: 700; }
.shelf-card strong { color: var(--deep-green); font-size: 32px; font-variant-numeric: tabular-nums; }
.shelf-card small { font-size: 18px; }.shelf-card em { width: fit-content; border-radius: 99px; padding: 4px 8px; background: var(--warn-bg); color: #87520b; font-size: 18px; font-style: normal; font-weight: 700; }.shelf-card p { margin: 0; color: var(--warn-red); font-size: 18px; line-height: 1.35; }.shelf-card.low p { color: #87520b; }.shelf-card.negative { border-color: var(--warn-red); }
.inventory-panel { margin-top: 20px; overflow: hidden; border: 1px solid var(--hairline); border-radius: 16px; background: var(--surface); }.panel-note { margin: 0; padding: 16px 20px; color: var(--matte-gray); }
.inventory-form { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; padding: 20px; border-top: 1px solid var(--hairline); }.inventory-form > label, .inventory-form fieldset > label { display: grid; gap: 6px; color: var(--charcoal); font-size: 18px; font-weight: 700; }.inventory-form .wide { grid-column: span 2; }.inventory-form .primary-action { width: fit-content; align-self: end; }
.inline-new-product { display: grid; grid-column: 1 / -1; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; padding: 16px; border-radius: 10px; background: var(--cream); }.inline-new-product > strong { grid-column: 1 / -1; color: var(--deep-green); }.inline-new-product label { display: grid; gap: 6px; font-weight: 700; }.check-label { display: flex !important; align-items: center; gap: 10px; min-height: 48px; }.check-label input { width: 24px; height: 24px; }
.inventory-form fieldset { display: grid; grid-column: 1 / -1; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; margin: 0; border: 1px solid var(--hairline); border-radius: 10px; padding: 16px; }.inventory-form legend { padding: 0 6px; color: var(--deep-green); font-size: 18px; font-weight: 700; }.label-reminder { grid-column: 1 / -1; margin: 0; padding: 12px; border-left: 4px solid var(--amber); background: var(--warn-bg); color: var(--charcoal); }
.ledger-history { padding: 20px; border-top: 1px solid var(--hairline); }.ledger-history > div { display: grid; grid-template-columns: 95px 1fr; gap: 12px; padding: 12px 0; border-top: 1px solid var(--hairline); font-variant-numeric: tabular-nums; }.ledger-history p { color: var(--matte-gray); }.negative-text { color: var(--warn-red); }
.compliance-heading { display: flex; align-items: center; justify-content: space-between; gap: 16px; }.compliance-heading .card-heading { border-radius: 15px 0 0 0; }.compliance-heading .check-label { padding-right: 18px; }.compliance-list { display: grid; gap: 16px; padding: 20px; }.compliance-list article { border: 1px solid var(--hairline); border-radius: 12px; padding: 18px; }.compliance-list article > p { margin: 0 0 14px; color: var(--matte-gray); }.check-columns { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }.check-columns > div { padding: 12px; border-radius: 8px; background: var(--cream); }.check-columns strong { color: var(--deep-green); }.check-columns ul { margin: 8px 0 0; padding-left: 22px; }.check-columns p { margin: 8px 0 0; color: var(--matte-gray); }.label-facts { margin-top: 14px !important; padding-top: 12px; border-top: 1px solid var(--hairline); font-size: 18px; }.teaching-empty { padding: 32px 20px; text-align: center; }.teaching-empty h2 { margin: 0; color: var(--deep-green); }.teaching-empty p { color: var(--matte-gray); }
.receipt-history { display: grid; gap: 12px; padding: 20px; border-top: 1px solid var(--hairline); }.receipt-history h2 { margin: 0; color: var(--deep-green); font-size: 22px; }.receipt-history article { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 14px 0; border-top: 1px solid var(--hairline); }.receipt-history article div { display: grid; gap: 4px; }.receipt-history span { color: var(--matte-gray); }.receipt-history button, .spray-product-row button { min-height: 48px; font: inherit; }.danger-action { color: var(--warn-red); border-color: var(--warn-red); }.spray-product-row { display: grid; grid-column: 1 / -1; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; padding: 16px; background: var(--cream); border-radius: 10px; }.spray-product-row > strong { grid-column: 1 / -1; color: var(--deep-green); }.spray-product-row label { display: grid; gap: 6px; font-weight: 700; }.inventory-page .panel-note, .inventory-page .receipt-history, .inventory-page .check-columns, .inventory-page .teaching-empty { font-size: 18px; }
@media (max-width: 767px) { .inventory-heading { align-items: start; flex-direction: column; }.inventory-heading .primary-action { width: 100%; }.inventory-form, .inline-new-product, .inventory-form fieldset, .spray-product-row { grid-template-columns: 1fr; }.inventory-form .wide { grid-column: auto; }.inventory-form .primary-action { width: 100%; }.shelf-grid { grid-template-columns: 1fr; }.shelf-card { min-height: 132px; }.check-columns { grid-template-columns: 1fr; }.compliance-heading { align-items: start; flex-direction: column; }.compliance-heading .card-heading { width: 100%; border-radius: 15px 15px 0 0; }.compliance-heading .check-label { padding: 0 18px 14px; }.receipt-history article { align-items: start; flex-direction: column; }.receipt-history button { width: 100%; } }

/* Module 4: Profitability. The matrix owns the only horizontal scroll on this page. */
.profitability-page { display: grid; gap: 24px; min-width: 0; }
.profitability-heading { margin-bottom: 0; }
.profitability-error { margin: 0; padding: 14px 18px; border: 2px solid var(--warn-red); border-radius: 10px; background: var(--warn-bg); color: var(--warn-red); font-weight: 700; }
.profitability-card { overflow: hidden; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--surface); box-shadow: 0 3px 10px rgb(23 81 58 / 5%); }
.budget-controls { display: grid; grid-template-columns: 1.3fr repeat(3, minmax(150px, 1fr)) auto; gap: 12px; align-items: end; padding: 18px; }
.budget-controls label, .field-edit label { display: grid; gap: 5px; color: var(--matte-gray); font-size: 18px; font-weight: 700; }
.budget-controls input, .budget-controls select, .cost-add-row input, .cost-add-row select, .costs-card td input, .costs-card td select, .field-edit input, .matrix-controls input { width: 100%; min-height: 48px; padding: 8px 10px; border: 2px solid var(--hairline); border-radius: 9px; background: var(--surface); color: var(--charcoal); font: inherit; font-variant-numeric: tabular-nums; }
.insurance-card { margin-top: 18px; padding: 18px; }
.insurance-inputs, .insurance-results { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; }
.insurance-inputs label { display: grid; gap: 5px; color: var(--matte-gray); font-size: 18px; font-weight: 700; }
.insurance-inputs input, .insurance-inputs select { width: 100%; min-height: 48px; padding: 8px 10px; border: 2px solid var(--hairline); border-radius: 9px; background: var(--surface); color: var(--charcoal); font: inherit; font-variant-numeric: tabular-nums; }
.insurance-inputs small, .insurance-results small { color: var(--matte-gray); font-size: 18px; font-weight: 600; }
.insurance-fact, .insurance-empty, .matrix-insurance-legend { margin: 14px 0 0; color: var(--matte-gray); font-size: 18px; line-height: 1.4; }
.insurance-area-warning { margin: 14px 0 0; padding: 14px 16px; border: 3px solid var(--warn-red); border-radius: 10px; background: var(--warn-bg); color: var(--warn-red); font-size: 18px; font-weight: 800; line-height: 1.4; }
.insurance-results { margin-top: 16px; grid-template-columns: repeat(2, minmax(0, 1fr)); border-top: 1px solid var(--hairline); border-left: 1px solid var(--hairline); }
.insurance-results > div { display: grid; gap: 4px; min-height: 96px; padding: 12px; border-right: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); }
.insurance-results span, .insurance-results small { color: var(--matte-gray); font-size: 18px; font-weight: 700; }
.insurance-results strong { color: var(--charcoal); font-size: 18px; line-height: 1.25; font-variant-numeric: tabular-nums; overflow-wrap: anywhere; }
.below-insurance-floor button { box-shadow: inset 0 0 0 3px rgb(92 76 39 / 55%); }
.profitability-kpis { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; }
.profitability-kpi { display: grid; gap: 6px; min-height: 116px; align-content: center; padding: 18px; border-radius: var(--radius); background: var(--light-green); text-align: center; }
.profitability-kpi strong { color: var(--deep-green); font-family: var(--brand-font); font-size: 25px; font-variant-numeric: tabular-nums; }
.profitability-kpi span { color: var(--matte-gray); font-size: 18px; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; }
.profitability-kpi.alert { background: var(--warn-bg); }
.profitability-kpi.alert strong { color: var(--warn-red); }
.matrix-card .section-heading, .costs-card .section-heading, .allocation-card .section-heading { padding: 20px 20px 14px; }
.matrix-controls { display: grid; grid-template-columns: auto repeat(3, 88px) auto repeat(3, 88px) auto; gap: 8px; align-items: center; padding: 0 20px 18px; border-bottom: 1px solid var(--hairline); color: var(--matte-gray); font-size: 18px; font-weight: 700; }
.matrix-controls input { min-height: 48px; }
.matrix-controls .secondary-action { min-height: 48px; white-space: nowrap; }
.matrix-scroll { max-width: 100%; overflow-x: auto; overscroll-behavior-inline: contain; padding: 18px 20px; }
.profit-matrix { width: max-content; min-width: 720px; border-collapse: separate; border-spacing: 5px; font-variant-numeric: tabular-nums; }
.profit-matrix th { padding: 8px 10px; color: var(--matte-gray); font-size: 18px; text-align: right; white-space: nowrap; }
.profit-matrix thead th { text-align: center; }
.profit-matrix td { padding: 0; border: 0; background: transparent; }
.profit-matrix button { width: 100%; min-width: 104px; min-height: 52px; border: 2px solid transparent; border-radius: 8px; color: var(--charcoal); font-family: var(--ui-font); font-size: 18px; font-weight: 800; font-variant-numeric: tabular-nums; }
.profit-matrix .breakeven-cell { border-color: var(--charcoal); box-shadow: inset 0 0 0 2px var(--surface); }
.profit-matrix .active-cell { outline: 4px solid var(--chrome-green); outline-offset: 1px; }
.matrix-answer { margin: 0; padding: 16px 20px 20px; border-top: 1px solid var(--hairline); color: var(--charcoal); font-size: 19px; font-weight: 700; font-variant-numeric: tabular-nums; }
.costs-card .table-scroll { margin: 0; }
.costs-card table { min-width: 720px; }
.costs-card td { padding: 8px 12px; }
.costs-card td input, .costs-card td select { min-width: 112px; }
.costs-card td:first-child input { min-width: 180px; }
.costs-card th, .costs-card td { font-variant-numeric: tabular-nums; }
.costs-card tbody tr:nth-child(even) td { background: var(--cream); }
.numeric { text-align: right; }
.remove-cost { min-height: 48px; border: 0; background: transparent; color: var(--deep-green); font: inherit; font-size: 18px; font-weight: 700; text-decoration: underline; }
.cost-add-row { display: grid; grid-template-columns: 1.4fr 1fr .7fr auto; gap: 10px; padding: 16px 20px; border-top: 1px solid var(--hairline); background: var(--light-green); }
.total-bar { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 16px 20px; background: var(--crx-green); color: var(--on-dark); font-family: var(--brand-font); font-size: 20px; font-weight: 700; font-variant-numeric: tabular-nums; }
.allocation-nudge { margin: 0 20px 12px; padding: 12px 14px; border-left: 5px solid var(--amber); background: #fffaf0; color: #604a22; font-weight: 600; }
.allocation-list { padding: 0 20px 20px; }
.allocation-row, .allocated-field { border-top: 1px solid var(--hairline); }
.allocation-row { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 14px 0; }
.allocation-row div, .field-edit > div { display: grid; gap: 3px; }
.allocation-row span, .field-edit > span { color: var(--matte-gray); font-size: 18px; }
.allocated-field { padding: 16px 0; }
.field-edit { display: grid; grid-template-columns: 1.5fr repeat(3, minmax(92px, .65fr)); gap: 10px; align-items: end; }
.field-edit strong, .field-edit > span { grid-column: 1; }
.field-edit label { grid-row: 1 / span 2; }
.field-results { display: flex; align-items: center; gap: 18px; margin-top: 12px; padding: 12px; border-radius: 9px; background: var(--cream); font-variant-numeric: tabular-nums; }
.field-results span { display: grid; gap: 2px; color: var(--matte-gray); font-size: 18px; }
.field-results strong { color: var(--deep-green); font-size: 19px; }
.field-results .negative { color: var(--warn-red); }
.field-results .remove-cost { margin-left: auto; }
.arrangement-comparison { margin-top: 12px; padding: 0 12px 12px; border-left: 4px solid var(--amber); background: #fffaf0; }
.arrangement-comparison summary { min-height: 48px; display: flex; align-items: center; color: var(--deep-green); font-size: 18px; font-weight: 700; cursor: pointer; }
.arrangement-comparison p { margin: 0 0 12px; color: var(--matte-gray); font-size: 18px; }
.arrangement-comparison > div { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 8px; }
.arrangement-comparison span { display: grid; gap: 3px; padding: 10px; border: 1px solid var(--hairline); border-radius: 8px; background: var(--surface); color: var(--matte-gray); font-size: 18px; }
.arrangement-comparison b { color: var(--charcoal); font-variant-numeric: tabular-nums; }
.arrangement-comparison .active-arrangement { border: 2px solid var(--crx-green); background: var(--light-green); }

/* Module 4 accessibility baseline: farmer-facing text is 18px+ and controls are 48px+. */
.profitability-page, .profitability-page p, .profitability-page span, .profitability-page th, .profitability-page td,
.profitability-page label, .profitability-page summary, .profitability-page .eyebrow { font-size: 18px; }
.profitability-page button, .profitability-page input, .profitability-page select, .profitability-page summary { min-height: 48px; font-size: 18px; }
.profitability-kpi span, .matrix-controls, .profit-matrix th, .remove-cost, .allocation-row span, .field-edit > span,
.field-results span, .arrangement-comparison p, .arrangement-comparison span { font-size: 18px; }
.matrix-controls input { min-height: 48px; }
.field-results { flex-wrap: wrap; }

@media (max-width: 980px) {
  .budget-controls { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .insurance-inputs { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .matrix-controls { grid-template-columns: auto repeat(3, minmax(62px, 1fr)); }
  .matrix-controls > span:nth-of-type(2) { grid-column: 1; }
  .matrix-controls > button { grid-column: 1 / -1; }
  .field-edit { grid-template-columns: 1fr repeat(3, minmax(84px, 1fr)); }
}
@media (max-width: 767px) {
  .harvest-heading { align-items: stretch; flex-direction: column; }
  .harvest-year { width: 100%; }
  .harvest-crop { grid-template-columns: 1fr; padding: 16px; }
  .harvest-enter { width: 100%; }
  .harvest-results, .harvest-form { grid-template-columns: 1fr; }
  .harvest-results > span { min-width: 0; }
  .harvest-form { padding: 14px; }
  .yield-history h3, .yield-history-strip, .yield-history .card-empty { padding-right: 16px; padding-left: 16px; }
  .yield-history-strip { display: grid; grid-template-columns: 1fr; }
  .yield-history-strip span { min-width: 0; }
  .profitability-page { gap: 18px; }
  .budget-controls, .profitability-kpis, .cost-add-row, .field-edit, .arrangement-comparison > div { grid-template-columns: 1fr; }
  .insurance-inputs, .insurance-results { grid-template-columns: 1fr; }
  .profitability-kpi { min-height: 100px; }
  .profitability-kpi strong { font-size: 27px; }
  .matrix-card .section-heading, .costs-card .section-heading, .allocation-card .section-heading, .matrix-scroll { padding-right: 16px; padding-left: 16px; }
  .matrix-controls { grid-template-columns: repeat(3, minmax(0, 1fr)); padding-right: 16px; padding-left: 16px; }
  .matrix-controls > span { grid-column: 1 / -1; }
  .matrix-controls > span:nth-of-type(2) { grid-column: 1 / -1; }
  .matrix-controls > button { grid-column: 1 / -1; }
  .profit-matrix { min-width: 630px; }
  .profit-matrix button { min-width: 86px; }
  .cost-add-row, .allocation-list { padding-right: 16px; padding-left: 16px; }
  .field-edit strong, .field-edit > span { grid-column: auto; }
  .field-edit label { grid-row: auto; }
  .field-results { align-items: start; flex-direction: column; gap: 8px; }
  .field-results .remove-cost { margin-left: 0; }
  .allocation-row { align-items: start; flex-direction: column; }
  .allocation-row .secondary-action { width: 100%; }
}

/* Module 2 accessibility baseline: every Grain label is 18px+ and every control is a 48px target. */
.grain-page .market-stamp, .grain-page .delayed-label, .grain-page .eyebrow, .grain-page .section-heading p,
.grain-page .commodity-picker, .grain-page .template-button strong, .grain-page .template-button span,
.grain-page .month-cell span, .grain-page .month-cell small, .grain-page .month-cell em, .grain-page .plan-status span:not(.status-chip),
.grain-page .plan-status strong, .grain-page .status-chip, .grain-page .saved-whisper, .grain-page .contract-entry > label,
.grain-page .contract-entry details, .grain-page .contract-entry details label, .grain-page .contracts-card td small,
.grain-page .bin-row > div:first-child span, .grain-page .commodity-badge, .grain-page .bin-balance span,
.grain-page .basis-list span, .grain-page .basis-list small, .grain-page .position-stats span, .grain-page .position-stats small,
.grain-page .position-foot, .grain-page .target-modal label small { font-size: 18px; }
.grain-page button, .grain-page input, .grain-page select, .grain-page summary { min-height: 48px; font-size: 18px; }
.grain-page .math-toggle { min-height: 48px; font-size: 18px; }
.grain-page .math-toggle button { min-width: 106px; border: 0; background: var(--surface); color: var(--charcoal); font-weight: 700; }
.grain-page .math-toggle button.active { color: var(--on-dark); background: var(--deep-green); }
.grain-page .math-toggle button:disabled { cursor: not-allowed; opacity: .55; }
.grain-page .position-stats strong { font-size: 20px; }
.grain-page .position-foot { flex-wrap: wrap; }
.grain-page .sale-limit-editor small { font-size: 18px; }
.grain-page .firm-offer-form, .grain-page .offer-fill-entry { margin: 16px 0; padding: 16px; border: 1px solid var(--hairline); border-radius: 10px; background: var(--light-green); }
.grain-page .firm-offer-form { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
.grain-page .firm-offer-form h3, .grain-page .firm-offer-form .offer-note, .grain-page .firm-offer-form > div { grid-column: 1 / -1; margin: 0; }
.grain-page .firm-offer-form label { display: grid; gap: 4px; font-size: 18px; color: var(--matte-gray); }
.grain-page .firm-offer-form input, .grain-page .firm-offer-form select, .grain-page .firm-offer-form textarea { width: 100%; min-height: 48px; padding: 9px 10px; border: 2px solid var(--hairline); border-radius: 9px; background: var(--surface); color: var(--charcoal); font: inherit; }
.grain-page .firm-offer-form textarea { min-height: 96px; resize: vertical; }
.grain-page .offer-list { display: grid; gap: 10px; margin-top: 16px; }
.grain-page .offer-list details { border-top: 1px solid var(--hairline); }
.grain-page .offer-list summary { min-height: 48px; display: flex; align-items: center; cursor: pointer; font-size: 18px; font-weight: 700; }
.grain-page .offer-row { display: flex; justify-content: space-between; gap: 16px; padding: 14px 0; border-top: 1px solid var(--hairline); }
.grain-page .offer-row > div:first-child { display: grid; gap: 3px; min-width: 0; }
.grain-page .offer-row span, .grain-page .offer-row small { color: var(--matte-gray); font-size: 18px; overflow-wrap: anywhere; }
.grain-page .offer-actions { display: flex; align-items: center; flex-wrap: wrap; gap: 8px; justify-content: flex-end; }
.grain-page .status-chip.open { background: var(--light-green); color: var(--deep-green); }
.grain-page .status-chip.expired, .grain-page .status-chip.canceled { background: #f5e5e0; color: #8b2f22; }
.grain-page .status-chip.filled { background: #e5edf8; color: #224b85; }
.grain-page .pending-offer-line { margin: 12px 0 0; padding: 10px 12px; border-left: 4px solid var(--warn-red); background: #fff4df; font-size: 18px; font-variant-numeric: tabular-nums; }
.grain-page .production-editor { display: grid; grid-template-columns: 1fr 1fr 1fr auto; gap: 12px; align-items: end; margin-top: 14px; }
.grain-page .production-editor label { display: grid; gap: 5px; color: var(--matte-gray); font-size: 18px; font-weight: 700; }
.grain-page .production-editor strong { min-height: 48px; display: flex; align-items: center; color: var(--charcoal); }
.grain-page .grain-inline-error { margin: 12px 20px; font-size: 18px; }
.grain-page .contract-entry { grid-template-columns: 1.2fr 1fr .8fr .8fr auto; }
.grain-page .contract-entry details { grid-column: 1 / -1; }
.grain-page .contract-entry details summary { display: flex; align-items: center; }
.grain-page .progress-track { height: 24px; margin: 0 20px 20px; overflow: hidden; border-radius: 99px; background: var(--cream); }
.grain-page .progress-track span { height: 100%; display: block; background: var(--crx-green); }
.grain-page .actual-plan-card { overflow: hidden; }
.grain-page .basis-chart { width: calc(100% - 40px); height: 150px; margin: 0 20px; overflow: visible; }
.grain-page .basis-chart text { fill: var(--matte-gray); font-size: 13px; } /* svg-viewbox-scale-exempt */
.grain-page .basis-zero { stroke: var(--hairline); stroke-width: 2; }
.grain-page .basis-positive { fill: var(--crx-green); }
.grain-page .basis-negative { fill: var(--amber); }
.grain-page .usda-calendar { padding-bottom: 20px; }
.grain-page .report-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; padding: 0 20px; max-height: 460px; overflow-y: auto; }
.grain-page .report-grid a { min-height: 96px; display: grid; align-content: center; gap: 5px; padding: 12px; border: 1px solid var(--hairline); border-radius: 9px; color: var(--deep-green); font-size: 18px; text-decoration: none; }
.grain-page .report-grid a:hover { background: var(--light-green); }
.grain-page .report-grid span, .grain-page .compliance-note span { color: var(--matte-gray); font-size: 18px; }
.grain-page .computed-price { margin: 0; padding: 12px; border-radius: 8px; background: var(--light-green); font-size: 18px; font-weight: 700; }
@media (max-width: 767px) {
  .grain-page .production-editor { grid-template-columns: 1fr; }
  .grain-page .contract-entry { grid-template-columns: 1fr; }
  .grain-page .firm-offer-form { grid-template-columns: 1fr; }
  .grain-page .offer-row { flex-direction: column; }
  .grain-page .offer-actions { justify-content: flex-start; }
  .grain-page .contract-entry > label, .grain-page .contract-entry details { grid-column: auto; }
  .grain-page .report-grid { grid-template-columns: 1fr; max-height: 420px; padding: 0 16px; }
  .grain-page .basis-chart { width: calc(100% - 32px); margin: 0 16px; }
  .market-data-note { padding-right: 16px; padding-left: 16px; }
  .market-quote-grid { grid-template-columns: 1fr; padding-right: 16px; padding-left: 16px; }
}

@media (max-width: 767px) {
  .grain-heading { gap: 8px; }
  .market-stamp { font-size: 18px; }
  .position-grid { grid-template-columns: minmax(0, 1fr); }
  .position-card { padding: 16px; }
  .position-sentence { min-height: 0; font-size: 18px; }
  .position-foot { align-items: start; flex-direction: column; gap: 4px; }
  .grain-section > .section-heading, .bins-card > .section-heading, .basis-card > .section-heading { padding: 18px 16px 14px; }
  .section-heading { align-items: start; flex-direction: column; gap: 10px; }
  .commodity-picker { width: 100%; }
  .template-bar { padding-right: 16px; padding-left: 16px; }
  .month-grid { padding-right: 16px; padding-left: 16px; }
  .plan-status { align-items: start; flex-direction: column; padding: 15px 16px; }
  .contract-entry { grid-template-columns: 1fr 1fr; padding: 16px; }
  .contract-entry > label:first-child, .contract-entry > label:nth-child(2), .contract-entry details { grid-column: 1 / -1; }
  .contract-entry details > div { grid-template-columns: 1fr 1fr; }
  .contract-entry .primary-action { width: 100%; }
  .storage-layout { grid-template-columns: 1fr; }
  .bins-card { border-right: 0; border-bottom: 1px solid var(--hairline); }
  .bin-list, .basis-list { padding-right: 16px; padding-left: 16px; }
  .bin-row { align-items: start; flex-wrap: wrap; }
  .bin-balance { margin-left: auto; }
  .bin-form, .movement-form { grid-template-columns: 1fr; padding-right: 16px; padding-left: 16px; }
  .bin-fill > div { align-items: start; flex-direction: column; gap: 2px; }
  .basis-entry { grid-template-columns: 1fr; padding: 0 16px 16px; }
  .basis-entry .secondary-action { width: 100%; }
}

.task-title-link { min-height: 48px; padding: 0; border: 0; background: transparent; color: var(--charcoal); font: inherit; font-size: 18px; font-weight: 700; text-align: left; text-decoration: underline; text-decoration-color: var(--crx-green); cursor: pointer; }
.program-task .chip-row button, .program-task .task-actions button { min-height: 48px; }

/* Banker report: on-screen preview overlay + clean print/PDF output. */
.profitability-heading-actions { display: flex; align-items: center; gap: 14px; }
.banker-report-layer { position: fixed; inset: 0; z-index: 40; overflow-y: auto; padding: 20px; background: rgb(46 46 46 / 55%); }
.banker-report-toolbar { display: flex; align-items: center; justify-content: space-between; gap: 16px; width: min(100%, 860px); margin: 0 auto 14px; padding: 14px 18px; border-radius: 12px; background: var(--nav-dark); color: #fff; }
.banker-report-toolbar p { margin: 0; font-size: 18px; }
.banker-report-toolbar > div { display: flex; gap: 10px; }
.banker-report-toolbar .secondary-action { border-color: #fff; color: #fff; background: transparent; }
.banker-report { width: min(100%, 860px); margin: 0 auto 40px; padding: 44px 48px; border-radius: 4px; background: #fff; color: #1c1c1c; font-size: 18px; line-height: 1.45; }
.banker-report .report-head { display: flex; align-items: start; justify-content: space-between; gap: 20px; padding-bottom: 16px; border-bottom: 3px solid var(--crx-green); }
.banker-report h1 { font-size: 30px; letter-spacing: -.01em; }
.banker-report .report-subject { margin: 6px 0 0; color: #4E4E4E; font-size: 18px; }
.banker-report .report-date { margin: 4px 0 0; color: #4E4E4E; font-size: 18px; white-space: nowrap; }
.banker-report .report-kpis { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; margin: 20px 0 10px; }
.banker-report .report-kpis > div { display: grid; gap: 4px; padding: 12px 14px; border: 1px solid #DDD9CF; border-top: 4px solid var(--crx-green); border-radius: 6px; }
.banker-report .report-kpis span { color: #4E4E4E; font-size: 18px; font-weight: 700; letter-spacing: .05em; text-transform: uppercase; }
.banker-report .report-kpis strong { font-family: var(--brand-font); font-size: 22px; font-variant-numeric: tabular-nums; }
.banker-report .report-assumption, .banker-report .report-note { margin: 0 0 8px; color: #4E4E4E; font-size: 18px; }
.banker-report h2 { margin: 26px 0 10px; color: var(--deep-green); font-family: var(--brand-font); font-size: 19px; }
.banker-report table { width: 100%; min-width: 0; border-collapse: collapse; }
.banker-report th { padding: 7px 10px; border-bottom: 2px solid #1c1c1c; color: #4E4E4E; font-size: 18px; font-weight: 700; letter-spacing: .05em; text-align: left; text-transform: uppercase; }
.banker-report td { padding: 8px 10px; border-top: 1px solid #DDD9CF; font-size: 18px; font-variant-numeric: tabular-nums; }
.banker-report .numeric { text-align: right; }
.banker-report .negative { color: var(--warn-red); }
.banker-report .report-total-bar { display: flex; align-items: center; justify-content: space-between; gap: 14px; margin-top: 8px; padding: 10px 12px; border-radius: 6px; background: var(--crx-green); color: #fff; font-weight: 700; font-variant-numeric: tabular-nums; print-color-adjust: exact; -webkit-print-color-adjust: exact; }
.banker-report .report-total-bar .negative { color: #FFD7D7; }
.banker-report .report-foot { display: flex; align-items: center; justify-content: end; gap: 8px; margin-top: 34px; padding-top: 12px; border-top: 1px solid #DDD9CF; color: #4E4E4E; font-size: 18px; }
.banker-report .report-rx { color: var(--crx-green); font-family: var(--brand-font); font-size: 20px; font-weight: 700; }
@media (max-width: 767px) { .banker-report { padding: 24px 18px; }.banker-report .report-kpis { grid-template-columns: repeat(2, minmax(0, 1fr)); }.banker-report .report-head { flex-direction: column; }.banker-report-toolbar { flex-direction: column; align-items: stretch; text-align: center; }.profitability-heading-actions { width: 100%; }.profitability-heading-actions .secondary-action { flex: 1; } }
@media print {
  body * { visibility: hidden; }
  .banker-report-layer { position: static; overflow: visible; padding: 0; background: none; }
  .banker-report, .banker-report * { visibility: visible; }
  .banker-report { width: 100%; margin: 0; padding: 0; border-radius: 0; }
  .screen-only { display: none !important; }
  .banker-report .report-total-bar, .banker-report .report-kpis > div { break-inside: avoid; }
  .landlord-report-page:not(:last-child) { break-after: page; }
}

/* Modern Farmstead restyle (docs/design, Mason 2026-07-12): soft depth + warm neutrals. */
.detail-card, .harvest-card, .scouting-card, .field-log-card, .program-card, .pass-card,
.position-card, .grain-section, .assignment-picker, .crop-tracker, .notification-row,
.empty-state, .phone-alerts { box-shadow: var(--shadow-card); }
.secondary-action, .sign-out { border-radius: 12px; }
.harvest-card-head, .scouting-card-head, .field-log-card-head, .pass-card > header,
.assignment-track > header { background: var(--green-tint); }

/* Profitability upgrade: plan comparison, ROI analyzer, university defaults, coach */
.plan-compare-card .table-scroll, .roi-card .table-scroll { margin: 0; }
.plan-compare { min-width: 760px; border-collapse: collapse; }
.plan-compare th, .plan-compare td { padding: 12px 14px; border-bottom: 1px solid var(--hairline); white-space: nowrap; font-size: 18px; }
.plan-compare thead th { color: var(--matte-gray); font-size: 18px; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; text-align: left; }
.plan-compare tbody th { text-align: left; }
.plan-compare .numeric { text-align: right; font-variant-numeric: tabular-nums; }
.plan-compare .negative { color: var(--warn-red); }
.plan-compare tr.active-plan { background: var(--light-green); }
.plan-compare .plan-name { min-height: 48px; padding: 0; border: 0; background: none; color: var(--deep-green); font-family: var(--ui-font); font-size: 18px; font-weight: 800; text-decoration: underline; cursor: pointer; text-align: left; }
.plan-compare .plan-scenario { display: block; color: var(--matte-gray); font-size: 18px; font-weight: 600; }
.winner-badge { display: inline-block; margin-left: 8px; padding: 2px 10px; border-radius: 999px; background: var(--crx-green); color: var(--on-dark); font-size: 18px; font-weight: 800; letter-spacing: .04em; text-transform: uppercase; }
.plan-compare-note, .roi-guide, .university-note { margin: 0; padding: 14px 20px 18px; color: var(--matte-gray); font-size: 18px; font-weight: 600; }
.roi-controls { display: flex; flex-wrap: wrap; align-items: end; gap: 14px; padding: 0 20px 16px; }
.roi-controls label { display: grid; gap: 6px; font-weight: 700; }
.roi-controls select { min-height: 48px; }
.roi-diff { display: grid; gap: 2px; padding: 8px 14px; border-radius: var(--radius); background: var(--light-green); }
.roi-diff span { color: var(--matte-gray); font-size: 18px; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; }
.roi-diff strong { color: var(--deep-green); font-family: var(--brand-font); font-size: 22px; font-variant-numeric: tabular-nums; }
.roi-table { min-width: 480px; }
.roi-whatif { display: flex; flex-wrap: wrap; align-items: end; gap: 14px; padding: 16px 20px; border-top: 1px solid var(--hairline); }
.roi-whatif label { display: grid; gap: 6px; font-weight: 700; }
.roi-whatif input { width: 120px; min-height: 48px; }
.roi-verdict { padding-bottom: 10px; color: var(--deep-green); font-family: var(--brand-font); font-size: 21px; font-weight: 800; font-variant-numeric: tabular-nums; }
.roi-verdict.negative { color: var(--warn-red); }
.coach-nudge { display: grid; gap: 10px; margin: 12px 20px 18px; }
.coach-nudge p { margin: 0; }
.coach-actions { display: flex; flex-wrap: wrap; gap: 10px; }
.default-badge { display: inline-block; margin-top: 4px; padding: 2px 10px; border-radius: 999px; background: var(--warn-bg); color: #604a22; font-size: 18px; font-weight: 700; }
.profitability-kpi em { color: var(--matte-gray); font-size: 18px; font-style: normal; font-weight: 700; font-variant-numeric: tabular-nums; }
.profitability-page .primary-action + .secondary-action { margin-left: 12px; }

/* Section header tabs (FPM pattern, 2026-07-13): sidebar picks the section, these pick the page */
.section-tabs { display: flex; gap: 4px; margin: 0 0 4px; border-bottom: 2px solid var(--hairline); overflow-x: auto; overscroll-behavior-inline: contain; }
.section-tabs a { display: inline-flex; align-items: center; min-height: 48px; padding: 10px 18px; border-bottom: 3px solid transparent; margin-bottom: -2px; color: var(--matte-gray); font-size: 18px; font-weight: 700; text-decoration: none; white-space: nowrap; }
.section-tabs a:hover { color: var(--deep-green); }
.section-tabs a.active { color: var(--deep-green); border-bottom-color: var(--crx-green); }
.overview-picker { display: flex; flex-wrap: wrap; align-items: center; gap: 16px; padding: 16px 20px; }
.overview-picker label { display: grid; gap: 6px; font-weight: 700; }
.overview-picker select { min-height: 48px; min-width: 240px; }
.overview-scenario { color: var(--matte-gray); font-size: 18px; font-weight: 700; font-variant-numeric: tabular-nums; }
.report-launcher { display: grid; gap: 16px; padding: 0 20px 20px; }
.report-launcher-row { display: flex; flex-wrap: wrap; align-items: end; gap: 12px; min-width: 0; }
.report-launcher-row p { flex: 1 1 320px; margin: 0; color: var(--matte-gray); font-size: 18px; font-weight: 600; }
.report-launcher-row label { display: grid; flex: 1 1 220px; gap: 6px; min-width: 0; color: var(--matte-gray); font-size: 18px; font-weight: 700; }
.report-launcher-row select { width: 100%; min-height: 48px; padding: 8px 10px; border: 2px solid var(--hairline); border-radius: 9px; background: var(--surface); color: var(--charcoal); font: inherit; font-size: 18px; font-variant-numeric: tabular-nums; }

/* Landlord report: uses the banker-report print shell so on-screen review and PDF output stay identical. */
.landlord-report-pages { display: grid; gap: 24px; }
.banker-report .landlord-field { margin-top: 26px; break-inside: avoid; }
.banker-report .landlord-field-head { display: flex; align-items: start; justify-content: space-between; gap: 16px; padding-bottom: 8px; border-bottom: 1px solid #DDD9CF; }
.banker-report .landlord-field h2 { margin: 0; color: #1c1c1c; font-size: 21px; }
.banker-report .landlord-field-head p { margin: 3px 0 0; color: #4E4E4E; font-size: 18px; font-variant-numeric: tabular-nums; }
.banker-report .landlord-field-head > span { padding: 3px 8px; border: 1px solid #DDD9CF; border-radius: 999px; color: #1c1c1c; font-size: 18px; font-weight: 700; white-space: nowrap; }
.banker-report .landlord-detail-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18px; margin-top: 14px; }
.banker-report .landlord-field h3 { margin: 0 0 7px; color: #1c1c1c; font-size: 18px; text-transform: uppercase; letter-spacing: .05em; }
.banker-report .landlord-field dl { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px 14px; margin: 0; }
.banker-report .landlord-field dl div { min-width: 0; }
.banker-report .landlord-field dt { color: #4E4E4E; font-size: 18px; font-weight: 700; }
.banker-report .landlord-field dd { margin: 1px 0 0; color: #1c1c1c; font-size: 18px; font-weight: 700; font-variant-numeric: tabular-nums; overflow-wrap: anywhere; }
.banker-report .landlord-planting + .landlord-planting { margin-top: 20px; padding-top: 20px; border-top: 1px solid #DDD9CF; }
.banker-report .landlord-inputs, .banker-report .landlord-settlement, .banker-report .landlord-rent { margin-top: 18px; }
.banker-report .landlord-inputs table { table-layout: fixed; }
.banker-report .landlord-inputs th, .banker-report .landlord-inputs td { overflow-wrap: anywhere; }
.banker-report .landlord-rent p { margin: 0; color: #1c1c1c; font-size: 18px; font-weight: 700; font-variant-numeric: tabular-nums; }
.banker-report .landlord-empty { margin-top: 26px; }
.banker-report.landlord-report-page, .banker-report.landlord-report-page p, .banker-report.landlord-report-page th, .banker-report.landlord-report-page td, .banker-report.landlord-report-page dt, .banker-report.landlord-report-page dd, .banker-report.landlord-report-page span { font-size: 18px; font-variant-numeric: tabular-nums; }
.banker-report.landlord-report-page h3 { font-size: 20px; }
.banker-report .settlement-block { padding: 12px; border: 2px solid var(--warn-red); color: var(--warn-red); font-weight: 800; }
.banker-report .landlord-net { margin: 10px 0 0; padding: 12px; border: 2px solid var(--deep-green); color: var(--deep-green); font-size: 20px; font-weight: 800; font-variant-numeric: tabular-nums; }
.banker-report .landlord-disclosure { margin-top: 24px; padding: 14px; border: 1px solid #DDD9CF; color: #1c1c1c; font-size: 18px; font-variant-numeric: tabular-nums; }
.banker-report .landlord-disclosure p { margin: 0; }.banker-report .landlord-disclosure p + p { margin-top: 10px; }
@media (max-width: 767px) { .report-launcher { padding-right: 16px; padding-left: 16px; }.report-launcher-row { align-items: stretch; }.report-launcher-row .primary-action, .report-launcher-row .secondary-action { width: 100%; }.report-launcher-row p { flex-basis: 100%; }.banker-report .landlord-detail-grid { grid-template-columns: 1fr; }.banker-report .landlord-field-head { flex-direction: column; }.banker-report .landlord-field-head > span { white-space: normal; } }
@media print {
  .banker-report.landlord-report-page, .banker-report.landlord-report-page p, .banker-report.landlord-report-page th, .banker-report.landlord-report-page td, .banker-report.landlord-report-page dt, .banker-report.landlord-report-page dd, .banker-report.landlord-report-page span { color: #000 !important; font-size: 18px !important; }
  .banker-report.landlord-report-page h1 { color: #000 !important; font-size: 30px !important; }
  .banker-report.landlord-report-page h2 { color: #000 !important; font-size: 24px !important; }
  .banker-report.landlord-report-page h3 { color: #000 !important; font-size: 20px !important; }
  .banker-report.landlord-report-page .report-total-bar, .banker-report.landlord-report-page .report-total-bar *, .banker-report.landlord-report-page .landlord-settlement, .banker-report.landlord-report-page .landlord-settlement * { background: #fff !important; color: #000 !important; }
  .banker-report.landlord-report-page .report-total-bar { border: 1px solid #000; }
}

/* Grain cost of carry: manual-price calculator, kept readable from a truck cab. */
.carry-settings { display: grid; grid-template-columns: 1.35fr repeat(3, minmax(150px, 1fr)); gap: 14px; align-items: end; padding: 0 20px 20px; }
.carry-settings > label, .carry-crop-controls > label { display: grid; gap: 6px; color: var(--matte-gray); font-size: 18px; font-weight: 700; }
.carry-settings input, .carry-crop-controls input, .carry-crop-controls select, .carry-table input { width: 100%; min-height: 48px; padding: 8px 10px; border: 2px solid var(--hairline); border-radius: 9px; background: var(--surface); color: var(--charcoal); font: inherit; font-size: 18px; font-variant-numeric: tabular-nums; }
.carry-toggle { display: grid; grid-template-columns: 1fr 1fr; min-height: 48px; overflow: hidden; border: 2px solid var(--hairline); border-radius: 10px; }
.carry-toggle button { min-height: 48px; padding: 8px 12px; border: 0; border-left: 1px solid var(--hairline); background: var(--surface); color: var(--deep-green); font: inherit; font-size: 18px; font-weight: 800; }
.carry-toggle button:first-child { border-left: 0; }.carry-toggle button.active { background: var(--deep-green); color: var(--on-dark); }
.carry-crop-controls { display: grid; grid-template-columns: repeat(2, minmax(180px, 260px)); gap: 14px; padding: 0 20px 20px; }
.carry-kpis { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; padding: 0 20px 20px; }
.carry-kpis .stat-card { min-width: 0; }.carry-kpis .stat-label { font-size: 18px; }.carry-kpis .stat-value { min-height: 72px; font-size: 31px; overflow-wrap: anywhere; }.carry-kpis .negative { color: var(--warn-red); }.carry-kpis .carry-verdict { color: var(--deep-green); font-size: 27px; }
.carry-table-scroll { border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); }.carry-table { min-width: 1280px; }.carry-table th, .carry-table td { padding: 12px 14px; font-size: 18px; font-variant-numeric: tabular-nums; white-space: nowrap; }.carry-table thead th { font-size: 18px; }.carry-table tbody tr:nth-child(even) td, .carry-table tbody tr:nth-child(even) th { background: var(--cream); }.carry-table .harvest-row td, .carry-table .harvest-row th { background: var(--green-tint); }.carry-table tbody th { text-align: left; }.carry-table tbody th span { display: block; margin-top: 4px; color: var(--deep-green); font-size: 18px; font-weight: 700; }.carry-table .positive { color: var(--crx-green); font-weight: 800; }.carry-table .negative { color: var(--warn-red); font-weight: 800; }.carry-table input { min-width: 112px; text-align: right; }
.carry-footer { margin: 0; padding: 18px 20px 20px; color: var(--charcoal); font-size: 19px; font-weight: 700; font-variant-numeric: tabular-nums; }
@media (max-width: 767px) { .carry-settings, .carry-kpis { grid-template-columns: 1fr; padding-right: 16px; padding-left: 16px; }.carry-crop-controls { grid-template-columns: 1fr; padding-right: 16px; padding-left: 16px; }.carry-toggle { width: 100%; }.carry-kpis .stat-value { min-height: 0; font-size: 32px; }.carry-footer { padding-right: 16px; padding-left: 16px; } }

/* Grain marketing alerts: factual, check-on-open reminders with phone-sized controls. */
.alert-template-row { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; padding: 0 20px 20px; }
.alert-template { display: grid; min-height: 126px; align-content: center; gap: 7px; padding: 16px; border: 1px solid var(--hairline); border-top: 6px solid var(--crx-green); border-radius: var(--radius); background: var(--surface); color: var(--charcoal); text-align: left; font: inherit; cursor: pointer; }
.alert-template:nth-child(2) { border-top-color: var(--amber); }.alert-template:nth-child(3) { border-top-color: var(--deep-green); }.alert-template:hover { background: var(--light-green); border-color: var(--deep-green); }.alert-template strong { font-family: var(--brand-font); font-size: 25px; }.alert-template span, .alert-rule span, .alert-rule small, .alert-empty { color: var(--matte-gray); font-size: 18px; }.alert-rule-form { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; padding: 20px; border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); background: var(--light-green); font-variant-numeric: tabular-nums; }.alert-rule-form > div:first-child, .alert-rule-form .alert-note, .alert-rule-form .form-error, .alert-rule-form .alert-form-actions { grid-column: 1 / -1; }.alert-rule-form h3, .alert-rule-form p { margin: 0; }.alert-rule-form h3 { font-size: 23px; }.alert-rule-form > div:first-child p { color: var(--matte-gray); }.alert-rule-form label, .alert-email-card label { display: grid; gap: 6px; color: var(--matte-gray); font-size: 18px; font-weight: 700; }.alert-rule-form input, .alert-rule-form select, .alert-email-card input { width: 100%; min-height: 48px; box-sizing: border-box; padding: 8px 10px; border: 2px solid var(--hairline); border-radius: 9px; background: var(--surface); color: var(--charcoal); font: inherit; font-size: 18px; font-variant-numeric: tabular-nums; }.alert-rule-form label small, .alert-email-card label small { color: var(--matte-gray); font-size: 18px; font-weight: 500; }.alert-fact { align-self: end; margin: 0; padding: 12px; border-left: 5px solid var(--crx-green); background: var(--surface); color: var(--charcoal); font-size: 18px; font-weight: 700; }.alert-form-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 14px; }.alert-rule-list { display: grid; padding: 0 20px; }.alert-rule { display: flex; align-items: center; justify-content: space-between; gap: 18px; padding: 18px 0; border-top: 1px solid var(--hairline); font-variant-numeric: tabular-nums; }.alert-rule > div:first-child { display: grid; gap: 5px; min-width: 0; }.alert-rule > div:first-child strong { font-size: 19px; }.alert-rule.paused { opacity: .62; }.alert-rule-actions { display: flex; flex-wrap: wrap; justify-content: end; gap: 8px; }.alert-rule-actions .text-action { min-height: 48px; }.alert-empty { margin: 0; padding: 20px 0; }.alert-email-card form { display: grid; gap: 14px; padding: 0 20px 20px; }.alert-email-card form > div { display: flex; align-items: center; flex-wrap: wrap; gap: 12px; }
@media (max-width: 767px) { .alert-template-row, .alert-rule-form { grid-template-columns: 1fr; padding-right: 16px; padding-left: 16px; }.alert-template { min-height: 104px; }.alert-rule-form > div:first-child, .alert-rule-form .alert-note, .alert-rule-form .form-error, .alert-rule-form .alert-form-actions { grid-column: auto; }.alert-rule { align-items: start; flex-direction: column; }.alert-rule-actions { width: 100%; justify-content: start; }.alert-rule-actions .secondary-action { flex: 1 1 100%; }.alert-email-card form { padding-right: 16px; padding-left: 16px; }.alert-email-card form .primary-action { width: 100%; } }

/* Chunk 7 profitability overview: crop cards + grouped expense categories. */
.whole-farm-kpis { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; }
.whole-farm-kpi { display: grid; gap: 10px; min-width: 0; min-height: 124px; align-content: center; padding: 18px; border: 1px solid var(--hairline); border-top: 6px solid var(--crx-green); border-radius: var(--radius); background: var(--surface); box-shadow: var(--shadow-card); font-variant-numeric: tabular-nums; }
.whole-farm-kpi:nth-child(2) { border-top-color: var(--amber); }.whole-farm-kpi:nth-child(3) { border-top-color: var(--deep-green); }.whole-farm-kpi:nth-child(4) { border-top-color: var(--crx-green); }
.whole-farm-kpi span { color: var(--matte-gray); font-size: 18px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; }.whole-farm-kpi strong { overflow-wrap: anywhere; color: var(--charcoal); font-family: var(--brand-font); font-size: 31px; line-height: 1; }.whole-farm-kpi.alert strong { color: var(--warn-red); }
.overview-budgets { display: grid; gap: 16px; min-width: 0; }.overview-budgets-heading { display: flex; align-items: end; justify-content: space-between; gap: 16px; }.overview-budgets-heading h2 { margin: 2px 0 4px; }.overview-budgets-heading p { margin: 0; color: var(--matte-gray); }.overview-budgets-heading label { display: grid; flex: 0 0 180px; gap: 6px; color: var(--matte-gray); font-size: 18px; font-weight: 700; }.overview-budgets-heading select { min-height: 48px; padding: 8px 10px; border: 2px solid var(--hairline); border-radius: 9px; background: var(--surface); color: var(--charcoal); font: inherit; font-size: 18px; font-variant-numeric: tabular-nums; }
.overview-budget-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; min-width: 0; }.overview-budget-card { display: grid; min-width: 0; overflow: hidden; border: 1px solid var(--hairline); border-top: 6px solid var(--crx-green); border-radius: var(--radius); background: var(--surface); box-shadow: var(--shadow-card); font-variant-numeric: tabular-nums; }.overview-budget-card:nth-child(3n+2) { border-top-color: var(--amber); }.overview-budget-card:nth-child(3n) { border-top-color: var(--deep-green); }
.overview-budget-main { display: grid; gap: 16px; min-width: 0; padding: 20px; cursor: pointer; }.overview-budget-main:focus-visible { outline: 3px solid var(--amber); outline-offset: -3px; }.overview-budget-main header { display: grid; gap: 2px; }.overview-budget-main header span, .overview-cost-bars-title { color: var(--matte-gray); font-size: 18px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; }.overview-budget-main h3 { margin: 0; color: var(--charcoal); font-family: var(--brand-font); font-size: 25px; line-height: 1.05; }.overview-profit { display: grid; gap: 4px; }.overview-profit span { color: var(--matte-gray); font-size: 18px; font-weight: 700; }.overview-profit strong { color: var(--deep-green); font-family: var(--brand-font); font-size: 42px; line-height: 1; }.overview-profit.negative strong { color: var(--warn-red); }
.overview-budget-metrics { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 8px; margin: 0; }.overview-budget-metrics div { min-width: 0; padding: 10px 0; border-top: 1px solid var(--hairline); }.overview-budget-metrics dt { color: var(--matte-gray); font-size: 18px; font-weight: 700; }.overview-budget-metrics dd { margin: 3px 0 0; color: var(--charcoal); font-size: 18px; font-weight: 800; overflow-wrap: anywhere; }.overview-cost-bars { display: grid; gap: 8px; }.overview-cost-bars p { margin: 0; color: var(--matte-gray); }.overview-cost-bar { display: grid; grid-template-columns: minmax(74px, .8fr) minmax(70px, 1fr) auto; gap: 8px; align-items: center; min-width: 0; }.overview-cost-bar > span, .overview-cost-bar strong { min-width: 0; font-size: 18px; overflow-wrap: anywhere; }.overview-cost-bar strong { text-align: right; white-space: nowrap; }.overview-cost-bar > div { height: 10px; overflow: hidden; border-radius: 999px; background: var(--cream-dark); }.overview-cost-bar i { display: block; height: 100%; border-radius: inherit; background: var(--deep-green); }.overview-budget-card footer { display: grid; gap: 10px; padding: 14px 20px 18px; border-top: 1px solid var(--hairline); background: var(--green-tint); }.overview-budget-card footer > span { color: var(--matte-gray); font-size: 18px; font-weight: 700; }.overview-view-budget { justify-self: start; min-height: 48px; padding: 0; border: 0; background: transparent; color: var(--deep-green); font: inherit; font-size: 18px; font-weight: 800; text-decoration: underline; cursor: pointer; }
.overview-budget-card.selected { border-color: var(--deep-green); box-shadow: 0 0 0 2px var(--deep-green), var(--shadow-card); }
.overview-budget-metrics dd em { display: block; margin-top: 2px; color: var(--matte-gray); font-size: 18px; font-style: normal; font-weight: 700; font-variant-numeric: tabular-nums; }
.cost-category-group .cost-category-subtotal th, .cost-category-group .cost-category-subtotal td { padding: 8px 12px; border-top: 2px solid var(--hairline); background: var(--green-tint); color: var(--charcoal); font-size: 18px; font-variant-numeric: tabular-nums; }.cost-category-group .cost-category-subtotal th { text-align: left; text-transform: none; }.cost-category-subtotal th span { font-weight: 800; }.cost-category-subtotal th small { display: block; margin-top: 2px; color: var(--matte-gray); font-size: 18px; font-weight: 700; text-transform: none; }.cost-category-subtotal td { font-weight: 800; }.cost-category-subtotal td:last-child { padding: 4px 8px; text-align: right; }.cost-category-toggle { display: inline-grid; width: 48px; min-height: 48px; place-items: center; border: 0; border-radius: 9px; background: transparent; color: var(--deep-green); font: inherit; font-size: 26px; font-weight: 800; cursor: pointer; }.cost-category-toggle:hover, .cost-category-toggle:focus-visible { background: var(--light-green); }.cost-category-group tr:nth-child(even) td { background: var(--cream); }
@media (max-width: 767px) { .whole-farm-kpis { grid-template-columns: 1fr; }.whole-farm-kpi { min-height: 104px; }.overview-budgets-heading { align-items: stretch; flex-direction: column; }.overview-budgets-heading label { flex-basis: auto; width: 100%; }.overview-budget-grid { grid-template-columns: minmax(0, 1fr); }.overview-budget-metrics { grid-template-columns: 1fr; }.overview-budget-main, .overview-budget-card footer { padding-right: 16px; padding-left: 16px; }.overview-cost-bar { grid-template-columns: minmax(82px, 1fr) minmax(70px, 1fr) auto; } }
 .save-receipt { display: inline-block; min-height: 18px; margin: 4px 0; font-size: 18px; line-height: 1.25; color: var(--ink-muted); }
 .save-receipt-saved { color: var(--success, #237a49); }
 .save-receipt-queued-offline { color: #805d00; }
 .save-receipt-needs-attention { color: #9b2525; font-weight: 700; }
.needs-attention-list { display: grid; gap: 14px; margin: 20px 0; padding: 20px; border: 2px solid var(--warn-red); border-radius: var(--radius); background: var(--warn-bg); }
.durability-update-message { grid-column: 1 / -1; margin: 0; color: #805d00; font-size: 18px; font-weight: 700; }
.needs-attention-list h2, .needs-attention-list p { margin: 0; }.needs-attention-list h2 { font-size: 24px; }.needs-attention-list > p, .needs-attention-list article span { color: var(--matte-gray); font-size: 18px; }
.needs-attention-list article { display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: center; padding: 16px; border: 1px solid var(--hairline); border-radius: 12px; background: var(--surface); }.needs-attention-list article > div:first-child { display: grid; gap: 5px; }.needs-attention-list article strong, .needs-attention-list article p { font-size: 18px; }.needs-attention-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 10px; }.needs-attention-actions button, .needs-attention-update { min-height: 48px; font-size: 18px; }.needs-attention-update { display: inline-flex; align-items: center; color: var(--warn-red); font-weight: 800; }.needs-attention-error { color: var(--warn-red); font-weight: 800; }
@media (max-width: 767px) { .needs-attention-list article { grid-template-columns: 1fr; }.needs-attention-actions { align-items: stretch; }.needs-attention-actions button { flex: 1 1 100%; } }
.revoked-work-recovery { display: grid; gap: 14px; margin: 20px 0; padding: 20px; border: 2px solid #805d00; border-radius: var(--radius); background: var(--warn-bg); }.revoked-work-recovery h2, .revoked-work-recovery p { margin: 0; }.revoked-work-recovery h2 { font-size: 24px; }.revoked-work-recovery > p, .revoked-work-recovery article span { color: #604a22; }.revoked-work-recovery article { display: flex; align-items: center; justify-content: space-between; gap: 14px; padding: 14px; border: 1px solid #d8bb74; border-radius: 12px; background: var(--surface); }.revoked-work-recovery article > div:first-child { display: grid; gap: 4px; }.revoked-work-recovery article > div:last-child { display: flex; flex-wrap: wrap; gap: 8px; }.revoked-work-recovery article span { font-size: 18px; } @media (max-width: 767px) { .revoked-work-recovery article { align-items: stretch; flex-direction: column; }.revoked-work-recovery article > div:last-child button { width: 100%; } }


