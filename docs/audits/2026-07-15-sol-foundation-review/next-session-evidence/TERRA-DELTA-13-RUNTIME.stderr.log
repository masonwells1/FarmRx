 373: function FarmAccessGate({ children }: { children: ReactNode }) {
 374:   const { user } = useAuth();
 375:   if (!user)
 376:     return (
 377:       <main className="login-page">
 378:         <p className="opening-farm">Opening your farm…</p>
 379:       </main>
 380:     );
 381:   return <FarmAccessGateForUser key={user.id} user={user}>{children}</FarmAccessGateForUser>;
 382: }
 383:
 384: function FarmAccessGateForUser({ children, user }: { children: ReactNode; user: User }) {
 385:   const [state, setState] = useState<
 386:     "checking" | "choose" | "ready" | "setup" | "blocked"
 387:   >("checking");
 388:   const [access, setAccess] = useState<FarmAccess | null>(null);
 389:   const [message, setMessage] = useState("");
 390:   useEffect(() => {
 391:     let active = true;
 392:     const acceptValidatedAccess = async (latest: FarmAccess) => {
 393:       if (!active) return;
 394:       if (latest.userId !== user.id) throw new Error("Farm access validation no longer matches the signed-in account.");
 395:       setAccess(latest);
 396:       if (!latest.selectedFarmId) {
 397:         if (latest.farms.length) setState("choose");
 398:         else if (user?.app_metadata.initial_farm_owner === true) setState("setup");
 399:         else { setMessage("Crop RX needs to finish your farm setup."); setState("blocked"); }
 400:         return;
 401:       }
 402:       setState("ready");
 403:       await replayFieldsQueue();
 404:       await replayProgramsThenGenerateDueItems(
 405:         replayProgramsQueue,
 406:         generateDueProgramItems,
 407:       );
 408:       await replayHarvestQueue();
 409:       void replayGrainQueue();
 410:       void replayInventoryQueue();
 411:       void replayProfitabilityQueue();
 412:       void replayEquipmentTasksQueue();
 413:       await replayFieldLocationQueue();
 414:       await replayFieldLogQueue();
 415:       await replayScoutingQueue();
 416:       await replayNotificationsQueue();
 417:     };
 418:     const replayOnReconnect = async () => {
 419:       if (!user) return;
 420:       try { await acceptValidatedAccess(await loadFarmAccess(user.id, true)); }
 421:       catch (error) {
 422:         if (!active) return;
 423:         setMessage(farmerError(error, "open your farm"));
 424:         setState("blocked");
 425:       }
 426:     };
 427:     const reconnect = () => { void replayOnReconnect() };
 428:     window.addEventListener("online", reconnect);
 429:     if (user) void loadFarmAccess(user.id, true)
 430:       .then(acceptValidatedAccess)
 431:       .catch((error: unknown) => {
 432:         if (!active) return;
 433:         setMessage(farmerError(error, "open your farm"));
 434:         setState("blocked");
 435:       });
 436:     return () => {
 437:       active = false;
 438:       window.removeEventListener("online", reconnect);
 439:     };
 440:   }, [user?.app_metadata.initial_farm_owner, user?.id]);
 441:   if (state === "checking")
 442:     return (
 443:       <main className="login-page">
 444:         <p className="opening-farm">Opening your farm…</p>
 445:       </main>
 446:     );
 447:   if (state === "setup")
 448:     return <InitialFarmSetup onComplete={async () => { const latest = await loadFarmAccess(user.id, true); setAccess(latest); setState(latest.selectedFarmId ? "ready" : "choose"); }} />;
 449:   if (state === "choose" && access?.userId === user.id)
 450:     return <main className="login-page"><section className="login-panel farm-choice" aria-labelledby="farm-choice-title"><h1 id="farm-choice-title">Choose a farm</h1><p>Your records and saved offline work stay separated by farm.</p><div className="farm-choice-list">{access.farms.map((farm) => <button className="primary-action" type="button" key={farm.id} onClick={() => { void selectFarm(user.id, farm.id).then(() => window.location.assign('/fields')).catch((error) => { setMessage(farmerError(error, 'open this farm')); setState('blocked') }) }}>{farm.name}</button>)}</div><RevokedFarmRecovery userId={user.id} /></section></main>;
 451:   if (state === "blocked")
 452:     return (
 453:       <main className="login-page">
 454:         <section className="login-panel">
 455:           <p className="opening-farm">{message}</p>
 456:           <RevokedFarmRecovery userId={user.id} />
 457:         </section>
 458:       </main>
 459:     );
 460:   if (access?.userId !== user.id || !access.selectedFarmId)
 461:     return (
 462:       <main className="login-page">
 463:         <p className="opening-farm">Opening your farm…</p>
 464:       </main>
 465:     );
 466:   const activeFarm = access.farms.find((farm) => farm.id === access.selectedFarmId);
 467:   if (!activeFarm) return null;
 468:   const chooseFarm = async (farmId: string) => {
 469:     if (farmId === activeFarm.id) return;
 470:     if (hasPendingFarmWork(user.id, activeFarm.id) && !window.confirm(`Saved changes are still waiting for ${activeFarm.name}. They will stay with that farm. Switch farms anyway?`)) return;
 471:     await selectFarm(user.id, farmId);
 472:     window.location.assign('/fields');
 473:   };
 474:   return <FarmAccessProvider value={{ farms: access.farms, activeFarm, source: access.source, chooseFarm }}>{children}</FarmAccessProvider>;
 475: }
 476:
 477: function InitialFarmSetup({ onComplete }: { onComplete: () => Promise<void> }) {
 478:   const [submitting, setSubmitting] = useState(false);
 479:   const [error, setError] = useState<string | null>(null);
 480:   const submitLock = useRef(createSubmitLock());
 481:   async function submit(event: FormEvent<HTMLFormElement>) {
 482:     event.preventDefault();
 483:     if (!submitLock.current.acquire()) return;
 484:     try {
 485:       setSubmitting(true);
 486:       setError(null);
 487:       const form = new FormData(event.currentTarget);
 488:       await bootstrapInitialOwnerFarm({
 489:         farmName: String(form.get("farmName") ?? ""),
 490:         entityName: String(form.get("entityName") ?? ""),
 491:         selectedEntityType: String(
 492:           form.get("entityType") ?? "llc",
 493:         ) as EntityType,
 494:       });
 495:       await onComplete();
 496:     } catch (caught) {
 497:       setError(farmerError(caught, "finish your setup"));
 498:     } finally {
 499:       submitLock.current.release();
 500:       setSubmitting(false);
 501:     }
 502:   }
 503:   return (
 504:     <main className="login-page">
 505:       <section className="login-panel" aria-labelledby="setup-title">
 506:         <div className="login-brand">
 507:           <h1 id="setup-title">Set up your farm</h1>
 508:           <p>Tell us the farm and operating name to get started.</p>
 509:         </div>
 510:         <form className="login-card" onSubmit={submit}>
 511:           <label htmlFor="farmName">Farm name</label>
 512:           <input id="farmName" name="farmName" required disabled={submitting} />
 513:           <label htmlFor="entityName">Operating name</label>
 514:           <input
 515:             id="entityName"
 516:             name="entityName"
 517:             required
 518:             disabled={submitting}
 519:           />
 520:           <label htmlFor="entityType">Entity type</label>
 521:           <select
 522:             id="entityType"
 523:             name="entityType"
 524:             defaultValue="llc"
 525:             disabled={submitting}
 526:           >
 527:             <option value="individual">Individual</option>
 528:             <option value="sole_proprietorship">Sole proprietorship</option>
 529:             <option value="partnership">Partnership</option>
 530:             <option value="llc">LLC</option>
 531:             <option value="corporation">Corporation</option>
 532:             <option value="trust">Trust</option>
 533:           </select>
 534:           {error && (
 535:             <p className="auth-error" role="alert">
 536:               {error}
 537:             </p>
 538:           )}
 539:           <button
 540:             className="primary-action"
 541:             type="submit"
 542:             disabled={submitting}
 543:           >
 544:             {submitting ? "Saving…" : "Save farm"}
 545:           </button>
 546:         </form>
 547:       </section>
 548:     </main>
 549:   );
 550: }
