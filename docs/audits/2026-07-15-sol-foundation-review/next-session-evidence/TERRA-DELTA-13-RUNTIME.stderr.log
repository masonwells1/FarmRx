src/styles/app.css-641-.ledger-history { padding: 20px; border-top: 1px solid var(--hairline); }.ledger-history > div { display: grid; grid-template-columns: 95px 1fr; gap: 12px; padding: 12px 0; border-top: 1px solid var(--hairline); font-variant-numeric: tabular-nums; }.ledger-history p { color: var(--matte-gray); }.negative-text { color: var(--warn-red); }
src/styles/app.css-642-.compliance-heading { display: flex; align-items: center; justify-content: space-between; gap: 16px; }.compliance-heading .card-heading { border-radius: 15px 0 0 0; }.compliance-heading .check-label { padding-right: 18px; }.compliance-list { display: grid; gap: 16px; padding: 20px; }.compliance-list article { border: 1px solid var(--hairline); border-radius: 12px; padding: 18px; }.compliance-list article > p { margin: 0 0 14px; color: var(--matte-gray); }.check-columns { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }.check-columns > div { padding: 12px; border-radius: 8px; background: var(--cream); }.check-columns strong { color: var(--deep-green); }.check-columns ul { margin: 8px 0 0; padding-left: 22px; }.check-columns p { margin: 8px 0 0; color: var(--matte-gray); }.label-facts { margin-top: 14px !important; padding-top: 12px; border-top: 1px solid var(--hairline); font-size: 18px; }.teaching-empty { padding: 32px 20px; text-align: center; }.teaching-empty h2 { margin: 0; color: var(--deep-green); }.teaching-empty p { color: var(--matte-gray); }
src/styles/app.css:643:.receipt-history { display: grid; gap: 12px; padding: 20px; border-top: 1px solid var(--hairline); }.receipt-history h2 { margin: 0; color: var(--deep-green); font-size: 22px; }.receipt-history article { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 14px 0; border-top: 1px solid var(--hairline); }.receipt-history article div { display: grid; gap: 4px; }.receipt-history span { color: var(--matte-gray); }.receipt-history button, .spray-product-row button { min-height: 48px; font: inherit; }.danger-action { color: var(--warn-red); border-color: var(--warn-red); }.spray-product-row { display: grid; grid-column: 1 / -1; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; padding: 16px; background: var(--cream); border-radius: 10px; }.spray-product-row > strong { grid-column: 1 / -1; color: var(--deep-green); }.spray-product-row label { display: grid; gap: 6px; font-weight: 700; }.inventory-page .panel-note, .inventory-page .receipt-history, .inventory-page .check-columns, .inventory-page .teaching-empty { font-size: 18px; }
src/styles/app.css:644:@media (max-width: 767px) { .inventory-heading { align-items: start; flex-direction: column; }.inventory-heading .primary-action { width: 100%; }.inventory-form, .inline-new-product, .inventory-form fieldset, .spray-product-row { grid-template-columns: 1fr; }.inventory-form .wide { grid-column: auto; }.inventory-form .primary-action { width: 100%; }.shelf-grid { grid-template-columns: 1fr; }.shelf-card { min-height: 132px; }.check-columns { grid-template-columns: 1fr; }.compliance-heading { align-items: start; flex-direction: column; }.compliance-heading .card-heading { width: 100%; border-radius: 15px 15px 0 0; }.compliance-heading .check-label { padding: 0 18px 14px; }.receipt-history article { align-items: start; flex-direction: column; }.receipt-history button { width: 100%; } }
