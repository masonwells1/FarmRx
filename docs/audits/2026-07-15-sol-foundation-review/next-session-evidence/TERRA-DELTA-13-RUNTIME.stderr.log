   4: export function safeNotificationLink(value: unknown, origin: string): string {
   5:   if (typeof value !== 'string' || value.length > 2_048 || !value.startsWith('/') || value.startsWith('//') || unsafeCharacters.test(value)) return fallback
   6:   try {
   7:     const resolved = new URL(value, origin)
   8:     if (resolved.origin !== origin) return fallback
   9:     const canonical = `${resolved.pathname}${resolved.search}${resolved.hash}`
  10:     // URL dot-segment normalization can turn an apparently relative path such
  11:     // as `/..//example.test` into a protocol-relative `//example.test` URL.
  12:     // Validate the canonical value that will actually be opened, not only the
  13:     // caller-provided spelling.
  14:     if (!canonical.startsWith('/') || canonical.startsWith('//') || unsafeCharacters.test(canonical)) return fallback
  15:     if (new URL(canonical, origin).origin !== origin) return fallback
  16:     return canonical
  17:   } catch { return fallback }
  18: }
