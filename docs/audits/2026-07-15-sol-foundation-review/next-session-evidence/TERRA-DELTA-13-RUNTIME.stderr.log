 366: function OfflineDataNotice() {
 367:   const notices = useSyncExternalStore(subscribeWorkspaceCacheNotices, getWorkspaceCacheNotices, getWorkspaceCacheNotices);
 368:   if (!notices.length) return null;
 369:   const oldest = notices[0];
 370:   return <div className="offline-data-notice" role="status">Showing an offline copy from {new Date(oldest.cachedAt).toLocaleString()}. Saved changes stay on this device until Farm Rx reconnects.</div>;
 371: }
