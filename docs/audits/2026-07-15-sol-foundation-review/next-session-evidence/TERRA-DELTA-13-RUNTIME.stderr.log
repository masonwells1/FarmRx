 477: function InitialFarmSetup({ onComplete }: { onComplete: () => Promise<void> }) {
 478:   const [submitting, setSubmitting] = useState(false);
 479:   const [error, setError] = useState<string | null>(null);
 480:   const submitLock = useRef(createSubmitLock());
 481:   async function submit(event: FormEvent<HTMLFormElement>) {
 482:     event.preventDefault();
 483:     if (!submitLock.current.acquire()) return;
 484:     try {
 485:       setSubmitting(true);
 486:       setError(null);
 487:       const form = new FormData(event.currentTarget);
 488:       await bootstrapInitialOwnerFarm({
 489:         farmName: String(form.get("farmName") ?? ""),
 490:         entityName: String(form.get("entityName") ?? ""),
 491:         selectedEntityType: String(
 492:           form.get("entityType") ?? "llc",
 493:         ) as EntityType,
 494:       });
 495:       await onComplete();
 496:     } catch (caught) {
 497:       setError(farmerError(caught, "finish your setup"));
 498:     } finally {
 499:       submitLock.current.release();
 500:       setSubmitting(false);
 501:     }
 502:   }
 503:   return (
 504:     <main className="login-page">
 505:       <section className="login-panel" aria-labelledby="setup-title">
 506:         <div className="login-brand">
 507:           <h1 id="setup-title">Set up your farm</h1>
 508:           <p>Tell us the farm and operating name to get started.</p>
 509:         </div>
 510:         <form className="login-card" onSubmit={submit}>
 511:           <label htmlFor="farmName">Farm name</label>
 512:           <input id="farmName" name="farmName" required disabled={submitting} />
 513:           <label htmlFor="entityName">Operating name</label>
 514:           <input
 515:             id="entityName"
 516:             name="entityName"
 517:             required
 518:             disabled={submitting}
 519:           />
 520:           <label htmlFor="entityType">Entity type</label>
 521:           <select
 522:             id="entityType"
 523:             name="entityType"
 524:             defaultValue="llc"
 525:             disabled={submitting}
 526:           >
 527:             <option value="individual">Individual</option>
 528:             <option value="sole_proprietorship">Sole proprietorship</option>
 529:             <option value="partnership">Partnership</option>
 530:             <option value="llc">LLC</option>
 531:             <option value="corporation">Corporation</option>
 532:             <option value="trust">Trust</option>
 533:           </select>
 534:           {error && (
 535:             <p className="auth-error" role="alert">
 536:               {error}
 537:             </p>
 538:           )}
 539:           <button
 540:             className="primary-action"
 541:             type="submit"
 542:             disabled={submitting}
 543:           >
 544:             {submitting ? "Saving…" : "Save farm"}
 545:           </button>
 546:         </form>
 547:       </section>
 548:     </main>
 549:   );
 550: }
