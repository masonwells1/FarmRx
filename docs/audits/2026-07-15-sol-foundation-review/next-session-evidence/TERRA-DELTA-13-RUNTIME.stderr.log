.nav-link.active::before { content: ""; position: absolute; left: 0; top: 8px; bottom: 8px; width: 3px; border-radius: 0 3px 3px 0; background: var(--crx-green); }
.nav-icon { width: 22px; display: inline-flex; align-items: center; justify-content: center; }
.nav-icon svg { width: 22px; height: 22px; display: block; }
.nav-link.active .nav-icon { color: var(--crx-green); }

.powered-by { margin: 8px; padding: 18px 0 0; border-top: 1px solid rgb(255 255 255 / 10%); color: var(--nav-muted); text-align: center; font-size: 18px; letter-spacing: .08em; text-transform: uppercase; }
.powered-mark { margin-bottom: 3px; color: #fff; font-size: 21px; font-weight: 700; letter-spacing: -.02em; text-transform: none; }
.powered-mark span, .product-name span { color: var(--crx-green); }

.app-main { min-width: 0; flex: 1; }
.topbar { position: sticky; top: 0; z-index: 10; min-height: 72px; display: flex; align-items: center; justify-content: space-between; gap: 20px; padding: 15px 32px; border-bottom: 1px solid var(--hairline); background: rgb(249 247 242 / 82%); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); }
.topbar-actions { display: flex; align-items: center; gap: 12px; }
