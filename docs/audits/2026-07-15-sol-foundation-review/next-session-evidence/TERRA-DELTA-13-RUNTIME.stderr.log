  81: .offline-context { display: inline-flex; align-items: center; min-height: 32px; padding: 4px 10px; border-radius: 99px; background: var(--warn-bg); color: #604a22; font-size: 18px; font-weight: 700; white-space: nowrap; }
  82: .offline-data-notice { padding: 10px 24px; border-bottom: 1px solid #e8d39d; background: var(--warn-bg); color: #604a22; font-size: 18px; font-weight: 650; text-align: center; }
  83: .alert-bell { position: relative; min-width: 48px; min-height: 48px; border: 1px solid var(--hairline); border-radius: 12px; background: rgb(255 255 255 / 65%); color: var(--matte-gray); font: inherit; font-size: 25px; transition: background-color 150ms ease-out, box-shadow 150ms ease-out; }
  84: .alert-bell:hover { background: var(--surface); box-shadow: var(--shadow-card); }
