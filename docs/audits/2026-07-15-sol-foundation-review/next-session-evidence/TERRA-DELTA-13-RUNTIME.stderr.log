src/styles/app.css-614-.machine-facts { display: flex; flex-wrap: wrap; gap: 10px; font-variant-numeric: tabular-nums; }.machine-facts b { font-size: 18px; }.chip-row { display: flex; flex-wrap: wrap; gap: 7px; }.chip-row em, .priority-chip { padding: 4px 8px; border-radius: 999px; font-size: 18px; font-style: normal; font-weight: 700; }.status-chip { background: var(--cream); color: var(--matte-gray); }.due-chip { background: #fff0f0; color: var(--warn-red); }.warranty-chip { background: var(--warn-bg); color: #8a5600; }.priority-chip { background: #fff0f0; color: var(--warn-red); }
src/styles/app.css:615:.equipment-form { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 13px; padding: 18px; }.equipment-form h2, .equipment-form .equipment-error, .equipment-form fieldset, .equipment-form > div { grid-column: 1 / -1; margin: 0; }.equipment-form label { display: grid; gap: 5px; color: var(--matte-gray); font-weight: 700; }.equipment-form input, .equipment-form select, .equipment-form textarea { width: 100%; box-sizing: border-box; padding: 9px 11px; border: 1px solid var(--hairline); border-radius: 8px; background: white; color: var(--charcoal); }.equipment-form textarea { min-height: 96px; resize: vertical; }.equipment-form .wide { grid-column: span 2; }.equipment-form.compact { grid-template-columns: repeat(3, minmax(0, 1fr)); padding: 0; border: 0; box-shadow: none; }.equipment-form fieldset { display: flex; align-items: center; flex-wrap: wrap; gap: 8px; border: 0; padding: 0; }.equipment-form fieldset button.active, .task-kpis button.active { color: var(--on-dark); background: var(--deep-green); }
src/styles/app.css-616-.equipment-detail { display: grid; gap: 18px; padding: 20px; }.detail-heading h2 { margin: 0; }.detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }.detail-grid section, .service-log { padding: 16px; border-radius: 10px; background: var(--cream); }.detail-grid h3, .service-log h3 { margin: 0 0 12px; }.list-row { display: flex; justify-content: space-between; gap: 10px; align-items: center; min-height: 46px; border-bottom: 1px solid var(--hairline); font-variant-numeric: tabular-nums; }.list-row:last-child { border-bottom: 0; }
src/styles/app.css:617:.equipment-error { margin: 0; padding: 12px; border-left: 4px solid var(--warn-red); background: #fff2f2; color: var(--warn-red); }.task-kpis { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; }.task-kpis button { display: grid; gap: 3px; padding: 13px; border: 1px solid var(--hairline); border-radius: 10px; background: var(--surface); color: var(--charcoal); text-align: left; }.task-kpis strong { font-size: 28px; font-variant-numeric: tabular-nums; }.task-kpis span { color: var(--matte-gray); }.task-board { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); align-items: start; gap: 14px; }.task-column { display: grid; gap: 12px; padding: 14px; min-height: 180px; }.task-card { display: grid; gap: 8px; padding: 14px; }.task-card h3, .task-card p { margin: 0; }.task-card .chip-row button { min-height: 48px; padding: 4px 9px; border: 1px solid var(--hairline); border-radius: 999px; background: var(--light-green); color: var(--deep-green); }.task-actions { display: flex; flex-wrap: wrap; gap: 7px; }.task-actions button { min-height: 48px; padding: 6px 10px; }.overdue-amber { border-left: 6px solid var(--amber); }.overdue-red { border-left: 6px solid var(--warn-red); }.critical { border-left: 6px solid #7e0000; animation: task-critical 1.1s ease-in-out infinite alternate; }@keyframes task-critical { to { box-shadow: 0 0 0 4px #c6282833; } }
src/styles/app.css-618-@media (max-width: 767px) { .equipment-heading, .detail-heading { align-items: start; flex-direction: column; }.equipment-heading .primary-action { width: 100%; }.equipment-form, .equipment-form.compact, .detail-grid, .task-kpis, .task-board { grid-template-columns: 1fr; }.equipment-form .wide { grid-column: auto; }.task-column { min-height: 0; } }
