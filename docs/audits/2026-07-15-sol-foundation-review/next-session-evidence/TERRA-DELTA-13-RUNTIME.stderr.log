 360:   await staleTab.route(/\/rest\/v1\/fields(?:\?|$)/, async (route) => {
 361:     if (route.request().method() !== 'GET') { await route.fallback(); return }
 362:     sawRead()
 363:     await readRelease
 364:     await route.fallback()
 365:   })
 366:   const staleReload = staleTab.reload()
 367:   await readStarted
 368:
 369:   const accessKey = `farm-rx-access:v1:${projectRef}:${userId}`
 370:   const fenceKey = `farm-rx-revocation-fence:v1:${projectRef}:${userId}:${farmA}`
