 552: function Navigation({ className, items = navigation, onNavigate }: { className: string; items?: NavigationItem[]; onNavigate?: () => void }) {
 553:   return (
 554:     <div className={className}>
 555:       {items.map((item) => (
 556:         <NavLink key={item.path} className="nav-link" to={item.path} onClick={onNavigate}>
 557:           <span className="nav-icon" aria-hidden="true">
 558:             {item.icon}
 559:           </span>
 560:           <span>{item.label}</span>
 561:         </NavLink>
 562:       ))}
 563:     </div>
 564:   );
 565: }
