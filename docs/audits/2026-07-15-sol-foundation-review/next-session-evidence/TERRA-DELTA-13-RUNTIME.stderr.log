 101: /** Authoritative live recovery after queues are quarantined and caches deleted. */
 102: export function resetFarmGrantFromLive(storage: StorageLike, scope: FarmRevocationScope, serverEpoch: number, changedAt = new Date().toISOString()): number {
 103:   if (!Number.isSafeInteger(serverEpoch) || serverEpoch < 1 || Number.isNaN(Date.parse(changedAt))) throw new Error(blocked)
 104:   let generation = serverEpoch
 105:   try { const state = readState(storage, scope); generation = Math.max(serverEpoch, state.fence?.generation ?? 0, state.ledger?.generation ?? 0) + 1 } catch { /* invalid metadata is replaced only after durable quarantine/cache cleanup */ }
 106:   writeFence(storage, scope, { version: 2, generation, token: nextToken(), serverEpoch, revoked: false, changedAt })
 107:   return generation
 108: }
 109:
 110: export function resetFarmRevokedFromLive(storage: StorageLike, scope: FarmRevocationScope, serverEpoch: number, changedAt = new Date().toISOString()): number {
 111:   if (!Number.isSafeInteger(serverEpoch) || serverEpoch < 1 || Number.isNaN(Date.parse(changedAt))) throw new Error(blocked)
 112:   let generation = serverEpoch
 113:   try { const state = readState(storage, scope); generation = Math.max(serverEpoch, state.fence?.generation ?? 0, state.ledger?.generation ?? 0) + 1 } catch { /* see resetFarmGrantFromLive */ }
 114:   writeFence(storage, scope, { version: 2, generation, token: nextToken(), serverEpoch, revoked: true, changedAt })
 115:   return generation
 116: }
 117:
 118: export function captureFarmRevocationFence(storage: StorageLike, scope: FarmRevocationScope): FarmRevocationSnapshot {
 119:   const current = readFence(storage, scope)
 120:   if (current.revoked) throw new Error(blocked)
 121:   return { ...scope, generation: current.generation, token: current.token, serverEpoch: current.serverEpoch }
 122: }
 123:
 124: export function verifyFarmRevocationFence(storage: StorageLike, snapshot: FarmRevocationSnapshot): void {
 125:   const current = readFence(storage, snapshot)
 126:   if (current.revoked || current.generation !== snapshot.generation || current.token !== snapshot.token || current.serverEpoch !== snapshot.serverEpoch) throw new Error(blocked)
 127: }
 128:
 129: export function markFarmRevoked(storage: StorageLike, scope: FarmRevocationScope, changedAt = new Date().toISOString(), serverEpoch?: number): number {
 130:   const { fence, ledger } = readState(storage, scope)
 131:   if (fence?.revoked && ledger) return fence.generation
 132:   const generation = Math.max(fence?.generation ?? 0, ledger?.generation ?? 0) + 1
 133:   const authoritativeEpoch = serverEpoch ?? fence?.serverEpoch ?? ledger?.serverEpoch
 134:   if (!authoritativeEpoch) throw new Error(blocked)
 135:   writeFence(storage, scope, { version: 2, generation, token: nextToken(), serverEpoch: authoritativeEpoch, revoked: true, changedAt })
 136:   return generation
 137: }
 138:
 139: export function markFarmGranted(storage: StorageLike, scope: FarmRevocationScope, changedAt = new Date().toISOString(), serverEpoch?: number): number {
 140:   const { fence, ledger } = readState(storage, scope)
 141:   if (Number.isNaN(Date.parse(changedAt))) throw new Error(blocked)
 142:   const authoritativeEpoch = serverEpoch ?? (!browserStorage(storage) ? fence?.serverEpoch ?? ledger?.serverEpoch ?? 1 : undefined)
 143:   if (!authoritativeEpoch || !Number.isSafeInteger(authoritativeEpoch) || authoritativeEpoch < 1) throw new Error(blocked)
 144:   const lastChangedAt = fence?.changedAt ?? ledger?.changedAt
 145:   // A live farm list is authoritative only for the snapshot time at which its
 146:   // request began. A delayed older response must not undo a newer revocation.
 147:   if ((!fence || fence.revoked) && lastChangedAt && Date.parse(lastChangedAt) > Date.parse(changedAt)) throw new Error(blocked)
 148:   const epochChanged = !!fence && fence.serverEpoch !== authoritativeEpoch
 149:   const generation = Math.max(fence?.generation ?? 0, ledger?.generation ?? 0, 1) + (epochChanged ? 1 : 0)
 150:   if (fence && ledger && !fence.revoked && !epochChanged) return generation
 151:   writeFence(storage, scope, { version: 2, generation, token: nextToken(), serverEpoch: authoritativeEpoch, revoked: false, changedAt })
 152:   return generation
 153: }
 154:
 155: /** Upgrade a previously stored access snapshot without letting a cached tab
 156:  * undo a revocation. Only an entirely absent pre-upgrade fence is initialized;
 157:  * partial, corrupt, or revoked state remains blocked until a live access check. */
 158: export function ensureStoredFarmGrant(storage: StorageLike, scope: FarmRevocationScope): number {
 159:   const snapshot = captureFarmRevocationFence(storage, scope)
 160:   return snapshot.generation
 161: }
 162:
 163: /** Repository compatibility for isolated tests and pre-access bootstrap only.
 164:  * In the browser, an existing access snapshot with missing fence metadata is a
 165:  * known farm and therefore fails closed instead of being silently re-created. */
 166: export function ensureQueueFarmGrant(storage: StorageLike, scope: FarmRevocationScope): number {
 167:   const { fence, ledger } = readState(storage, scope)
 168:   if (!fence && !ledger) {
 169:     if (browserStorage(storage)) throw new Error(blocked)
 170:     return resetFarmGrantFromLive(storage, scope, 1)
 171:   }
 172:   return captureFarmRevocationFence(storage, scope).generation
 173: }
