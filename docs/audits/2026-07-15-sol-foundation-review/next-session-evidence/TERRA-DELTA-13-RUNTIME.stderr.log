 319: function SyncNotice() {
 320:   const status = useSyncExternalStore(
 321:     subscribeSyncStatus,
 322:     getSyncStatus,
 323:     getSyncStatus,
 324:   );
 325:   const retryLock = useRef(createSubmitLock());
 326:   const retry = async () => {
 327:     if (!retryLock.current.acquire()) return;
 328:     try {
 329:       await retrySavedChanges();
 330:     } finally {
 331:       retryLock.current.release();
 332:     }
 333:   };
 334:   if (status.kind === "synced")
 335:     return (
 336:       <div className="sync-notice synced" role="status">
 337:         All changes synced.
 338:       </div>
 339:     );
 340:   if (status.kind === "pending")
 341:     return (
 342:       <div className="sync-notice pending" role="status">
 343:         Saved on this device — waiting for signal. {status.pending} change
 344:         {status.pending === 1 ? "" : "s"} pending.
 345:       </div>
 346:     );
 347:   if (status.kind === "syncing")
 348:     return (
 349:       <div className="sync-notice syncing" role="status">
 350:         Sending saved changes…
 351:       </div>
 352:     );
 353:   return (
 354:     <div className="sync-notice blocked" role="alert">
 355:       <span>
 356:         {status.pending} saved change{status.pending === 1 ? "" : "s"} needs
 357:         attention. Nothing was deleted.
 358:       </span>
 359:       <button type="button" onClick={() => void retry()}>
 360:         Try again
 361:       </button>
 362:     </div>
 363:   );
 364: }
