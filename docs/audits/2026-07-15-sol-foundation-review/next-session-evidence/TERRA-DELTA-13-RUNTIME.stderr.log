}

.farm-lockup { margin: 0 8px 16px; padding: 16px 12px 18px; border-bottom: 1px solid rgb(255 255 255 / 10%); }
.farm-name, h1, .product-name, .card-heading, .table-total, .stat-label, .powered-mark { font-family: var(--brand-font); }
.farm-name { font-weight: 700; font-size: 20px; line-height: 1.2; }
.farm-logo-note { margin-top: 4px; color: var(--nav-muted); font-size: 18px; letter-spacing: .06em; text-transform: uppercase; }
.sidebar-nav { flex: 1; }

.nav-link {
  position: relative;
  min-height: 48px;
  display: flex;
  align-items: center;
  gap: 13px;
  margin-bottom: 2px;
  padding: 12px 14px;
  border-radius: 10px;
