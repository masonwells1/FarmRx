_on: entry.value.service_date, source: 'service', notes: `Service: ${entry.value.work_performed}`, created_by: entry.userId, created_at: entry.enqueuedAt, updated_at: entry.enqueuedAt }) } continue } if (entry.kind === 'saveTask') { const prior = next.tasks.find((row) => row.id === entry.value.id); next.tasks = replace(next.tasks, { ...entry.value, farm_id: entry.farmId, program_assigned_pass_id: entry.value.program_assigned_pass_id ?? prior?.program_assigned_pass_id ?? null, program_cycle_key: entry.value.program_cycle_key ?? prior?.program_cycle_key ?? null, completed_by: entry.value.status === 'done' ? entry.userId : null, completed_at: entry.value.status === 'done' ? entry.enqueuedAt : null, created_by: prior?.created_by ?? entry.userId, created_at: prior?.created_at ?? entry.enqueuedAt, updated_at: entry.enqueuedAt } as FarmTask); continue } if (entry.kind === 'deleteTask') next.tasks = next.tasks.filter((row) => row.id !== entry.id); else if (entry.kind === 'deleteInterval') { next.intervals = next.intervals.filter((row) => row.id !== entry.id); next.service_due = next.service_due.filter((row) => row.interval_id !== entry.id) } else { next.service_log = next.service_log.filter((row) => row.id !== entry.id); const readingId = readingsByService.get(entry.id); if (readingId) next.meter_readings = next.meter_readings.filter((row) => row.id !== readingId) } } return next }
