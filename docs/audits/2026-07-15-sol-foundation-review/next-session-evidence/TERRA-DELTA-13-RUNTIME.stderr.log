 598: function LoginPage() {
 599:   const { phase, signIn } = useAuth();
 600:   const navigate = useNavigate();
 601:   const location = useLocation();
 602:   const [submitting, setSubmitting] = useState(false);
 603:   const [error, setError] = useState<string | null>(null);
 604:   const signInLock = useRef(createSubmitLock());
 605:
 606:   if (phase === "restoring")
 607:     return (
 608:       <main className="login-page">
 609:         <p className="opening-farm">Opening your farm…</p>
 610:       </main>
 611:     );
 612:   if (phase === "signed_in") {
 613:     const from = (location.state as { from?: string } | null)?.from;
 614:     return (
 615:       <Navigate
 616:         to={from?.startsWith("/") && !from.startsWith("//") ? from : "/fields"}
 617:         replace
 618:       />
 619:     );
 620:   }
 621:
 622:   async function handleSubmit(event: FormEvent<HTMLFormElement>) {
 623:     event.preventDefault();
 624:     if (!signInLock.current.acquire()) return;
 625:     try {
 626:       setSubmitting(true);
 627:       setError(null);
 628:       const form = new FormData(event.currentTarget);
 629:       await signIn(
 630:         String(form.get("email") ?? ""),
 631:         String(form.get("password") ?? ""),
 632:       );
 633:       const from = (location.state as { from?: string } | null)?.from;
 634:       navigate(
 635:         from?.startsWith("/") && !from.startsWith("//") ? from : "/fields",
 636:         { replace: true },
 637:       );
 638:     } catch (caught) {
 639:       const message =
 640:         caught instanceof Error ? caught.message.toLowerCase() : "";
 641:       if (
 642:         /invalid login credentials|invalid.*password|invalid.*email/.test(
 643:           message,
 644:         )
 645:       )
 646:         setError(
 647:           "That email or password did not work. Check both and try again.",
 648:         );
 649:       else if (/rate limit|too many requests/.test(message))
 650:         setError("Too many tries. Wait a few minutes, then try again.");
 651:       else if (/network|fetch|timeout|timed out|connection/.test(message))
 652:         setError(
 653:           "We could not reach Farm Rx. Check your signal and try again.",
 654:         );
 655:       else
 656:         setError("Farm Rx could not sign you in right now. Please try again.");
 657:     } finally {
 658:       setSubmitting(false);
 659:       signInLock.current.release();
 660:     }
 661:   }
 662:
 663:   return (
 664:     <main className="login-page">
 665:       <section className="login-panel" aria-labelledby="login-title">
 666:         <div className="login-brand">
 667:           <div className="rx-mark" aria-hidden="true">
 668:             ℞
 669:           </div>
 670:           <h1 id="login-title">
