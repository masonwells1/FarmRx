 397: test('an expired offline workspace fails closed with a useful connection message', async ({ page, context }) => {
 398:   await seedSession(context)
 399:   await mockSupabase(page, [farms[0]])
 400:   await page.goto('/fields')
 401:   await expect(page.getByText('North Forty')).toBeVisible()
 402:   await page.evaluate(async ({ databaseName, key, cachedAt }) => {
 403:     const database = await new Promise<IDBDatabase>((resolve, reject) => { const request = indexedDB.open(databaseName); request.onsuccess = () => resolve(request.result); request.onerror = () => reject(request.error) })
 404:     try {
 405:       const transaction = database.transaction('workspaces', 'readwrite')
 406:       const store = transaction.objectStore('workspaces')
 407:       const value = await new Promise<Record<string, unknown>>((resolve, reject) => { const request = store.get(key); request.onsuccess = () => resolve(request.result); request.onerror = () => reject(request.error) })
