 245: test('revoked farm work is quarantined, exportable, and never returned to an active queue', async ({ page, context }) => {
 246:   await seedSession(context)
 247:   const operationId = '00000000-0000-4000-8000-000000000043'
 248:   const queueKey = `farm-rx-notifications-write-queue:v1:${projectRef}:${userId}:${farmA}`
 249:   const recoveryKey = `farm-rx-revoked-work-recovery:v1:${projectRef}:${userId}`
 250:   await context.addInitScript(({ accessKey, access, queueKey: targetQueue, queue }) => {
 251:     localStorage.setItem(accessKey, JSON.stringify(access))
 252:     localStorage.setItem(targetQueue, JSON.stringify(queue))
 253:   }, {
 254:     accessKey: `farm-rx-access:v1:${projectRef}:${userId}`,
 255:     access: { version: 1, userId, farms: [farmRow(farms[0])], selectedFarmId: farmA, validatedAt: now },
 256:     queueKey,
 257:     queue: { version: 1, entries: [{ version: 1, module: 'notifications', kind: 'markRead', operationId, userId, farmId: farmA, enqueuedAt: now, ids: [notificationA] }] },
 258:   })
 259:   const unexpected = await mockSupabase(page, [])
 260:   await page.goto('/fields')
 261:   await expect(page.getByRole('heading', { name: 'Saved work needs your review' })).toBeVisible()
 262:   await expect(page.getByText(/will never send them automatically/i)).toBeVisible()
 263:   expect(await page.evaluate((key) => localStorage.getItem(key), queueKey)).toBeNull()
 264:   const saved = await page.evaluate((key) => JSON.parse(localStorage.getItem(key) ?? '{}') as { records?: Array<{ payload?: { entries?: Array<{ operationId?: string }> } }> }, recoveryKey)
 265:   expect(saved.records).toHaveLength(1)
 266:   expect(saved.records?.[0]?.payload?.entries?.[0]?.operationId).toBe(operationId)
 267:   const download = page.waitForEvent('download')
 268:   await page.getByRole('button', { name: 'Export copy' }).click()
 269:   expect((await download).suggestedFilename()).toMatch(/^farm-rx-recovery-.*\.json$/)
 270:   await page.getByRole('button', { name: 'Dismiss' }).click()
 271:   await page.getByRole('button', { name: 'Yes, dismiss' }).click()
 272:   await expect(page.getByRole('heading', { name: 'Saved work needs your review' })).toBeHidden()
 273:   expect(await page.evaluate((key) => localStorage.getItem(key), queueKey)).toBeNull()
 274:   expect(await page.evaluate((key) => (JSON.parse(localStorage.getItem(key) ?? '{}') as { records?: unknown[] }).records?.length, recoveryKey)).toBe(0)
 275:   expect(unexpected).toEqual([])
 276: })
