 278: test('a stale tab cannot recreate revoked queue or readable cache work after regrant', async ({ page, context }) => {
 279:   await seedSession(context)
 280:   const staleTab = await context.newPage()
 281:   const notifications = [{ id: notificationA, farm_id: farmA, user_id: userId, category: 'general', title: 'Stale tab alert', body: null, link: '/notifications', dedupe_key: null, read_at: null, created_by: userId, created_at: now }]
 282:   await mockSupabase(page, [farms[0]], notifications)
 283:   await mockSupabase(staleTab, [farms[0]], notifications)
 284:   await Promise.all([page.goto('/fields'), staleTab.goto('/fields')])
 285:   await Promise.all([expect(page.getByText('North Forty')).toBeVisible(), expect(staleTab.getByText('North Forty')).toBeVisible()])
 286:   const databaseName = `farm-rx-offline-v1-${projectRef}`
 287:   const cacheKey = `${projectRef}:${userId}:${farmA}:fields`
 288:   const staleCache = await staleTab.evaluate(async ({ databaseName: name, key }) => {
 289:     const database = await new Promise<IDBDatabase>((resolve, reject) => { const request = indexedDB.open(name); request.onsuccess = () => resolve(request.result); request.onerror = () => reject(request.error) })
 290:     try { return await new Promise<Record<string, unknown>>((resolve, reject) => { const request = database.transaction('workspaces').objectStore('workspaces').get(key); request.onsuccess = () => resolve(request.result); request.onerror = () => reject(request.error) }) } finally { database.close() }
 291:   }, { databaseName, key: cacheKey })
 292:   expect(staleCache).toMatchObject({ version: 2, farmId: farmA, serverEpoch: 1 })
 293:   expect(staleCache.generation).toEqual(expect.any(Number))
 294:   expect(staleCache.fenceToken).toEqual(expect.any(String))
 295:
 296:   await staleTab.goto('/notifications')
 297:   await expect(staleTab.getByText('Stale tab alert')).toBeVisible()
 298:   let releasePatch!: () => void
 299:   const patchRelease = new Promise<void>((resolve) => { releasePatch = resolve })
 300:   let sawPatch!: () => void
 301:   const patchStarted = new Promise<void>((resolve) => { sawPatch = resolve })
 302:   let patchAttempts = 0
 303:   await staleTab.route(/\/rest\/v1\/rpc\/mark_notifications_read(?:\?|$)/, async (route) => {
 304:     if (route.request().method() !== 'POST') { await route.fallback(); return }
 305:     patchAttempts += 1
 306:     sawPatch()
 307:     await patchRelease
 308:     await route.abort('timedout')
 309:   })
 310:   const click = staleTab.locator('.notification-row').filter({ hasText: 'Stale tab alert' }).getByRole('button', { name: 'Mark read' }).click()
 311:   await patchStarted
 312:
 313:   await page.unroute('https://*.supabase.co/**')
 314:   await mockSupabase(page, [], notifications)
 315:   const accessKey = `farm-rx-access:v1:${projectRef}:${userId}`
 316:   await page.evaluate((key) => { const value = JSON.parse(localStorage.getItem(key) ?? '{}'); value.validatedAt = '2020-01-01T00:00:00.000Z'; localStorage.setItem(key, JSON.stringify(value)) }, accessKey)
 317:   await page.reload()
 318:   const fenceKey = `farm-rx-revocation-fence:v1:${projectRef}:${userId}:${farmA}`
 319:   await expect.poll(() => page.evaluate((key) => JSON.parse(localStorage.getItem(key) ?? '{}') as { revoked?: boolean; generation?: number }, fenceKey)).toMatchObject({ revoked: true })
 320:   await page.evaluate((key) => localStorage.removeItem(key), fenceKey)
 321:
 322:   releasePatch()
 323:   await click
 324:   const queueKey = `farm-rx-notifications-write-queue:v1:${projectRef}:${userId}:${farmA}`
 325:   expect(await staleTab.evaluate((key) => localStorage.getItem(key), queueKey)).toBeNull()
 326:   await staleTab.evaluate(async ({ databaseName: name, value }) => {
 327:     const database = await new Promise<IDBDatabase>((resolve, reject) => { const request = indexedDB.open(name); request.onsuccess = () => resolve(request.result); request.onerror = () => reject(request.error) })
 328:     try { const transaction = database.transaction('workspaces', 'readwrite'); transaction.objectStore('workspaces').put(value); await new Promise<void>((resolve, reject) => { transaction.oncomplete = () => resolve(); transaction.onerror = () => reject(transaction.error) }) } finally { database.close() }
 329:   }, { databaseName, value: staleCache })
 330:
 331:   await page.unroute('https://*.supabase.co/**')
 332:   await mockSupabase(page, [farms[0]], notifications, false, 3)
 333:   await page.evaluate((key) => { const value = JSON.parse(localStorage.getItem(key) ?? '{}'); value.validatedAt = '2020-01-01T00:00:00.000Z'; localStorage.setItem(key, JSON.stringify(value)) }, accessKey)
 334:   await page.reload()
 335:   await page.waitForTimeout(750)
 336:   await expect.poll(() => page.evaluate((key) => JSON.parse(localStorage.getItem(key) ?? '{}') as { revoked?: boolean; generation?: number }, fenceKey)).toMatchObject({ revoked: false })
 337:   expect((await page.evaluate((key) => JSON.parse(localStorage.getItem(key) ?? '{}') as { generation?: number }, fenceKey)).generation).toBeGreaterThanOrEqual(2)
 338:
 339:   await context.setOffline(true)
 340:   await staleTab.goto('/fields')
 341:   await expect(staleTab.getByText('North Forty')).toBeHidden()
 342:   expect(patchAttempts).toBe(1)
 343:   expect(await staleTab.evaluate((key) => localStorage.getItem(key), queueKey)).toBeNull()
 344:   await context.setOffline(false)
 345:   await staleTab.close()
 346: })
