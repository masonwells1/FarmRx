m_pass') return this.live.skipProgramPassOperation(entry.assignedPassId, entry.skippedOn, entry.reason, entry.operationId, operationContext); return this.live.unassignProgramOperation(entry.assignmentId, entry.reason, entry.operationId, operationContext) }
