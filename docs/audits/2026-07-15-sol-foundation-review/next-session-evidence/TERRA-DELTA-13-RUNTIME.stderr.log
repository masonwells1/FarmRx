   3: export type FarmRevocationScope = { projectRef: string; userId: string; farmId: string }
   4: export type FarmRevocationSnapshot = FarmRevocationScope & { generation: number; token: string; serverEpoch: number }
   5: type Fence = { version: 2; generation: number; token: string; serverEpoch: number; revoked: boolean; changedAt: string }
   6: type GenerationLedger = { version: 2; generation: number; token: string; serverEpoch: number; changedAt: string }
   7: type EnumeratedStorage = StorageLike & { readonly length: number; key(index: number): string | null }
   8:
   9: const blocked = 'Access to this farm changed while work was being saved. Nothing was queued or replayed.'
  10: const queueKeyPattern = /^farm-rx-[^:]+:v1:([^:]+):([^:]+):([^:]+)$/
  11: const fenceKeyPattern = /^farm-rx-revocation-(?:fence|generation):v1:([^:]+):([^:]+):([^:]+)$/
  12: const tokenPattern = /^[a-z0-9-]{16,128}$/i
  13:
  14: function nextToken() { return typeof crypto !== 'undefined' && typeof crypto.randomUUID === 'function' ? crypto.randomUUID() : `${Date.now()}-${Math.random().toString(16).slice(2)}-${Math.random().toString(16).slice(2)}` }
  15: function browserStorage(storage: StorageLike) { return typeof window !== 'undefined' && storage === window.localStorage }
  16:
  17: export function farmRevocationFenceKey(scope: FarmRevocationScope) {
  18:   return `farm-rx-revocation-fence:v1:${scope.projectRef}:${scope.userId}:${scope.farmId}`
  19: }
  20:
  21: export function farmRevocationGenerationKey(scope: FarmRevocationScope) {
  22:   return `farm-rx-revocation-generation:v1:${scope.projectRef}:${scope.userId}:${scope.farmId}`
  23: }
  24:
  25: function parseFence(raw: string): Fence {
  26:   try {
  27:     const value = JSON.parse(raw) as Partial<Fence>
  28:     if (value.version !== 2 || !Number.isSafeInteger(value.generation) || value.generation! < 1 || typeof value.token !== 'string' || !tokenPattern.test(value.token) || !Number.isSafeInteger(value.serverEpoch) || value.serverEpoch! < 1 || typeof value.revoked !== 'boolean' || typeof value.changedAt !== 'string' || Number.isNaN(Date.parse(value.changedAt))) throw new Error()
  29:     return value as Fence
  30:   } catch { throw new Error(blocked) }
  31: }
  32:
  33: function parseLedger(raw: string): GenerationLedger {
  34:   try {
  35:     const value = JSON.parse(raw) as Partial<GenerationLedger>
  36:     if (value.version !== 2 || !Number.isSafeInteger(value.generation) || value.generation! < 1 || typeof value.token !== 'string' || !tokenPattern.test(value.token) || !Number.isSafeInteger(value.serverEpoch) || value.serverEpoch! < 1 || typeof value.changedAt !== 'string' || Number.isNaN(Date.parse(value.changedAt))) throw new Error()
  37:     return value as GenerationLedger
  38:   } catch { throw new Error(blocked) }
  39: }
  40:
  41: function readState(storage: StorageLike, scope: FarmRevocationScope) {
  42:   const fenceRaw = storage.getItem(farmRevocationFenceKey(scope))
  43:   const ledgerRaw = storage.getItem(farmRevocationGenerationKey(scope))
  44:   const fence = fenceRaw === null ? null : parseFence(fenceRaw)
  45:   const ledger = ledgerRaw === null ? null : parseLedger(ledgerRaw)
  46:   if (fence && ledger && (fence.generation !== ledger.generation || fence.token !== ledger.token || fence.serverEpoch !== ledger.serverEpoch)) throw new Error(blocked)
  47:   return { fence, ledger }
  48: }
  49:
  50: function readFence(storage: StorageLike, scope: FarmRevocationScope): Fence {
  51:   const { fence, ledger } = readState(storage, scope)
  52:   if (!fence || !ledger) throw new Error(blocked)
  53:   return fence
  54: }
  55:
  56: function writeFence(storage: StorageLike, scope: FarmRevocationScope, value: Fence) {
  57:   const ledgerKey = farmRevocationGenerationKey(scope)
  58:   const fenceKey = farmRevocationFenceKey(scope)
  59:   const ledgerBytes = JSON.stringify({ version: 2, generation: value.generation, token: value.token, serverEpoch: value.serverEpoch, changedAt: value.changedAt } satisfies GenerationLedger)
  60:   const fenceBytes = JSON.stringify(value)
  61:   // Advance the independent generation ledger first. A tab observing a partial
  62:   // write sees a mismatch and fails closed instead of accepting the old fence.
  63:   storage.setItem(ledgerKey, ledgerBytes)
  64:   if (storage.getItem(ledgerKey) !== ledgerBytes || JSON.stringify(parseLedger(ledgerBytes)) !== ledgerBytes) throw new Error(blocked)
  65:   storage.setItem(fenceKey, fenceBytes)
  66:   if (storage.getItem(fenceKey) !== fenceBytes || JSON.stringify(readFence(storage, scope)) !== fenceBytes) throw new Error(blocked)
  67: }
